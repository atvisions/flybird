{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, DocumentTextIcon, TrophyIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'ProjectContent',\n  props: {\n    data: {\n      type: Array,\n      required: true\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 格式化日期显示\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;\n    };\n    const __returned__ = {\n      formatDate,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },\n      get TrophyIcon() {\n        return TrophyIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","DocumentTextIcon","TrophyIcon","formatDate","dateString","date","Date","getFullYear","String","getMonth","padStart"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ProjectContent.vue"],"sourcesContent":["<template>\n  <div class=\"relative space-y-0\">\n    <!-- 时间线 -->\n    <div class=\"absolute left-[0.5625rem] top-3 bottom-3 w-px bg-gray-200\"></div>\n\n    <!-- 项目经历列表 -->\n    <div \n      v-for=\"(project, index) in data\" \n      :key=\"index\" \n      class=\"relative pl-12 pb-6\"\n    >\n      <!-- 时间节点 -->\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n      \n      <!-- 内容卡片 -->\n      <div class=\"bg-gray-50 rounded-lg border border-gray-100 p-4 hover:shadow-sm transition-shadow\">\n        <!-- 头部信息 -->\n        <div class=\"flex items-center justify-between mb-3\">\n          <div class=\"flex-1\">\n            <div class=\"text-sm text-gray-500\">\n              {{ formatDate(project.start_date) }} - {{ project.is_current ? '至今' : formatDate(project.end_date) }}\n            </div>\n            <div class=\"flex items-center justify-between mt-1.5\">\n              <span class=\"text-base font-medium text-gray-900\">{{ project.name }}</span>\n              <div class=\"flex items-center space-x-2\">\n                <button\n                  @click=\"$emit('edit', project)\"\n                  class=\"p-1 hover:bg-white rounded-full transition-colors\"\n                >\n                  <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n                </button>\n                <button\n                  @click=\"$emit('delete', project.id)\"\n                  class=\"p-1 hover:bg-white rounded-full transition-colors\"\n                >\n                  <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 角色 -->\n        <div class=\"text-sm font-medium text-blue-600 mb-3\">\n          {{ project.role }}\n        </div>\n\n        <!-- 项目描述 -->\n        <div class=\"space-y-2\">\n          <div class=\"flex items-center space-x-2\">\n            <DocumentTextIcon class=\"w-4 h-4 text-gray-400\" />\n            <span class=\"text-sm text-gray-500\">项目描述</span>\n          </div>\n          <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n            {{ project.description }}\n          </div>\n        </div>\n\n        <!-- 项目成就 -->\n        <div v-if=\"project.achievement\" class=\"mt-3 space-y-2\">\n          <div class=\"flex items-center space-x-2\">\n            <TrophyIcon class=\"w-4 h-4 text-yellow-500\" />\n            <span class=\"text-sm text-gray-500\">项目成就</span>\n          </div>\n          <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n            {{ project.achievement }}\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 添加按钮 -->\n    <div class=\"relative pl-12\">\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n      <button\n        @click=\"$emit('add')\"\n        class=\"w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n      >\n        <PlusIcon class=\"w-4 h-4 mr-2\" />\n        添加项目经历\n      </button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { PencilSquareIcon, TrashIcon, PlusIcon, DocumentTextIcon, TrophyIcon } from '@heroicons/vue/24/outline'\n\ndefineProps({\n  data: {\n    type: Array,\n    required: true\n  }\n})\n\ndefineEmits(['edit', 'delete', 'add'])\n\n// 格式化日期显示\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`\n}\n</script> "],"mappings":"AAsFA,SAASA,gBAAgB,EAAEC,SAAS,EAAEC,QAAQ,EAAEC,gBAAgB,EAAEC,UAAU,QAAQ,2BAA0B;;;;;;;;;;;;;;;IAW9G;IACA,MAAMC,UAAU,GAAIC,UAAU,IAAK;MACjC,IAAI,CAACA,UAAU,EAAE,OAAO,EAAC;MACzB,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,UAAU;MAChC,OAAO,GAAGC,IAAI,CAACE,WAAW,CAAC,CAAC,IAAIC,MAAM,CAACH,IAAI,CAACI,QAAQ,CAAC,CAAC,GAAG,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,EAAC;IAC/E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}