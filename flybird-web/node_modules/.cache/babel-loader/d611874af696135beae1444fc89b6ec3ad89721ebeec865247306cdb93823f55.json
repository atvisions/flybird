{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.map.js\";\nimport \"core-js/modules/esnext.iterator.reduce.js\";\nimport { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { SparklesIcon, ArrowDownTrayIcon, EyeIcon, XMarkIcon, LightBulbIcon } from '@heroicons/vue/24/outline';\nimport ProfilePreview from './ProfilePreview.vue';\nimport AIOptimizeDialog from '../dialogs/AIOptimizeDialog.vue';\nimport { ElMessage } from 'element-plus';\nimport profile from '@/api/profile'; // 修改为默认导入\n\nexport default {\n  __name: 'ResumeStatus',\n  props: {\n    completionData: {\n      type: Object,\n      default: () => ({})\n    },\n    profileData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['ai-optimize', 'import', 'preview'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 预览对话框控制\n    const showPreview = ref(false);\n\n    // 响应式布局\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      if (width.value < 1024) return '80%';\n      return '800px'; // 预览窗口可以稍微宽一点\n    });\n\n    // 完整度数据\n    const completeness = ref({\n      total_score: 0,\n      dimensions: {},\n      suggestions: []\n    });\n\n    // 监听完整度数据变化\n    watch(() => props.completionData, newVal => {\n      if (newVal) {\n        completeness.value = {\n          total_score: newVal.total_score || 0,\n          dimensions: newVal.dimensions || {},\n          suggestions: newVal.suggestions || []\n        };\n      }\n    }, {\n      immediate: true\n    });\n\n    // 计算完整度百分比\n    const completionPercentage = computed(() => {\n      return Math.round(completeness.value.total_score || 0);\n    });\n\n    // 获取完整度数据\n    const fetchCompleteness = async () => {\n      try {\n        const response = await profile.getCompleteness();\n        if (response?.data) {\n          completeness.value = {\n            total_score: response.data.total_score || 0,\n            dimensions: response.data.dimensions || {},\n            suggestions: response.data.suggestions || []\n          };\n        }\n      } catch (error) {\n        console.error('获取简历完整度失败:', error);\n        ElMessage.error('获取完整度数据失败，请稍后重试');\n      }\n    };\n\n    // 监听 profileData 变化时更新完整度\n    watch(() => props.profileData, async newVal => {\n      if (newVal && Object.keys(newVal).length > 0) {\n        await fetchCompleteness();\n      } else {\n        console.log('profileData is empty');\n      }\n    }, {\n      immediate: true\n    });\n\n    // 总分 - 保留一位小数\n    const totalScore = computed(() => {\n      const score = completeness.value?.total_score || 0;\n      return Number(score.toFixed(1));\n    });\n\n    // 维度数据 - 保留整数\n    const dimensions = computed(() => {\n      const dims = completeness.value?.dimensions || {};\n      return Object.entries(dims).reduce((acc, [key, value]) => {\n        acc[key] = _objectSpread(_objectSpread({}, value), {}, {\n          score: Math.round(value.score || 0),\n          weighted_score: value.weighted_score || 0\n        });\n        return acc;\n      }, {});\n    });\n\n    // 建议\n    const suggestions = computed(() => {\n      const rawSuggestions = completeness.value?.suggestions || [];\n      // 只返回建议消息\n      return rawSuggestions.map(suggestion => suggestion.message);\n    });\n\n    // 维度名称映射\n    const getDimensionName = key => {\n      const nameMap = {\n        basic_info: '基本信息',\n        experience: '工作经历',\n        capability: '能力素质',\n        achievement: '个人成就'\n      };\n      return nameMap[key] || key;\n    };\n\n    // 进度条颜色 - 根据实际分数范围调整\n    const progressColorClass = computed(() => {\n      const score = totalScore.value;\n      if (score >= 70) return 'bg-green-500';\n      if (score >= 40) return 'bg-yellow-500';\n      return 'bg-red-500';\n    });\n\n    // 文字颜色 - 与进度条颜色对应\n    const progressTextColorClass = computed(() => {\n      const score = totalScore.value;\n      if (score >= 70) return 'text-green-600';\n      if (score >= 40) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n\n    // 处理预览按钮点击\n    const handlePreview = () => {\n      showPreview.value = true;\n    };\n\n    // AI优化相关\n    const showOptimize = ref(false);\n\n    // 处理优化结果\n    const handleOptimizeApply = optimizedData => {\n      console.log('优化后的数据:', optimizedData);\n      // 这里处理优化后的数据，可能需要调用 API 更新档案\n    };\n    const __returned__ = {\n      props,\n      showPreview,\n      width,\n      isMobile,\n      dialogWidth,\n      completeness,\n      completionPercentage,\n      fetchCompleteness,\n      totalScore,\n      dimensions,\n      suggestions,\n      getDimensionName,\n      progressColorClass,\n      progressTextColorClass,\n      handlePreview,\n      showOptimize,\n      handleOptimizeApply,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get ArrowDownTrayIcon() {\n        return ArrowDownTrayIcon;\n      },\n      get EyeIcon() {\n        return EyeIcon;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get LightBulbIcon() {\n        return LightBulbIcon;\n      },\n      ProfilePreview,\n      AIOptimizeDialog,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get profile() {\n        return profile;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","SparklesIcon","ArrowDownTrayIcon","EyeIcon","XMarkIcon","LightBulbIcon","ProfilePreview","AIOptimizeDialog","ElMessage","profile","props","__props","showPreview","width","isMobile","value","dialogWidth","completeness","total_score","dimensions","suggestions","completionData","newVal","immediate","completionPercentage","Math","round","fetchCompleteness","response","getCompleteness","data","error","console","profileData","Object","keys","length","log","totalScore","score","Number","toFixed","dims","entries","reduce","acc","key","_objectSpread","weighted_score","rawSuggestions","map","suggestion","message","getDimensionName","nameMap","basic_info","experience","capability","achievement","progressColorClass","progressTextColorClass","handlePreview","showOptimize","handleOptimizeApply","optimizedData"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ResumeStatus.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ResumeStatus.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <div class=\"p-4\">\n        <!-- 标题和总分 -->\n        <div class=\"flex items-center justify-between mb-4\">\n          <div class=\"flex items-center space-x-4\">\n            <h3 class=\"text-base font-medium text-gray-900\">简历评分</h3>\n            <span class=\"text-lg font-semibold\" :class=\"progressTextColorClass\">\n              {{ totalScore }} 分\n            </span>\n          </div>\n          <!-- AI优化按钮 -->\n          <button\n            @click=\"showOptimize = true\"\n            class=\"flex items-center px-3 py-1.5 text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 rounded-md transition-all duration-200 shadow-sm\"\n          >\n            <SparklesIcon class=\"w-4 h-4 mr-1.5\" />\n            AI优化\n          </button>\n        </div>\n  \n        <!-- 总进度条 -->\n        <div class=\"bg-gray-200 rounded-full h-2.5 mb-4\">\n          <div \n            class=\"h-2.5 rounded-full transition-all duration-500\"\n            :class=\"progressColorClass\"\n            :style=\"{ width: `${totalScore}%` }\"\n          ></div>\n        </div>\n  \n        <!-- 维度得分 -->\n        <div class=\"space-y-3 mb-6\">\n          <div v-for=\"(dimension, key) in dimensions\" :key=\"key\" class=\"flex items-center\">\n            <span class=\"text-sm text-gray-600 w-24\">{{ getDimensionName(key) }}</span>\n            <div class=\"flex-1 mx-2\">\n              <div class=\"bg-gray-200 rounded-full h-1.5\">\n                <div \n                  class=\"h-1.5 rounded-full bg-blue-500\"\n                  :style=\"{ width: `${dimension.score}%` }\"\n                ></div>\n              </div>\n            </div>\n            <span class=\"text-sm text-gray-500\">{{ dimension.score }}%</span>\n          </div>\n        </div>\n  \n        <!-- 优化建议 -->\n        <div v-if=\"suggestions.length > 0\" class=\"space-y-2\">\n          <h4 class=\"text-sm font-medium text-gray-700\">优化建议</h4>\n          <ul class=\"space-y-1\">\n            <li \n              v-for=\"(suggestion, index) in suggestions\" \n              :key=\"index\"\n              class=\"flex items-start space-x-2 text-sm text-gray-600\"\n            >\n              <LightBulbIcon class=\"w-4 h-4 text-yellow-500 mt-0.5 flex-shrink-0\" />\n              <span>{{ suggestion }}</span>\n            </li>\n          </ul>\n        </div>\n  \n        <!-- 其他操作按钮 -->\n        <div class=\"grid grid-cols-2 gap-3 mt-6\">\n          <button\n            @click=\"$emit('import')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <ArrowDownTrayIcon class=\"w-4 h-4 mr-1.5\" />\n            导入简历\n          </button>\n  \n          <button\n            @click=\"handlePreview\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <EyeIcon class=\"w-4 h-4 mr-1.5\" />\n            预览简历\n          </button>\n        </div>\n      </div>\n    </div>\n  \n    <!-- 预览对话框 -->\n    <el-dialog\n      v-model=\"showPreview\"\n      :width=\"dialogWidth\"\n      :fullscreen=\"isMobile\"\n      :close-on-click-modal=\"false\"\n      :show-close=\"false\"\n      class=\"preview-dialog\"\n      destroy-on-close\n    >\n      <div class=\"dialog-container\">\n        <!-- 头部 -->\n        <div class=\"dialog-header\">\n          <div class=\"flex items-center justify-between\">\n            <h3 class=\"text-lg font-medium text-gray-900\">简历预览</h3>\n            <button\n              @click=\"showPreview = false\"\n              class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200\"\n              title=\"关闭\"\n            >\n              <XMarkIcon class=\"w-6 h-6 text-gray-500\" />\n            </button>\n          </div>\n        </div>\n  \n        <!-- 内容区域 -->\n        <div class=\"dialog-body\">\n          <ProfilePreview />\n        </div>\n      </div>\n    </el-dialog>\n  \n    <!-- AI优化对话框 -->\n    <AIOptimizeDialog\n      v-model=\"showOptimize\"\n      :profile-data=\"props.profileData\"\n      @apply=\"handleOptimizeApply\"\n    />\n  </template>\n  \n  <script setup>\n  import { ref, computed, watch } from 'vue'\n  import { useWindowSize } from '@vueuse/core'\n  import { \n    SparklesIcon,\n    ArrowDownTrayIcon,\n    EyeIcon,\n    XMarkIcon,\n    LightBulbIcon \n  } from '@heroicons/vue/24/outline'\n  import ProfilePreview from './ProfilePreview.vue'\n  import AIOptimizeDialog from '../dialogs/AIOptimizeDialog.vue'\n  import { ElMessage } from 'element-plus'\n  import profile from '@/api/profile'  // 修改为默认导入\n  \n  const props = defineProps({\n    completionData: {\n      type: Object,\n      default: () => ({})\n    },\n    profileData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  })\n  \n  defineEmits(['ai-optimize', 'import', 'preview'])\n  \n  // 预览对话框控制\n  const showPreview = ref(false)\n  \n  // 响应式布局\n  const { width } = useWindowSize()\n  const isMobile = computed(() => width.value < 640)\n  const dialogWidth = computed(() => {\n    if (isMobile.value) return '100%'\n    if (width.value < 1024) return '80%'\n    return '800px'  // 预览窗口可以稍微宽一点\n  })\n  \n  // 完整度数据\n  const completeness = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 监听完整度数据变化\n  watch(() => props.completionData, (newVal) => {\n    if (newVal) {\n      completeness.value = {\n        total_score: newVal.total_score || 0,\n        dimensions: newVal.dimensions || {},\n        suggestions: newVal.suggestions || []\n      }\n    }\n  }, { immediate: true })\n  \n  // 计算完整度百分比\n  const completionPercentage = computed(() => {\n    return Math.round(completeness.value.total_score || 0)\n  })\n  \n  // 获取完整度数据\n  const fetchCompleteness = async () => {\n    try {\n      const response = await profile.getCompleteness()\n      if (response?.data) {\n        completeness.value = {\n          total_score: response.data.total_score || 0,\n          dimensions: response.data.dimensions || {},\n          suggestions: response.data.suggestions || []\n        }\n      }\n    } catch (error) {\n      console.error('获取简历完整度失败:', error)\n      ElMessage.error('获取完整度数据失败，请稍后重试')\n    }\n  }\n  \n  // 监听 profileData 变化时更新完整度\n  watch(() => props.profileData, async (newVal) => {\n    if (newVal && Object.keys(newVal).length > 0) {\n      await fetchCompleteness()\n    } else {\n      console.log('profileData is empty')\n    }\n  }, { immediate: true })\n  \n  // 总分 - 保留一位小数\n  const totalScore = computed(() => {\n    const score = completeness.value?.total_score || 0\n    return Number(score.toFixed(1))\n  })\n  \n  // 维度数据 - 保留整数\n  const dimensions = computed(() => {\n    const dims = completeness.value?.dimensions || {}\n    return Object.entries(dims).reduce((acc, [key, value]) => {\n      acc[key] = {\n        ...value,\n        score: Math.round(value.score || 0),\n        weighted_score: value.weighted_score || 0\n      }\n      return acc\n    }, {})\n  })\n  \n  // 建议\n  const suggestions = computed(() => {\n    const rawSuggestions = completeness.value?.suggestions || []\n    // 只返回建议消息\n    return rawSuggestions.map(suggestion => suggestion.message)\n  })\n  \n  // 维度名称映射\n  const getDimensionName = (key) => {\n    const nameMap = {\n      basic_info: '基本信息',\n      experience: '工作经历',\n      capability: '能力素质',\n      achievement: '个人成就'\n    }\n    return nameMap[key] || key\n  }\n  \n  // 进度条颜色 - 根据实际分数范围调整\n  const progressColorClass = computed(() => {\n    const score = totalScore.value\n    if (score >= 70) return 'bg-green-500'\n    if (score >= 40) return 'bg-yellow-500'\n    return 'bg-red-500'\n  })\n  \n  // 文字颜色 - 与进度条颜色对应\n  const progressTextColorClass = computed(() => {\n    const score = totalScore.value\n    if (score >= 70) return 'text-green-600'\n    if (score >= 40) return 'text-yellow-600'\n    return 'text-red-600'\n  })\n  \n  // 处理预览按钮点击\n  const handlePreview = () => {\n    showPreview.value = true\n  }\n  \n  // AI优化相关\n  const showOptimize = ref(false)\n  \n  // 处理优化结果\n  const handleOptimizeApply = (optimizedData) => {\n    console.log('优化后的数据:', optimizedData)\n    // 这里处理优化后的数据，可能需要调用 API 更新档案\n  }\n  </script>\n\n<style scoped>\n/* 添加按钮悬停效果 */\nbutton {\n  position: relative;\n  overflow: hidden;\n}\n\nbutton::after {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 100%;\n  height: 100%;\n  background-color: rgba(255, 255, 255, 0.1);\n  transform: translate(-50%, -50%) scale(0);\n  border-radius: inherit;\n  transition: transform 0.3s ease;\n}\n\nbutton:hover::after {\n  transform: translate(-50%, -50%) scale(1.5);