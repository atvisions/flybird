{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.reduce.js\";\nimport { ref, onMounted } from 'vue';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nimport { updateBasicInfo } from '@/api/profile';\nexport default {\n  __name: 'BasicInfo',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n    const form = ref({\n      name: '',\n      gender: '',\n      birth_date: '',\n      phone: '',\n      email: '',\n      location: '',\n      personal_summary: ''\n    });\n\n    // 处理头像上传\n    const handleAvatarUpload = async file => {\n      try {\n        await store.dispatch('uploadAvatar', file);\n        ElMessage.success('头像上传成功');\n      } catch (error) {\n        ElMessage.error(error.response?.data?.message || '头像上传失败');\n      }\n    };\n\n    // 处理表单提交\n    const handleSubmit = async () => {\n      try {\n        // 过滤掉空值，但保留日期的 null 值\n        const submitData = Object.entries(form.value).reduce((acc, [key, value]) => {\n          if (key === 'birth_date') {\n            acc[key] = value || null;\n          } else if (value !== null && value !== undefined && value !== '') {\n            acc[key] = value;\n          }\n          return acc;\n        }, {});\n        await updateBasicInfo(submitData);\n        ElMessage.success('保存成功');\n      } catch (error) {\n        ElMessage.error(error.response?.data?.message || '保存失败');\n      }\n    };\n\n    // 加载基本信息\n    const loadBasicInfo = async () => {\n      try {\n        const response = await store.dispatch('getProfile');\n        if (response.data.code === 200) {\n          const basicInfo = response.data.data;\n          form.value = {\n            name: basicInfo.name || '',\n            gender: basicInfo.gender || '',\n            birth_date: basicInfo.birth_date || '',\n            phone: basicInfo.phone || '',\n            email: basicInfo.email || '',\n            location: basicInfo.location || '',\n            personal_summary: basicInfo.personal_summary || ''\n          };\n        }\n      } catch (error) {\n        ElMessage.error('获取基本信息失败');\n      }\n    };\n    onMounted(() => {\n      loadBasicInfo();\n    });\n    const __returned__ = {\n      store,\n      form,\n      handleAvatarUpload,\n      handleSubmit,\n      loadBasicInfo,\n      ref,\n      onMounted,\n      get useStore() {\n        return useStore;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get updateBasicInfo() {\n        return updateBasicInfo;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useStore","ElMessage","updateBasicInfo","store","form","name","gender","birth_date","phone","email","location","personal_summary","handleAvatarUpload","file","dispatch","success","error","response","data","message","handleSubmit","submitData","Object","entries","value","reduce","acc","key","undefined","loadBasicInfo","code","basicInfo"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n  <div class=\"basic-info\">\n    <!-- 头像上传 -->\n    <div class=\"avatar-upload\">\n      <el-upload\n        class=\"avatar-uploader\"\n        :show-file-list=\"false\"\n        :on-success=\"handleAvatarUpload\"\n        action=\"/api/v1/users/profile/avatar/upload/\"\n        :headers=\"{ Authorization: `Bearer ${store.state.token}` }\"\n      >\n        <img v-if=\"store.getters.getUserAvatar\" :src=\"store.getters.getUserAvatar\" class=\"avatar\">\n        <el-icon v-else class=\"avatar-uploader-icon\"><Plus /></el-icon>\n      </el-upload>\n    </div>\n\n    <!-- 基本信息表单 -->\n    <el-form :model=\"form\" label-width=\"80px\">\n      <el-form-item label=\"姓名\">\n        <el-input v-model=\"form.name\" />\n      </el-form-item>\n\n      <el-form-item label=\"性别\">\n        <el-select v-model=\"form.gender\" clearable>\n          <el-option label=\"男\" value=\"male\" />\n          <el-option label=\"女\" value=\"female\" />\n          <el-option label=\"其他\" value=\"other\" />\n        </el-select>\n      </el-form-item>\n\n      <el-form-item label=\"出生日期\">\n        <el-date-picker\n          v-model=\"form.birth_date\"\n          type=\"date\"\n          clearable\n          value-format=\"YYYY-MM-DD\"\n          format=\"YYYY-MM-DD\"\n          placeholder=\"选择日期\"\n        />\n      </el-form-item>\n\n      <el-form-item label=\"手机号\">\n        <el-input v-model=\"form.phone\" />\n      </el-form-item>\n\n      <el-form-item label=\"邮箱\">\n        <el-input v-model=\"form.email\" />\n      </el-form-item>\n\n      <el-form-item label=\"所在地\">\n        <el-input v-model=\"form.location\" />\n      </el-form-item>\n\n      <el-form-item label=\"个人简介\">\n        <el-input\n          v-model=\"form.personal_summary\"\n          type=\"textarea\"\n          :rows=\"4\"\n        />\n      </el-form-item>\n\n      <el-form-item>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </el-form-item>\n    </el-form>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport { useStore } from 'vuex'\nimport { ElMessage } from 'element-plus'\nimport { updateBasicInfo } from '@/api/profile'\n\nconst store = useStore()\nconst form = ref({\n  name: '',\n  gender: '',\n  birth_date: '',\n  phone: '',\n  email: '',\n  location: '',\n  personal_summary: ''\n})\n\n// 处理头像上传\nconst handleAvatarUpload = async (file) => {\n  try {\n    await store.dispatch('uploadAvatar', file)\n    ElMessage.success('头像上传成功')\n  } catch (error) {\n    ElMessage.error(error.response?.data?.message || '头像上传失败')\n  }\n}\n\n// 处理表单提交\nconst handleSubmit = async () => {\n  try {\n    // 过滤掉空值，但保留日期的 null 值\n    const submitData = Object.entries(form.value).reduce((acc, [key, value]) => {\n      if (key === 'birth_date') {\n        acc[key] = value || null\n      } else if (value !== null && value !== undefined && value !== '') {\n        acc[key] = value\n      }\n      return acc\n    }, {})\n\n    await updateBasicInfo(submitData)\n    ElMessage.success('保存成功')\n  } catch (error) {\n    ElMessage.error(error.response?.data?.message || '保存失败')\n  }\n}\n\n// 加载基本信息\nconst loadBasicInfo = async () => {\n  try {\n    const response = await store.dispatch('getProfile')\n    if (response.data.code === 200) {\n      const basicInfo = response.data.data\n      form.value = {\n        name: basicInfo.name || '',\n        gender: basicInfo.gender || '',\n        birth_date: basicInfo.birth_date || '',\n        phone: basicInfo.phone || '',\n        email: basicInfo.email || '',\n        location: basicInfo.location || '',\n        personal_summary: basicInfo.personal_summary || ''\n      }\n    }\n  } catch (error) {\n    ElMessage.error('获取基本信息失败')\n  }\n}\n\nonMounted(() => {\n  loadBasicInfo()\n})\n</script>\n\n<style scoped>\n.basic-info {\n  padding: 20px;\n}\n\n.avatar-upload {\n  text-align: center;\n  margin-bottom: 20px;\n}\n\n.avatar-uploader {\n  border: 1px dashed #d9d9d9;\n  border-radius: 6px;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n}\n\n.avatar-uploader:hover {\n  border-color: #409EFF;\n}\n\n.avatar {\n  width: 100px;\n  height: 100px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.avatar-uploader-icon {\n  font-size: 28px;\n  color: #8c939d;\n  width: 100px;\n  height: 100px;\n  line-height: 100px;\n  text-align: center;\n}\n</style>"],"mappings":";;AAsEA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAI;AACnC,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,cAAa;AACvC,SAASC,eAAe,QAAQ,eAAc;;;;;;;IAE9C,MAAMC,KAAK,GAAGH,QAAQ,CAAC;IACvB,MAAMI,IAAI,GAAGN,GAAG,CAAC;MACfO,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,