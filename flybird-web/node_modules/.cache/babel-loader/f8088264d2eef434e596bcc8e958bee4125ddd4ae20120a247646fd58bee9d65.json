{"ast":null,"code":"import { computed } from 'vue';\nimport { SparklesIcon, ArrowDownTrayIcon, EyeIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'ResumeStatus',\n  props: {\n    completionRate: {\n      type: Number,\n      default: 0\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['ai-optimize', 'import', 'preview'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n    const progressColorClass = computed(() => {\n      if (props.completionRate >= 80) return 'bg-green-500';\n      if (props.completionRate >= 50) return 'bg-yellow-500';\n      return 'bg-red-500';\n    });\n    const progressTextColorClass = computed(() => {\n      if (props.completionRate >= 80) return 'text-green-600';\n      if (props.completionRate >= 50) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n    const progressMessage = computed(() => {\n      if (props.completionRate >= 80) return '您的简历完整度很高，继续保持！';\n      if (props.completionRate >= 50) return '简历完整度一般，建议继续完善。';\n      return '简历完整度较低，请尽快完善简历信息。';\n    });\n    const __returned__ = {\n      props,\n      progressColorClass,\n      progressTextColorClass,\n      progressMessage,\n      computed,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get ArrowDownTrayIcon() {\n        return ArrowDownTrayIcon;\n      },\n      get EyeIcon() {\n        return EyeIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","SparklesIcon","ArrowDownTrayIcon","EyeIcon","props","__props","progressColorClass","completionRate","progressTextColorClass","progressMessage"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/ResumeStatus.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ResumeStatus.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <div class=\"p-4\">\n        <!-- 标题和百分比 -->\n        <div class=\"flex items-center justify-between mb-4\">\n          <h3 class=\"text-base font-medium text-gray-900\">简历完整度</h3>\n          <span class=\"text-lg font-semibold\" :class=\"progressTextColorClass\">\n            {{ completionRate }}%\n          </span>\n        </div>\n  \n        <!-- 进度条 -->\n        <div class=\"bg-gray-200 rounded-full h-2.5 mb-3\">\n          <div \n            class=\"h-2.5 rounded-full transition-all duration-500\"\n            :class=\"progressColorClass\"\n            :style=\"{ width: `${completionRate}%` }\"\n          ></div>\n        </div>\n  \n        <!-- 提示信息 -->\n        <p class=\"text-sm mb-4\" :class=\"progressTextColorClass\">\n          {{ progressMessage }}\n        </p>\n  \n        <!-- 操作按钮 -->\n        <div class=\"grid grid-cols-3 gap-3\">\n          <button\n            @click=\"$emit('ai-optimize')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 transition-all duration-200 shadow-sm\"\n          >\n            <SparklesIcon class=\"w-4 h-4 mr-1.5\" />\n            AI优化\n          </button>\n  \n          <button\n            @click=\"$emit('import')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <ArrowDownTrayIcon class=\"w-4 h-4 mr-1.5\" />\n            导入简历\n          </button>\n  \n          <button\n            @click=\"$emit('preview')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <EyeIcon class=\"w-4 h-4 mr-1.5\" />\n            预览简历\n          </button>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\n  import { computed } from 'vue'\n  import { \n    SparklesIcon,\n    ArrowDownTrayIcon,\n    EyeIcon \n  } from '@heroicons/vue/24/outline'\n  \n  const props = defineProps({\n    completionRate: {\n      type: Number,\n      default: 0\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  })\n  \n  defineEmits(['ai-optimize', 'import', 'preview'])\n  \n  const progressColorClass = computed(() => {\n    if (props.completionRate >= 80) return 'bg-green-500'\n    if (props.completionRate >= 50) return 'bg-yellow-500'\n    return 'bg-red-500'\n  })\n  \n  const progressTextColorClass = computed(() => {\n    if (props.completionRate >= 80) return 'text-green-600'\n    if (props.completionRate >= 50) return 'text-yellow-600'\n    return 'text-red-600'\n  })\n  \n  const progressMessage = computed(() => {\n    if (props.completionRate >= 80) return '您的简历完整度很高，继续保持！'\n    if (props.completionRate >= 50) return '简历完整度一般，建议继续完善。'\n    return '简历完整度较低，请尽快完善简历信息。'\n  })\n  </script>\n\n<style scoped>\n/* 添加按钮悬停效果 */\nbutton {\n  position: relative;\n  overflow: hidden;\n}\n\nbutton::after {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 100%;\n  height: 100%;\n  background-color: rgba(255, 255, 255, 0.1);\n  transform: translate(-50%, -50%) scale(0);\n  border-radius: inherit;\n  transition: transform 0.3s ease;\n}\n\nbutton:hover::after {\n  transform: translate(-50%, -50%) scale(1.5);\n}\n\n/* 渐变进度条效果 */\n.bg-green-500 {\n  background: linear-gradient(90deg, #10B981 0%, #34D399 100%);\n}\n\n.bg-yellow-500 {\n  background: linear-gradient(90deg, #F59E0B 0%, #FBBF24 100%);\n}\n\n.bg-red-500 {\n  background: linear-gradient(90deg, #EF4444 0%, #F87171 100%);\n}\n</style>"],"mappings":"AAyDE,SAASA,QAAQ,QAAQ,KAAI;AAC7B,SACEC,YAAY,EACZC,iBAAiB,EACjBC,OAAO,QACF,2BAA0B;;;;;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;IAad,MAA