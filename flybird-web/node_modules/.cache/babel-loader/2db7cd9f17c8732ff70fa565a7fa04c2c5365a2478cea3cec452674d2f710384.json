{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport { computed, onMounted, watch } from 'vue';\nexport default {\n  __name: 'WorkExperienceContent',\n  props: {\n    data: {\n      type: Object,\n      default: () => null\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 添加数据监听\n    watch(() => props.data, newData => {\n      console.log('WorkExperienceContent data changed:', newData);\n    }, {\n      immediate: true\n    });\n    onMounted(() => {\n      console.log('WorkExperienceContent mounted, data:', props.data);\n    });\n\n    // 格式化日期范围\n    const formatDateRange = (startDate, endDate, isCurrent) => {\n      if (!startDate) return '';\n      const start = new Date(startDate).toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'numeric'\n      });\n      if (isCurrent) {\n        return `${start} - 至今`;\n      }\n      if (endDate) {\n        const end = new Date(endDate).toLocaleDateString('zh-CN', {\n          year: 'numeric',\n          month: 'numeric'\n        });\n        return `${start} - ${end}`;\n      }\n      return start;\n    };\n\n    // 格式化技术栈\n    const formatTechStack = technologies => {\n      if (!technologies) return [];\n      return technologies.split(/[,，、\\s]+/).filter(Boolean);\n    };\n    const __returned__ = {\n      props,\n      formatDateRange,\n      formatTechStack,\n      computed,\n      onMounted,\n      watch\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","onMounted","watch","props","__props","data","newData","console","log","immediate","formatDateRange","startDate","endDate","isCurrent","start","Date","toLocaleDateString","year","month","end","formatTechStack","technologies","split","filter","Boolean"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/WorkExperienceContent.vue"],"sourcesContent":["<template>\n  <!-- 添加调试信息 -->\n  <div class=\"text-xs text-gray-400 mb-2\">\n    Debug: {{ data ? JSON.stringify(data) : 'No data' }}\n  </div>\n\n  <div v-if=\"data\" class=\"work-experience-content\">\n    <!-- 公司和职位信息 -->\n    <div class=\"flex items-center justify-between mb-3\">\n      <div class=\"flex items-center space-x-2\">\n        <span class=\"text-base font-medium\">{{ data.company }}</span>\n        <span class=\"text-gray-500\">·</span>\n        <span class=\"text-gray-600\">{{ data.position }}</span>\n      </div>\n      <div class=\"text-sm text-gray-500\">\n        {{ formatDateRange(data.start_date, data.end_date, data.is_current) }}\n        <span v-if=\"data.duration\" class=\"ml-1\">({{ data.duration }})</span>\n      </div>\n    </div>\n\n    <!-- 部门信息 -->\n    <div v-if=\"data.department\" class=\"mb-3 text-sm text-gray-600\">\n      <span class=\"font-medium\">所在部门：</span>{{ data.department }}\n    </div>\n\n    <!-- 工作描述 -->\n    <div v-if=\"data.description\" class=\"mb-3\">\n      <div class=\"text-sm font-medium text-gray-600 mb-1\">工作描述：</div>\n      <div class=\"text-sm text-gray-600 whitespace-pre-line\">{{ data.description }}</div>\n    </div>\n\n    <!-- 工作成就 -->\n    <div v-if=\"data.achievements\" class=\"mb-3\">\n      <div class=\"text-sm font-medium text-gray-600 mb-1\">工作成就：</div>\n      <div class=\"text-sm text-gray-600 whitespace-pre-line\">{{ data.achievements }}</div>\n    </div>\n\n    <!-- 技术栈 -->\n    <div v-if=\"data.technologies\" class=\"mb-3\">\n      <div class=\"text-sm font-medium text-gray-600 mb-1\">技术栈：</div>\n      <div class=\"flex flex-wrap gap-2\">\n        <el-tag\n          v-for=\"tech in formatTechStack(data.technologies)\"\n          :key=\"tech\"\n          size=\"small\"\n          type=\"info\"\n        >\n          {{ tech }}\n        </el-tag>\n      </div>\n    </div>\n  </div>\n  <div v-else class=\"text-gray-400 text-center py-4\">\n    暂无内容，点击编辑添加\n  </div>\n</template>\n\n<script setup>\nimport { computed, onMounted, watch } from 'vue'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: () => null\n  }\n})\n\n// 添加数据监听\nwatch(() => props.data, (newData) => {\n  console.log('WorkExperienceContent data changed:', newData)\n}, { immediate: true })\n\nonMounted(() => {\n  console.log('WorkExperienceContent mounted, data:', props.data)\n})\n\n// 格式化日期范围\nconst formatDateRange = (startDate, endDate, isCurrent) => {\n  if (!startDate) return ''\n  \n  const start = new Date(startDate).toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'numeric'\n  })\n  \n  if (isCurrent) {\n    return `${start} - 至今`\n  }\n  \n  if (endDate) {\n    const end = new Date(endDate).toLocaleDateString('zh-CN', {\n      year: 'numeric',\n      month: 'numeric'\n    })\n    return `${start} - ${end}`\n  }\n  \n  return start\n}\n\n// 格式化技术栈\nconst formatTechStack = (technologies) => {\n  if (!technologies) return []\n  return technologies.split(/[,，、\\s]+/).filter(Boolean)\n}\n</script>\n\n<style scoped>\n.work-experience-content {\n  @apply space-y-4;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .work-experience-content {\n    @apply space-y-3;\n  }\n}\n\n:deep(.el-tag--small) {\n  height: 22px;\n  padding: 0 8px;\n  font-size: 12px;\n}\n</style> "],"mappings":";;AA0DA,SAASA,QAAQ,EAAEC,SAAS,EAAEC,KAAK,QAAQ,KAAI;;;;;;;;;;;;;IAE/C,MAAMC,KAAK,GAAGC,OAAA;;IAOd;IACAF,KAAK,CAAC,MAAMC,KAAK,CAACE,IAAI,EAAGC,OAAO,IAAK;MACnCC,OAAO,CAACC,GAAG,CAAC,qCAAqC,EAAEF,OAAO;IAC5D,CAAC,EAAE;MAAEG,SAAS,EAAE;IAAK,CAAC;IAEtBR,SAAS,CAAC,MAAM;MACdM,OAAO,CAACC,GAAG,CAAC,sCAAsC,EAAEL,KAAK,CAACE,IAAI;IAChE,CAAC;;IAED;IACA,MAAMK,eAAe,GAAGA,CAACC,SAAS,EAAEC,OAAO,EAAEC,SAAS,KAAK;MACzD,IAAI,CAACF,SAAS,EAAE,OAAO,EAAC;MAExB,MAAMG,KAAK,GAAG,IAAIC,IAAI,CAACJ,SAAS,CAAC,CAACK,kBAAkB,CAAC,OAAO,EAAE;QAC5DC,IAAI,EAAE,SAAS;QAC