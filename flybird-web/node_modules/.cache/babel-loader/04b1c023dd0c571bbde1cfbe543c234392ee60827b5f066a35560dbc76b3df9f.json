{"ast":null,"code":"import { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions';\nimport { INDUSTRY_CATEGORIES } from '../constants/industryOptions';\nimport { useFormValidation } from '../composables/useFormValidation';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'EditJobIntentionDialog',\n  props: {\n    modelValue: {\n      type: Boolean,\n      default: false\n    },\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const {\n      width\n    } = useWindowSize();\n\n    // 判断是否为移动端\n    const isMobile = computed(() => width.value < 640);\n\n    // 根据屏幕宽度设置弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n    const props = __props;\n    const emit = __emit;\n\n    // 表单引用\n    const formRef = ref(null);\n\n    // 表单数据\n    const form = ref({\n      job_type: '',\n      job_status: '',\n      expected_salary: '',\n      expected_city: '',\n      industries: ''\n    });\n    const {\n      rules,\n      validateForm\n    } = useFormValidation();\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      if (newVal) {\n        console.log('Dialog received initial data:', newVal);\n        form.value = {\n          job_type: newVal.job_type || '',\n          job_status: newVal.job_status || '',\n          expected_salary: newVal.expected_salary || '',\n          expected_city: newVal.expected_city || '',\n          industries: newVal.industries || ''\n        };\n        console.log('Dialog form data updated:', form.value);\n      }\n    }, {\n      immediate: true,\n      deep: true\n    });\n\n    // 处理提交\n    const handleSubmit = async () => {\n      try {\n        console.log('开始验证表单:', {\n          formRef: formRef.value,\n          formData: form.value\n        });\n        const {\n          valid,\n          errors\n        } = await validateForm(formRef.value, form.value);\n        console.log('验证结果:', {\n          valid,\n          errors\n        });\n        if (!valid) {\n          // 显示具体的错误信息\n          ElMessage.error(errors.join('\\n'));\n          return;\n        }\n        emit('submit', form.value);\n      } catch (error) {\n        console.error('表单提交失败:', error);\n        ElMessage.error('提交失败，请稍后重试');\n      }\n    };\n    const handleClose = () => {\n      emit('update:modelValue', false);\n    };\n\n    // 求职状态选项\n    const LOCAL_JOB_STATUS_OPTIONS = [{\n      value: 'unemployed_looking',\n      label: '离职-找工作'\n    }, {\n      value: 'employed_not_looking',\n      label: '在职-暂不考虑'\n    }, {\n      value: 'employed_looking',\n      label: '在职-看机会'\n    }, {\n      value: 'student_internship',\n      label: '在校-找实习'\n    }, {\n      value: 'fresh_graduate',\n      label: '应届生'\n    }];\n    const __returned__ = {\n      width,\n      isMobile,\n      dialogWidth,\n      props,\n      emit,\n      formRef,\n      form,\n      rules,\n      validateForm,\n      handleSubmit,\n      handleClose,\n      LOCAL_JOB_STATUS_OPTIONS,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get JOB_TYPE_OPTIONS() {\n        return JOB_TYPE_OPTIONS;\n      },\n      get JOB_STATUS_OPTIONS() {\n        return JOB_STATUS_OPTIONS;\n      },\n      get SALARY_OPTIONS() {\n        return SALARY_OPTIONS;\n      },\n      get INDUSTRY_CATEGORIES() {\n        return INDUSTRY_CATEGORIES;\n      },\n      get useFormValidation() {\n        return useFormValidation;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","JOB_TYPE_OPTIONS","JOB_STATUS_OPTIONS","SALARY_OPTIONS","INDUSTRY_CATEGORIES","useFormValidation","ElMessage","width","isMobile","value","dialogWidth","props","__props","emit","__emit","formRef","form","job_type","job_status","expected_salary","expected_city","industries","rules","validateForm","initialData","newVal","console","log","immediate","deep","handleSubmit","formData","valid","errors","error","join","handleClose","LOCAL_JOB_STATUS_OPTIONS","label"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditJobIntentionDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n    @close=\"handleClose\"\n    class=\"relative\"\n  >\n    <!-- Header -->\n    <template #header>\n      <div class=\"border-b border-gray-200 px-6 py-5\">\n        <h3 class=\"text-lg font-medium text-gray-900\">编辑求职意向</h3>\n      </div>\n    </template>\n\n    <!-- Body -->\n    <div class=\"px-6 py-5\">\n      <el-form\n        ref=\"formRef\"\n        :model=\"form\"\n        :rules=\"rules\"\n      >\n        <form @submit.prevent=\"handleSubmit\" class=\"space-y-5\">\n          <!-- 两列布局 -->\n          <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n            <!-- 工作类型 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">工作类型</label>\n              <el-form-item prop=\"job_type\" class=\"mb-0\">\n                <div class=\"relative\">\n                  <select\n                    v-model=\"form.job_type\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-base focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  >\n                    <option value=\"\" disabled>请选择工作类型</option>\n                    <option v-for=\"option in JOB_TYPE_OPTIONS\" :key=\"option.value\" :value=\"option.value\">\n                      {{ option.label }}\n                    </option>\n                  </select>\n                  <div class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-2\">\n                    <svg class=\"h-4 w-4 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" />\n                    </svg>\n                  </div>\n                </div>\n              </el-form-item>\n            </div>\n\n            <!-- 求职状态 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">求职状态</label>\n              <el-form-item prop=\"job_status\" class=\"mb-0\">\n                <div class=\"relative\">\n                  <select\n                    v-model=\"form.job_status\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-base focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  >\n                    <option value=\"\" disabled>请选择求职状态</option>\n                    <option v-for=\"option in LOCAL_JOB_STATUS_OPTIONS\" :key=\"option.value\" :value=\"option.value\">\n                      {{ option.label }}\n                    </option>\n                  </select>\n                  <div class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-2\">\n                    <svg class=\"h-4 w-4 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" />\n                    </svg>\n                  </div>\n                </div>\n              </el-form-item>\n            </div>\n\n            <!-- 期望薪资 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">期望薪资</label>\n              <el-form-item prop=\"expected_salary\" class=\"mb-0\">\n                <div class=\"relative\">\n                  <select\n                    v-model=\"form.expected_salary\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-base focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  >\n                    <option value=\"\" disabled>请选择期望薪资</option>\n                    <option v-for=\"option in SALARY_OPTIONS\" :key=\"option.value\" :value=\"option.value\">\n                      {{ option.label }}\n                    </option>\n                  </select>\n                  <div class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-2\">\n                    <svg class=\"h-4 w-4 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" />\n                    </svg>\n                  </div>\n                </div>\n              </el-form-item>\n            </div>\n\n            <!-- 期望城市 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">期望城市</label>\n              <el-form-item prop=\"expected_city\" class=\"mb-0\">\n                <input\n                  v-model=\"form.expected_city\"\n                  type=\"text\"\n                  placeholder=\"请输入期望城市，多个城市用逗号分隔\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                />\n              </el-form-item>\n            </div>\n          </div>\n\n          <!-- 期望行业 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">期望行业</label>\n            <el-form-item prop=\"industries\" class=\"mb-0\">\n              <input\n                v-model=\"form.industries\"\n                type=\"text\"\n                placeholder=\"请输入期望行业，多个行业用逗号分隔\"\n                class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n              />\n            </el-form-item>\n          </div>\n        </form>\n      </el-form>\n    </div>\n\n    <!-- Footer -->\n    <template #footer>\n      <div class=\"border-t border-gray-200 px-6 py-4\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions'\nimport { INDUSTRY_CATEGORIES } from '../constants/industryOptions'\nimport { useFormValidation } from '../composables/useFormValidation'\nimport { ElMessage } from 'element-plus'\n\nconst { width } = useWindowSize()\n\n// 判断是否为移动端\nconst isMobile = computed(() => width.value < 640)\n\n// 根据屏幕宽度设置弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    default: false\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单引用\nconst formRef = ref(null)\n\n// 表单数据\nconst form = ref({\n  job_type: '',\n  job_status: '',\n  expected_salary: '',\n  expected_city: '',\n  industries: ''\n})\n\nconst { rules, validateForm } = useFormValidation()\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newVal) => {\n  if (newVal) {\n    console.log('Dialog received initial data:', newVal)\n    form.value = {\n      job_type: newVal.job_type || '',\n      job_status: newVal.job_status || '',\n      expected_salary: newVal.expected_salary || '',\n      expected_city: newVal.expected_city || '',\n      industries: newVal.industries || ''\n    }\n    console.log('Dialog form data updated:', form.value)\n  }\n}, { immediate: true, deep: true })\n\n// 处理提交\nconst handleSubmit = async () => {\n  try {\n    console.log('开始验证表单:', {\n      formRef: formRef.value,\n      formData: form.value\n    })\n    const { valid, errors } = await validateForm(formRef.value, form.value)\n    console.log('验证结果:', { valid, errors })\n    if (!valid) {\n      // 显示具体的错误信息\n      ElMessage.error(errors.join('\\n'))\n      return\n    }\n    emit('submit', form.value)\n  } catch (error) {\n    console.error('表单提交失败:', error)\n    ElMessage.error('提交失败，请稍后重试')\n  }\n}\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n\n// 求职状态选项\nconst LOCAL_JOB_STATUS_OPTIONS = [\n  { value: 'unemployed_looking', label: '离职-找工作' },\n  { value: 'employed_not_looking', label: '在职-暂不考虑' },\n  { value: 'employed_looking', label: '在职-看机会' },\n  { value: 'student_internship', label: '在校-找实习' },\n  { value: 'fresh_graduate', label: '应届生' }\n]\n</script>\n\n<style>\n/* 隐藏 el-form-item 的默认样式 */\n.el-form-item__error {\n  display: none;\n}\n\n/* 自定义下拉框样式 */\nselect {\n  appearance: none;\n  -webkit-appearance: none;\n  -moz-appearance: none;\n}\n\nselect:focus {\n  @apply border-gray-900 ring-1 ring-gray-900/10;\n}\n\n/* 禁用选项的样式 */\nselect option[value=\"\"] {\n  @apply text-gray-400;\n}\n\n/* 下拉选项的悬停效果 */\nselect option:not([value=\"\"]):hover {\n  @apply bg-gray-100;\n}\n\n/* 输入框样式统一 */\ninput, select {\n  @apply block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm text-sm;\n}\n\ninput:focus, select:focus {\n  @apply border-gray-900 ring-1 ring-gray-900/10 outline-none;\n}\n\n/* 占位符文本颜色 */\ninput::placeholder {\n  @apply text-gray-400;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  input, select {\n    @apply text-base;\n  }\n}\n</style> "],"mappings":"AAuJA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,gBAAgB,EAAEC,kBAAkB,EAAEC,cAAc,QAAQ,yBAAwB;AAC7F,SAASC,mBAAmB,QAAQ,8BAA6B;AACjE,SAASC,iBAAiB,QAAQ,kCAAiC;AACnE,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;;;;;;;IAEvC,MAAM;MAAEC;IAAM,CAAC,GAAGP,aAAa,CAAC;;IAEhC;IACA,MAAMQ,QAAQ,GAAGV,QAAQ,CAAC,MAAMS,KAAK,CAACE,KAAK,GAAG,GAAG;;IAEjD;IACA,MAAMC,WAAW,GAAGZ,QAAQ,CAAC,MAAM;MACjC,IAAIS,KAAK,CAACE,KAAK,GAAG,GAAG,EAAE,OAAO,KAAI;MAClC,IAAIF,KAAK,CAACE,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;IAED,MAAME,KAAK,GAAGC,OAAA;IAed,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,OAAO,GAAGlB,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMmB,IAAI,GAAGnB,GAAG,CAAC;MACfoB,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,eAAe,EAAE,EAAE;MACnBC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE;IACd,CAAC;IAED,MAAM;MAAEC,KAAK;MAAEC;IAAa,CAAC,GAAGlB,iBAAiB,C