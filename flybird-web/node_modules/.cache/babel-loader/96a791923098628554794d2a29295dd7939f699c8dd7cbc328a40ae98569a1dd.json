{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport { ref, computed, nextTick, watch, onMounted } from 'vue';\nimport { ElMessage } from 'element-plus';\nimport defaultAvatarImage from '@/assets/images/default-avatar.png';\nimport { useStore } from 'vuex';\nimport { MEDIA_URL } from '@/config';\nimport { showToast } from '@/components/ToastMessage';\nimport { PencilIcon, PhoneIcon, EnvelopeIcon, MapPinIcon, BriefcaseIcon, ClockIcon, CurrencyYenIcon, DocumentTextIcon, CameraIcon, UserIcon, CalendarIcon, ChevronDownIcon, ChevronUpIcon, CakeIcon, PencilSquareIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'BasicInfo',\n  props: {\n    resumeData: {\n      type: Object,\n      required: true\n    },\n    loading: Boolean,\n    bioExpanded: Boolean,\n    showBioExpandButton: Boolean,\n    getBioText: String\n  },\n  emits: ['update', 'edit', 'toggleBioExpand'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const store = useStore();\n    const loading = ref(true);\n    const userBasicInfo = ref(null);\n\n    // 修改头像上传处理函数\n    const handleAvatarUpload = async file => {\n      try {\n        loading.value = true;\n        const formData = new FormData();\n        formData.append('avatar', file);\n\n        // 使用 store action 上传头像\n        const response = await store.dispatch('updateBasicInfo', {\n          type: 'avatar',\n          data: formData\n        });\n        if (response.data?.code === 200) {\n          // 更新成功后重新获取用户信息\n          await store.dispatch('fetchUserInfo');\n          showToast('头像上传成功', 'success');\n          // 触发父组件更新\n          emit('update');\n        }\n      } catch (error) {\n        console.error('头像上传失败:', error);\n        showToast(error.message || '头像上传失败，请稍后重试', 'error');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 获取用户基本信息\n    const fetchUserBasicInfo = async () => {\n      try {\n        loading.value = true;\n        await store.dispatch('fetchUserInfo');\n        // 从 store 中获取用户信息\n        userBasicInfo.value = _objectSpread(_objectSpread({}, store.state.basicInfo), store.state.userInfo);\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n        showToast('获取用户信息失败', 'error');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 监听 store 中的用户信息变化\n    watch(() => [store.state.userInfo, store.state.basicInfo], ([newUserInfo, newBasicInfo]) => {\n      if (newUserInfo || newBasicInfo) {\n        userBasicInfo.value = _objectSpread(_objectSpread({}, newBasicInfo), newUserInfo);\n      }\n    }, {\n      immediate: true\n    });\n\n    // 在组件挂载时获取用户信息\n    onMounted(async () => {\n      if (store.state.isAuthenticated) {\n        await fetchUserBasicInfo();\n      }\n    });\n\n    // 添加用户头像计算属性\n    const userAvatar = computed(() => {\n      const avatar = store.getters.userAvatar;\n      return avatar.startsWith('/') ? `${MEDIA_URL}${avatar}` : avatar;\n    });\n\n    // 添加用户名计算属性\n    const userName = computed(() => store.getters.userName);\n\n    // 添加用户手机号计算属性\n    const userPhone = computed(() => store.getters.userPhone);\n    const props = __props;\n    const emit = __emit;\n    const fileInput = ref(null);\n\n    // 修改调试日志方式\n    const logResumeData = () => {\n      const plainData = {\n        name: props.resumeData.name,\n        gender: props.resumeData.gender,\n        phone: props.resumeData.phone,\n        email: props.resumeData.email,\n        location: props.resumeData.location,\n        birth_date: props.resumeData.birth_date,\n        personal_summary: props.resumeData.personal_summary,\n        created_at: props.resumeData.created_at,\n        updated_at: props.resumeData.updated_at\n      };\n      console.log('BasicInfo data:', plainData);\n    };\n\n    // 监听数据变化\n    watch(() => props.resumeData, newVal => {\n      // 当 resumeData 加载完成时，关闭 loading 状态\n      if (newVal && Object.keys(newVal).length > 0) {\n        loading.value = false;\n      }\n    }, {\n      immediate: true\n    });\n\n    // 处理文件选择\n    const handleFileChange = async event => {\n      const file = event.target.files[0];\n      if (!file) return;\n\n      // 验证文件类型\n      if (!file.type.startsWith('image/')) {\n        showToast('请选择图片文件', 'error');\n        return;\n      }\n\n      // 验证文件大小（例如限制为 2MB）\n      const maxSize = 2 * 1024 * 1024; // 2MB\n      if (file.size > maxSize) {\n        showToast('图片大小不能超过 2MB', 'error');\n        return;\n      }\n      await handleAvatarUpload(file);\n\n      // 清空文件选择器，以便能够选择同一个文件\n      event.target.value = '';\n    };\n\n    // 添加 basicInfo ref\n    const basicInfo = ref({});\n\n    // 性别显示文本\n    const genderText = computed(() => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[props.resumeData.gender] || '未设置性别';\n    });\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return date.toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'long',\n        day: 'numeric'\n      });\n    };\n\n    // 处理编辑按钮点击\n    const handleEdit = () => {\n      console.log('点击编辑按钮, 当前数据:', props.resumeData);\n      emit('edit');\n    };\n\n    // 处理展开/收起\n    const toggleBioExpand = () => {\n      emit('toggleBioExpand');\n    };\n\n    // 计算年龄的函数\n    const calculateAge = birthDate => {\n      if (!birthDate) return '';\n      const birth = new Date(birthDate);\n      const today = new Date();\n      let age = today.getFullYear() - birth.getFullYear();\n      const monthDiff = today.getMonth() - birth.getMonth();\n\n      // 如果还没到生日，年龄减1\n      if (monthDiff < 0 || monthDiff === 0 && today.getDate() < birth.getDate()) {\n        age--;\n      }\n      return `${age}岁`;\n    };\n\n    // 格式化性别显示\n    const formatGender = gender => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[gender] || '未填写';\n    };\n\n    // 格式化基本信息\n    const formatBasicInfo = computed(() => {\n      const info = props.resumeData || {};\n      return {\n        name: info.name || '未填写',\n        gender: formatGender(info.gender),\n        phone: info.phone || '未填写',\n        email: info.email || '未填写',\n        location: info.location || '未填写',\n        age: calculateAge(info.birth_date) || '未填写',\n        personal_summary: info.personal_summary || '未填写'\n      };\n    });\n\n    // 计算当前性别\n    const currentGender = computed(() => {\n      // 优先使用 resumeData 中的性别\n      const gender = props.resumeData?.gender || userBasicInfo.value?.gender || store.state.userInfo?.gender;\n      return gender;\n    });\n\n    // 触发文件选择\n    const triggerUpload = () => {\n      fileInput.value.click();\n    };\n    const __returned__ = {\n      store,\n      loading,\n      userBasicInfo,\n      handleAvatarUpload,\n      fetchUserBasicInfo,\n      userAvatar,\n      userName,\n      userPhone,\n      props,\n      emit,\n      fileInput,\n      logResumeData,\n      handleFileChange,\n      basicInfo,\n      genderText,\n      formatDate,\n      handleEdit,\n      toggleBioExpand,\n      calculateAge,\n      formatGender,\n      formatBasicInfo,\n      currentGender,\n      triggerUpload,\n      ref,\n      computed,\n      nextTick,\n      watch,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get defaultAvatarImage() {\n        return defaultAvatarImage;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get MEDIA_URL() {\n        return MEDIA_URL;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get PhoneIcon() {\n        return PhoneIcon;\n      },\n      get EnvelopeIcon() {\n        return EnvelopeIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },\n      get CameraIcon() {\n        return CameraIcon;\n      },\n      get UserIcon() {\n        return UserIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get ChevronDownIcon() {\n        return ChevronDownIcon;\n      },\n      get ChevronUpIcon() {\n        return ChevronUpIcon;\n      },\n      get CakeIcon() {\n        return CakeIcon;\n      },\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","nextTick","watch","onMounted","ElMessage","defaultAvatarImage","useStore","MEDIA_URL","showToast","PencilIcon","PhoneIcon","EnvelopeIcon","MapPinIcon","BriefcaseIcon","ClockIcon","CurrencyYenIcon","DocumentTextIcon","CameraIcon","UserIcon","CalendarIcon","ChevronDownIcon","ChevronUpIcon","CakeIcon","PencilSquareIcon","store","loading","userBasicInfo","handleAvatarUpload","file","value","formData","FormData","append","response","dispatch","type","data","code","emit","error","console","message","fetchUserBasicInfo","_objectSpread","state","basicInfo","userInfo","newUserInfo","newBasicInfo","immediate","isAuthenticated","userAvatar","avatar","getters","startsWith","userName","userPhone","props","__props","__emit","fileInput","logResumeData","plainData","name","resumeData","gender","phone","email","location","birth_date","personal_summary","created_at","updated_at","log","newVal","Object","keys","length","handleFileChange","event","target","files","maxSize","size","genderText","genderMap","male","female","other","formatDate","dateString","date","Date","toLocaleDateString","year","month","day","handleEdit","toggleBioExpand","calculateAge","birthDate","birth","today","age","getFullYear","monthDiff","getMonth","getDate","formatGender","formatBasicInfo","info","currentGender","triggerUpload","click"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <!-- 骨架图加载状态 -->\n      <template v-if=\"loading\">\n        <div class=\"p-4\">\n          <div class=\"flex items-start space-x-5\">\n            <!-- 头像骨架 -->\n            <div class=\"relative\">\n              <div class=\"w-20 h-20 rounded-full bg-gray-200 animate-pulse\"></div>\n              <div class=\"absolute -bottom-1 -right-1 w-6 h-6 rounded-full bg-gray-200 animate-pulse\"></div>\n            </div>\n            \n            <!-- 信息骨架 -->\n            <div class=\"flex-1 min-w-0\">\n              <!-- 名字骨架 -->\n              <div class=\"flex items-center justify-between mb-3\">\n                <div class=\"h-6 w-24 bg-gray-200 rounded animate-pulse\"></div>\n              </div>\n              \n              <!-- 基本信息骨架 -->\n              <div class=\"grid grid-cols-2 gap-3\">\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n              </div>\n              \n              <!-- 个人简介骨架 -->\n              <div class=\"mt-3\">\n                <div class=\"flex items-center mb-2\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-16 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"bg-gray-50 rounded-md p-4\">\n                  <div class=\"space-y-2\">\n                    <div class=\"h-4 bg-gray-200 rounded animate-pulse\"></div>\n                    <div class=\"h-4 bg-gray-200 rounded animate-pulse\"></div>\n                    <div class=\"h-4 w-2/3 bg-gray-200 rounded animate-pulse\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </template>\n\n      <!-- 实际内容 -->\n      <template v-else>\n        <div class=\"p-4\">\n          <div class=\"flex items-start space-x-5\">\n            <!-- 头像部分 -->\n            <div class=\"relative group\">\n              <img \n                  :src=\"userBasicInfo?.avatar ? `${MEDIA_URL}${userBasicInfo.avatar}` : defaultAvatarImage\" \n                  class=\"w-20 h-20 rounded-full object-cover border-2 border-white shadow\"\n                  alt=\"用户头像\"\n                  @error=\"handleImageError\"\n                  />\n                  <!-- 性别图标 -->\n                  <div class=\"absolute -bottom-1 -right-1 bg-white rounded-full p-1 shadow\">\n                    <svg v-if=\"currentGender === 'male'\" \n                      class=\"w-4 h-4 text-blue-500\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                      <path d=\"M12 2C9.243 2 7 4.243 7 7v2h10V7c0-2.757-2.243-5-5-5zM9 11H7v9c0 1.654 1.346 3 3 3h4c1.654 0 3-1.346 3-3v-9h-2v9c0 .552-.448 1-1 1h-4c-.552 0-1-.448-1-1v-9z\"/>\n                    </svg>\n                    <svg v-else-if=\"currentGender === 'female'\" \n                      class=\"w-4 h-4 text-pink-500\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                      <path d=\"M12 2C9.243 2 7 4.243 7 7v2h10V7c0-2.757-2.243-5-5-5zM9 11H7v5h10v-5h-2v3H9v-3z\"/>\n                    </svg>\n                  </div>\n                  <div \n                  @click=\"triggerUpload\"\n                  class=\"absolute inset-0 flex items-center justify-center rounded-full bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-200\"\n                  >\n                    <template v-if=\"loading\">\n                      <div class=\"animate-spin rounded-full h-8 w-8 border-2 border-white border-t-transparent\"></div>\n                    </template>\n                    <template v-else>\n                      <CameraIcon class=\"w-8 h-8 text-white\" />\n                    </template>\n                  </div>\n                  <input\n                  ref=\"fileInput\"\n                  type=\"file\"\n                  accept=\"image/*\"\n                  class=\"hidden\"\n                  @change=\"handleFileChange\"\n                  />\n            </div>\n    \n            <!-- 用户信息 -->\n            <div class=\"flex-1 min-w-0\">\n              <div class=\"flex items-center justify-between mb-3\">\n                <h2 class=\"text-lg font-medium text-gray-900\">\n                  {{ resumeData.name || '未设置姓名' }}\n                </h2>\n                <div class=\"flex items-center space-x-2\">\n                  <!-- 使用 heroicons 的编辑图标 -->\n                  <button\n                    @click=\"handleEdit\"\n                    class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200\"\n                    title=\"编辑基本信息\"\n                  >\n                    <PencilSquareIcon class=\"w-5 h-5 text-gray-500 hover:text-gray-700\" />\n                  </button>\n                </div>\n              </div>\n    \n              <!-- 基本信息列表 -->\n              <div class=\"grid grid-cols-2 gap-3\">\n                <!-- 手机号 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ resumeData.phone || '未设置手机号' }}</span>\n                </div>\n    \n                <!-- 邮箱 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ resumeData.email || '未设置邮箱' }}</span>\n                </div>\n    \n                <!-- 所在地 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ resumeData.location || '未设置所在地' }}</span>\n                </div>\n    \n                <!-- 年龄 (使用图标) -->\n                <div class=\"flex items-center text-gray-600\">\n                  <CakeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ formatBasicInfo.age }}</span>\n                </div>\n              </div>\n    \n              <!-- 个人简介 -->\n              <div class=\"mt-3\">\n                <div class=\"flex items-center text-gray-600 mb-2\">\n                  <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm font-medium\">个人简介</span>\n                </div>\n                <div class=\"bg-gray-50 rounded-md p-4\">\n                  <div class=\"relative\">\n                    <template v-if=\"resumeData.personal_summary\">\n                      <p \n                        class=\"text-sm text-gray-600 leading-relaxed min-h-[4.5em] line-clamp-3\"\n                        :class=\"{ 'line-clamp-none': bioExpanded }\"\n                      >\n                        {{ resumeData.personal_summary }}\n                      </p>\n                      <button\n                        v-if=\"showBioExpandButton\"\n                        @click=\"toggleBioExpand\"\n                        class=\"text-xs text-primary-600 hover:text-primary-700 mt-2 inline-flex items-center\"\n                      >\n                        {{ bioExpanded ? '收起' : '展开全部' }}\n                        <ChevronDownIcon \n                          v-if=\"!bioExpanded\" \n                          class=\"w-4 h-4 ml-0.5\" \n                        />\n                        <ChevronUpIcon \n                          v-else \n                          class=\"w-4 h-4 ml-0.5\" \n                        />\n                      </button>\n                    </template>\n                    <p \n                      v-else \n                      class=\"text-sm text-gray-400 text-center min-h-[4.5em] flex items-center justify-center\"\n                    >\n                      你还没有设置个人简介\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </template>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed, nextTick, watch, onMounted } from 'vue'\nimport { ElMessage } from 'element-plus'\nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nimport { MEDIA_URL } from '@/config'\nimport { showToast } from '@/components/ToastMessage'\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon,\n  UserIcon,\n  CalendarIcon,\n  ChevronDownIcon,\n  ChevronUpIcon,\n  CakeIcon,\n  PencilSquareIcon\n} from '@heroicons/vue/24/outline'\n\nconst store = useStore()\nconst loading = ref(true)\nconst userBasicInfo = ref(null)\n\n// 修改头像上传处理函数\nconst handleAvatarUpload = async (file) => {\n  try {\n    loading.value = true\n    const formData = new FormData()\n    formData.append('avatar', file)\n    \n    // 使用 store action 上传头像\n    const response = await store.dispatch('updateBasicInfo', {\n      type: 'avatar',\n      data: formData\n    })\n    \n    if (response.data?.code === 200) {\n      // 更新成功后重新获取用户信息\n      await store.dispatch('fetchUserInfo')\n      showToast('头像上传成功', 'success')\n      // 触发父组件更新\n      emit('update')\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error)\n    showToast(error.message || '头像上传失败，请稍后重试', 'error')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 获取用户基本信息\nconst fetchUserBasicInfo = async () => {\n  try {\n    loading.value = true\n    await store.dispatch('fetchUserInfo')\n    // 从 store 中获取用户信息\n    userBasicInfo.value = {\n      ...store.state.basicInfo,\n      ...store.state.userInfo\n    }\n  } catch (error) {\n    console.error('获取用户信息失败:', error)\n    showToast('获取用户信息失败', 'error')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 监听 store 中的用户信息变化\nwatch(\n  () => [store.state.userInfo, store.state.basicInfo],\n  ([newUserInfo, newBasicInfo]) => {\n    if (newUserInfo || newBasicInfo) {\n      userBasicInfo.value = {\n        ...newBasicInfo,\n        ...newUserInfo\n      }\n    }\n  },\n  { immediate: true }\n)\n\n// 在组件挂载时获取用户信息\nonMounted(async () => {\n  if (store.state.isAuthenticated) {\n    await fetchUserBasicInfo()\n  }\n})\n\n// 添加用户头像计算属性\nconst userAvatar = computed(() => {\n  const avatar = store.getters.userAvatar\n  return avatar.startsWith('/') ? `${MEDIA_URL}${avatar}` : avatar\n})\n\n// 添加用户名计算属性\nconst userName = computed(() => store.getters.userName)\n\n// 添加用户手机号计算属性\nconst userPhone = computed(() => store.getters.userPhone)\n\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean,\n  bioExpanded: Boolean,\n  showBioExpandButton: Boolean,\n  getBioText: String\n})\n\nconst emit = defineEmits(['update', 'edit', 'toggleBioExpand'])\nconst fileInput = ref(null)\n\n// 修改调试日志方式\nconst logResumeData = () => {\n  const plainData = {\n    name: props.resumeData.name,\n    gender: props.resumeData.gender,\n    phone: props.resumeData.phone,\n    email: props.resumeData.email,\n    location: props.resumeData.location,\n    birth_date: props.resumeData.birth_date,\n    personal_summary: props.resumeData.personal_summary,\n    created_at: props.resumeData.created_at,\n    updated_at: props.resumeData.updated_at\n  }\n  console.log('BasicInfo data:', plainData)\n}\n\n// 监听数据变化\nwatch(() => props.resumeData, (newVal) => {\n  // 当 resumeData 加载完成时，关闭 loading 状态\n  if (newVal && Object.keys(newVal).length > 0) {\n    loading.value = false\n  }\n}, { immediate: true })\n\n// 处理文件选择\nconst handleFileChange = async (event) => {\n  const file = event.target.files[0]\n  if (!file) return\n\n  // 验证文件类型\n  if (!file.type.startsWith('image/')) {\n    showToast('请选择图片文件', 'error')\n    return\n  }\n\n  // 验证文件大小（例如限制为 2MB）\n  const maxSize = 2 * 1024 * 1024 // 2MB\n  if (file.size > maxSize) {\n    showToast('图片大小不能超过 2MB', 'error')\n    return\n  }\n\n  await handleAvatarUpload(file)\n  \n  // 清空文件选择器，以便能够选择同一个文件\n  event.target.value = ''\n}\n\n// 添加 basicInfo ref\nconst basicInfo = ref({})\n\n// 性别显示文本\nconst genderText = computed(() => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[props.resumeData.gender] || '未设置性别'\n})\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return date.toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'long',\n    day: 'numeric'\n  })\n}\n\n// 处理编辑按钮点击\nconst handleEdit = () => {\n  console.log('点击编辑按钮, 当前数据:', props.resumeData)\n  emit('edit')\n}\n\n// 处理展开/收起\nconst toggleBioExpand = () => {\n  emit('toggleBioExpand')\n}\n\n// 计算年龄的函数\nconst calculateAge = (birthDate) => {\n  if (!birthDate) return ''\n  \n  const birth = new Date(birthDate)\n  const today = new Date()\n  \n  let age = today.getFullYear() - birth.getFullYear()\n  const monthDiff = today.getMonth() - birth.getMonth()\n  \n  // 如果还没到生日，年龄减1\n  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {\n    age--\n  }\n  \n  return `${age}岁`\n}\n\n// 格式化性别显示\nconst formatGender = (gender) => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[gender] || '未填写'\n}\n\n// 格式化基本信息\nconst formatBasicInfo = computed(() => {\n  const info = props.resumeData || {}\n  return {\n    name: info.name || '未填写',\n    gender: formatGender(info.gender),\n    phone: info.phone || '未填写',\n    email: info.email || '未填写',\n    location: info.location || '未填写',\n    age: calculateAge(info.birth_date) || '未填写',\n    personal_summary: info.personal_summary || '未填写'\n  }\n})\n\n// 计算当前性别\nconst currentGender = computed(() => {\n  // 优先使用 resumeData 中的性别\n  const gender = props.resumeData?.gender || userBasicInfo.value?.gender || store.state.userInfo?.gender\n  return gender\n})\n\n// 触发文件选择\nconst triggerUpload = () => {\n  fileInput.value.click()\n}\n</script>"],"mappings":";AAmMA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,KAAK,EAAEC,SAAS,QAAQ,KAAI;AAC9D,SAASC,SAAS,QAAQ,cAAa;AACvC,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,UAAS;AACnC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAU,EACVC,QAAQ,EACRC,YAAY,EACZC,eAAe,EACfC,aAAa,EACbC,QAAQ,EACRC,gBAAe,QACV,2BAA0B;;;;;;;;;;;;;;;