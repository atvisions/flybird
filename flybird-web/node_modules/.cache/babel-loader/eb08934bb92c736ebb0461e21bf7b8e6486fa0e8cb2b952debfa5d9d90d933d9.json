{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, ArrowTopRightOnSquareIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'PortfolioContent',\n  props: {\n    data: {\n      type: Array,\n      required: true\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const __returned__ = {\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get ArrowTopRightOnSquareIcon() {\n        return ArrowTopRightOnSquareIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","ArrowTopRightOnSquareIcon"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/PortfolioContent.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-4\">\n    <!-- 作品列表 -->\n    <div class=\"space-y-4\">\n      <div v-for=\"(work, index) in data\" :key=\"index\" \n        class=\"bg-gray-50 rounded-lg p-4\">\n        <div class=\"flex items-center justify-between mb-2\">\n          <div class=\"font-medium\">{{ work.name }}</div>\n          <div class=\"flex items-center space-x-2\">\n            <button\n              @click=\"$emit('edit', work)\"\n              class=\"p-1 hover:bg-white rounded-full transition-colors\"\n            >\n              <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n            </button>\n            <button\n              @click=\"$emit('delete', work.id)\"\n              class=\"p-1 hover:bg-white rounded-full transition-colors\"\n            >\n              <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n        <di