{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, CalendarIcon, PlusIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'EducationContent',\n  props: {\n    data: {\n      type: Array,\n      required: true\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 判断是否为最后一项\n    const isLast = item => {\n      return props.data.indexOf(item) === props.data.length - 1;\n    };\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;\n    };\n\n    // 获取学历标签\n    const getDegreeLabel = value => {\n      const degreeMap = {\n        'high_school': '高中',\n        'junior_college': '大专',\n        'bachelor': '本科',\n        'master': '硕士',\n        'doctor': '博士',\n        'other': '其他'\n      };\n      return degreeMap[value] || value;\n    };\n    const __returned__ = {\n      props,\n      isLast,\n      formatDate,\n      getDegreeLabel,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","CalendarIcon","PlusIcon","props","__props","isLast","item","data","indexOf","length","formatDate","dateString","date","Date","getFullYear","String","getMonth","padStart","getDegreeLabel","value","degreeMap"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/EducationContent.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/EducationContent.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <!-- 教育经历列表 -->\n    <div v-for=\"item in data\" :key=\"item.id\" class=\"relative\">\n      <!-- 时间线装饰 -->\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n      <div v-if=\"!isLast(item)\" class=\"absolute left-[0.5625rem] -translate-x-1/2 top-5 bottom-0 w-0.5 bg-gray-200\"></div>\n\n      <!-- 内容区域 -->\n      <div class=\"relative pl-12\">\n        <div class=\"flex items-center justify-between group\">\n          <div>\n            <h4 class=\"text-base font-medium text-gray-900\">{{ item.school }}</h4>\n            <p class=\"text-sm text-gray-500\">{{ item.major }} · {{ getDegreeLabel(item.degree) }}</p>\n          </div>\n          <div class=\"flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity\">\n            <button\n              @click=\"$emit('edit', item)\"\n              class=\"p-1 hover:bg-gray-100 rounded-full\"\n            >\n              <PencilSquareIcon class=\"w-5 h-5 text-gray-400\" />\n            </button>\n            <button\n              @click=\"$emit('delete', item.id)\"\n              class=\"p-1 hover:bg-gray-100 rounded-full\"\n            >\n              <TrashIcon class=\"w-5 h-5 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n\n        <!-- 时间段 -->\n        <div class=\"mt-2 flex items-center text-sm text-gray-500\">\n          <CalendarIcon class=\"w-4 h-4 mr-1.5\" />\n          {{ formatDate(item.start_date) }} - {{ item.is_current ? '至今' : formatDate(item.end_date) }}\n        </div>\n\n        <!-- 在校经历 -->\n        <div v-if=\"item.description\" class=\"mt-3 text-sm text-gray-600\">\n          <p class=\"whitespace-pre-line\">{{ item.description }}</p>\n        </div>\n\n        <!-- 在校成就 -->\n        <div v-if=\"item.achievements\" class=\"mt-3 text-sm text-gray-600\">\n          <div class=\"text-sm font-medium text-gray-700 mb-1\">在校成就</div>\n          <p class=\"whitespace-pre-line\">{{ item.achievements }}</p>\n        </div>\n      </div>\n    </div>\n\n    <!-- 添加按钮 -->\n    <div class=\"relative pl-12\">\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n      <button\n        @click=\"$emit('add')\"\n        class=\"w-full flex items-center justify-center px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors\"\n      >\n        <PlusIcon class=\"w-4 h-4 mr-2\" />\n        添加教育经历\n      </button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport {\n  PencilSquareIcon,\n  TrashIcon,\n  CalendarIcon,\n  PlusIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    required: true\n  }\n})\n\ndefineEmits(['edit', 'delete', 'add'])\n\n// 判断是否为最后一项\nconst isLast = (item) => {\n  return props.data.indexOf(item) === props.data.length - 1\n}\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`\n}\n\n// 获取学历标签\nconst getDegreeLabel = (value) => {\n  const degreeMap = {\n    'high_school': '高中',\n    'junior_college': '大专',\n    'bachelor': '本科',\n    'master': '硕士',\n    'doctor': '博士',\n    'other': '其他'\n  }\n  return degreeMap[value] || value\n}\n</script>\n\n<style scoped>\n/* 悬停效果 */\n.group:hover {\n  @apply bg-gray-50/50;\n}\n\n/* 时间线样式 */\n.border-blue-500 {\n  @apply border-blue-600;\n}\n\n/* 按钮过渡效果 */\n.transition-colors {\n  @apply duration-200;\n}\n</style>"],"mappings":"AAkEA,SACEA,gBAAgB,EAChBC,SAAS,EACTC,YAAY,EACZC,QAAO,QACF,2BAA0B;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;;IASd;IACA,MAAMC,MAAM,GAAIC,IAAI,IAAK;MACvB,OAAOH,KAAK,CAACI,IAAI,CAACC,OAAO,CAACF,IAAI,CAAC,KAAKH,KAAK,CAACI,IAAI,CAACE,MAAM,GAAG;IAC1D;;IAEA;IACA,MAAMC,UAAU,GAAIC,UAAU,IAAK;MACjC,IAAI,CAACA,UAAU,EAAE,OAAO,EAAC;MACzB,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,UAAU;MAChC,OAAO,GAAGC,IAAI,CAACE,WAAW,CAAC,CAAC,IAAIC,MAAM,CAACH,IAAI,CAACI,QAAQ,CAAC,CAAC,GAAG,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,EAAC;IAC/E;;IAEA;IACA,MAAMC,cAAc,GAAIC,KAAK,IAAK;MAChC,MAAMC,SAAS,GAAG;QAChB,aAAa,EAAE,IAAI;QACnB,gBAAgB,EAAE,IAAI;QACtB,UAAU,EAAE,IAAI;QAChB,QAAQ,EAAE,IAAI;QACd,QAAQ,EAAE,IAAI;QACd,OAAO,EAAE;MACX;MACA,OAAOA,SAAS,CAACD,KAAK,CAAC,IAAIA,KAAI;IACjC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}