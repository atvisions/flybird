{"ast":null,"code":"import BasicInfoContent from './BasicInfoContent.vue';\nimport JobIntentionContent from './JobIntentionContent.vue';\nimport WorkExperienceContent from './WorkExperienceContent.vue';\nimport EducationContent from './EducationContent.vue';\nimport ProjectContent from './ProjectContent.vue';\nimport SkillContent from './SkillContent.vue';\nimport CertificateContent from './CertificateContent.vue';\nimport LanguageContent from './LanguageContent.vue';\nimport PortfolioContent from './PortfolioContent.vue';\nimport SocialLinkContent from './SocialLinkContent.vue';\n\n// Props 定义\n\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true,\n      default: () => []\n    },\n    inactiveModules: {\n      type: Array,\n      required: true,\n      default: () => []\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    },\n    fetchModulesData: {\n      type: Function,\n      required: true\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 导入所需的组件\n\n    const __returned__ = {\n      BasicInfoContent,\n      JobIntentionContent,\n      WorkExperienceContent,\n      EducationContent,\n      ProjectContent,\n      SkillContent,\n      CertificateContent,\n      LanguageContent,\n      PortfolioContent,\n      SocialLinkContent\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["BasicInfoContent","JobIntentionContent","WorkExperienceContent","EducationContent","ProjectContent","SkillContent","CertificateContent","LanguageContent","PortfolioContent","SocialLinkContent"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <!-- 激活的模块列表 -->\n    <div \n      v-for=\"module in activeModules\" \n      :key=\"module.type\" \n      class=\"bg-white rounded-lg shadow\"\n    >\n      <!-- 模块头部 -->\n      <div class=\"flex items-center justify-between px-4 py-3\">\n        <h3 class=\"text-base font-medium text-gray-900\">\n          {{ module.name }}\n        </h3>\n        <div class=\"flex items-center space-x-2\">\n          <!-- 控制按钮 -->\n        </div>\n      </div>\n      \n      <!-- 模块内容 -->\n      <div class=\"px-4 pb-4\">\n        <!-- 基本信息 -->\n        <template v-if=\"module.type === 'basic_info' && module.data\">\n          <BasicInfoContent :data=\"module.data\" />\n        </template>\n\n        <!-- 求职意向 -->\n        <template v-if=\"module.type === 'job_intention' && module.data\">\n          <JobIntentionContent :data=\"module.data\" />\n        </template>\n\n        <!-- 工作经历 -->\n        <template v-if=\"module.type === 'work_experience' && module.data\">\n          <WorkExperienceContent :data=\"module.data\" />\n        </template>\n\n        <!-- 教育经历 -->\n        <template v-if=\"module.type === 'education' && module.data\">\n          <EducationContent :data=\"module.data\" />\n        </template>\n\n        <!-- 项目经历 -->\n        <template v-if=\"module.type === 'project' && module.data\">\n          <ProjectContent :data=\"module.data\" />\n        </template>\n\n        <!-- 专业技能 -->\n        <template v-if=\"module.type === 'skill' && module.data\">\n          <SkillContent :data=\"module.data\" />\n        </template>\n\n        <!-- 证书奖项 -->\n        <template v-if=\"module.type === 'certificate' && module.data\">\n          <CertificateContent :data=\"module.data\" />\n        </template>\n\n        <!-- 语言能力 -->\n        <template v-if=\"module.type === 'language' && module.data\">\n          <LanguageContent :data=\"module.data\" />\n        </template>\n\n        <!-- 作品展示 -->\n        <template v-if=\"module.type === 'portfolio' && module.data\">\n          <PortfolioContent :data=\"module.data\" />\n        </template>\n\n        <!-- 社交主页 -->\n        <template v-if=\"module.type === 'social_link' && module.data\">\n          <SocialLinkContent :data=\"module.data\" />\n        </template>\n\n        <!-- 空状态提示 -->\n        <template v-if=\"!module.data && !loading\">\n          <div class=\"text-center py-8\">\n            <p class=\"text-sm text-gray-500\">暂无数据</p>\n          </div>\n        </template>\n\n        <!-- 加载状态 -->\n        <template v-if=\"loading\">\n          <div class=\"py-8\">\n            <div class=\"animate-pulse space-y-4\">\n              <div class=\"h-4 bg-gray-200 rounded w-3/4\"></div>\n              <div class=\"h-4 bg-gray-200 rounded w-1/2\"></div>\n            </div>\n          </div>\n        </template>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\n// 导入所需的组件\nimport BasicInfoContent from './BasicInfoContent.vue'\nimport JobIntentionContent from './JobIntentionContent.vue'\nimport WorkExperienceContent from './WorkExperienceContent.vue'\nimport EducationContent from './EducationContent.vue'\nimport ProjectContent from './ProjectContent.vue'\nimport SkillContent from './SkillContent.vue'\nimport CertificateContent from './CertificateContent.vue'\nimport LanguageContent from './LanguageContent.vue'\nimport PortfolioContent from './PortfolioContent.vue'\nimport SocialLinkContent from './SocialLinkContent.vue'\n\n// Props 定义\ndefineProps({\n  activeModules: {\n    type: Array,\n    required: true,\n    default: () => []\n  },\n  inactiveModules: {\n    type: Array,\n    required: true,\n    default: () => []\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  },\n  fetchModulesData: {\n    type: Function,\n    required: true\n  }\n})\n</script>\n"],"mappings":"AA8FA,OAAOA,gBAAgB,MAAM,wBAAuB;AACpD,OAAOC,mBAAmB,MAAM,2BAA0B;AAC1D,OAAOC,qBAAqB,MAAM,6BAA4B;AAC9D,OAAOC,gBAAgB,MAAM,wBAAuB;AACpD,OAAOC,cAAc,MAAM,sBAAqB;AAChD,OAAOC,YAAY,MAAM,oBAAmB;AAC5C,OAAOC,kBAAkB,MAAM,0BAAyB;AACxD,OAAOC,eAAe,MAAM,uBAAsB;AAClD,OAAOC,gBAAgB,MAAM,wBAAuB;AACpD,OAAOC,iBAAiB,MAAM,yBAAwB;;AAEtD;;;;;;;;;;;;;;;;;;;;;;;;;;;;;IAZA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}