{"ast":null,"code":"import { computed, ref } from 'vue';\nimport { SparklesIcon, InformationCircleIcon } from '@heroicons/vue/24/outline';\nimport { useWindowSize } from '@vueuse/core';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nimport AIOptimizingDialog from './AIOptimizingDialog.vue';\nexport default {\n  __name: 'AIDialog',\n  props: {\n    modelValue: Boolean,\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    totalScore: {\n      type: Number,\n      default: 0\n    },\n    remainingOptimizations: {\n      type: Number,\n      required: true\n    },\n    totalOptimizations: {\n      type: Number,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'action'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const store = useStore();\n    const {\n      width\n    } = useWindowSize();\n    const showOptimizing = ref(false);\n    const optimizationResult = ref(null);\n\n    // 弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 总分颜色\n    const scoreColorClass = computed(() => {\n      if (props.totalScore >= 80) return 'text-green-600';\n      if (props.totalScore >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n\n    // 建议类型样式\n    const getTypeClass = type => {\n      const classMap = {\n        basic_info: 'bg-blue-50 text-blue-700',\n        work_experience: 'bg-purple-50 text-purple-700',\n        skill: 'bg-green-50 text-green-700',\n        education: 'bg-yellow-50 text-yellow-700',\n        project: 'bg-indigo-50 text-indigo-700',\n        achievement: 'bg-pink-50 text-pink-700'\n      };\n      return classMap[type] || 'bg-gray-50 text-gray-700';\n    };\n\n    // 建议类型名称\n    const getTypeName = type => {\n      const typeMap = {\n        basic_info: '基本信息',\n        work_experience: '工作经历',\n        skill: '技能特长',\n        education: '教育背景',\n        project: '项目经验',\n        achievement: '个人成就'\n      };\n      return typeMap[type] || type;\n    };\n\n    // 按重要性和提升分数排序的建议\n    const sortedSuggestions = computed(() => {\n      const importanceOrder = {\n        high: 3,\n        medium: 2,\n        low: 1\n      };\n      return [...props.suggestions].sort((a, b) => {\n        const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance];\n        if (importanceDiff !== 0) return importanceDiff;\n        return b.score_impact - a.score_impact;\n      });\n    });\n\n    // 是否是VIP会员\n    const isVip = computed(() => store.getters.isVip);\n\n    // 处理优化\n    const handleOptimize = () => {\n      showOptimizing.value = true;\n      emit('action', 'optimize');\n    };\n\n    // 处理优化确认\n    const handleOptimizationConfirm = optimizationId => {\n      emit('action', 'confirm', optimizationId);\n    };\n\n    // 处理优化取消\n    const handleOptimizationCancel = () => {\n      showOptimizing.value = false;\n    };\n    const __returned__ = {\n      props,\n      emit,\n      store,\n      width,\n      showOptimizing,\n      optimizationResult,\n      dialogWidth,\n      scoreColorClass,\n      getTypeClass,\n      getTypeName,\n      sortedSuggestions,\n      isVip,\n      handleOptimize,\n      handleOptimizationConfirm,\n      handleOptimizationCancel,\n      computed,\n      ref,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get InformationCircleIcon() {\n        return InformationCircleIcon;\n      },\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      AIOptimizingDialog\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","ref","SparklesIcon","InformationCircleIcon","useWindowSize","useStore","ElMessage","AIOptimizingDialog","props","__props","emit","__emit","store","width","showOptimizing","optimizationResult","dialogWidth","value","scoreColorClass","totalScore","getTypeClass","type","classMap","basic_info","work_experience","skill","education","project","achievement","getTypeName","typeMap","sortedSuggestions","importanceOrder","high","medium","low","suggestions","sort","a","b","importanceDiff","importance","score_impact","isVip","getters","handleOptimize","handleOptimizationConfirm","optimizationId","handleOptimizationCancel"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/AIDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"AI 优化建议\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n  >\n    <div class=\"space-y-6\">\n      <!-- 总体评分和优化次数 -->\n      <div class=\"bg-gray-50 rounded-lg p-4\">\n        <div class=\"flex items-center justify-between mb-2\">\n          <div class=\"flex items-center space-x-4\">\n            <h3 class=\"text-base font-medium text-gray-900\">总体评分</h3>\n            <div class=\"flex items-center space-x-1 text-sm text-gray-500\">\n              <SparklesIcon class=\"w-4 h-4\" />\n              <span>剩余优化次数：</span>\n              <span class=\"font-medium\" :class=\"{'text-red-600': remainingOptimizations === 0}\">\n                {{ remainingOptimizations }}/{{ totalOptimizations }}\n              </span>\n              <el-tooltip v-if=\"!isVip\" effect=\"dark\" placement=\"top\">\n                <template #content>\n                  <div class=\"text-xs\">\n                    <p>普通用户每月可使用3次</p>\n                    <p class=\"mt-1\">升级会员可享无限次数</p>\n                  </div>\n                </template>\n                <InformationCircleIcon class=\"w-4 h-4 cursor-help\" />\n              </el-tooltip>\n            </div>\n          </div>\n          <span class=\"text-lg font-semibold\" :class=\"scoreColorClass\">{{ totalScore }}分</span>\n        </div>\n        <p class=\"text-sm text-gray-600\">基于各维度权重计算的综合评分</p>\n      </div>\n\n      <!-- 改进建议 -->\n      <div class=\"space-y-4\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-base font-medium text-gray-900\">改进建议</h3>\n          <span class=\"text-sm text-gray-500\">按优先级排序</span>\n        </div>\n        <div class=\"space-y-3\">\n          <div \n            v-for=\"(suggestion, index) in sortedSuggestions\" \n            :key=\"index\"\n            class=\"bg-white rounded-lg p-4 border border-gray-200\"\n          >\n            <div class=\"flex items-start space-x-3\">\n              <div \n                class=\"flex-shrink-0 w-2 h-2 mt-2 rounded-full\"\n                :class=\"{\n                  'bg-red-500': suggestion.importance === 'high',\n                  'bg-yellow-500': suggestion.importance === 'medium',\n                  'bg-blue-500': suggestion.importance === 'low'\n                }\"\n              ></div>\n              <div class=\"flex-1\">\n                <div class=\"flex items-center space-x-2\">\n                  <span class=\"text-xs font-medium px-2 py-0.5 rounded\" \n                    :class=\"getTypeClass(suggestion.type)\">\n                    {{ getTypeName(suggestion.type) }}\n                  </span>\n                  <span class=\"text-sm text-gray-700\">{{ suggestion.message }}</span>\n                </div>\n                <p class=\"text-xs text-gray-500 mt-1\">\n                  预计提升：+{{ suggestion.score_impact }}分\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- AI 优化按钮 -->\n      <div class=\"flex justify-center pt-4\">\n        <button\n          @click=\"handleOptimize\"\n          :disabled=\"loading || remainingOptimizations === 0\"\n          class=\"inline-flex items-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\n        >\n          <SparklesIcon class=\"w-5 h-5 mr-2\" />\n          {{ loading ? '优化中...' : '开始AI优化' }}\n        </button>\n      </div>\n    </div>\n\n    <!-- 优化结果弹窗 -->\n    <AIOptimizingDialog\n      v-if=\"showOptimizing\"\n      v-model=\"showOptimizing\"\n      :optimization-result=\"optimizationResult\"\n      :loading=\"loading\"\n      @confirm=\"handleOptimizationConfirm\"\n      @cancel=\"handleOptimizationCancel\"\n    />\n  </el-dialog>\n</template>\n\n<script setup>\nimport { computed, ref } from 'vue'\nimport { SparklesIcon, InformationCircleIcon } from '@heroicons/vue/24/outline'\nimport { useWindowSize } from '@vueuse/core'\nimport { useStore } from 'vuex'\nimport { ElMessage } from 'element-plus'\nimport AIOptimizingDialog from './AIOptimizingDialog.vue'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  suggestions: {\n    type: Array,\n    default: () => []\n  },\n  totalScore: {\n    type: Number,\n    default: 0\n  },\n  remainingOptimizations: {\n    type: Number,\n    required: true\n  },\n  totalOptimizations: {\n    type: Number,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'action'])\n\nconst store = useStore()\nconst { width } = useWindowSize()\nconst showOptimizing = ref(false)\nconst optimizationResult = ref(null)\n\n// 弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 总分颜色\nconst scoreColorClass = computed(() => {\n  if (props.totalScore >= 80) return 'text-green-600'\n  if (props.totalScore >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n})\n\n// 建议类型样式\nconst getTypeClass = (type) => {\n  const classMap = {\n    basic_info: 'bg-blue-50 text-blue-700',\n    work_experience: 'bg-purple-50 text-purple-700',\n    skill: 'bg-green-50 text-green-700',\n    education: 'bg-yellow-50 text-yellow-700',\n    project: 'bg-indigo-50 text-indigo-700',\n    achievement: 'bg-pink-50 text-pink-700'\n  }\n  return classMap[type] || 'bg-gray-50 text-gray-700'\n}\n\n// 建议类型名称\nconst getTypeName = (type) => {\n  const typeMap = {\n    basic_info: '基本信息',\n    work_experience: '工作经历',\n    skill: '技能特长',\n    education: '教育背景',\n    project: '项目经验',\n    achievement: '个人成就'\n  }\n  return typeMap[type] || type\n}\n\n// 按重要性和提升分数排序的建议\nconst sortedSuggestions = computed(() => {\n  const importanceOrder = { high: 3, medium: 2, low: 1 }\n  return [...props.suggestions].sort((a, b) => {\n    const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance]\n    if (importanceDiff !== 0) return importanceDiff\n    return b.score_impact - a.score_impact\n  })\n})\n\n// 是否是VIP会员\nconst isVip = computed(() => store.getters.isVip)\n\n// 处理优化\nconst handleOptimize = () => {\n  showOptimizing.value = true\n  emit('action', 'optimize')\n}\n\n// 处理优化确认\nconst handleOptimizationConfirm = (optimizationId) => {\n  emit('action', 'confirm', optimizationId)\n}\n\n// 处理优化取消\nconst handleOptimizationCancel = () => {\n  showOptimizing.value = false\n}\n</script>"],"mappings":"AAqGA,SAASA,QAAQ,EAAEC,GAAG,QAAQ,KAAI;AAClC,SAASC,YAAY,EAAEC,qBAAqB,QAAQ,2BAA0B;AAC9E,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,cAAa;AACvC,OAAOC,kBAAkB,MAAM,0BAAyB;;;;;;;;;;;;;;;;;;;;;;;;;;;;;IAExD,MAAMC,KAAK,GAAGC,OAAA;IAqBd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,KAAK,GAAGP,QAAQ,CAAC;IACvB,MAAM;MAAEQ;IAAM,CAAC,GAAGT,aAAa,CAAC;IAChC,MAAMU,cAAc,GAAGb,GAAG,CAAC,KAAK;IAChC,MAAMc,kBAAkB,GAAGd,GAAG,CAAC,IAAI;;IAEnC;IACA,MAAMe,WAAW,GAAGhB,QAAQ,CAAC,MAAM;MACjC,IAAIa,KAAK,CAACI,KAAK,GAAG,GAAG,EAAE,O