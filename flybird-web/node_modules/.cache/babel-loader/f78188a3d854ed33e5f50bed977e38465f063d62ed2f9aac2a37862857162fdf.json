{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nexport default {\n  __name: 'EditBasicDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 表单引用\n    const formRef = ref(null);\n\n    // 对话框可见性\n    const dialogVisible = computed({\n      get: () => props.modelValue,\n      set: value => emit('update:modelValue', value)\n    });\n\n    // 表单数据\n    const formData = ref({\n      name: '',\n      gender: '',\n      birth_date: '',\n      phone: '',\n      email: '',\n      location: '',\n      personal_summary: ''\n    });\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      if (newVal) {\n        formData.value = _objectSpread({}, newVal);\n      }\n    }, {\n      immediate: true\n    });\n\n    // 响应式布局\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      return '600px';\n    });\n\n    // 表单字段配置\n    const formFields = [{\n      name: 'name',\n      label: '姓名',\n      type: 'text',\n      required: true,\n      rules: [{\n        required: true,\n        message: '请输入姓名',\n        trigger: 'blur'\n      }, {\n        min: 2,\n        max: 20,\n        message: '长度在 2 到 20 个字符',\n        trigger: 'blur'\n      }]\n    }, {\n      name: 'gender',\n      label: '性别',\n      type: 'select',\n      required: true,\n      options: [{\n        label: '男',\n        value: 'male'\n      }, {\n        label: '女',\n        value: 'female'\n      }, {\n        label: '其他',\n        value: 'other'\n      }],\n      rules: [{\n        required: true,\n        message: '请选择性别',\n        trigger: 'change'\n      }]\n    }, {\n      name: 'birth_date',\n      label: '出生日期',\n      type: 'date',\n      required: true,\n      rules: [{\n        required: true,\n        message: '请选择出生日期',\n        trigger: 'change'\n      }]\n    }, {\n      name: 'phone',\n      label: '手机号码',\n      type: 'text',\n      required: true,\n      rules: [{\n        required: true,\n        message: '请输入手机号码',\n        trigger: 'blur'\n      }, {\n        pattern: /^1[3-9]\\d{9}$/,\n        message: '请输入正确的手机号码',\n        trigger: 'blur'\n      }]\n    }, {\n      name: 'email',\n      label: '电子邮箱',\n      type: 'text',\n      required: true,\n      rules: [{\n        required: true,\n        message: '请输入电子邮箱',\n        trigger: 'blur'\n      }, {\n        type: 'email',\n        message: '请输入正确的邮箱地址',\n        trigger: 'blur'\n      }]\n    }, {\n      name: 'location',\n      label: '所在地',\n      type: 'text',\n      required: true,\n      rules: [{\n        required: true,\n        message: '请输入所在地',\n        trigger: 'blur'\n      }]\n    }, {\n      name: 'personal_summary',\n      label: '个人简介',\n      type: 'textarea',\n      required: false,\n      maxlength: 500,\n      showWordLimit: true,\n      autosize: {\n        minRows: 3,\n        maxRows: 6\n      },\n      placeholder: '请简要描述您的个人情况、工作经验和职业目标等'\n    }];\n\n    // 处理关闭\n    const handleClose = () => {\n      dialogVisible.value = false;\n    };\n\n    // 处理提交\n    const handleSubmit = async () => {\n      if (!formRef.value) return;\n      try {\n        await formRef.value.validate();\n        emit('submit', formData.value);\n      } catch (error) {\n        console.error('表单验证失败:', error);\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      formRef,\n      dialogVisible,\n      formData,\n      width,\n      isMobile,\n      dialogWidth,\n      formFields,\n      handleClose,\n      handleSubmit,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","props","__props","emit","__emit","formRef","dialogVisible","get","modelValue","set","value","formData","name","gender","birth_date","phone","email","location","personal_summary","initialData","newVal","_objectSpread","immediate","width","isMobile","dialogWidth","formFields","label","type","required","rules","message","trigger","min","max","options","pattern","maxlength","showWordLimit","autosize","minRows","maxRows","placeholder","handleClose","handleSubmit","validate","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    v-model=\"dialogVisible\"\n    title=\"编辑基本信息\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n    class=\"edit-dialog\"\n    destroy-on-close\n  >\n    <el-form\n      ref=\"formRef\"\n      :model=\"formData\"\n      :rules=\"rules\"\n      label-width=\"100px\"\n      class=\"basic-form p-6\"\n    >\n      <el-form-item\n        v-for=\"field in formFields\"\n        :key=\"field.name\"\n        :label=\"field.label\"\n        :prop=\"field.name\"\n        :rules=\"field.rules\"\n      >\n        <!-- 根据字段类型渲染不同的表单控件 -->\n        <template v-if=\"field.type === 'select'\">\n          <el-select\n            v-model=\"formData[field.name]\"\n            :placeholder=\"`请选择${field.label}`\"\n          >\n            <el-option\n              v-for=\"option in field.options\"\n              :key=\"option.value\"\n              :label=\"option.label\"\n              :value=\"option.value\"\n            />\n          </el-select>\n        </template>\n        \n        <template v-else-if=\"field.type === 'date'\">\n          <el-date-picker\n            v-model=\"formData[field.name]\"\n            type=\"date\"\n            :placeholder=\"`请选择${field.label}`\"\n            format=\"YYYY-MM-DD\"\n            value-format=\"YYYY-MM-DD\"\n          />\n        </template>\n        \n        <template v-else-if=\"field.type === 'textarea'\">\n          <el-input\n            v-model=\"formData[field.name]\"\n            type=\"textarea\"\n            :placeholder=\"field.placeholder\"\n            :maxlength=\"field.maxlength\"\n            :show-word-limit=\"field.showWordLimit\"\n            :autosize=\"field.autosize\"\n          />\n        </template>\n        \n        <template v-else>\n          <el-input\n            v-model=\"formData[field.name]\"\n            :placeholder=\"`请输入${field.label}`\"\n          />\n        </template>\n      </el-form-item>\n    </el-form>\n\n    <template #footer>\n      <div class=\"dialog-footer px-6 py-4\">\n        <el-button @click=\"handleClose\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"loading\">\n          保存\n        </el-button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单引用\nconst formRef = ref(null)\n\n// 对话框可见性\nconst dialogVisible = computed({\n  get: () => props.modelValue,\n  set: (value) => emit('update:modelValue', value)\n})\n\n// 表单数据\nconst formData = ref({\n  name: '',\n  gender: '',\n  birth_date: '',\n  phone: '',\n  email: '',\n  location: '',\n  personal_summary: ''\n})\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    if (newVal) {\n      formData.value = { ...newVal }\n    }\n  },\n  { immediate: true }\n)\n\n// 响应式布局\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  return '600px'\n})\n\n// 表单字段配置\nconst formFields = [\n  {\n    name: 'name',\n    label: '姓名',\n    type: 'text',\n    required: true,\n    rules: [\n      { required: true, message: '请输入姓名', trigger: 'blur' },\n      { min: 2, max: 20, message: '长度在 2 到 20 个字符', trigger: 'blur' }\n    ]\n  },\n  {\n    name: 'gender',\n    label: '性别',\n    type: 'select',\n    required: true,\n    options: [\n      { label: '男', value: 'male' },\n      { label: '女', value: 'female' },\n      { label: '其他', value: 'other' }\n    ],\n    rules: [\n      { required: true, message: '请选择性别', trigger: 'change' }\n    ]\n  },\n  {\n    name: 'birth_date',\n    label: '出生日期',\n    type: 'date',\n    required: true,\n    rules: [\n      { required: true, message: '请选择出生日期', trigger: 'change' }\n    ]\n  },\n  {\n    name: 'phone',\n    label: '手机号码',\n    type: 'text',\n    required: true,\n    rules: [\n      { required: true, message: '请输入手机号码', trigger: 'blur' },\n      { pattern: /^1[3-9]\\d{9}$/, message: '请输入正确的手机号码', trigger: 'blur' }\n    ]\n  },\n  {\n    name: 'email',\n    label: '电子邮箱',\n    type: 'text',\n    required: true,\n    rules: [\n      { required: true, message: '请输入电子邮箱', trigger: 'blur' },\n      { type: 'email', message: '请输入正确的邮箱地址', trigger: 'blur' }\n    ]\n  },\n  {\n    name: 'location',\n    label: '所在地',\n    type: 'text',\n    required: true,\n    rules: [\n      { required: true, message: '请输入所在地', trigger: 'blur' }\n    ]\n  },\n  {\n    name: 'personal_summary',\n    label: '个人简介',\n    type: 'textarea',\n    required: false,\n    maxlength: 500,\n    showWordLimit: true,\n    autosize: { minRows: 3, maxRows: 6 },\n    placeholder: '请简要描述您的个人情况、工作经验和职业目标等'\n  }\n]\n\n// 处理关闭\nconst handleClose = () => {\n  dialogVisible.value = false\n}\n\n// 处理提交\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    await formRef.value.validate()\n    emit('submit', formData.value)\n  } catch (error) {\n    console.error('表单验证失败:', error)\n  }\n}\n</script>\n\n<style scoped>\n.basic-form {\n  max-height: 60vh;\n  overflow-y: auto;\n}\n\n.dialog-footer {\n  text-align: right;\n}\n\n/* 移动端样式 */\n@media (max-width: 640px) {\n  .edit-dialog {\n    margin: 0;\n  }\n  \n  .basic-form {\n    padding: 1rem;\n  }\n}\n</style>"],"mappings":";AAiFA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;;;;;;;;;;;;;;;;;IAE3C,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,OAAO,GAAGR,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMS,aAAa,GAAGR,QAAQ,CAAC;MAC7BS,GAAG,EAAEA,CAAA,KAAMN,KAAK,CAACO,UAAU;MAC3BC,GAAG,EAAGC,KAAK,IAAKP,IAAI,CAAC,mBAAmB,EAAEO,KAAK;IACjD,CAAC;;IAED;IACA,MAAMC,QAAQ,GAAGd,GAAG,CAAC;MACnBe,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,UAAU,EAAE,EAAE;MACdC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACAnB,KAAK,CACH,MAAME,KAAK,CAACkB,WAAW,EACtBC,MAAM,IAAK;MACV,IAAIA,MAAM,EAAE;QACVT,QAAQ,CAACD,KAAK,GAAAW,aAAA,KAAQD,MAAM,CAAC;MAC/B;IACF,CAAC,EACD;MAAEE,SAAS,EAAE;IAAK,CACpB;;IAEA;IACA,MAAM;MAAEC;IAAM,CAAC,GAAGvB,aAAa,CAAC;IAChC,MAAMwB,QAAQ,GAAG1B,QAAQ,CAAC,MAAMyB,KAAK,CAACb,KAAK,GAAG,GAAG;IACjD,MAAMe,WAAW,GAAG3B,QAAQ,CAAC,MAAM;MACjC,IAAI0B,QAAQ,CAACd,KAAK,EAAE,OAAO,MAAK;MAChC,OAAO,OAAM;IACf,CAAC;;IAED;IACA,MAAMgB,UAAU,GAAG,CACjB;MACEd,IAAI,EAAE,MAAM;MACZe,KAAK,EAAE,IAAI;MACXC,IAAI,EAAE,MAAM;MACZC,QAAQ,EAAE,IAAI;MACdC,KAAK,EAAE,CACL;QAAED,QAAQ,EAAE,IAAI;QAAEE,OAAO,EAAE,OAAO;QAAEC,OAAO,EAAE;MAAO,CAAC,EACrD;QAAEC,GAAG,EAAE,CAAC;QAAEC,GAAG,EAAE,EAAE;QAAEH,OAAO,EAAE,gBAAgB;QAAEC,OAAO,EAAE;MAAO;IAElE,CAAC,EACD;MACEpB,IAAI,EAAE,QAAQ;MACde,KAAK,EAAE,IAAI;MACXC,IAAI,EAAE,QAAQ;M