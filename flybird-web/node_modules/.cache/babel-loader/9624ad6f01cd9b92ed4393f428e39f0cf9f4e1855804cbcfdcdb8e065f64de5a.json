{"ast":null,"code":"import { ref, computed, watch, onMounted } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { auth } from '@/api/auth';\nimport { deleteAccount } from '@/api/user';\nimport { SMS_SCENE } from '@/store';\nexport default {\n  __name: 'AccountSettings',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n    const router = useRouter();\n\n    // 用户基本信息\n    const userBasicInfo = ref(null);\n    const loading = ref(false);\n\n    // 获取用户基本信息\n    const fetchUserBasicInfo = async () => {\n      try {\n        loading.value = true;\n        const response = await auth.getUserInfo();\n        if (response.data?.code === 200) {\n          userBasicInfo.value = response.data.data;\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n        showToast('获取用户信息失败', 'error');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 在组件挂载时获取用户信息\n    onMounted(() => {\n      if (store.state.isAuthenticated) {\n        fetchUserBasicInfo();\n      }\n    });\n\n    // 监听认证状态变化\n    watch(() => store.state.isAuthenticated, isAuthenticated => {\n      if (isAuthenticated) {\n        fetchUserBasicInfo();\n      } else {\n        userBasicInfo.value = null;\n      }\n    });\n\n    // 计算属性\n    const username = computed(() => userBasicInfo.value?.user?.username || '未设置');\n    const uid = computed(() => userBasicInfo.value?.user?.uid || '暂无');\n    const phone = computed(() => userBasicInfo.value?.user?.phone || '');\n\n    // 手机号脱敏处理\n    const maskPhone = phone => {\n      if (!phone) return '未绑定';\n      return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2');\n    };\n\n    // 模态框状态\n    const showPhoneModal = ref(false);\n    const showPasswordModal = ref(false);\n\n    // 其他方法和状态保持不变...\n\n    const __returned__ = {\n      store,\n      router,\n      userBasicInfo,\n      loading,\n      fetchUserBasicInfo,\n      username,\n      uid,\n      phone,\n      maskPhone,\n      showPhoneModal,\n      showPasswordModal,\n      ref,\n      computed,\n      watch,\n      onMounted,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get auth() {\n        return auth;\n      },\n      get deleteAccount() {\n        return deleteAccount;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","onMounted","useStore","useRouter","showToast","auth","deleteAccount","SMS_SCENE","store","router","userBasicInfo","loading","fetchUserBasicInfo","value","response","getUserInfo","data","code","error","console","state","isAuthenticated","username","user","uid","phone","maskPhone","replace","showPhoneModal","showPasswordModal"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/AccountSettings.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <!-- 账户信息 -->\n    <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n      <!-- 标题栏 -->\n      <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n        <h2 class=\"text-lg font-medium text-gray-900\">账户信息</h2>\n      </div>\n      \n      <!-- 内容区 -->\n      <div class=\"p-6 space-y-6\">\n        <!-- UID -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-2\">\n            <span class=\"text-sm font-medium text-gray-500\">用户 ID</span>\n            <span class=\"text-sm text-gray-900\">{{ uid }}</span>\n          </div>\n          <div class=\"text-xs text-gray-500\">用户唯一标识</div>\n        </div>\n\n        <!-- 昵称 -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-2\">\n            <span class=\"text-sm font-medium text-gray-500\">昵称</span>\n            <span class=\"text-sm text-gray-900\">{{ username }}</span>\n            <span class=\"text-xs text-gray-400\" v-if=\"!username\">\n              (默认为 Flybird + 手机号后4位)\n            </span>\n          </div>\n          <button @click=\"showNicknameModal = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n            transition-colors rounded-md hover:bg-indigo-50\">\n            <svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                d=\"M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z\" />\n            </svg>\n            设置\n          </button>\n        </div>\n      </div>\n    </section>\n\n    <!-- 账户安全 -->\n    <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n      <!-- 标题栏 -->\n      <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n        <h2 class=\"text-lg font-medium text-gray-900\">账户安全</h2>\n      </div>\n      \n      <!-- 内容区 -->\n      <div class=\"p-6 space-y-6\">\n        <!-- 手机号 -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex-1\">\n            <div class=\"flex items-center space-x-2\">\n              <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z\" />\n              </svg>\n              <span class=\"text-sm font-medium text-gray-900\">手机号</span>\n            </div>\n            <p class=\"mt-1 text-sm text-gray-500\">{{ maskPhone(phone) }}</p>\n          </div>\n          <button @click=\"showPhoneModal = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n            transition-colors rounded-md hover:bg-indigo-50\">\n            更换手机号\n          </button>\n        </div>\n\n        <!-- 密码 -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex-1\">\n            <div class=\"flex items-center space-x-2\">\n              <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n              </svg>\n              <span class=\"text-sm font-medium text-gray-900\">登录密码</span>\n            </div>\n            <p class=\"mt-1 text-sm text-gray-500\">用于保护账号安全</p>\n          </div>\n          <button @click=\"showPasswordModal = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n            transition-colors rounded-md hover:bg-indigo-50\">\n            修改密码\n          </button>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, watch, onMounted } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { auth } from '@/api/auth'\nimport { deleteAccount } from '@/api/user'\nimport { SMS_SCENE } from '@/store'\n\nconst store = useStore()\nconst router = useRouter()\n\n// 用户基本信息\nconst userBasicInfo = ref(null)\nconst loading = ref(false)\n\n// 获取用户基本信息\nconst fetchUserBasicInfo = async () => {\n  try {\n    loading.value = true\n    const response = await auth.getUserInfo()\n    if (response.data?.code === 200) {\n      userBasicInfo.value = response.data.data\n    }\n  } catch (error) {\n    console.error('获取用户信息失败:', error)\n    showToast('获取用户信息失败', 'error')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 在组件挂载时获取用户信息\nonMounted(() => {\n  if (store.state.isAuthenticated) {\n    fetchUserBasicInfo()\n  }\n})\n\n// 监听认证状态变化\nwatch(() => store.state.isAuthenticated, (isAuthenticated) => {\n  if (isAuthenticated) {\n    fetchUserBasicInfo()\n  } else {\n    userBasicInfo.value = null\n  }\n})\n\n// 计算属性\nconst username = computed(() => userBasicInfo.value?.user?.username || '未设置')\nconst uid = computed(() => userBasicInfo.value?.user?.uid || '暂无')\nconst phone = computed(() => userBasicInfo.value?.user?.phone || '')\n\n// 手机号脱敏处理\nconst maskPhone = (phone) => {\n  if (!phone) return '未绑定'\n  return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n// 模态框状态\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\n\n// 其他方法和状态保持不变...\n\n</script>\n\n<style scoped>\n/* 如果有任何样式，放在这里 */\n</style>"],"mappings":"AA8FA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,EAAEC,SAAS,QAAQ,KAAI;AACpD,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,IAAI,QAAQ,YAAW;AAChC,SAASC,aAAa,QAAQ,YAAW;AACzC,SAASC,SAAS,QAAQ,SAAQ;;;;;;;IAElC,MAAMC,KAAK,GAAGN,QAAQ,CAAC;IACvB,MAAMO,MAAM,GAAGN,SAAS,CAAC;;IAEzB;IACA,MAAMO,aAAa,GAAGZ,GAAG,CAAC,IAAI;IAC9B,MAAMa,OAAO,GAAGb,GAAG,CAAC,KAAK;;IAEzB;IACA,MAAMc,kBAAkB,GAAG,MAAAA,CAAA,KAAY;MACrC,IAAI;QACFD,OAAO,CAACE,KAAK,GAAG,IAAG;QACnB,MAAMC,QAAQ,GAAG,MAAMT,IAAI,CAACU,WAAW,CAAC;QACxC,IAAID,QAAQ,CAACE,IAAI,EAAEC,IAAI,KAAK,GAAG,EAAE;UAC/BP,aAAa,CAACG,KAAK,GAAGC,QAAQ,CAACE,IAAI,CAACA,IAAG;QACzC;MACF,CAAC,CAAC,OAAOE,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;QAChCd,SAAS,CAAC,UAAU,EAAE,OAAO;MAC/B,CAAC,SAAS;QACRO,OAAO,CAACE,KAAK,GAAG,KAAI;MACtB;IACF;;IAEA;IACAZ,SAAS,CAAC,MAAM;MACd,IAAIO,KAAK,CAACY,KAAK,CAACC,eAAe,EAAE;QAC/BT,kBAAkB,CAA