{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { XMarkIcon, ChevronUpDownIcon, CheckIcon, CalendarIcon } from '@heroicons/vue/24/outline';\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue';\nexport default {\n  __name: 'EditBasicDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const form = ref({\n      name: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: '',\n      personal_summary: ''\n    });\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      if (newVal) {\n        form.value = _objectSpread({}, newVal);\n      }\n    }, {\n      immediate: true\n    });\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n\n    // 根据屏幕宽度设置弹窗宽度\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 处理关闭对话框\n    const handleClose = () => {\n      emit('update:modelValue', false);\n    };\n\n    // 提交表单\n    const handleSubmit = () => {\n      emit('submit', form.value);\n    };\n    const GENDER_OPTIONS = [{\n      value: 'male',\n      label: '男'\n    }, {\n      value: 'female',\n      label: '女'\n    }];\n    const getGenderLabel = value => {\n      const option = GENDER_OPTIONS.find(option => option.value === value);\n      return option ? option.label : '';\n    };\n    const __returned__ = {\n      props,\n      emit,\n      form,\n      width,\n      isMobile,\n      dialogWidth,\n      handleClose,\n      handleSubmit,\n      GENDER_OPTIONS,\n      getGenderLabel,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get ChevronUpDownIcon() {\n        return ChevronUpDownIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","XMarkIcon","ChevronUpDownIcon","CheckIcon","CalendarIcon","Listbox","ListboxButton","ListboxOptions","ListboxOption","props","__props","emit","__emit","form","name","gender","phone","email","location","birth_date","personal_summary","initialData","newVal","value","_objectSpread","immediate","width","isMobile","dialogWidth","handleClose","handleSubmit","GENDER_OPTIONS","label","getGenderLabel","option","find"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    @close=\"handleClose\"\n    class=\"edit-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- Header -->\n      <div class=\"dialog-header px-6 py-4\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-lg font-medium text-gray-900\">编辑基本信息</h3>\n          <!-- 移动端显示关闭按钮 -->\n          <button\n            v-if=\"isMobile\"\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- Body -->\n      <div class=\"dialog-body px-6 pt-4 pb-6\">\n        <el-form\n          ref=\"formRef\"\n          :model=\"form\"\n          :disabled=\"loading\"\n        >\n          <form @submit.prevent=\"handleSubmit\" class=\"space-y-4 sm:space-y-5\">\n            <!-- 两列布局 -->\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5\">\n              <!-- 姓名 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">姓名</label>\n                <el-form-item prop=\"name\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.name\"\n                    type=\"text\"\n                    placeholder=\"请输入姓名\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 性别 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">性别</label>\n                <el-form-item prop=\"gender\" class=\"mb-0\">\n                  <Listbox v-model=\"form.gender\">\n                    <div class=\"relative w-full\">\n                      <ListboxButton class=\"relative w-full cursor-default rounded-md border border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-left shadow-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\">\n                        <span class=\"block truncate\">{{ getGenderLabel(form.gender) }}</span>\n                        <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2\">\n                          <ChevronUpDownIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                        </span>\n                      </ListboxButton>\n\n                      <transition\n                        leave-active-class=\"transition ease-in duration-100\"\n                        leave-from-class=\"opacity-100\"\n                        leave-to-class=\"opacity-0\"\n                      >\n                        <ListboxOptions class=\"absolute z-10 mt-1 w-full overflow-auto rounded-md bg-white py-1 text-base shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none sm:text-sm\">\n                          <ListboxOption\n                            v-for=\"option in GENDER_OPTIONS\"\n                            :key=\"option.value\"\n                            :value=\"option.value\"\n                            v-slot=\"{ active, selected }\"\n                          >\n                            <div :class=\"[\n                              active ? 'bg-gray-100 text-gray-900' : 'text-gray-700',\n                              'relative cursor-default select-none py-2 pl-3 pr-9'\n                            ]\">\n                              <span :class=\"[selected ? 'font-semibold' : 'font-normal', 'block truncate']\">\n                                {{ option.label }}\n                              </span>\n                              <span v-if=\"selected\" :class=\"[active ? 'text-gray-900' : 'text-gray-600', 'absolute inset-y-0 right-0 flex items-center pr-4']\">\n                                <CheckIcon class=\"h-5 w-5\" aria-hidden=\"true\" />\n                              </span>\n                            </div>\n                          </ListboxOption>\n                        </ListboxOptions>\n                      </transition>\n                    </div>\n                  </Listbox>\n                </el-form-item>\n              </div>\n\n              <!-- 手机号 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">手机号</label>\n                <el-form-item prop=\"phone\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.phone\"\n                    type=\"tel\"\n                    placeholder=\"请输入手机号\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 邮箱 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">邮箱</label>\n                <el-form-item prop=\"email\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.email\"\n                    type=\"email\"\n                    placeholder=\"请输入邮箱\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 所在地 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">所在地</label>\n                <el-form-item prop=\"location\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.location\"\n                    type=\"text\"\n                    placeholder=\"请输入所在地\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 出生日期 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">出生日期</label>\n                <el-form-item prop=\"birth_date\" class=\"mb-0\">\n                  <div class=\"relative w-full\">\n                    <input\n                      v-model=\"form.birth_date\"\n                      type=\"date\"\n                      class=\"!w-full block rounded-md border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-left shadow-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                    />\n                    <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2\">\n                      <CalendarIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                    </span>\n                  </div>\n                </el-form-item>\n              </div>\n            </div>\n\n            <!-- 个人简介 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">个人简介</label>\n              <el-form-item prop=\"personal_summary\" class=\"mb-0\">\n                <el-input\n                  v-model=\"form.personal_summary\"\n                  type=\"textarea\"\n                  :rows=\"4\"\n                  placeholder=\"请输入个人简介\"\n                  resize=\"none\"\n                  class=\"!w-full\"\n                />\n              </el-form-item>\n            </div>\n          </form>\n        </el-form>\n      </div>\n\n      <!-- Footer -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-3 sm:px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-3 sm:px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { XMarkIcon, ChevronUpDownIcon, CheckIcon, CalendarIcon } from '@heroicons/vue/24/outline'\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst form = ref({\n  name: '',\n  gender: '',\n  phone: '',\n  email: '',\n  location: '',\n  birth_date: '',\n  personal_summary: ''\n})\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    if (newVal) {\n      form.value = { ...newVal }\n    }\n  },\n  { immediate: true }\n)\n\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\n\n// 根据屏幕宽度设置弹窗宽度\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 处理关闭对话框\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n\n// 提交表单\nconst handleSubmit = () => {\n  emit('submit', form.value)\n}\n\nconst GENDER_OPTIONS = [\n  { value: 'male', label: '男' },\n  { value: 'female', label: '女' }\n]\n\nconst getGenderLabel = (value) => {\n  const option = GENDER_OPTIONS.find(option => option.value === value)\n  return option ? option.label : ''\n}\n</script>\n\n<style>\n.edit-dialog {\n  @apply max-h-screen flex flex-col;\n}\n\n.edit-dialog :deep(.el-dialog__body) {\n  @apply flex-1 overflow-y-auto;\n}\n\n.edit-dialog :deep(.el-dialog__footer) {\n  @apply sticky bottom-0 bg-gray-50 z-10;\n}\n\n/* 移动端样式 */\n@media (max-width: 640px) {\n  .edit-dialog {\n    margin: 0 !important;\n  }\n\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    height: calc(100vh - 120px);\n    overflow-y: auto;\n  }\n\n  .el-form-item {\n    @apply mb-3;\n  }\n\n  /* 调整输入框在移动端的大小 */\n  input, select, textarea {\n    @apply text-base py-2.5;\n  }\n}\n\n/* 桌面端样式 */\n@media (min-width: 641px) {\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    max-height: calc(80vh - 120px);\n    overflow-y: auto;\n  }\n}\n</style>"],"mappings":";AAoMA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,SAAS,EAAEC,iBAAiB,EAAEC,SAAS,EAAEC,YAAY,QAAQ,2BAA0B;AAChG,SAASC,OAAO,EAAEC,aAAa,EAAEC,cAAc,EAAEC,aAAa,QAAQ,iBAAgB;;;;;;;;;;;;;;;;;IAEtF,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,IAAI,GAAGhB,GAAG,CAAC;MACfiB,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACArB,KAAK,CACH,MAAMU,KAAK,CAACY,WAAW,EACtBC,MAAM,IAAK;MACV,IAAIA,MAAM,EAAE;QACVT,IAAI,CAACU,KAAK,GAAAC,aAAA,KAAQF,MAAM,CAAC;MAC3B;IACF,CAAC,EACD;MAAEG,SAAS,EAAE;IAAK,CACpB;IAEA,MAAM;MAAEC;IAAM,CAAC,GAAG1B,aAAa,CAAC;IAChC,MAAM2B,QAAQ,GAAG7B,QAAQ,CAAC,MAAM4B,KAAK,CAACH,KAAK,GAAG,GAAG;;IAEjD;IACA,MAAMK,WAAW,GAAG9B,QAAQ,CAAC,MAAM;MACjC,IAAI6B,QAAQ,CAACJ,KAAK,EAAE,OAAO,MAAK;MAChC,IAAIG,KAAK,CAACH,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;;IAED;IACA,MAAMM,WAAW,GAAGA,CAAA,KAAM;MACxBlB,IAAI,CAAC,mBAAmB,EAAE,KAAK;IACjC;;IAEA;IACA,MAAMmB,YAAY,GAAGA,CAAA,KAAM;MACzBnB,IAAI,CAAC,QAAQ,EAAEE,IAAI,CAACU,KAAK;IAC3B;IAEA,MAAMQ,cAAc,GAAG,CACrB;MAAER,KAAK,EAAE,MAAM;MAAES,KAAK,EAAE;IAAI