perienceDialog = $event),\n    \"initial-data\": _ctx.currentEditData,\n    loading: _ctx.profileLoading,\n    onSubmit: _ctx.handleWorkExperienceSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"]), _createCommentVNode(\" 求职意向编辑弹窗 \"), _ctx.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock(_component_EditJobIntentionDialog, {\n    key: 1,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.profileLoading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), _ctx.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock(_component_EditBasicDialog, {\n    key: 2,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.profileLoading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true), _createVNode(_component_AIOptimizeDialog, {\n    modelValue: _ctx.showAIOptimizeDialog,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => _ctx.showAIOptimizeDialog = $event),\n    \"profile-data\": _ctx.profileData,\n    onApply: _ctx.handleAIOptimize\n  }, null, 8 /* PROPS */, [\"modelValue\", \"profile-data\", \"onApply\"])])]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","_component_BasicInfo","resumeData","_ctx","basicInfo","loading","profileLoading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onUpdate","handleUpdate","onToggleBioExpand","toggleBioExpand","_component_ResumeStatus","completionData","profileData","_createCommentVNode","_component_ModuleList","activeModules","inactiveModules","modulesLoading","onRemove","handleModuleRemove","onEditItem","handleEditItem","onRemoveItem","handleRemoveItem","length","_hoisted_3","_hoisted_4","_hoisted_5","_Fragment","_renderList","module","type","onClick","$event","handleAddModule","_createTextVNode","_toDisplayString","getModuleName","_component_PlusIcon","_hoisted_6","_component_EditWorkExperienceDialog","modelValue","showWorkExperienceDialog","_cache","currentEditData","onSubmit","handleWorkExperienceSubmit","currentModule","_createBlock","_component_EditJobIntentionDialog","showEditModal","editFormData","handleSubmit","_component_EditBasicDialog","_component_AIOptimizeDialog","showAIOptimizeDialog","onApply","handleAIOptimize"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto px-4 py-6\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"profileLoading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @update=\"handleUpdate\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"profileLoading\"\n      />\n\n      <!-- 激活的模块列表 -->\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"modulesLoading\"\n        @edit=\"handleEdit\"\n        @remove=\"handleModuleRemove\"\n        @edit-item=\"handleEditItem\"\n        @remove-item=\"handleRemoveItem\"\n      />\n\n      <!-- 未激活的模块按钮组 -->\n      <div v-if=\"inactiveModules.length > 0\" class=\"bg-white rounded-lg shadow\">\n        <div class=\"px-4 py-3\">\n          <h3 class=\"text-sm font-medium text-gray-900\">添加更多模块</h3>\n          <div class=\"mt-3 flex flex-wrap gap-2\">\n            <button\n              v-for=\"module in inactiveModules\"\n              :key=\"module.type\"\n              @click=\"handleAddModule(module.type)\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm text-gray-600 bg-gray-50 hover:bg-gray-100 rounded border border-gray-200\"\n            >\n              {{ getModuleName(module.type) }}\n              <PlusIcon class=\"w-4 h-4 ml-1 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-model=\"showWorkExperienceDialog\"\n        :initial-data=\"currentEditData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleWorkExperienceSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch, computed } from 'vue'\nimport { useModules } from './composables/useModules'\nimport { useProfileData } from './composables/useProfileData'\nimport { profile } from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { PlusIcon } from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\nimport AIOptimizeDialog from './dialogs/AIOptimizeDialog.vue'\n\n// 使用模块管理\nconst { \n  loading: modulesLoading,\n  activeModules,\n  inactiveModules,\n  fetchModulesData,\n  addModule,\n  removeModule\n} = useModules()\n\nconst {\n  loading: profileLoading,\n  basicInfo,\n  profileData,\n  completionData,\n  fetchBasicInfo,\n  fetchModuleData,\n  fetchCompletionData\n} = useProfileData()\n\n// 当前编辑的模块\nconst currentModule = ref(null)\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 添加缺失的响应式变量\nconst showAIOptimizeDialog = ref(false)\n\n// 处理 Bio 展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 定义组件的 emits\ndefineEmits([\n  'update:modelValue',\n  'edit',\n  'add',\n  'remove',\n  'edit-item',\n  'remove-item'\n])\n\n// 初始化数据\nonMounted(async () => {\n  try {\n    // 获取基本信息\n    await fetchBasicInfo()\n    console.log('基本信息:', basicInfo.value)\n    \n    // 获取模块数据\n    await fetchModulesData()\n\n    // 获取完整度数据\n    await fetchCompletionData()\n    console.log('完整度数据:', completionData.value)\n  } catch (error) {\n    console.error('初始化数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  }\n})\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchUserData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    if (currentModule.value?.type === 'basic_info') {\n      // 基本信息保存\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        // 重新获取基本信息\n        await fetchBasicInfo()\n      } else {\n        throw new Error(response.data?.message || '保存失败')\n      }\n    } else if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.workExperience.update(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchModulesData()\n        } else {\n          throw new Error(response.data?.message || '更新失败')\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.workExperience.add(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchModulesData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.jobIntention.update(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchModulesData()\n      }\n    }\n\n    // 在成功保存后刷新完整度\n    await fetchCompletionData()\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.type === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\n// 处理 AI 优化结果\nconst handleAIOptimize = (optimizedData) => {\n  Object.entries(optimizedData).forEach(([key, value]) => {\n    const [category, field] = key.split('.')\n    if (category && field) {\n      if (!profileData.value[category]) {\n        profileData.value[category] = {}\n      }\n      profileData.value[category][field] = value\n    } else {\n      profileData.value[key] = value\n    }\n  })\n}\n\n// 添加更新处理方法\nconst handleUpdate = async () => {\n  await fetchBasicInfo()\n  await fetchModulesData()\n  await fetchCompletionData()\n}\n\n// 处理模块移除\nconst handleModuleRemove = async (moduleType) => {\n  await removeModule(moduleType)\n}\n\n// 处理添加模块\nconst handleAddModule = async (moduleType) => {\n  await addModule(moduleType)\n}\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n\n// 添加工作经历对话框\nconst showWorkExperienceDialog = ref(false)\nconst currentEditData = ref({})\n\n// 处理编辑\nconst handleEdit = (type) => {\n  if (type === 'work_experience') {\n    currentEditData.value = {}\n    showWorkExperienceDialog.value = true\n  }\n}\n\n// 处理编辑具体项目\nconst handleEditItem = (type, item) => {\n  if (type === 'work_experience') {\n    currentEditData.value = { ...item }\n    showWorkExperienceDialog.value = true\n  }\n}\n\n// 处理删除\nconst handleRemoveItem = async (type, itemId) => {\n  if (type === 'work_experience') {\n    if (confirm('确定要删除这条工作经历吗？')) {\n      await withLoading(async () => {\n        await deleteWorkExperience(itemId)\n        await refreshModules()\n      })\n    }\n  }\n}\n\n// 处理提交\nconst handleWorkExperienceSubmit = async (data) => {\n  await withLoading(async () => {\n    if (data.id) {\n      await updateWorkExperience(data)\n    } else {\n      await createWorkExperience(data)\n    }\n    showWorkExperienceDialog.value = false\n    await refreshModules()\n  })\n}\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAA6B;;EACjCA,KAAK,EAAC;AAA6B;;EAH5CC,GAAA;EAgC6CD,KAAK,EAAC;;;EACtCA,KAAK,EAAC;AAAW;;EAEfA,KAAK,EAAC;AAA2B;mBAnChD;;;;;;;;;;uBAEEE,mBAAA,CA+EM,OA/ENC,UA+EM,GA9EJC,mBAAA,CA6EM,OA7ENC,UA6EM,GA5EJC,YAAA,CAQEC,oBAAA;IAPCC,UAAU,EAAEC,IAAA,CAAAC,SAAS;IACrBC,OAAO,EAAEF,IAAA,CAAAG,cAAc;IACvBC,WAAW,EAAEJ,IAAA,CAAAI,WAAW;IACxBC,mBAAmB,EAAEL,IAAA,CAAAK,mBAAmB;IACxCC,MAAI,EAAEN,IAAA,CAAAO,UAAU;IAChBC,QAAM,EAAER,IAAA,CAAAS,YAAY;IACpBC,iBAAe,EAAEV,IAAA,CAAAW;uIAGpBd,YAAA,CAIEe,uBAAA;IAHC,iBAAe,EAAEZ,IAAA,CAAAa,cAAc;IAC/B,cAAY,EAAEb,IAAA,CAAAc,WAAW;IACzBZ,OAAO,EAAEF,IAAA,CAAAG;2EAGZY,mBAAA,aAAgB,EAChBlB,YAAA,CAQEmB,qBAAA;IAPC,gBAAc,EAAEhB,IAAA,CAAAiB,aAAa;IAC7B,kBAAgB,EAAEjB,IAAA,CAAAkB,eAAe;IACjChB,OAAO,EAAEF,IAAA,CAAAmB,cAAc;IACvBb,MAAI,EAAEN,IAAA,CAAAO,UAAU;IAChBa,QAAM,EAAEpB,IAAA,CAAAqB,kBAAkB;IAC1BC,UAAS,EAAEtB,IAAA,CAAAuB,cAAc;IACzBC,YAAW,EAAExB,IAAA,CAAAyB;kIAGhBV,mBAAA,eAAkB,EACPf,IAAA,CAAAkB,eAAe,CAACQ,MAAM,Q,cAAjCjC,mBAAA,CAeM,OAfNkC,UAeM,GAdJhC,mBAAA,CAaM,OAbNiC,UAaM,G,0BAZJjC,mBAAA,CAAyD;IAArDJ,KAAK,EAAC;EAAmC,GAAC,QAAM,sBACpDI,mBAAA,CAUM,OAVNkC,UAUM,I,kBATJpC,mBAAA,CAQSqC,SAAA,QA5CrBC,WAAA,CAqC+B/B,IAAA,CAAAkB,eAAe,EAAzBc,MAAM;yBADfvC,mBAAA,CAQS;MANND,GAAG,EAAEwC,MAAM,CAACC,IAAI;MAChBC,OAAK,EAAAC,MAAA,IAAEnC,IAAA,CAAAoC,eAAe,CAACJ,MAAM,CAACC,IAAI;MACnC1C,KAAK,EAAC;QAxCpB8C,gBAAA,CAAAC,gBAAA,CA0CiBtC,IAAA,CAAAuC,aAAa,CAACP,MAAM,CAACC,IAAI,KAAI,GAChC,iBAAApC,YAAA,CAA+C2C,mBAAA;MAArCjD,KAAK,EAAC;IAA4B,G,iBA3C1DkD,UAAA;0CAAA1B,mBAAA,gBAiDMA,mBAAA,cAAiB,EACjBlB,YAAA,CAKE6C,mCAAA;IAvDRC,UAAA,EAmDiB3C,IAAA,CAAA4C,wBAAwB;IAnDzC,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IAmDiBnC,IAAA,CAAA4C,wBAAwB,GAAAT,MAAA;IAChC,cAAY,EAAEnC,IAAA,CAAA8C,eAAe;IAC7B5C,OAAO,EAAEF,IAAA,CAAAG,cAAc;IACvB4C,QAAM,EAAE/C,IAAA,CAAAgD;kFAGXjC,mBAAA,cAAiB,EAETf,IAAA,CAAAiD,aAAa,EAAEhB,IAAI,wB,cAD3BiB,YAAA,CAMEC,iCAAA;IAhER3D,GAAA;IAAAmD,UAAA,EA4DiB3C,IAAA,CAAAoD,aAAa;IA5D9B,uBAAAP,MAAA,QAAAA,MAAA,MAAAV,MAAA,IA4DiBnC,IAAA,CAAAoD,aAAa,GAAAjB,MAAA;IACrB,cAAY,EAAEnC,IAAA,CAAAqD,YAAY;IAC1BnD,OAAO,EAAEF,IAAA,CAAAG,cAAc;IACvB4C,QAAM,EAAE/C,IAAA,CAAAsD;oFA/DjBvC,mBAAA,gBAkEMA,mBAAA,cAAiB,EAETf,IAAA,CAAAiD,aAAa,EAAEhB,IAAI,qB,cAD3BiB,YAAA,CAMEK,0BAAA;IAzER/D,GAAA;IAAAmD,UAAA,EAqEiB3C,IAAA,CAAAoD,aAAa;IArE9B,uBAAAP,MAAA,QAAAA,MAAA,MAAAV,MAAA,IAqEiBnC,IAAA,CAAAoD,aAAa,GAAAjB,MAAA;IACrB,cAAY,EAAEnC,IAAA,CAAAqD,YAAY;IAC1BnD,OAAO,EAAEF,IAAA,CAAAG,cAAc;IACvB4C,QAAM,EAAE/C,IAAA,CAAAsD;oFAxEjBvC,mBAAA,gBA2EMlB,YAAA,CAIE2D,2BAAA;IA/ERb,UAAA,EA4EiB3C,IAAA,CAAAyD,oBAAoB;IA5ErC,uBAAAZ,MAAA,QAAAA,MAAA,MAAAV,MAAA,IA4EiBnC,IAAA,CAAAyD,oBAAoB,GAAAtB,MAAA;IAC5B,cAAY,EAAEnC,IAAA,CAAAc,WAAW;IACzB4C,OAAK,EAAE1D,IAAA,CAAA2D","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}