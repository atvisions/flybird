oyed_looking',\n            'closed': 'employed_not_looking'\n          };\n          return statusMap[oldStatus] || oldStatus;\n        };\n        const formData = _objectSpread(_objectSpread(_objectSpread({}, form.value), newVal), {}, {\n          job_status: convertOldStatus(newVal.job_status) // 转换状态值\n        });\n        form.value = formData;\n        console.log('更新后的表单数据:', form.value);\n\n        // 解析城市数据\n        if (newVal.expected_city) {\n          selectedCities.value = newVal.expected_city.split('-');\n          console.log('解析后的城市数据:', selectedCities.value);\n        } else {\n          selectedCities.value = [];\n        }\n\n        // 解析行业数据\n        if (newVal.industries) {\n          form.value.industries = typeof newVal.industries === 'string' ? newVal.industries.split(',').filter(Boolean) : newVal.industries;\n          console.log('解析后的行业数据:', form.value.industries);\n        }\n      }\n    }, {\n      immediate: true\n    });\n\n    // 表单验证规则\n    const rules = {\n      job_type: [{\n        required: true,\n        message: '请选择工作类型',\n        trigger: 'change'\n      }],\n      job_status: [{\n        required: true,\n        message: '请选择求职状态',\n        trigger: 'change'\n      }]\n    };\n\n    // 对话框可见性\n    const dialogVisible = computed({\n      get: () => props.modelValue,\n      set: val => emit('update:modelValue', val)\n    });\n\n    // 提交表单\n    const handleSubmit = async () => {\n      if (!formRef.value) return;\n      try {\n        await formRef.value.validate();\n        console.log('表单验证通过');\n\n        // 处理行业数据\n        const formData = _objectSpread({}, form.value);\n\n        // 确保使用新的状态值\n        const statusMap = {\n          'open': 'unemployed_looking',\n          'closed': 'employed_not_looking'\n        };\n        formData.job_status = statusMap[formData.job_status] || formData.job_status;\n        if (Array.isArray(formData.industries)) {\n          formData.industries = formData.industries.join(',');\n        }\n        console.log('提交的数据:', formData);\n        emit('submit', formData);\n      } catch (error) {\n        console.error('表单验证失败:', error);\n      }\n    };\n\n    // 临时定义选项用于测试\n    const LOCAL_JOB_STATUS_OPTIONS = [{\n      value: 'unemployed_looking',\n      label: '离职-找工作'\n    }, {\n      value: 'employed_not_looking',\n      label: '在职-暂不考虑'\n    }, {\n      value: 'employed_looking',\n      label: '在职-看机会'\n    }, {\n      value: 'student_internship',\n      label: '在校-找实习'\n    }, {\n      value: 'fresh_graduate',\n      label: '应届生'\n    }];\n\n    // 计算对话框宽度\n    const dialogWidth = computed(() => {\n      // 这里可以根据需要计算对话框宽度\n      return '640px';\n    });\n\n    // 处理关闭对话框\n    const handleClose = () => {\n      dialogVisible.value = false;\n    };\n\n    // 获取工作类型标签\n    const getJobTypeLabel = value => {\n      const option = JOB_TYPE_OPTIONS.find(opt => opt.value === value);\n      return option ? option.label : '请选择工作类型';\n    };\n    const __returned__ = {\n      props,\n      emit,\n      formRef,\n      commonCities,\n      selectedCities,\n      form,\n      handleCityChange,\n      rules,\n      dialogVisible,\n      handleSubmit,\n      LOCAL_JOB_STATUS_OPTIONS,\n      dialogWidth,\n      handleClose,\n      getJobTypeLabel,\n      ref,\n      computed,\n      watch,\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get ChevronUpDownIcon() {\n        return ChevronUpDownIcon;\n      },\n      get JOB_TYPE_OPTIONS() {\n        return JOB_TYPE_OPTIONS;\n      },\n      get JOB_STATUS_OPTIONS() {\n        return JOB_STATUS_OPTIONS;\n      },\n      get SALARY_OPTIONS() {\n        return SALARY_OPTIONS;\n      },\n      get INDUSTRY_CATEGORIES() {\n        return INDUSTRY_CATEGORIES;\n      },\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","Listbox","ListboxButton","ListboxOptions","ListboxOption","CheckIcon","ChevronUpDownIcon","JOB_TYPE_OPTIONS","JOB_STATUS_OPTIONS","SALARY_OPTIONS","INDUSTRY_CATEGORIES","useWindowSize","ElMessage","console","log","props","__props","emit","__emit","formRef","commonCities","selectedCities","form","job_type","job_status","expected_salary","expected_city","industries","handleCityChange","value","join","initialData","newVal","convertOldStatus","oldStatus","statusMap","formData","_objectSpread","split","filter","Boolean","immediate","rules","required","message","trigger","dialogVisible","get","modelValue","set","val","handleSubmit","validate","Array","isArray","error","LOCAL_JOB_STATUS_OPTIONS","label","dialogWidth","handleClose","getJobTypeLabel","option","find","opt"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditJobIntentionDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n    @close=\"handleClose\"\n    class=\"relative\"\n  >\n    <!-- Header -->\n    <template #header>\n      <div class=\"border-b border-gray-200 px-6 py-5\">\n        <h3 class=\"text-lg font-medium text-gray-900\">编辑求职意向</h3>\n      </div>\n    </template>\n\n    <!-- Body -->\n    <div class=\"px-6 py-5\">\n      <el-form\n        ref=\"formRef\"\n        :model=\"form\"\n        :rules=\"rules\"\n      >\n        <form @submit.prevent=\"handleSubmit\" class=\"space-y-5\">\n          <!-- 两列布局 -->\n          <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n            <!-- 工作类型 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">工作类型</label>\n              <el-form-item prop=\"job_type\" class=\"mb-0\">\n                <Listbox v-model=\"form.job_type\">\n                  <div class=\"relative\">\n                    <ListboxButton class=\"relative w-full cursor-default rounded-md border border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-left shadow-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\">\n                      <span class=\"block truncate\">{{ getJobTypeLabel(form.job_type) }}</span>\n                      <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2\">\n                        <ChevronUpDownIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                      </span>\n                    </ListboxButton>\n\n                    <transition\n                      leave-active-class=\"transition ease-in duration-100\"\n                      leave-from-class=\"opacity-100\"\n                      leave-to-class=\"opacity-0\"\n                    >\n                      <ListboxOptions class=\"absolute z-10 mt-1 max-h-60 w-full overflow-auto rounded-md bg-white py-1 text-base shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none sm:text-sm\">\n                        <ListboxOption\n                          v-for=\"option in JOB_TYPE_OPTIONS\"\n                          :key=\"option.value\"\n                          :value=\"option.value\"\n                          v-slot=\"{ active, selected }\"\n                        >\n                          <div :class=\"[\n                            active ? 'bg-gray-100 text-gray-900' : 'text-gray-700',\n                            'relative cursor-default select-none py-2 pl-3 pr-9'\n                          ]\">\n                            <span :class=\"[selected ? 'font-semibold' : 'font-normal', 'block truncate']\">\n                              {{ option.label }}\n                            </span>\n                            <span v-if=\"selected\" :class=\"[active ? 'text-gray-900' : 'text-gray-600', 'absolute inset-y-0 right-0 flex items-center pr-4']\">\n                              <CheckIcon class=\"h-5 w-5\" aria-hidden=\"true\" />\n                            </span>\n                          </div>\n                        </ListboxOption>\n                      </ListboxOptions>\n                    </transition>\n                  </div>\n                </Listbox>\n              </el-form-item>\n            </div>\n\n            <!-- 求职状态 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">求职状态</label>\n              <el-form-item prop=\"job_status\" class=\"mb-0\">\n                <select\n                  v-model=\"form.job_status\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                >\n                  <option value=\"\" class=\"text-gray-400\" disabled>请选择求职状态</option>\n                  <option \n                    v-for=\"option in LOCAL_JOB_STATUS_OPTIONS\" \n                    :key=\"option.value\" \n                    :value=\"option.value\"\n                    class=\"py-2 text-gray-900 hover:bg-gray-100\"\n                  >\n                    {{ option.label }}\n                  </option>\n                </select>\n              </el-form-item>\n            </div>\n\n            <!-- 期望薪资 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">期望薪资</label>\n              <el-form-item prop=\"expected_salary\" class=\"mb-0\">\n                <select\n                  v-model=\"form.expected_salary\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                >\n                  <option value=\"\" class=\"text-gray-400\" disabled>请选择期望薪资</option>\n                  <option \n                    v-for=\"option in SALARY_OPTIONS\" \n                    :key=\"option.value\" \n                    :value=\"option.value\"\n                    class=\"py-2 text-gray-900 hover:bg-gray-100\"\n                  >\n                    {{ option.label }}\n                  </option>\n                </select>\n              </el-form-item>\n            </div>\n\n            <!-- 期望城市 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">期望城市</label>\n              <el-form-item prop=\"expected_city\" class=\"mb-0\">\n                <input\n                  v-model=\"form.expected_city\"\n                  type=\"text\"\n                  placeholder=\"请输入期望城市，多个城市用逗号分隔\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                />\n              </el-form-item>\n            </div>\n          </div>\n\n          <!-- 期望行业 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">期望行业</label>\n            <el-form-item prop=\"industries\" class=\"mb-0\">\n              <input\n                v-model=\"form.industries\"\n                type=\"text\"\n                placeholder=\"请输入期望行业，多个行业用逗号分隔\"\n                class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n              />\n            </el-form-item>\n          </div>\n        </form>\n      </el-form>\n    </div>\n\n    <!-- Footer -->\n    <template #footer>\n      <div class=\"border-t border-gray-200 px-6 py-4\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue'\nimport { CheckIcon, ChevronUpDownIcon } from '@heroicons/vue/20/solid'\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions'\nimport { INDUSTRY_CATEGORIES } from '../constants/industryOptions'\nimport { useWindowSize } from '@vueuse/core'\nimport { ElMessage } from 'element-plus'\n\n// 添加调试日志\nconsole.log('求职状态选项:', JOB_STATUS_OPTIONS)\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单引用\nconst formRef = ref(null)\n\n// 常用城市列表\nconst commonCities = [\n  '北京',\n  '上海',\n  '广州',\n  '深圳',\n  '杭州',\n  '南京',\n  '成都',\n  '武汉',\n  '西安',\n  '苏州',\n  '天津',\n  '重庆'\n]\n\n// 城市选择\nconst selectedCities = ref([])\n\n// 表单数据\nconst form = ref({\n  job_type: '',\n  job_status: '',\n  expected_salary: '',\n  expected_city: '',\n  industries: []\n})\n\n// 处理城市变化\nconst handleCityChange = (value) => {\n  form.value.expected_city = value.join('-')\n}\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newVal) => {\n  console.log('初始数据变化:', newVal)\n  if (newVal) {\n    // 转换旧的状态值到新的状态值\n    const convertOldStatus = (oldStatus) => {\n      const statusMap = {\n        'open': 'unemployed_looking',\n        'closed': 'employed_not_looking'\n      }\n      return statusMap[oldStatus] || oldStatus\n    }\n\n    const formData = {\n      ...form.value,\n      ...newVal,\n      job_status: convertOldStatus(newVal.job_status)  // 转换状态值\n    }\n    \n    form.value = formData\n    console.log('更新后的表单数据:', form.value)\n    \n    // 解析城市数据\n    if (newVal.expected_city) {\n      selectedCities.value = newVal.expected_city.split('-')\n      console.log('解析后的城市数据:', selectedCities.value)\n    } else {\n      selectedCities.value = []\n    }\n    \n    // 解析行业数据\n    if (newVal.industries) {\n      form.value.industries = typeof newVal.industries === 'string'\n        ? newVal.industries.split(',').filter(Boolean)\n        : newVal.industries\n      console.log('解析后的行业数据:', form.value.industries)\n    }\n  }\n}, { immediate: true })\n\n// 表单验证规则\nconst rules = {\n  job_type: [{ required: true, message: '请选择工作类型', trigger: 'change' }],\n  job_status: [{ required: true, message: '请选择求职状态', trigger: 'change' }]\n}\n\n// 对话框可见性\nconst dialogVisible = computed({\n  get: () => props.modelValue,\n  set: (val) => emit('update:modelValue', val)\n})\n\n// 提交表单\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    await formRef.value.validate()\n    console.log('表单验证通过')\n    \n    // 处理行业数据\n    const formData = { ...form.value }\n    \n    // 确保使用新的状态值\n    const statusMap = {\n      'open': 'unemployed_looking',\n      'closed': 'employed_not_looking'\n    }\n    formData.job_status = statusMap[formData.job_status] || formData.job_status\n    \n    if (Array.isArray(formData.industries)) {\n      formData.industries = formData.industries.join(',')\n    }\n    \n    console.log('提交的数据:', formData)\n    emit('submit', formData)\n  } catch (error) {\n    console.error('表单验证失败:', error)\n  }\n}\n\n// 临时定义选项用于测试\nconst LOCAL_JOB_STATUS_OPTIONS = [\n  { value: 'unemployed_looking', label: '离职-找工作' },\n  { value: 'employed_not_looking', label: '在职-暂不考虑' },\n  { value: 'employed_looking', label: '在职-看机会' },\n  { value: 'student_internship', label: '在校-找实习' },\n  { value: 'fresh_graduate', label: '应届生' }\n]\n\n// 计算对话框宽度\nconst dialogWidth = computed(() => {\n  // 这里可以根据需要计算对话框宽度\n  return '640px'\n})\n\n// 处理关闭对话框\nconst handleClose = () => {\n  dialogVisible.value = false\n}\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const option = JOB_TYPE_OPTIONS.find(opt => opt.value === value)\n  return option ? option.label : '请选择工作类型'\n}\n</script>\n\n<style>\n/* 可以移除之前的 select 相关样式 */\n.el-form-item__error {\n  display: none;\n}\n</style> "],"mappings":";;;;AAwKA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,OAAO,EAAEC,aAAa,EAAEC,cAAc,EAAEC,aAAa,QAAQ,iBAAgB;AACtF,SAASC,SAAS,EAAEC,iBAAiB,QAAQ,yBAAwB;AACrE,SAASC,gBAAgB,EAAEC,kBAAkB,EAAEC,cAAc,QAAQ,yBAAwB;AAC7F,SAASC,mBAAmB,QAAQ,8BAA6B;AACjE,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,SAAS,QAAQ,cAAa;;AAEvC;;;;;;;;;;;;;;;;;;IACAC,OAAO,CAACC,GAAG,CAAC,SAAS,EAAEN,kBAAkB;IAEzC,MAAMO,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,OAAO,GAAGrB,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMsB,YAAY,GAAG,CACnB,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAI,EACJ,IAAG,CACL;;IAEA;IACA,MAAMC,cAAc,GAAGvB,GAAG,CAAC,EAAE;;IAE7B;IACA,MAAMwB,IAAI,GAAGxB,GAAG,CAAC;MACfyB,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,eAAe,EAAE,EAAE;MACnBC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE;IACd,CAAC;;IAED;IACA,MAAMC,gBAAgB,GAAIC,KAAK,IAAK;MAClCP,IAAI,CAACO,KAAK,CAACH,aAAa,GAAGG,KAAK,CAACC,IAAI,CAAC,GAAG;IAC3C;;IAEA;IACA9B,KAAK,CAAC,MAAMe,KAAK,CAACgB,WAAW,EAAGC,MAAM,IAAK;