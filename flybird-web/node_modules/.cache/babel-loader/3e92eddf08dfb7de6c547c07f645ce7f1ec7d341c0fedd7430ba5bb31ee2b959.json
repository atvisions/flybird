{"ast":null,"code":"import \"core-js/modules/esnext.iterator.map.js\";\nimport { PlusIcon, PencilIcon, XMarkIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['add', 'remove', 'edit', 'edit-item'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 格式化薪资显示\n    const formatSalary = (min, max) => {\n      if (!min && !max) return '未填写';\n      if (!max) return `${min}K 以上`;\n      if (!min) return `${max}K 以下`;\n      return `${min}K - ${max}K`;\n    };\n\n    // 格式化城市显示\n    const formatCity = city => {\n      if (!city || !city.length) return '未填写';\n      return city.map(c => c.label || c).join(' - ');\n    };\n\n    // 获取到岗时间文本\n    const getAvailabilityText = availability => {\n      const availabilityMap = {\n        immediately: '随时到岗',\n        one_week: '一周内',\n        one_month: '一个月内',\n        three_months: '三个月内',\n        negotiable: '待商议'\n      };\n      return availabilityMap[availability] || '未填写';\n    };\n\n    // 获取工作类型文本\n    const getJobTypeText = jobType => {\n      const jobTypeMap = {\n        full_time: '全职',\n        part_time: '兼职',\n        internship: '实习',\n        freelance: '自由职业'\n      };\n      return jobTypeMap[jobType] || '未填写';\n    };\n\n    // 获取求职状态文本\n    const getJobStatusText = status => {\n      const statusMap = {\n        open: '在找工作',\n        closed: '暂不找工作'\n      };\n      return statusMap[status] || '未填写';\n    };\n    const __returned__ = {\n      formatSalary,\n      formatCity,\n      getAvailabilityText,\n      getJobTypeText,\n      getJobStatusText,\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PlusIcon","PencilIcon","XMarkIcon","formatSalary","min","max","formatCity","city","length","map","c","label","join","getAvailabilityText","availability","availabilityMap","immediately","one_week","one_month","three_months","negotiable","getJobTypeText","jobType","jobTypeMap","full_time","part_time","internship","freelance","getJobStatusText","status","statusMap","open","closed"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n    <div class=\"space-y-3\">\n      <div \n        v-for=\"module in activeModules\" \n        :key=\"module.id\"\n        class=\"bg-white rounded-lg shadow\"\n      >\n        <!-- 模块头部 -->\n        <div class=\"p-4 flex items-center justify-between border-b border-gray-200\">\n          <div class=\"flex items-center\">\n            <component \n              :is=\"module.icon\" \n              class=\"w-5 h-5 text-gray-400 mr-2\"\n            />\n            <h3 class=\"text-lg font-medium text-gray-900\">\n              {{ module.name }}\n            </h3>\n          </div>\n          <div class=\"flex items-center space-x-2\">\n            <button\n              v-if=\"module.multiple\"\n              @click=\"$emit('add', module.id)\"\n              class=\"text-primary-600 hover:text-primary-700\"\n            >\n              <PlusIcon class=\"w-5 h-5\" />\n            </button>\n            <button\n              v-if=\"!module.required\"\n              @click=\"$emit('remove', module.id)\"\n              class=\"text-gray-400 hover:text-gray-500\"\n            >\n              <XMarkIcon class=\"w-5 h-5\" />\n            </button>\n          </div>\n        </div>\n  \n        <!-- 模块内容 -->\n        <div class=\"p-4\">\n          <!-- 求职意向内容 -->\n          <template v-if=\"module.type === 'job_intention'\">\n            <div v-if=\"module.data\" class=\"space-y-3\">\n              <div class=\"flex items-start\">\n                <div class=\"w-24 flex-shrink-0\">\n                  <span class=\"text-sm text-gray-500\">工作类型</span>\n                </div>\n                <div class=\"flex-1\">\n                  <span class=\"text-sm text-gray-900\">{{ getJobTypeText(module.data.job_type) }}</span>\n                </div>\n              </div>\n              <div class=\"flex items-start\">\n                <div class=\"w-24 flex-shrink-0\">\n                  <span class=\"text-sm text-gray-500\">求职状态</span>\n                </div>\n                <div class=\"flex-1\">\n                  <span class=\"text-sm text-gray-900\">{{ getJobStatusText(module.data.job_status) }}</span>\n                </div>\n              </div>\n              <div class=\"flex items-start\">\n                <div class=\"w-24 flex-shrink-0\">\n                  <span class=\"text-sm text-gray-500\">期望薪资</span>\n                </div>\n                <div class=\"flex-1\">\n                  <span class=\"text-sm text-gray-900\">{{ module.data.expected_salary || '未填写' }}</span>\n                </div>\n              </div>\n              <div class=\"flex items-start\">\n                <div class=\"w-24 flex-shrink-0\">\n                  <span class=\"text-sm text-gray-500\">期望城市</span>\n                </div>\n                <div class=\"flex-1\">\n                  <span class=\"text-sm text-gray-900\">{{ module.data.expected_city || '未填写' }}</span>\n                </div>\n              </div>\n              <div class=\"flex items-start\">\n                <div class=\"w-24 flex-shrink-0\">\n                  <span class=\"text-sm text-gray-500\">期望行业</span>\n                </div>\n                <div class=\"flex-1\">\n                  <span class=\"text-sm text-gray-900\">{{ module.data.industries || '未填写' }}</span>\n                </div>\n              </div>\n              <div class=\"flex justify-end\">\n                <button\n                  @click=\"$emit('edit', module.id, module.data)\"\n                  class=\"text-primary-600 hover:text-primary-700\"\n                >\n                  <PencilIcon class=\"w-4 h-4\" />\n                </button>\n              </div>\n            </div>\n            <div v-else class=\"text-center py-4\">\n              <button\n                @click=\"$emit('edit', module.id)\"\n                class=\"text-primary-600 hover:text-primary-700 text-sm font-medium\"\n              >\n                添加{{ module.name }}\n              </button>\n            </div>\n          </template>\n\n          <!-- 其他模块的内容 -->\n          <template v-else>\n            <template v-if=\"module.items && module.items.length\">\n              <div \n                v-for=\"(item, index) in module.items\" \n                :key=\"index\"\n                class=\"flex items-center justify-between py-2\"\n              >\n                <div>\n                  <div class=\"font-medium text-gray-900\">{{ item.title }}</div>\n                  <div class=\"text-sm text-gray-500\">{{ item.subtitle }}</div>\n                </div>\n                <button\n                  @click=\"$emit('edit-item', module.id, item)\"\n                  class=\"text-primary-600 hover:text-primary-700\"\n                >\n                  <PencilIcon class=\"w-4 h-4\" />\n                </button>\n              </div>\n            </template>\n            <div \n              v-else\n              class=\"text-center py-4\"\n            >\n              <button\n                @click=\"$emit('add', module.id)\"\n                class=\"text-primary-600 hover:text-primary-700 text-sm font-medium\"\n              >\n                添加{{ module.name }}\n              </button>\n            </div>\n          </template>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\n  import {\n    PlusIcon,\n    PencilIcon,\n    XMarkIcon\n  } from '@heroicons/vue/24/outline'\n  \n  defineProps({\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  })\n  \n  defineEmits(['add', 'remove', 'edit', 'edit-item'])\n  \n  // 格式化薪资显示\n  const formatSalary = (min, max) => {\n    if (!min && !max) return '未填写'\n    if (!max) return `${min}K 以上`\n    if (!min) return `${max}K 以下`\n    return `${min}K - ${max}K`\n  }\n  \n  // 格式化城市显示\n  const formatCity = (city) => {\n    if (!city || !city.length) return '未填写'\n    return city.map(c => c.label || c).join(' - ')\n  }\n  \n  // 获取到岗时间文本\n  const getAvailabilityText = (availability) => {\n    const availabilityMap = {\n      immediately: '随时到岗',\n      one_week: '一周内',\n      one_month: '一个月内',\n      three_months: '三个月内',\n      negotiable: '待商议'\n    }\n    return availabilityMap[availability] || '未填写'\n  }\n  \n  // 获取工作类型文本\n  const getJobTypeText = (jobType) => {\n    const jobTypeMap = {\n      full_time: '全职',\n      part_time: '兼职',\n      internship: '实习',\n      freelance: '自由职业'\n    }\n    return jobTypeMap[jobType] || '未填写'\n  }\n  \n  // 获取求职状态文本\n  const getJobStatusText = (status) => {\n    const statusMap = {\n      open: '在找工作',\n      closed: '暂不找工作'\n    }\n    return statusMap[status] || '未填写'\n  }\n  </script>"],"mappings":";AA2IE,SACEA,QAAQ,EACRC,UAAU,EACVC,SAAQ,QACH,2BAA0B;;;;;;;;;;;;;;;;;;;IAejC;IACA,MAAMC,YAAY,GAAGA,CAACC,GAAG,EAAEC,GAAG,KAAK;MACjC,IAAI,CAACD,GAAG,IAAI,CAACC,GAAG,EAAE,OAAO,KAAI;MAC7B,IAAI,CAACA,GAAG,EAAE,OAAO,GAAGD,GAAG,MAAK;MAC5B,IAAI,CAACA,GAAG,EAAE,OAAO,GAAGC,GAAG,MAAK;MAC5B,OAAO,GAAGD,GAAG,OAAOC,GAAG,GAAE;IAC3B;;IAEA;IACA,MAAMC,UAAU,GAAIC,IAAI,IAAK;MAC3B,IAAI,CAACA,IAAI,IAAI,CAACA,IAAI,CAACC,MAAM,EAAE,OAAO,KAAI;MACtC,OAAOD,IAAI,CAACE,GAAG,CAACC,CAAC,IAAIA,CAAC,CAACC,KAAK,IAAID,CAAC,CAAC,CAACE,IAAI,CAAC,KAAK;IAC/C;;IAEA;IACA,MAAMC,mBAAmB