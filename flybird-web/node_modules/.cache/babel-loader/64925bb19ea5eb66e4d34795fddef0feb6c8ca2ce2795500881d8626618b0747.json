\", \"onAiOptimize\", \"onImport\", \"onPreview\"]), _createCommentVNode(\" 常规模块列表 \"), _createVNode(_component_ModuleList, {\n    \"active-modules\": _ctx.activeModules,\n    loading: _ctx.loading,\n    onEdit: _ctx.editModule,\n    onAdd: _ctx.addItem,\n    onRemove: _ctx.removeModule,\n    onEditItem: _ctx.editItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onEdit\", \"onAdd\", \"onRemove\", \"onEditItem\"]), _createCommentVNode(\" 添加更多模块 \"), _createVNode(_component_AddModule, {\n    \"inactive-modules\": _ctx.inactiveModules,\n    loading: _ctx.loading,\n    onActivate: _ctx.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"])]), _createCommentVNode(\" 弹窗组件 \"), _createVNode(_component_EditBasicDialog, {\n    modelValue: _ctx.showEditBasicDialog,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => _ctx.showEditBasicDialog = $event),\n    \"initial-data\": _ctx.basicFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleBasicSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"]), _createVNode(_component_EditDialog, {\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => _ctx.showEditModal = $event),\n    module: _ctx.currentModule,\n    \"initial-form-data\": _ctx.editFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleSubmit,\n    onCancel: _ctx.handleCancel\n  }, null, 8 /* PROPS */, [\"modelValue\", \"module\", \"initial-form-data\", \"loading\", \"onSubmit\", \"onCancel\"]), _createVNode(_component_AIDialog, {\n    modelValue: _ctx.showAIModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => _ctx.showAIModal = $event),\n    \"total-score\": _ctx.completionData.total_score,\n    dimensions: _ctx.completionData.dimensions,\n    suggestions: _ctx.completionData.suggestions,\n    \"remaining-optimizations\": _ctx.remainingOptimizations,\n    \"total-optimizations\": _ctx.totalOptimizations,\n    loading: _ctx.loading,\n    onAction: _ctx.handleAIAction\n  }, null, 8 /* PROPS */, [\"modelValue\", \"total-score\", \"dimensions\", \"suggestions\", \"remaining-optimizations\", \"total-optimizations\", \"loading\", \"onAction\"]), _createVNode(_component_CreationDialog, {\n    modelValue: _ctx.showCreationModal,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => _ctx.showCreationModal = $event),\n    \"selected-ids\": _ctx.selectedCreationIds,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleCreationsSelected,\n    onCancel: _ctx.closeCreationModal\n  }, null, 8 /* PROPS */, [\"modelValue\", \"selected-ids\", \"loading\", \"onSubmit\", \"onCancel\"])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createCommentVNode","_createVNode","_component_BasicInfo","resumeData","_ctx","profileData","value","loading","bioExpanded","showBioExpandButton","getBioText","onSave","handleSave","onToggleBioExpand","toggleBioExpand","onEdit","handleEdit","_component_ResumeStatus","completionData","onAiOptimize","showAIOptimize","onImport","importResume","onPreview","previewResume","_component_ModuleList","activeModules","editModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","_component_AddModule","inactiveModules","onActivate","activateModule","_component_EditBasicDialog","modelValue","showEditBasicDialog","_cache","$event","basicFormData","onSubmit","handleBasicSubmit","_component_EditDialog","showEditModal","module","currentModule","editFormData","handleSubmit","onCancel","handleCancel","_component_AIDialog","showAIModal","total_score","dimensions","suggestions","remainingOptimizations","totalOptimizations","onAction","handleAIAction","_component_CreationDialog","showCreationModal","selectedCreationIds","handleCreationsSelected","closeCreationModal"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <!-- 基本信息卡片 -->\n        <BasicInfo\n        :resumeData=\"profileData.resumeData.value || {}\"\n        :loading=\"loading\"\n        :bioExpanded=\"profileData.bioExpanded.value\"\n        :showBioExpandButton=\"profileData.showBioExpandButton.value\"\n        :getBioText=\"getBioText\"\n        @save=\"handleSave\"\n        @toggleBioExpand=\"toggleBioExpand\"\n        @edit=\"handleEdit\"\n      />\n  \n        <!-- 简历状态卡片 -->\n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :loading=\"loading\"\n          @ai-optimize=\"showAIOptimize\"\n          @import=\"importResume\"\n          @preview=\"previewResume\"\n        />\n  \n        <!-- 常规模块列表 -->\n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"editModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n        />\n  \n        <!-- 添加更多模块 -->\n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 弹窗组件 -->\n      <EditBasicDialog\n        v-model=\"showEditBasicDialog\"\n        :initial-data=\"basicFormData\"\n        :loading=\"loading\"\n        @submit=\"handleBasicSubmit\"\n      />\n  \n      <EditDialog\n        v-model=\"showEditModal\"\n        :module=\"currentModule\"\n        :initial-form-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n        @cancel=\"handleCancel\"\n      />\n  \n      <AIDialog\n        v-model=\"showAIModal\"\n        :total-score=\"completionData.total_score\"\n        :dimensions=\"completionData.dimensions\"\n        :suggestions=\"completionData.suggestions\"\n        :remaining-optimizations=\"remainingOptimizations\"\n        :total-optimizations=\"totalOptimizations\"\n        :loading=\"loading\"\n        @action=\"handleAIAction\"\n      />\n  \n      <CreationDialog\n        v-model=\"showCreationModal\"\n        :selected-ids=\"selectedCreationIds\"\n        :loading=\"loading\"\n        @submit=\"handleCreationsSelected\"\n        @cancel=\"closeCreationModal\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted, computed, watch, onBeforeUnmount } from 'vue'\n  import { ElMessage } from 'element-plus'\n  import store from '@/store'\n  import { profile } from '@/api/profile'\n  \n  // 组件导入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditDialog from './dialogs/EditDialog.vue'\n  import AIDialog from './dialogs/AIDialog.vue'\n  import CreationDialog from './dialogs/CreationDialog.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  \n  // Composables\n  import { useProfileData } from './composables/useProfileData'\n  import { useModules } from './composables/useModules'\n  import { useDialog } from './composables/useDialog'\n  import { useLoading } from './composables/useLoading'\n \n  // 初始化 profileData\n  const profileData = useProfileData()\n  const loading = ref(false)\n  const editFormData = ref({})\n  \n  // 添加调试日志\n  console.log('MyProfile profileData:', profileData)\n  \n  // 计算属性：获取处理后的个人简介文本\n  const getBioText = computed(() => {\n    if (!profileData.resumeData.value) return ''\n    return profileData.getBioText()\n  })\n  \n  // 处理保存\n  const handleSave = async (formData) => {\n    console.log('Handling save:', formData)\n    const success = await profileData.updateResumeData(formData)\n    if (success) {\n      await profileData.fetchInitialData()\n    }\n    return success\n  }\n  \n  // 处理展开/收起\n  const toggleBioExpand = () => {\n    console.log('Toggling bio expand')\n    profileData.toggleBioExpand()\n  }\n  \n  const {\n    activeModules,\n    inactiveModules,\n    currentModule,\n    editModule,\n    addItem,\n    removeModule,\n    activateModule\n  } = useModules()\n  \n  const {\n    showEditModal,\n    showAIModal,\n    showCreationModal,\n    aiSuggestions,\n    selectedCreationIds,\n    showAIOptimize,\n    closeCreationModal,\n    handleAIAction\n  } = useDialog()\n  \n  const { loading: actionLoading, withLoading } = useLoading()  // 重命名避免冲突\n  \n  // 基本信息编辑状态\n  const showEditBasicDialog = ref(false)\n  const basicFormData = ref({})\n  \n  // 处理编辑按钮点击\n  const handleEdit = () => {\n    if (!profileData.resumeData.value) return\n    basicFormData.value = {\n      name: profileData.resumeData.value.name || '',\n      gender: profileData.resumeData.value.gender || '',\n      phone: profileData.resumeData.value.phone || '',\n      email: profileData.resumeData.value.email || '',\n      location: profileData.resumeData.value.location || '',\n      birth_date: profileData.resumeData.value.birth_date || '',\n      personal_summary: profileData.resumeData.value.personal_summary || ''\n    }\n    console.log('编辑表单数据:', basicFormData.value)\n    showEditBasicDialog.value = true\n  }\n  \n  // 处理基本信息提交\n  const handleBasicSubmit = async (formData) => {\n    if (!formData) return\n\n    loading.value = true\n    try {\n      await profileData.updateResumeData(formData)\n      showEditBasicDialog.value = false\n      ElMessage.success('保存成功')\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 获取完整度数据\n  const fetchCompleteness = async () => {\n    try {\n      console.log('开始获取完整度数据')\n      const response = await profile.getCompleteness()\n      console.log('完整度接口响应:', response)\n      \n      if (response.data?.data) {\n        console.log('更新前的完整度数据:', completionData.value)\n        completionData.value = response.data.data\n        console.log('更新后的完整度数据:', completionData.value)\n      } else {\n        console.warn('完整度数据格式不正确:', response)\n      }\n    } catch (error) {\n      console.error('获取简历完整度失败:', error)\n    }\n  }\n  \n  // 监听完整度数据变化\n  watch(() => completionData.value, (newVal) => {\n    console.log('完整度数据变化:', newVal)\n  }, { deep: true })\n  \n  // AI优化次数\n  const remainingOptimizations = ref(3) // 默认每月3次\n  const totalOptimizations = ref(3)\n  \n  // 获取优化次数\n  const fetchOptimizationCount = async () => {\n    try {\n      const response = await profile.getOptimizationCount()\n      if (response.data?.data) {\n        remainingOptimizations.value = response.data.data.remaining\n        totalOptimizations.value = response.data.data.total\n      }\n    } catch (error) {\n      console.error('获取优化次数失败:', error)\n    }\n  }\n  \n  // 生命周期钩子\n  onMounted(async () => {\n    console.log('MyProfile mounted')\n    loading.value = true\n    try {\n      // 并行请求所有数据\n      await Promise.all([\n        profileData.fetchInitialData(),\n        fetchCompleteness(),\n        fetchOptimizationCount()\n      ])\n    } catch (error) {\n      console.error('初始化数据失败:', error)\n      ElMessage.error('加载数据失败，请刷新页面重试')\n    } finally {\n      loading.value = false\n    }\n  })\n  \n  // 监听数据变化，当基本信息更新时重新获取完整度\n  watch(() => profileData.resumeData.value, async () => {\n    try {\n      await fetchCompleteness()\n    } catch (error) {\n      console.error('更新完整度失败:', error)\n    }\n  }, { deep: true })\n  \n  // 处理函数\n  const handleSubmit = async (formData) => {\n    try {\n      await withLoading(async () => {\n        await profileData.updateResumeData(formData)\n        showEditModal.value = false\n        ElMessage.success('保存成功')\n      })\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请检查表单')\n    }\n  }\n  \n  const handleCancel = () => {\n    showEditModal.value = false\n  }\n  \n  \n  const importResume = async () => {\n    try {\n      await withLoading(async () => {\n        // TODO: 实现导入功能\n        ElMessage.info('功能开发中')\n      })\n    } catch (error) {\n      console.error('导入失败:', error)\n      ElMessage.error('导入失败，请稍后重试')\n    }\n  }\n  \n  const previewResume = () => {\n    // TODO: 实现预览功能\n    ElMessage.info('功能开发中')\n  }\n  // 处理头像更新\n\n  const handleCreationsSelected = async (selectedIds) => {\n    try {\n      await withLoading(async () => {\n        selectedCreationIds.value = selectedIds\n        closeCreationModal()\n        ElMessage.success('作品选择成功')\n      })\n    } catch (error) {\n      console.error('作品选择失败:', error)\n      ElMessage.error('作品选择失败，请稍后重试')\n    }\n  }\n  \n  const editItem = (moduleId, item) => {\n    editModule(moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n  }\n  \n  // 添加调试日志\n  watch(() => profileData.resumeData.value, (newVal) => {\n    console.log('Profile data changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 添加调试日志\n  watch(() => store.getters.getUserInfo, (newVal) => {\n    console.log('Store user info changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 处理组件卸载\n  onBeforeUnmount(() => {\n    // 清理状态\n    showEditBasicDialog.value = false\n    loading.value = false\n  })\n  \n  // 处理 AI 优化\n  const handleAIAction = async (action) => {\n    if (action === 'optimize') {\n      try {\n        loading.value = true\n        const response = await profile.getOptimizationPreview()\n        if (response.data?.code === 200) {\n          // 显示优化预览弹窗\n          optimizationResult.value = response.data.data\n          showOptimizingDialog.value = true\n        }\n      } catch (error) {\n        console.error('获取优化预览失败:', error)\n        ElMessage.error('获取优化预览失败，请重试')\n      } finally {\n        loading.value = false\n      }\n    }\n  }\n  \n  // 处理优化确认\n  const handleOptimizationConfirm = async (optimizationId) => {\n    try {\n      loading.value = true\n      const response = await profile.confirmOptimization(optimizationId)\n      if (response.data?.code === 200) {\n        ElMessage.success('简历优化成功！')\n        await fetchCompleteness() // 刷新完整度数据\n        showOptimizingDialog.value = false\n      }\n    } catch (error) {\n      console.error('确认优化失败:', error)\n      ElMessage.error('确认优化失败，请重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 处理优化取消\n  const handleOptimizationCancel = () => {\n    showOptimizingDialog.value = false\n  }\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;;;;;;;;;uBAD1CC,mBAAA,CA4EM,OA5ENC,UA4EM,GA3EJC,mBAAA,CAsCM,OAtCNC,UAsCM,GArCJC,mBAAA,YAAe,EACfC,YAAA,CASAC,oBAAA;IARCC,UAAU,EAAEC,IAAA,CAAAC,WAAW,CAACF,UAAU,CAACG,KAAK;IACxCC,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBC,WAAW,EAAEJ,IAAA,CAAAC,WAAW,CAACG,WAAW,CAACF,KAAK;IAC1CG,mBAAmB,EAAEL,IAAA,CAAAC,WAAW,CAACI,mBAAmB,CAACH,KAAK;IAC1DI,UAAU,EAAEN,IAAA,CAAAM,UAAU;IACtBC,MAAI,EAAEP,IAAA,CAAAQ,UAAU;IAChBC,iBAAe,EAAET,IAAA,CAAAU,eAAe;IAChCC,MAAI,EAAEX,IAAA,CAAAY;mJAGPhB,mBAAA,YAAe,EACfC,YAAA,CAMEgB,uBAAA;IALC,iBAAe,EAAEb,IAAA,CAAAc,cAAc;IAC/BX,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBY,YAAW,EAAEf,IAAA,CAAAgB,cAAc;IAC3BC,QAAM,EAAEjB,IAAA,CAAAkB,YAAY;IACpBC,SAAO,EAAEnB,IAAA,CAAAoB;oGAGZxB,mBAAA,YAAe,EACfC,YAAA,CAOEwB,qBAAA;IANC,gBAAc,EAAErB,IAAA,CAAAsB,aAAa;IAC7BnB,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBQ,MAAI,EAAEX,IAAA,CAAAuB,UAAU;IAChBC,KAAG,EAAExB,IAAA,CAAAyB,OAAO;IACZC,QAAM,EAAE1B,IAAA,CAAA2B,YAAY;IACpBC,UAAS,EAAE5B,IAAA,CAAA6B;uGAGdjC,mBAAA,YAAe,EACfC,YAAA,CAIEiC,oBAAA;IAHC,kBAAgB,EAAE9B,IAAA,CAAA+B,eAAe;IACjC5B,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChB6B,UAAQ,EAAEhC,IAAA,CAAAiC;4EAIfrC,mBAAA,UAAa,EACbC,YAAA,CAKEqC,0BAAA;IAjDRC,UAAA,EA6CiBnC,IAAA,CAAAoC,mBAAmB;IA7CpC,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA6CiBtC,IAAA,CAAAoC,mBAAmB,GAAAE,MAAA;IAC3B,cAAY,EAAEtC,IAAA,CAAAuC,aAAa;IAC3BpC,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBqC,QAAM,EAAExC,IAAA,CAAAyC;kFAGX5C,YAAA,CAOE6C,qBAAA;IA1DRP,UAAA,EAoDiBnC,IAAA,CAAA2C,aAAa;IApD9B,uBAAAN,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAoDiBtC,IAAA,CAAA2C,aAAa,GAAAL,MAAA;IACrBM,MAAM,EAAE5C,IAAA,CAAA6C,aAAa;IACrB,mBAAiB,EAAE7C,IAAA,CAAA8C,YAAY;IAC/B3C,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBqC,QAAM,EAAExC,IAAA,CAAA+C,YAAY;IACpBC,QAAM,EAAEhD,IAAA,CAAAiD;6GAGXpD,YAAA,CASEqD,mBAAA;IArERf,UAAA,EA6DiBnC,IAAA,CAAAmD,WAAW;IA7D5B,uBAAAd,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA6DiBtC,IAAA,CAAAmD,WAAW,GAAAb,MAAA;IACnB,aAAW,EAAEtC,IAAA,CAAAc,cAAc,CAACsC,WAAW;IACvCC,UAAU,EAAErD,IAAA,CAAAc,cAAc,CAACuC,UAAU;IACrCC,WAAW,EAAEtD,IAAA,CAAAc,cAAc,CAACwC,WAAW;IACvC,yBAAuB,EAAEtD,IAAA,CAAAuD,sBAAsB;IAC/C,qBAAmB,EAAEvD,IAAA,CAAAwD,kBAAkB;IACvCrD,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBsD,QAAM,EAAEzD,IAAA,CAAA0D;gKAGX7D,YAAA,CAME8D,yBAAA;IA7ERxB,UAAA,EAwEiBnC,IAAA,CAAA4D,iBAAiB;IAxElC,uBAAAvB,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAwEiBtC,IAAA,CAAA4D,iBAAiB,GAAAtB,MAAA;IACzB,cAAY,EAAEtC,IAAA,CAAA6D,mBAAmB;IACjC1D,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBqC,QAAM,EAAExC,IAAA,CAAA8D,uBAAuB;IAC/Bd,QAAM,EAAEhD,IAAA,CAAA+D","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}