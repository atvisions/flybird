{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { profile } from '@/api/profile';\nimport { showToast } from '@/components/ToastMessage';\nexport default {\n  __name: 'BasicInfo',\n  props: {\n    resumeData: {\n      type: Object,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:resumeData'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 保存处理\n    const handleSave = async () => {\n      try {\n        const formData = {\n          name: props.resumeData.name,\n          gender: props.resumeData.gender,\n          phone: props.resumeData.phone,\n          email: props.resumeData.email,\n          location: props.resumeData.location,\n          birth_date: props.resumeData.birth_date,\n          personal_summary: props.resumeData.bio,\n          jobStatus: props.resumeData.jobStatus,\n          expectedSalary: props.resumeData.expectedSalary\n        };\n        emit('save', formData);\n      } catch (error) {\n        console.error('保存失败:', error);\n        showToast('保存失败，请重试', 'error');\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      handleSave,\n      ref,\n      computed,\n      get useStore() {\n        return useStore;\n      },\n      get profile() {\n        return profile;\n      },\n      get showToast() {\n        return showToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","profile","showToast","props","__props","emit","__emit","handleSave","formData","name","resumeData","gender","phone","email","location","birth_date","personal_summary","bio","jobStatus","expectedSalary","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n  <div class=\"bg-white shadow sm:rounded-lg\">\n    <div class=\"px-4 py-5 sm:p-6\">\n      <!-- 头像上传部分保持不变 -->\n      \n      <!-- 基本信息表单 -->\n      <div class=\"mt-6 grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2\">\n        <!-- 姓名 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">姓名</label>\n          <input \n            type=\"text\"\n            v-model=\"resumeData.name\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入姓名\"\n          />\n        </div>\n\n        <!-- 性别 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">性别</label>\n          <select\n            v-model=\"resumeData.gender\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n          >\n            <option value=\"\">请选择性别</option>\n            <option value=\"male\">男</option>\n            <option value=\"female\">女</option>\n            <option value=\"other\">其他</option>\n          </select>\n        </div>\n\n        <!-- 手机号 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">手机号</label>\n          <input \n            type=\"tel\"\n            v-model=\"resumeData.phone\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入手机号\"\n          />\n        </div>\n\n        <!-- 邮箱 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">邮箱</label>\n          <input \n            type=\"email\"\n            v-model=\"resumeData.email\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入邮箱\"\n          />\n        </div>\n\n        <!-- 所在地 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">所在地</label>\n          <input \n            type=\"text\"\n            v-model=\"resumeData.location\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入所在地\"\n          />\n        </div>\n\n        <!-- 生日 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">生日</label>\n          <input \n            type=\"date\"\n            v-model=\"resumeData.birth_date\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n          />\n        </div>\n\n        <!-- 求职状态 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">求职状态</label>\n          <select\n            v-model=\"resumeData.jobStatus\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n          >\n            <option value=\"\">请选择求职状态</option>\n            <option value=\"looking\">正在找工作</option>\n            <option value=\"considering\">考虑机会</option>\n            <option value=\"employed\">已就业</option>\n          </select>\n        </div>\n\n        <!-- 期望薪资 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">期望薪资</label>\n          <input \n            type=\"text\"\n            v-model=\"resumeData.expectedSalary\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入期望薪资\"\n          />\n        </div>\n      </div>\n\n      <!-- 个人简介 -->\n      <div class=\"mt-6\">\n        <label class=\"block text-sm font-medium text-gray-700\">个人简介</label>\n        <textarea\n          v-model=\"resumeData.bio\"\n          rows=\"4\"\n          class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n          placeholder=\"请输入个人简介\"\n        ></textarea>\n      </div>\n\n      <!-- 保存按钮 -->\n      <div class=\"mt-6 flex justify-end\">\n        <button\n          type=\"button\"\n          @click=\"handleSave\"\n          :disabled=\"loading\"\n          class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50\"\n        >\n          <span v-if=\"loading\">保存中...</span>\n          <span v-else>保存</span>\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { profile } from '@/api/profile'\nimport { showToast } from '@/components/ToastMessage'\n\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:resumeData'])\n\n// 保存处理\nconst handleSave = async () => {\n  try {\n    const formData = {\n      name: props.resumeData.name,\n      gender: props.resumeData.gender,\n      phone: props.resumeData.phone,\n      email: props.resumeData.email,\n      location: props.resumeData.location,\n      birth_date: props.resumeData.birth_date,\n      personal_summary: props.resumeData.bio,\n      jobStatus: props.resumeData.jobStatus,\n      expectedSalary: props.resumeData.expectedSalary\n    }\n\n    emit('save', formData)\n  } catch (error) {\n    console.error('保存失败:', error)\n    showToast('保存失败，请重试', 'error')\n  }\n}\n</script>"],"mappings":"AAkIA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,QAAQ,QAAQ,M