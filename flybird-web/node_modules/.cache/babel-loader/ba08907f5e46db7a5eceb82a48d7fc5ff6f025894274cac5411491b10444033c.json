{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, ArrowTopRightOnSquareIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'SocialLinkContent',\n  props: {\n    data: {\n      type: Array,\n      required: true\n    },\n    error: {\n      type: String,\n      default: ''\n    }\n  },\n  emits: ['edit', 'delete', 'add', 'retry'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const emit = __emit;\n\n    // 添加处理函数\n    const handleAdd = () => {\n      emit('add', {\n        platform: '',\n        url: '',\n        description: ''\n      });\n    };\n    const __returned__ = {\n      emit,\n      handleAdd,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get ArrowTopRightOnSquareIcon() {\n        return ArrowTopRightOnSquareIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","ArrowTopRightOnSquareIcon","emit","__emit","handleAdd","platform","url","description"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/SocialLinkContent.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-4\">\n    <!-- 添加错误状态显示 -->\n    <div v-if=\"error\" class=\"bg-red-50 border border-red-100 rounded-lg p-4 mb-4\">\n      <p class=\"text-red-600 text-sm\">{{ error }}</p>\n      <button \n        @click=\"$emit('retry')\" \n        class=\"mt-2 text-sm text-red-600 hover:text-red-800\"\n      >\n        重试\n      </button>\n    </div>\n\n    <!-- 社交主页列表 -->\n    <div v-else class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n      <div \n        v-for=\"(social, index) in data\" \n        :key=\"index\" \n       