{"ast":null,"code":"import { toDisplayString as _toDisplayString, openBlock as _openBlock, createElementBlock as _createElementBlock, createCommentVNode as _createCommentVNode, createVNode as _createVNode, createBlock as _createBlock, createElementVNode as _createElementVNode } from \"vue\";\nconst _hoisted_1 = {\n  class: \"container mx-auto\"\n};\nconst _hoisted_2 = {\n  class: \"max-w-4xl mx-auto space-y-4\"\n};\nconst _hoisted_3 = {\n  key: 0,\n  class: \"text-xs text-gray-400\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createElementVNode(\"div\", _hoisted_2, [_ctx.process.env.NODE_ENV === 'development' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_3, \" Completion Score: \" + _toDisplayString($setup.completionData.total_score), 1 /* TEXT */)) : _createCommentVNode(\"v-if\", true), _createVNode($setup[\"BasicInfo\"], {\n    resumeData: $setup.basicInfo,\n    loading: $setup.loading,\n    bioExpanded: $setup.bioExpanded,\n    showBioExpandButton: $setup.showBioExpandButton,\n    onEdit: $setup.handleEdit,\n    onToggleBioExpand: _ctx.toggleBioExpand\n  }, null, 8 /* PROPS */, [\"resumeData\", \"loading\", \"bioExpanded\", \"showBioExpandButton\", \"onToggleBioExpand\"]), _createVNode($setup[\"ResumeStatus\"], {\n    \"completion-data\": $setup.completionData,\n    \"profile-data\": $setup.profileData,\n    loading: $setup.loading\n  }, null, 8 /* PROPS */, [\"completion-data\", \"profile-data\", \"loading\"]), _createVNode($setup[\"ModuleList\"], {\n    \"active-modules\": $setup.activeModules,\n    loading: $setup.loading,\n    onEdit: $setup.handleEditModule,\n    onAdd: $setup.addItem,\n    onRemove: $setup.removeModule,\n    onEditItem: $setup.editItem,\n    onRemoveItem: $setup.removeItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onAdd\", \"onRemove\"]), _createVNode($setup[\"AddModule\"], {\n    \"inactive-modules\": $setup.inactiveModules,\n    loading: $setup.loading,\n    onActivate: $setup.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"]), _createCommentVNode(\" 工作经历编辑弹窗 \"), $setup.currentModule?.type === 'work_experience' ? (_openBlock(), _createBlock($setup[\"EditWorkExperienceDialog\"], {\n    key: 1,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), $setup.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock($setup[\"EditJobIntentionDialog\"], {\n    key: 2,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), $setup.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock($setup[\"EditBasicDialog\"], {\n    key: 3,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true)])]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_ctx","process","env","NODE_ENV","_hoisted_3","_toDisplayString","$setup","completionData","total_score","_createCommentVNode","_createVNode","resumeData","basicInfo","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onToggleBioExpand","toggleBioExpand","profileData","activeModules","handleEditModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","onRemoveItem","removeItem","inactiveModules","onActivate","activateModule","currentModule","type","_createBlock","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <div v-if=\"process.env.NODE_ENV === 'development'\" class=\"text-xs text-gray-400\">\n        Completion Score: {{ completionData.total_score }}\n      </div>\n\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"loading\"\n      />\n\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :loading=\"loading\"\n        @edit=\"handleEditModule\"\n        @add=\"addItem\"\n        @remove=\"removeModule\"\n        @edit-item=\"editItem\"\n        @remove-item=\"removeItem\"\n      />\n\n      <AddModule\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"loading\"\n        @activate=\"activateModule\"\n      />\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch } from 'vue'\nimport { useModules } from './composables/useModules'\nimport { profile } from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\n\n// 状态管理\nconst { \n  activeModules, \n  currentModule, \n  inactiveModules, \n  addItem, \n  removeModule, \n  activateModule \n} = useModules()\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\nconst loading = ref(false)\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 基本信息数据\nconst basicInfo = ref({})\n\n// 档案数据\nconst profileData = ref({\n  basic_info: {\n    name: '',\n    name_en: '',\n    personal_summary: '',\n    personal_summary_en: '',\n    gender: '',\n    phone: '',\n    email: '',\n    location: '',\n    birth_date: ''\n  },\n  job_intention: {\n    job_type: '',\n    job_status: '',\n    expected_salary: '',\n    expected_city: '',\n    industries: ''\n  },\n  work_experiences: [],\n  educations: [],\n  skills: []\n})\n\n// 完整度数据\nconst completionData = ref({\n  total_score: 0,\n  dimensions: {},\n  suggestions: []\n})\n\n// 获取档案数据\nconst fetchProfileData = async () => {\n  try {\n    loading.value = true\n    \n    // 获取完整度评分\n    const completenessResponse = await profile.getCompleteness()\n    console.log('Completeness API response:', completenessResponse.data)\n    \n    if (completenessResponse.data?.code === 200) {\n      const data = completenessResponse.data.data\n      console.log('Setting completionData:', data)\n      \n      completionData.value = {\n        total_score: data.total_score || 0,\n        dimensions: data.dimensions || {},\n        suggestions: data.suggestions || []\n      }\n    }\n\n    const response = await profile.getComplete()\n    if (response.data?.code === 200) {\n      const data = response.data.data\n      \n      // 更新档案数据\n      profileData.value = {\n        basic_info: data.basic_info || profileData.value.basic_info,\n        job_intention: data.job_intention || profileData.value.job_intention,\n        work_experiences: data.work_experiences || [],\n        educations: data.educations || [],\n        skills: data.skills || []\n      }\n\n      // 更新基本信息\n      basicInfo.value = data.basic_info || {}\n\n      // 更新活动模块数据\n      const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n      if (jobIntentionModule) {\n        jobIntentionModule.data = data.job_intention || {}\n      }\n\n      const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n      if (workExperienceModule) {\n        workExperienceModule.data = data.work_experiences || []\n      }\n    }\n  } catch (error) {\n    console.error('获取数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 监听完整度数据变化\nwatch(() => completionData.value, (newVal) => {\n  console.log('completionData updated:', newVal)\n}, { deep: true })\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchProfileData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    loading.value = true\n    \n    if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.updateWorkExperience(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.addWorkExperience(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.updateJobIntention(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchProfileData()\n      }\n    } else if (currentModule.value?.type === 'basic_info') {\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchProfileData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\nonMounted(() => {\n  fetchProfileData()\n})\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;EAH5CC,GAAA;EAIyDD,KAAK,EAAC;;;uBAF7DE,mBAAA,CAgEM,OAhENC,UAgEM,GA/DJC,mBAAA,CA8DM,OA9DNC,UA8DM,GA7DOC,IAAA,CAAAC,OAAO,CAACC,GAAG,CAACC,QAAQ,sB,cAA/BP,mBAAA,CAEM,OAFNQ,UAEM,EAF2E,qBAC7D,GAAAC,gBAAA,CAAGC,MAAA,CAAAC,cAAc,CAACC,WAAW,oBALvDC,mBAAA,gBAQMC,YAAA,CAOEJ,MAAA;IANCK,UAAU,EAAEL,MAAA,CAAAM,SAAS;IACrBC,OAAO,EAAEP,MAAA,CAAAO,OAAO;IAChBC,WAAW,EAAER,MAAA,CAAAQ,WAAW;IACxBC,mBAAmB,EAAET,MAAA,CAAAS,mBAAmB;IACxCC,MAAI,EAAEV,MAAA,CAAAW,UAAU;IAChBC,iBAAe,EAAElB,IAAA,CAAAmB;iHAGpBT,YAAA,CAIEJ,MAAA;IAHC,iBAAe,EAAEA,MAAA,CAAAC,cAAc;IAC/B,cAAY,EAAED,MAAA,CAAAc,WAAW;IACzBP,OAAO,EAAEP,MAAA,CAAAO;2EAGZH,YAAA,CAQEJ,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAAe,aAAa;IAC7BR,OAAO,EAAEP,MAAA,CAAAO,OAAO;IAChBG,MAAI,EAAEV,MAAA,CAAAgB,gBAAgB;IACtBC,KAAG,EAAEjB,MAAA,CAAAkB,OAAO;IACZC,QAAM,EAAEnB,MAAA,CAAAoB,YAAY;IACpBC,UAAS,EAAErB,MAAA,CAAAsB,QAAQ;IACnBC,YAAW,EAAEvB,MAAA,CAAAwB;+EAGhBpB,YAAA,CAIEJ,MAAA;IAHC,kBAAgB,EAAEA,MAAA,CAAAyB,eAAe;IACjClB,OAAO,EAAEP,MAAA,CAAAO,OAAO;IAChBmB,UAAQ,EAAE1B,MAAA,CAAA2B;0EAGbxB,mBAAA,cAAiB,EAETH,MAAA,CAAA4B,aAAa,EAAEC,IAAI,0B,cAD3BC,YAAA,CAME9B,MAAA;IA9CRX,GAAA;IAAA0C,UAAA,EA0CiB/B,MAAA,CAAAgC,aAAa;IA1C9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA0CiBlC,MAAA,CAAAgC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAAmC,YAAY;IAC1B5B,OAAO,EAAEP,MAAA,CAAAO,OAAO;IAChB6B,QAAM,EAAEpC,MAAA,CAAAqC;wEA7CjBlC,mBAAA,gBAgDMA,mBAAA,cAAiB,EAETH,MAAA,CAAA4B,aAAa,EAAEC,IAAI,wB,cAD3BC,YAAA,CAME9B,MAAA;IAvDRX,GAAA;IAAA0C,UAAA,EAmDiB/B,MAAA,CAAAgC,aAAa;IAnD9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAmDiBlC,MAAA,CAAAgC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAAmC,YAAY;IAC1B5B,OAAO,EAAEP,MAAA,CAAAO,OAAO;IAChB6B,QAAM,EAAEpC,MAAA,CAAAqC;wEAtDjBlC,mBAAA,gBAyDMA,mBAAA,cAAiB,EAETH,MAAA,CAAA4B,aAAa,EAAEC,IAAI,qB,cAD3BC,YAAA,CAME9B,MAAA;IAhERX,GAAA;IAAA0C,UAAA,EA4DiB/B,MAAA,CAAAgC,aAAa;IA5D9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA4DiBlC,MAAA,CAAAgC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAAmC,YAAY;IAC1B5B,OAAO,EAAEP,MAAA,CAAAO,OAAO;IAChB6B,QAAM,EAAEpC,MAAA,CAAAqC;wEA/DjBlC,mBAAA,e","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}