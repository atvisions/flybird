{"ast":null,"code":"import { PlusIcon, PencilIcon, XMarkIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['add', 'remove', 'edit-item'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const __returned__ = {\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PlusIcon","PencilIcon","XMarkIcon"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n    <div class=\"space-y-3\">\n      <div \n        v-for=\"module in activeModules\" \n        :key=\"module.id\"\n        class=\"bg-white rounded-lg shadow\"\n      >\n        <!-- 模块头部 -->\n        <div class=\"p-4 flex items-center justify-between border-b border-gray-200\">\n          <div class=\"flex items-center\">\n            <component \n              :is=\"module.icon\" \n              class=\"w-5 h-5 text-gray-400 mr-2\"\n            />\n            <h3 class=\"text-lg font-medium text-gray-900\">\n              {{ module.name }}\n            </h3>\n          </div>\n          <div class=\"flex items-center space-x-2\">\n            <button\n              v-if=\"module.multiple\"\n              @click=\"$emit('add', module.id)\"\n              class=\"text-primary-600 hover:text-primary-700\"\n            >\n              <PlusIcon class=\"w-5 h-5\" />\n            </button>\n            <button\n              v-if=\"!module.required\"\n              @click=\"$emit('remove', module.id)\"\n              class=\"text-gray-400 hover:text-gray-500\"\n            >\n              <XMarkIcon class=\"w-5 h-5\" />\n            </button>\n          </div>\n        </div>\n  \n        <!-- 模块内容 -->\n        <div class=\"p-4\">\n          <template v-if=\"module.items && module.items.length\">\n            <div \n              v-for=\"(item, index) in module.items\" \n              :key=\"index\"\n              class=\"flex items-center justify-between py-2\"\n            >\n              <div>\n                <div class=\"font-medium text-gray-900\">{{ item.title }}</div>\n                <div class=\"text-sm text-gray-500\">{{ item.subtitle }}</div>\n              </div>\n              <button\n                @click=\"$emit('edit-item', module.id, item)\"\n                class=\"text-primary-600 hover:text-primary-700\"\n              >\n                <PencilIcon class=\"w-4 h-4\" />\n              </button>\n            </div>\n          </template>\n          <div \n            v-else\n            class=\"text-center py-4\"\n          >\n            <button\n              @click=\"$emit('add', module.id)\"\n              class=\"text-primary-600 hover:text-primary-700 text-sm font-medium\"\n            >\n              添加{{ module.name }}\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\n  import {\n    PlusIcon,\n    PencilIcon,\n    XMarkIcon\n  } from '@heroicons/vue/24/outline'\n  \n  defineProps({\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  })\n  \n  defineEmits(['add', 'remove', 'edit-item'])\n  </script>"],"mappings":"AA0EE,SACEA,QAAQ,EACRC,UAAU,EACVC,SAAQ,QACH,2BAA0B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}