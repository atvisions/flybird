");\n  return _openBlock(), _createBlock(_component_el_dialog, {\n    modelValue: $setup.dialogVisible,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.dialogVisible = $event),\n    width: $setup.dialogWidth,\n    fullscreen: $setup.isMobile,\n    \"close-on-click-modal\": false,\n    \"show-close\": false,\n    class: \"optimize-dialog\",\n    \"destroy-on-close\": \"\"\n  }, {\n    default: _withCtx(() => [_createElementVNode(\"div\", _hoisted_1, [_createCommentVNode(\" 头部 \"), _createElementVNode(\"div\", _hoisted_2, [_createElementVNode(\"div\", _hoisted_3, [_createElementVNode(\"div\", _hoisted_4, [_cache[3] || (_cache[3] = _createElementVNode(\"h3\", {\n      class: \"text-lg font-medium text-gray-900\"\n    }, \"AI 优化\", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_5, [_cache[1] || (_cache[1] = _createElementVNode(\"span\", null, \"已完成\", -1 /* HOISTED */)), _createElementVNode(\"span\", _hoisted_6, _toDisplayString($setup.completedCount), 1 /* TEXT */), _cache[2] || (_cache[2] = _createElementVNode(\"span\", null, \"/\", -1 /* HOISTED */)), _createElementVNode(\"span\", null, _toDisplayString($setup.totalFields), 1 /* TEXT */)])]), _createElementVNode(\"button\", {\n      onClick: $setup.handleClose,\n      class: \"text-gray-400 hover:text-gray-500\"\n    }, [_createVNode($setup[\"XMarkIcon\"], {\n      class: \"h-6 w-6\"\n    })])])]), _createCommentVNode(\" 内容区域 \"), _createElementVNode(\"div\", _hoisted_7, [_createElementVNode(\"div\", _hoisted_8, [_createElementVNode(\"table\", _hoisted_9, [_cache[5] || (_cache[5] = _createElementVNode(\"thead\", {\n      class: \"text-xs text-gray-700 uppercase bg-gray-50 sticky top-0 z-10\"\n    }, [_createElementVNode(\"tr\", null, [_createElementVNode(\"th\", {\n      class: \"px-4 py-3 w-40\"\n    }, \"字段名称\"), _createElementVNode(\"th\", {\n      class: \"px-4 py-3\"\n    }, \"当前内容\"), _createElementVNode(\"th\", {\n      class: \"px-4 py-3\"\n    }, \"AI 优化建议\"), _createElementVNode(\"th\", {\n      class: \"px-4 py-3 w-20 text-center\"\n    }, \"状态\")])], -1 /* HOISTED */)), _createElementVNode(\"tbody\", null, [_createVNode(_TransitionGroup, {\n      name: \"list\",\n      tag: \"template\"\n    }, {\n      default: _withCtx(() => [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.displayFields, field => {\n        return _openBlock(), _createElementBlock(\"tr\", {\n          key: field.name,\n          class: _normalizeClass([\"bg-white border-b hover:bg-gray-50\", {\n            'opacity-50': field.status === 'processing'\n          }])\n        }, [_createElementVNode(\"td\", _hoisted_10, _toDisplayString(field.label), 1 /* TEXT */), _createElementVNode(\"td\", _hoisted_11, [_createElementVNode(\"div\", _hoisted_12, _toDisplayString(field.currentValue || '未填写'), 1 /* TEXT */)]), _createElementVNode(\"td\", _hoisted_13, [_createElementVNode(\"div\", {\n          class: _normalizeClass([\"max-h-20 overflow-y-auto\", {\n            'text-gray-400': !field.optimizedValue,\n            'text-gray-900': field.optimizedValue\n          }])\n        }, [field.status === 'processing' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_14, [...(_cache[4] || (_cache[4] = [_createElementVNode(\"div\", {\n          class: \"animate-pulse\"\n        }, [_createElementVNode(\"div\", {\n          class: \"h-2 bg-gray-200 rounded w-full\"\n        }), _createElementVNode(\"div\", {\n          class: \"h-2 bg-gray-200 rounded w-3/4 mt-2\"\n        })], -1 /* HOISTED */)]))])) : (_openBlock(), _createElementBlock(_Fragment, {\n          key: 1\n        }, [_createTextVNode(_toDisplayString(field.optimizedValue || '等待优化...'), 1 /* TEXT */)], 64 /* STABLE_FRAGMENT */))], 2 /* CLASS */)]), _createElementVNode(\"td\", _hoisted_15, [field.status === 'success' ? (_openBlock(), _createBlock($setup[\"CheckCircleIcon\"], {\n          key: 0,\n          class: \"w-5 h-5 text-green-500 mx-auto\"\n        })) : field.status === 'failed' ? (_openBlock(), _createBlock($setup[\"XCircleIcon\"], {\n          key: 1,\n          class: \"w-5 h-5 text-red-500 mx-auto\"\n        })) : field.status === 'processing' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_16)) : (_openBlock(), _createBlock($setup[\"MinusCircleIcon\"], {\n          key: 3,\n          class: \"w-5 h-5 text-gray-300 mx-auto\"\n        }))])], 2 /* CLASS */);\n      }), 128 /* KEYED_FRAGMENT */))]),\n      _: 1 /* STABLE */\n    })])])])]), _createCommentVNode(\" 底部 \"), _createElementVNode(\"div\", _hoisted_17, [_createElementVNode(\"div\", _hoisted_18, [_cache[6] || (_cache[6] = _createElementVNode(\"div\", {\n      class: \"text-sm text-gray-500\"\n    }, \" 优化完成后，您可以选择应用建议的内容 \", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_19, [_createElementVNode(\"button\", {\n      onClick: $setup.handleClose,\n      class: \"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n    }, \" 取消 \"), _createElementVNode(\"button\", {\n      onClick: $setup.handleApply,\n      disabled: !$setup.hasOptimized,\n      class: \"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed\"\n    }, \" 应用优化 \", 8 /* PROPS */, _hoisted_20)])])])])]),\n    _: 1 /* STABLE */\n  }, 8 /* PROPS */, [\"modelValue\", \"width\", \"fullscreen\"]);\n}","map":{"version":3,"names":["class","key","_createBlock","_component_el_dialog","modelValue","$setup","dialogVisible","_cache","$event","width","dialogWidth","fullscreen","isMobile","default","_withCtx","_createElementVNode","_hoisted_1","_createCommentVNode","_hoisted_2","_hoisted_3","_hoisted_4","_hoisted_5","_hoisted_6","_toDisplayString","completedCount","totalFields","onClick","handleClose","_createVNode","_hoisted_7","_hoisted_8","_hoisted_9","_TransitionGroup","name","tag","_createElementBlock","_Fragment","_renderList","displayFields","field","_normalizeClass","status","_hoisted_10","label","_hoisted_11","_hoisted_12","currentValue","_hoisted_13","optimizedValue","_hoisted_14","_createTextVNode","_hoisted_15","_hoisted_16","_","_hoisted_17","_hoisted_18","_hoisted_19","handleApply","disabled","hasOptimized","_hoisted_20"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/AIOptimizeDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    v-model=\"dialogVisible\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    class=\"optimize-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- 头部 -->\n      <div class=\"dialog-header\">\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-3\">\n            <h3 class=\"text-lg font-medium text-gray-900\">AI 优化</h3>\n            <div class=\"flex items-center space-x-1 text-sm text-gray-500\">\n              <span>已完成</span>\n              <span class=\"font-medium text-blue-600\">{{ completedCount }}</span>\n              <span>/</span>\n              <span>{{ totalFields }}</span>\n            </div>\n          </div>\n          <button\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- 内容区域 -->\n      <div class=\"dialog-body\">\n        <div class=\"relative overflow-x-auto\">\n          <table class=\"w-full text-sm text-left\">\n            <thead class=\"text-xs text-gray-700 uppercase bg-gray-50 sticky top-0 z-10\">\n              <tr>\n                <th class=\"px-4 py-3 w-40\">字段名称</th>\n                <th class=\"px-4 py-3\">当前内容</th>\n                <th class=\"px-4 py-3\">AI 优化建议</th>\n                <th class=\"px-4 py-3 w-20 text-center\">状态</th>\n              </tr>\n            </thead>\n            <tbody>\n              <TransitionGroup \n                name=\"list\"\n                tag=\"template\"\n              >\n                <tr \n                  v-for=\"field in displayFields\" \n                  :key=\"field.name\"\n                  class=\"bg-white border-b hover:bg-gray-50\"\n                  :class=\"{'opacity-50': field.status === 'processing'}\"\n                >\n                  <td class=\"px-4 py-3 font-medium text-gray-900\">\n                    {{ field.label }}\n                  </td>\n                  <td class=\"px-4 py-3 text-gray-600\">\n                    <div class=\"max-h-20 overflow-y-auto\">\n                      {{ field.currentValue || '未填写' }}\n                    </div>\n                  </td>\n                  <td class=\"px-4 py-3\">\n                    <div \n                      class=\"max-h-20 overflow-y-auto\"\n                      :class=\"{\n                        'text-gray-400': !field.optimizedValue,\n                        'text-gray-900': field.optimizedValue\n                      }\"\n                    >\n                      <template v-if=\"field.status === 'processing'\">\n                        <div class=\"flex items-center space-x-2\">\n                          <div class=\"animate-pulse\">\n                            <div class=\"h-2 bg-gray-200 rounded w-full\"></div>\n                            <div class=\"h-2 bg-gray-200 rounded w-3/4 mt-2\"></div>\n                          </div>\n                        </div>\n                      </template>\n                      <template v-else>\n                        {{ field.optimizedValue || '等待优化...' }}\n                      </template>\n                    </div>\n                  </td>\n                  <td class=\"px-4 py-3 text-center\">\n                    <template v-if=\"field.status === 'success'\">\n                      <CheckCircleIcon class=\"w-5 h-5 text-green-500 mx-auto\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'failed'\">\n                      <XCircleIcon class=\"w-5 h-5 text-red-500 mx-auto\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'processing'\">\n                      <div class=\"animate-spin rounded-full h-5 w-5 border-2 border-gray-300 border-t-blue-600 mx-auto\"></div>\n                    </template>\n                    <template v-else>\n                      <MinusCircleIcon class=\"w-5 h-5 text-gray-300 mx-auto\" />\n                    </template>\n                  </td>\n                </tr>\n              </TransitionGroup>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <!-- 底部 -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-between items-center\">\n          <div class=\"text-sm text-gray-500\">\n            优化完成后，您可以选择应用建议的内容\n          </div>\n          <div class=\"flex space-x-3\">\n            <button\n              @click=\"handleClose\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n            >\n              取消\n            </button>\n            <button\n              @click=\"handleApply\"\n              :disabled=\"!hasOptimized\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              应用优化\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { \n  XMarkIcon, \n  CheckCircleIcon, \n  XCircleIcon,\n  MinusCircleIcon\n} from '@heroicons/vue/24/solid'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  profileData: {\n    type: Object,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'apply'])\n\n// 字段配置\nconst fieldConfig = [\n  // 基本信息\n  { name: 'basic_info.name', label: '姓名（中文）', group: '基本信息' },\n  { name: 'basic_info.name_en', label: '姓名（英文）', group: '基本信息' },\n  { name: 'basic_info.personal_summary', label: '个人简介（中文）', group: '基本信息' },\n  { name: 'basic_info.personal_summary_en', label: '个人简介（英文）', group: '基本信息' },\n  \n  // 求职意向\n  { name: 'job_intention.job_type', label: '工作类型', group: '求职意向' },\n  { name: 'job_intention.job_status', label: '求职状态', group: '求职意向' },\n  { name: 'job_intention.expected_salary', label: '期望薪资', group: '求职意向' },\n  { name: 'job_intention.expected_city', label: '期望城市', group: '求职意向' },\n  { name: 'job_intention.industries', label: '期望行业', group: '求职意向' },\n\n  // 工作经历（对每个工作经历的字段进行优化）\n  { name: 'work_experiences', label: '工作经历', group: '工作经历', isArray: true, fields: [\n    { name: 'company', label: '公司名称' },\n    { name: 'position', label: '职位名称' },\n    { name: 'department', label: '所在部门' },\n    { name: 'description', label: '工作描述' },\n    { name: 'achievements', label: '工作成就' },\n    { name: 'technologies', label: '技术栈' }\n  ]},\n\n  // 教育经历\n  { name: 'educations', label: '教育经历', group: '教育经历', isArray: true, fields: [\n    { name: 'school', label: '学校名称' },\n    { name: 'major', label: '专业' },\n    { name: 'degree', label: '学位' }\n  ]},\n\n  // 技能特长\n  { name: 'skills', label: '技能特长', group: '技能特长', isArray: true }\n]\n\n// 模拟 AI 优化结果\nconst mockOptimize = async (field, value) => {\n  if (!value) return null\n\n  const optimizations = {\n    // 基本信息优化\n    name_en: value => value.toLowerCase().replace(/\\b\\w/g, l => l.toUpperCase()),\n    personal_summary: value => `我是一名经验丰富的${value.includes('开发') ? '开发工程师' : '专业人士'}，${value}`,\n    personal_summary_en: value => `I am an experienced ${value.includes('developer') ? 'developer' : 'professional'} ${value}`,\n\n    // 求职意向优化\n    expected_salary: value => value.includes('面议') ? '根据经验和能力，期望薪资15k-25k' : value,\n    industries: value => value.split(',').map(i => i.trim()).join('、'),\n\n    // 工作经历优化\n    description: value => value.replace(/^我/, '').replace(/。$/, '，工作中注重团队协作和技术创新。'),\n    achievements: value => value ? `${value}，为团队和公司创造了显著价值。` : '通过技术创新和流程优化，提升了团队工作效率，获得领导和同事的一致好评。',\n    technologies: value => value ? value.split(',').sort().join(', ') : '',\n\n    // 技能特长优化\n    skills: value => Array.isArray(value) ? \n      value.map(skill => skill.replace(/^熟悉/, '精通')).join(', ') : \n      value.split(',').map(skill => skill.trim()).join(', ')\n  }\n\n  // 模拟 API 延迟\n  await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 2000))\n\n  // 根据字段名返回优化结果\n  return optimizations[field.name] ? \n    optimizations[field.name](value) : \n    `${value}（已优化）`\n}\n\n// 处理字段数据\nconst processFields = () => {\n  const result = []\n  \n  // 确保 profileData 存在且有效\n  if (!props.profileData) {\n    console.warn('profileData is undefined')\n    return result\n  }\n\n  fieldConfig.forEach(field => {\n    if (field.isArray) {\n      // 处理数组类型的字段（如工作经历、教育经历）\n      const items = props.profileData[field.name] || []\n      items.forEach((item, index) => {\n        if (field.fields) {\n          // 如果有子字段（如工作经历的详细信息）\n          field.fields.forEach(subField => {\n            result.push({\n              ...subField,\n              label: `${field.label} ${index + 1} - ${subField.label}`,\n              currentValue: item?.[subField.name] || '',  // 添加可选链操作符\n              group: field.group,\n              optimizedValue: '',\n              status: 'pending'\n            })\n          })\n        } else {\n          // 如果是简单数组（如技能特长）\n          result.push({\n            ...field,\n            currentValue: item || '',\n            optimizedValue: '',\n            status: 'pending'\n          })\n        }\n      })\n    } else {\n      // 处理普通字段，从嵌套对象中获取值\n      let currentValue = ''\n      if (field.name.includes('_')) {\n        // 处理嵌套字段，如 basic_info.name\n        const [category, key] = field.name.split('_')\n        currentValue = props.profileData[category]?.[key] || ''\n      } else {\n        currentValue = props.profileData[field.name] || ''\n      }\n\n      result.push({\n        ...field,\n        currentValue,\n        optimizedValue: '',\n        status: 'pending'\n      })\n    }\n  })\n\n  return result\n}\n\nconst fields = ref(processFields())\n\n// 计算属性\nconst displayFields = computed(() => {\n  return fields.value.sort((a, b) => {\n    if (a.status === 'pending' && b.status !== 'pending') return 1\n    if (a.status !== 'pending' && b.status === 'pending') return -1\n    return 0\n  })\n})\n\nconst completedCount = computed(() => \n  fields.value.filter(f => ['success', 'failed'].includes(f.status)).length\n)\n\nconst totalFields = computed(() => fields.value.length)\n\nconst hasOptimized = computed(() => \n  fields.value.some(f => f.status === 'success')\n)\n\n// 开始优化\nconst startOptimize = async () => {\n  for (const field of fields.value) {\n    if (!field.currentValue) continue\n    \n    field.status = 'processing'\n    try {\n      const optimized = await mockOptimize(field, field.currentValue)\n      if (optimized) {\n        field.optimizedValue = optimized\n        field.status = 'success'\n      } else {\n        field.status = 'pending'\n      }\n    } catch (error) {\n      console.error('优化失败:', error)\n      field.status = 'failed'\n    }\n  }\n}\n\n// 对话框控制\nconst dialogVisible = computed({\n  get: () => props.modelValue,\n  set: (value) => emit('update:modelValue', value)\n})\n\n// 响应式布局\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  return '900px'\n})\n\n// 处理关闭\nconst handleClose = () => {\n  dialogVisible.value = false\n}\n\n// 处理应用优化\nconst handleApply = () => {\n  const optimizedData = {}\n  fields.value.forEach(field => {\n    if (field.s