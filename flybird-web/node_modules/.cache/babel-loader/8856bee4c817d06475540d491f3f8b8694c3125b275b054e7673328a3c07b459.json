{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.some.js\";\nimport { ref, watch } from 'vue';\nimport { Dialog, DialogPanel, DialogTitle, DialogOverlay, TransitionChild, TransitionRoot, Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue';\nimport { XMarkIcon, CheckIcon, ChevronUpDownIcon } from '@heroicons/vue/24/outline';\n\n// 平台选项\n\nexport default {\n  __name: 'EditSocialLinkDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const PLATFORM_OPTIONS = [{\n      value: 'weibo',\n      label: '新浪微博'\n    }, {\n      value: 'zhihu',\n      label: '知乎'\n    }, {\n      value: 'zcool',\n      label: '站酷'\n    }, {\n      value: 'douyin',\n      label: '抖音'\n    }, {\n      value: 'bilibili',\n      label: 'Bilibili'\n    }, {\n      value: 'github',\n      label: 'GitHub'\n    }, {\n      value: 'twitter',\n      label: 'Twitter'\n    }, {\n      value: 'website',\n      label: '个人网站'\n    }, {\n      value: 'other',\n      label: '其他'\n    }];\n\n    // 平台网址映射\n    const PLATFORM_URL_MAP = {\n      weibo: 'https://weibo.com/',\n      zhihu: 'https://www.zhihu.com/people/',\n      zcool: 'https://www.zcool.com.cn/u/',\n      douyin: 'https://www.douyin.com/user/',\n      bilibili: 'https://space.bilibili.com/',\n      github: 'https://github.com/',\n      twitter: 'https://twitter.com/',\n      website: 'https://',\n      other: ''\n    };\n    const props = __props;\n    const emit = __emit;\n\n    // 表单数据\n    const form = ref({\n      id: null,\n      platform: '',\n      url: '',\n      description: ''\n    });\n\n    // 错误状态\n    const errors = ref({\n      platform: '',\n      url: '',\n      description: ''\n    });\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      console.log('【EditSocialLinkDialog】接收到初始数据:', newVal);\n      if (newVal) {\n        form.value = {\n          id: newVal.id || null,\n          platform: newVal.platform || '',\n          url: newVal.url || '',\n          description: newVal.description || ''\n        };\n        console.log('【EditSocialLinkDialog】设置表单数据后:', form.value);\n      }\n    }, {\n      immediate: true\n    });\n\n    // 监听平台选择变化\n    watch(() => form.value.platform, newPlatform => {\n      if (newPlatform && PLATFORM_URL_MAP[newPlatform]) {\n        // 如果当前 url 为空或者是其他平台的链接，则重置为新平台的前缀\n        const currentUrl = form.value.url;\n        const shouldReset = !currentUrl || Object.values(PLATFORM_URL_MAP).some(prefix => currentUrl.startsWith(prefix) && !currentUrl.startsWith(PLATFORM_URL_MAP[newPlatform]));\n        if (shouldReset) {\n          form.value.url = PLATFORM_URL_MAP[newPlatform];\n        }\n      }\n    });\n    const handleClose = () => {\n      emit('update:modelValue', false);\n      // 重置表单\n      form.value = {\n        platform: '',\n        url: '',\n        description: ''\n      };\n    };\n\n    // 验证表单\n    const validateForm = () => {\n      let isValid = true;\n      errors.value = {\n        platform: '',\n        url: '',\n        description: ''\n      };\n      if (!form.value.platform?.trim()) {\n        errors.value.platform = '请输入平台名称';\n        isValid = false;\n      }\n      if (!form.value.url?.trim()) {\n        errors.value.url = '请输入链接地址';\n        isValid = false;\n      } else if (!isValidUrl(form.value.url)) {\n        errors.value.url = '请输入有效的链接地址';\n        isValid = false;\n      }\n      return isValid;\n    };\n\n    // 验证 URL\n    const isValidUrl = url => {\n      try {\n        new URL(url);\n        // 检查是否使用了选定平台的正确前缀\n        const platform = form.value.platform;\n        if (platform && platform !== 'other') {\n          const expectedPrefix = PLATFORM_URL_MAP[platform];\n          if (!url.startsWith(expectedPrefix)) {\n            errors.value.url = `请使用 ${expectedPrefix} 开头的链接地址`;\n            return false;\n          }\n        }\n        return true;\n      } catch {\n        return false;\n      }\n    };\n\n    // 提交处理\n    const handleSubmit = () => {\n      if (!validateForm()) {\n        return;\n      }\n      const formData = {\n        id: form.value.id,\n        platform: form.value.platform.trim(),\n        url: form.value.url.trim(),\n        description: form.value.description?.trim() || ''\n      };\n      console.log('【EditSocialLinkDialog】提交数据:', formData);\n      emit('submit', formData);\n    };\n    const __returned__ = {\n      PLATFORM_OPTIONS,\n      PLATFORM_URL_MAP,\n      props,\n      emit,\n      form,\n      errors,\n      handleClose,\n      validateForm,\n      isValidUrl,\n      handleSubmit,\n      ref,\n      watch,\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get DialogOverlay() {\n        return DialogOverlay;\n      },\n      get TransitionChild() {\n        return TransitionChild;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get ChevronUpDownIcon() {\n        return ChevronUpDownIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","Dialog","DialogPanel","DialogTitle","DialogOverlay","TransitionChild","TransitionRoot","Listbox","ListboxButton","ListboxOptions","ListboxOption","XMarkIcon","CheckIcon","ChevronUpDownIcon","PLATFORM_OPTIONS","value","label","PLATFORM_URL_MAP","weibo","zhihu","zcool","douyin","bilibili","github","twitter","website","other","props","__props","emit","__emit","form","id","platform","url","description","errors","initialData","newVal","console","log","immediate","newPlatform","currentUrl","shouldReset","Object","values","some","prefix","startsWith","handleClose","validateForm","isValid","trim","isValidUrl","URL","expectedPrefix","handleSubmit","formData"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditSocialLinkDialog.vue"],"sourcesContent":["<template>\n  <TransitionRoot appear :show=\"modelValue\" as=\"template\">\n    <Dialog as=\"div\" class=\"relative z-50\" @close=\"handleClose\">\n      <TransitionChild\n        as=\"template\"\n        enter=\"duration-300 ease-out\"\n        enter-from=\"opacity-0\"\n        enter-to=\"opacity-100\"\n        leave=\"duration-200 ease-in\"\n        leave-from=\"opacity-100\"\n        leave-to=\"opacity-0\"\n      >\n        <div class=\"fixed inset-0 bg-black/25\" />\n      </TransitionChild>\n\n      <div class=\"fixed inset-0 overflow-y-auto\">\n        <div class=\"flex min-h-full items-center justify-center p-4 text-center\">\n          <TransitionChild\n            as=\"template\"\n            enter=\"duration-300 ease-out\"\n            enter-from=\"opacity-0 scale-95\"\n            enter-to=\"opacity-100 scale-100\"\n            leave=\"duration-200 ease-in\"\n            leave-from=\"opacity-100 scale-100\"\n            leave-to=\"opacity-0 scale-95\"\n          >\n            <DialogPanel class=\"w-full max-w-2xl transform overflow-hidden rounded-xl bg-white text-left align-middle shadow-xl transition-all\">\n              <form @submit.prevent=\"handleSubmit\">\n                <div class=\"p-6 space-y-4\">\n                  <!-- 标题 -->\n                  <DialogTitle as=\"h3\" class=\"text-lg font-medium leading-6 text-gray-900 flex items-center justify-between\">\n                    {{ initialData?.id ? '编辑社交主页' : '添加社交主页' }}\n                    <button\n                      type=\"button\"\n                      class=\"rounded-full p-1 hover:bg-gray-100 transition-colors\"\n                      @click=\"handleClose\"\n                    >\n                      <XMarkIcon class=\"w-5 h-5 text-gray-400\" />\n                    </button>\n                  </DialogTitle>\n\n                  <!-- 平台名称 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      平台名称 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <div class=\"relative\">\n                      <Listbox v-model=\"form.platform\">\n                        <div class=\"relative\">\n                          <ListboxButton\n                            class=\"relative w-full cursor-pointer rounded-lg bg-white py-2.5 pl-4 pr-10 text-left border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 text-sm\"\n                            :class=\"{ 'border-red-300': errors.platform }\"\n                          >\n                            <span class=\"block truncate\">\n                              {{ PLATFORM_OPTIONS.find(opt => opt.value === form.platform)?.label || '请选择平台' }}\n                            </span>\n                            <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3\">\n                              <ChevronUpDownIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                            </span>\n                          </ListboxButton>\n                          <transition\n                            leave-active-class=\"transition duration-100 ease-in\"\n                            leave-from-class=\"opacity-100\"\n                            leave-to-class=\"opacity-0\"\n                          >\n                            <ListboxOptions\n                              class=\"absolute z-10 mt-1 max-h-60 w-full overflow-auto rounded-lg bg-white py-1 text-sm shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none\"\n                            >\n                              <ListboxOption\n                                v-for=\"option in PLATFORM_OPTIONS\"\n                                :key=\"option.value\"\n                                :value=\"option.value\"\n                                v-slot=\"slotProps\"\n                                as=\"template\"\n                              >\n                                <li\n                                  :class=\"[\n                                    slotProps?.active ? 'bg-blue-50 text-blue-600' : 'text-gray-900',\n                                    'relative cursor-pointer select-none py-2.5 pl-4 pr-9'\n                                  ]\"\n                                >\n                                  <span :class=\"[slotProps?.selected ? 'font-medium' : 'font-normal', 'block truncate']\">\n                                    {{ option.label }}\n                                  </span>\n                                  <span\n                                    v-if=\"slotProps?.selected\"\n                                    :class=\"[\n                                      slotProps?.active ? 'text-blue-600' : 'text-blue-500',\n                                      'absolute inset-y-0 right-0 flex items-center pr-3'\n                                    ]\"\n                                  >\n                                    <CheckIcon class=\"h-5 w-5\" />\n                                  </span>\n                                </li>\n                              </ListboxOption>\n                            </ListboxOptions>\n                          </transition>\n                        </div>\n                      </Listbox>\n                    </div>\n                    <p v-if=\"errors.platform\" class=\"text-sm text-red-500 mt-1\">{{ errors.platform }}</p>\n                  </div>\n\n                  <!-- 链接地址 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      链接地址 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <input\n                      type=\"url\"\n                      v-model=\"form.url\"\n                      required\n                      :class=\"[\n                        'w-full rounded-lg border py-2.5 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/10',\n                        errors.url ? 'border-red-300 focus:border-red-500' : 'border-gray-300 focus:border-blue-500'\n                      ]\"\n                      placeholder=\"请输入完整的链接地址\"\n                    />\n                    <p v-if=\"errors.url\" class=\"text-sm text-red-500 mt-1\">{{ errors.url }}</p>\n                  </div>\n\n                  <!-- 链接描述 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      链接描述\n                    </label>\n                    <el-input\n                      v-model=\"form.description\"\n                      type=\"textarea\"\n                      :rows=\"4\"\n                      placeholder=\"请描述该社交主页的内容（选填）\"\n                      :class=\"[\n                        '!w-full',\n                        errors.description ? 'is-error' : ''\n                      ]\"\n                    />\n                    <p v-if=\"errors.description\" class=\"text-sm text-red-500 mt-1\">{{ errors.description }}</p>\n                  </div>\n\n                  <!-- 底部按钮 -->\n                  <div class=\"flex justify-end space-x-3 pt-6\">\n                    <button\n                      type=\"button\"\n                      @click=\"handleClose\"\n                      class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n                    >\n                      取消\n                    </button>\n                    <button\n                      type=\"submit\"\n                      :disabled=\"loading\"\n                      class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                    >\n                      {{ loading ? '保存中...' : '确认' }}\n                    </button>\n                  </div>\n                </div>\n              </form>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { ref, watch } from 'vue'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  DialogOverlay,\n  TransitionChild,\n  TransitionRoot,\n  Listbox,\n  ListboxButton,\n  ListboxOptions,\n  ListboxOption\n} from '@headlessui/vue'\nimport { XMarkIcon, CheckIcon, ChevronUpDownIcon } from '@heroicons/vue/24/outline'\n\n// 平台选项\nconst PLATFORM_OPTIONS = [\n  { value: 'weibo', label: '新浪微博' },\n  { value: 'zhihu', label: '知乎' },\n  { value: 'zcool', label: '站酷' },\n  { value: 'douyin', label: '抖音' },\n  { value: 'bilibili', label: 'Bilibili' },\n  { value: 'github', label: 'GitHub' },\n  { value: 'twitter', label: 'Twitter' },\n  { value: 'website', label: '个人网站' },\n  { value: 'other', label: '其他' }\n]\n\n// 平台网址映射\nconst PLATFORM_URL_MAP = {\n  weibo: 'https://weibo.com/',\n  zhihu: 'https://www.zhihu.com/people/',\n  zcool: 'https://www.zcool.com.cn/u/',\n  douyin: 'https://www.douyin.com/user/',\n  bilibili: 'https://space.bilibili.com/',\n  github: 'https://github.com/',\n  twitter: 'https://twitter.com/',\n  website: 'https://',\n  other: ''\n}\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单数据\nconst form = ref({\n  id: null,\n  platform: '',\n  url: '',\n  description: ''\n})\n\n// 错误状态\nconst errors = ref({\n  platform: '',\n  url: '',\n  description: ''\n})\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newVal) => {\n  console.log('【EditSocialLinkDialog】接收到初始数据:', newVal)\n  if (newVal) {\n    form.value = {\n      id: newVal.id || null,\n      platform: newVal.platform || '',\n      url: newVal.url || '',\n      description: newVal.description || ''\n    }\n    console.log('【EditSocialLinkDialog】设置表单数据后:', form.value)\n  }\n}, { immediate: true })\n\n// 监听平台选择变化\nwatch(() => form.value.platform, (newPlatform) => {\n  if (newPlatform && PLATFORM_URL_MAP[newPlatform]) {\n    // 如果当前 url 为空或者是其他平台的链接，则重置为新平台的前缀\n    const currentUrl = form.value.url\n    const shouldReset = !currentUrl || Object.values(PLATFORM_URL_MAP).some(prefix => \n      currentUrl.startsWith(prefix) && !currentUrl.startsWith(PLATFORM_URL_MAP[newPlatform])\n    )\n    \n    if (shouldReset) {\n      form.value.url = PLATFORM_URL_MAP[newPlatform]\n    }\n  }\n})\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n  // 重置表单\n  form.value = {\n    platform: '',\n    url: '',\n    description: ''\n  }\n}\n\n// 验证表单\nconst validateForm = () => {\n  let isValid = true\n  errors.value = {\n    platform: '',\n    url: '',\n    description: ''\n  }\n\n  if (!form.value.platform?.trim()) {\n    errors.value.platform = '请输入平台名称'\n    isValid = false\n  }\n\n  if (!form.value.url?.trim()) {\n    errors.value.url = '请输入链接地址'\n    isValid = false\n  } else if (!isValidUrl(form.value.url)) {\n    errors.value.url = '请输入有效的链接地址'\n    isValid = false\n  }\n\n  return isValid\n}\n\n// 验证 URL\nconst isValidUrl = (url) => {\n  try {\n    new URL(url)\n    // 检查是否使用了选定平台的正确前缀\n    const platform = form.value.platform\n    if (platform && platform !== 'other') {\n      const expectedPrefix = PLATFORM_URL_MAP[platform]\n      if (!url.startsWith(expectedPrefix)) {\n        errors.value.url = `请使用 ${expectedPrefix} 开头的链接地址`\n        return false\n      }\n    }\n    return true\n  } catch {\n    return false\n  }\n}\n\n// 提交处理\nconst handleSubmit = () => {\n  if (!validateForm()) {\n    return\n  }\n\n  const formData = {\n    id: form.value.id,\n    platform: form.value.platform.trim(),\n    url: form.value.url.trim(),\n    description: form.value.description?.trim() || ''\n  }\n\n  console.log('【EditSocialLinkDialog】提交数据:', formData)\n  emit('submit', formData)\n}\n</script>\n\n<style scoped>\n/* 添加输入框的禁用样式 */\ninput[type=\"url\"]:disabled {\n  background-color: #f3f4f6;\n  cursor: not-allowed;\n}\n</style> "],"mappings":";;AAuKA,SAASA,GAAG,EAAEC,KAAK,QAAQ,KAAI;AAC/B,SACEC,MAAM,EACNC,WAAW,EACXC,WAAW,EACXC,aAAa,EACbC,eAAe,EACfC,cAAc,EACdC,OAAO,EACPC,aAAa,EACbC,cAAc,EACdC,aAAY,QACP,iBAAgB;AACvB,SAASC,SAAS,EAAEC,SAAS,EAAEC,iBAAiB,QAAQ,2BAA0B;;AAElF;;;;;;;;;;;;;;;;;;IACA,MAAMC,gBAAgB,GAAG,CACvB;MAAEC,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAO,CAAC,EACjC;MAAED,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAK,CAAC,EAC/B;MAAED,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAK,CAAC,EAC/B;MAAED,KAAK,EAAE,QAAQ;MAAEC,KAAK,EAAE;IAAK,CAAC,EAChC;MAAED,KAAK,EAAE,UAAU;MAAEC,KAAK,EAAE;IAAW,CAAC,EACxC;MAAED,KAAK,EAAE,QAAQ;MAAEC,KAAK,EAAE;IAAS,CAAC,EACpC;MAAED,KAAK,EAAE,SAAS;MAAEC,KAAK,EAAE;IAAU,CAAC,EACtC;MAAED,KAAK,EAAE,SAAS;MAAEC,KAAK,EAAE;IAAO,CAAC,EACnC;MAAED,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAK,EAChC;;IAEA;IACA,MAAMC,gBAAgB,GAAG;MACvBC,KAAK,EAAE,oBAAoB;MAC3BC,KAAK,EAAE,+BAA+B;MACtCC,KAAK,EAAE,6BAA6B;MACpCC,MAAM,EAAE,8BAA8B;MACtCC,QAAQ,E