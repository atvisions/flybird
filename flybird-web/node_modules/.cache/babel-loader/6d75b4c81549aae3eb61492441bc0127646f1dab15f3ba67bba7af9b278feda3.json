t('update:modelValue', val)\n  })\n  \n  const currentModule = computed(() => props.module)\n  const dialogTitle = computed(() => {\n    if (!currentModule.value) return ''\n    return `编辑${currentModule.value.name}`\n  })\n  \n  const currentRules = computed(() => {\n    if (!currentModule.value) return {}\n    return validationRules[currentModule.value.id] || {}\n  })\n  \n  const getOptions = (fieldKey) => {\n    return options[fieldKey] || []\n  }\n  \n  const handleSubmit = async () => {\n  if (!formRef.value) return\n  try {\n    await formRef.value.validate()\n    emit('submit', formData.value) // 提交本地表单数据\n  } catch (error) {\n    console.error('表单验证失败:', error)\n  }\n}\n  \n  const handleClose = () => {\n    emit('cancel')\n  }\n  \n  // 监听弹窗关闭，重置表单\n  watch(visible, (val) => {\n    if (!val && formRef.value) {\n      formRef.value.resetFields()\n    }\n  })\n  </script>"],"mappings":";AAgIE,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,OAAO,QAAQ,sBAAqB;AAC7C,SAASC,eAAe,QAAQ,oBAAmB;;;;;;;;;;;;;;;;IAEnD,MAAMC,KAAK,GAAGC,OAAA;IAMd;IACF,MAAMC,aAAa,GAAGP,GAAG,CAAAQ,aAAA,KAAKH,KAAK,CAACI,QAAQ,CAAC;;IAE7C;IACAP,KAAK,CAAC,MAAMG,KAAK,CAACI,QAAQ,EAAGC,MAAM,IAAK;MACtCH,aAAa,CAACI,KAAK,GAAAH,aAAA,KAAOE,MAAM;IAClC,CAAC,EAAE;MAAEE,IAAI,EAAE;IAAK,CAAC;IACf,MAAMC,IAAI,GAAGC,MAAA;IACb;IACF,MAAML,QAAQ,GAAGT,GAAG,CAAAQ,aAAA,KAAKH,KAAK,CAACU,eAAe,CAAC;;IAE/C;IACAb,KAAK,CAAC,MAAMG,KAAK,CAACU,eAAe,EAAGL,MAAM,IAAK;MAC7CD,QAAQ,CAACE,KAAK,GAAAH,aAAA,KAAOE,MAAM;IAC7B,CAAC,EAAE;MAAEE,IAAI,EAAE;IAAK,CAAC;IACf,MAAMI,OAAO,GAAGhB,GAAG,CAAC,IAAI;IACxB,MAAMiB,OAAO,GAAGhB,QAAQ,CAAC;MACvBiB,GAAG,EAAEA,CAAA,KAAMb,KAAK,CAACc,UAAU;MAC3BC,GAAG,EAAGC,GAAG,IAAKR,IAAI,CAAC,mBAAmB,EAAEQ,GAAG;IAC7C,CAAC;IAED,MAAMC,aAAa,GAAGrB,QAAQ,CAAC,MAAMI,KAAK,CAACkB,MAAM;IACjD,MAAMC,WAAW,GAAGvB,QAAQ,CAAC,MAAM;MACjC,IAAI,CAACqB,aAAa,CAACX,KAAK,EAAE,OAAO,EAAC;MAClC,OAAO,KAAKW,aAAa,CAACX,KAAK,CAACc,IAAI,EAAC;IACvC,CAAC;IAED,MAAMC,YAAY,GAAGzB,QAAQ,CAAC,MAAM;MAClC,IAAI,CAACqB,aAAa,CAACX,KAAK,EAAE,OAAO,CAAC;M