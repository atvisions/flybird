   onAdd: () => $setup.handleAdd(module.type)\n    }, null, 40 /* PROPS, NEED_HYDRATION */, [\"data\", \"onEdit\", \"onDelete\", \"onAdd\"]))])])]);\n  }), 64 /* STABLE_FRAGMENT */))]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_Fragment","_renderList","$setup","modules","module","_createElementVNode","key","type","_createCommentVNode","_hoisted_2","_hoisted_3","_hoisted_4","_hoisted_5","_toDisplayString","title","canAdd","onClick","$event","handleAdd","_hoisted_6","_hoisted_7","_createBlock","_resolveDynamicComponent","getComponentByType","data","$props","moduleData","onEdit","item","handleEdit","onDelete","id","handleDelete","onAdd"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-6\">\n    <div v-for=\"module in modules\" :key=\"module.type\">\n      <!-- 模块卡片 -->\n      <div class=\"bg-white rounded-lg shadow\">\n        <!-- 模块头部 -->\n        <div class=\"px-6 py-4 border-b border-gray-200\">\n          <div class=\"flex items-center justify-between\">\n            <h3 class=\"text-lg font-medium text-gray-900\">{{ module.title }}</h3>\n            <button\n              v-if=\"module.canAdd\"\n              @click=\"handleAdd(module.type)\"\n              class=\"text-sm text-blue-600 hover:text-blue-700\"\n            >\n              添加\n            </button>\n          </div>\n        </div>\n\n        <!-- 模块内容 -->\n        <div class=\"p-6\">\n          <component\n            :is=\"getComponentByType(module.type)\"\n            :data=\"moduleData[module.type]\"\n            @edit=\"item => handleEdit(module.type, item)\"\n            @delete=\"id => handleDelete(module.type, id)\"\n            @add=\"() => handleAdd(module.type)\"\n          />\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport WorkExperienceContent from './WorkExperienceContent.vue'\nimport EducationContent from './EducationContent.vue'\nimport ProjectContent from './ProjectContent.vue'\nimport SkillContent from './SkillContent.vue'\nimport PortfolioContent from './PortfolioContent.vue'\nimport SocialLinkContent from './SocialLinkContent.vue'\nimport LanguageContent from './LanguageContent.vue'\nimport { ElMessage } from 'element-plus'\nimport profile from '@/api/profile'\n\nconst props = defineProps({\n  moduleData: {\n    type: Object,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['update:moduleData'])\n\n// 获取对应的内容组件\nconst getComponentByType = (type) => {\n  const componentMap = {\n    work_experience: WorkExperienceContent,\n    education: EducationContent,\n    project: ProjectContent,\n    skill: SkillContent,\n    portfolio: PortfolioContent,\n    social_link: SocialLinkContent,\n    language: LanguageContent\n  }\n  return componentMap[type]\n}\n\n// 模块配置\nconst modules = [\n  {\n    type: 'work_experience',\n    title: '工作经历',\n    canAdd: true\n  },\n  {\n    type: 'education',\n    title: '教育经历',\n    canAdd: true\n  },\n  {\n    type: 'project',\n    title: '项目经历',\n    canAdd: true\n  },\n  {\n    type: 'skill',\n    title: '技能特长',\n    canAdd: true\n  },\n  {\n    type: 'portfolio',\n    title: '作品展示',\n    canAdd: true\n  },\n  {\n    type: 'social_link',\n    title: '社交主页',\n    canAdd: true\n  },\n  {\n    type: 'language',\n    title: '语言能力',\n    canAdd: true\n  }\n]\n\n// 处理添加操作\nconst handleAdd = (type) => {\n  emit('add', type)\n}\n\n// 处理编辑操作\nconst handleEdit = (type, item) => {\n  emit('edit', type, item)\n}\n\n// 处理删除操作\nconst handleDelete = async (type, id) => {\n  try {\n    await profile.deleteModuleItem(type, id)\n    ElMessage.success('删除成功')\n    // 通知父组件刷新数据\n    emit('delete', type, id)\n  } catch (error) {\n    console.error('删除失败:', error)\n    ElMessage.error(error.message || '删除失败')\n  }\n}\n</script>\n"],