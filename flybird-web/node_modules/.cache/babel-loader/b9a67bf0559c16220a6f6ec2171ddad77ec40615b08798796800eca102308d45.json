c/views/user/MyProfile/dialogs/EditWorkExperienceDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    @close=\"handleClose\"\n    class=\"edit-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- Header -->\n      <div class=\"dialog-header\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-lg font-medium text-gray-900\">\n            {{ initialData.id ? '编辑工作经历' : '添加工作经历' }}\n          </h3>\n          <!-- 移动端显示关闭按钮 -->\n          <button\n            v-if=\"isMobile\"\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- Body -->\n      <div class=\"dialog-body\">\n        <el-form\n          ref=\"formRef\"\n          :model=\"form\"\n        >\n          <form @submit.prevent=\"handleSubmit\" class=\"space-y-4 sm:space-y-5\">\n            <!-- 两列布局 -->\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5\">\n              <!-- 公司名称 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">公司名称</label>\n                <el-form-item prop=\"company\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.company\"\n                    type=\"text\"\n                    placeholder=\"请输入公司名称\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 职位名称 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">职位名称</label>\n                <el-form-item prop=\"position\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.position\"\n                    type=\"text\"\n                    placeholder=\"请输入职位名称\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 部门 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">所在部门</label>\n                <el-form-item prop=\"department\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.department\"\n                    type=\"text\"\n                    placeholder=\"请输入所在部门\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 工作时间 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">工作时间</label>\n                <el-form-item prop=\"date_range\" class=\"mb-0\">\n                  <el-date-picker\n                    v-model=\"form.date_range\"\n                    type=\"daterange\"\n                    range-separator=\"至\"\n                    start-placeholder=\"开始日期\"\n                    end-placeholder=\"结束日期\"\n                    format=\"YYYY-MM\"\n                    value-format=\"YYYY-MM\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n            </div>\n\n            <!-- 工作内容 -->\n            <div class=\"space-y-4\">\n              <!-- 公司描述 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">公司描述</label>\n                <el-form-item prop=\"company_description\" class=\"mb-0\">\n                  <el-input\n                    v-model=\"form.company_description\"\n                    type=\"textarea\"\n                    :rows=\"2\"\n                    placeholder=\"请简要描述公司情况\"\n                    resize=\"none\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 工作职责 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">工作职责</label>\n                <el-form-item prop=\"responsibilities\" class=\"mb-0\">\n                  <el-input\n                    v-model=\"form.responsibilities\"\n                    type=\"textarea\"\n                    :rows=\"3\"\n                    placeholder=\"请描述您的主要工作职责\"\n                    resize=\"none\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 工作成就 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">工作成就</label>\n                <el-form-item prop=\"achievements\" class=\"mb-0\">\n                  <el-input\n                    v-model=\"form.achievements\"\n                    type=\"textarea\"\n                    :rows=\"3\"\n                    placeholder=\"请描述您在该岗位的主要成就\"\n                    resize=\"none\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n            </div>\n          </form>\n        </el-form>\n      </div>\n\n      <!-- Footer -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n     