nconst fetchUserBasicInfo = async () => {\n  try {\n    loading.value = true\n    const response = await auth.getUserInfo()\n    if (response.data?.code === 200) {\n      userBasicInfo.value = response.data.data\n    }\n  } catch (error) {\n    console.error('获取用户信息失败:', error)\n    showToast('获取用户信息失败', 'error')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 在组件挂载时获取用户信息\nonMounted(() => {\n  if (store.state.isAuthenticated) {\n    fetchUserBasicInfo()\n  }\n})\n\n// 监听认证状态变化\nwatch(() => store.state.isAuthenticated, (isAuthenticated) => {\n  if (isAuthenticated) {\n    fetchUserBasicInfo()\n  } else {\n    userBasicInfo.value = null\n  }\n})\n\n// 计算属性\nconst username = computed(() => userBasicInfo.value?.user?.username || '未设置')\nconst uid = computed(() => userBasicInfo.value?.user?.uid || '暂无')\nconst phone = computed(() => userBasicInfo.value?.user?.phone || '')\n\n// 手机号脱敏处理\nconst maskPhone = (phone) => {\n  if (!phone) return '未绑定'\n  return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n// 模态框状态\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\n\n// 添加注销账户相关的状态和方法\nconst showDeleteConfirm = ref(false)\nconst deletePassword = ref('')\n\n// 处理注销账户\nconst handleDeleteAccount = async () => {\n  try {\n    if (!deletePassword.value) {\n      showToast('请输入密码确认', 'warning')\n      return\n    }\n\n    // 显示加载状态\n    loading.value = true\n\n    await auth.deleteAccount({\n      password: deletePassword.value\n    })\n\n    showToast('账户已注销', 'success')\n    store.dispatch('logout')\n    router.push('/login')\n  } catch (error) {\n    showToast(error.message || '注销账户失败，请重试', 'error')\n  } finally {\n    loading.value = false\n    showDeleteConfirm.value = false\n    deletePassword.value = ''\n  }\n}\n\n// 昵称设置弹窗\nconst showNicknameModal = ref(false)\nconst newNickname = ref('')\n\n// 处理昵称更新\nconst handleUpdateNickname = async () => {\n  const nickname = newNickname.value.trim()\n  if (!nickname) {\n    showToast('请输入昵称', 'warning')\n    return\n  }\n  \n  // 验证昵称长度\n  if (nickname.length < 4) {\n    showToast('昵称长度不能少于4个字符', 'warning')\n    return\n  }\n  \n  try {\n    const response = await auth.updateUsername({ username: nickname })\n    if (response.data?.code === 200) {\n      // 更新成功后重新获取用户信息\n      const userResponse = await auth.getUserInfo()\n      if (userResponse.data?.code === 200) {\n        const userData = {\n          ...userResponse.data.data.basic_info,\n          ...userResponse.data.data.user\n        }\n        store.commit('SET_USER_INFO', userData)\n      }\n      showToast('昵称修改成功', 'success')\n    }\n  } catch (error) {\n    showToast(error.message || '昵称修改失败', 'error')\n  }\n}\n\n// 手机号相关\nconst newPhone = ref('')\nconst phoneVerifyCode = ref('')\nconst phoneCodeCountdown = ref(0)\n\n// 密码相关\nconst currentPassword = ref('')\nconst newPassword = ref('')\nconst confirmPassword = ref('')\n\n// 发送手机验证码\nconst handleSendPhoneCode = async () => {\n  try {\n    await auth.sendVerifyCode({\n      phone: newPhone.value,\n      scene: SMS_SCENE.CHANGE_PHONE\n    })\n    \n    showToast('验证码已发送', 'success')\n    // 开始倒计时\n    phoneCodeCountdown.value = 60\n    const timer = setInterval(() => {\n      phoneCodeCountdown.value--\n      if (phoneCodeCountdown.value <= 0) {\n        clearInterval(timer)\n      }\n    }, 1000)\n  } catch (error) {\n    showToast(error.message || '发送验证码失败', 'error')\n  }\n}\n\n// 更新手机号\nconst handleUpdatePhone = async () => {\n  try {\n    await auth.changePhone({\n      phone: newPhone.value,\n      code: phoneVerifyCode.value\n    })\n    \n    showToast('手机号更新成功', 'success')\n    showPhoneModal.value = false\n    newPhone.value = ''\n    phoneVerifyCode.value = ''\n    \n    // 刷新用户信息\n    await fetchUserBasicInfo()\n  } catch (error) {\n    showToast(error.message || '更新手机号失败', 'error')\n  }\n}\n\n// 更新密码\nconst handleUpdatePassword = async () => {\n  if (newPassword.value !== confirmPassword.value) {\n    showToast('两次输入的密码不一致', 'error')\n    return\n  }\n  \n  try {\n    await auth.updatePassword({\n      old_password: currentPassword.value,\n      new_password: newPassword.value,\n      confirm_password: confirmPassword.value\n    })\n    \n    showToast('密码修改成功', 'success')\n    showPasswordModal.value = false\n    currentPassword.value = ''\n    newPassword.value = ''\n    confirmPassword.value = ''\n  } catch (error) {\n    showToast(error.message || '修改密码失败', 'error')\n  }\n}\n\n</script>\n\n<style scoped>\n/* 如果有任何样式，放在这里 */\n</style>"],"mappings":";AAsWA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,EAAEC,SAAS,QAAQ,KAAI;AACpD,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,IAAI,QAAQ,YAAW;AAChC,SAASC,aAAa,QAAQ,YAAW;AACzC,SAASC,SAAS,QAAQ,SAAQ;;;;;;;IAElC,MAAMC,KAAK,GAAGN,QAAQ,CAAC;IACvB,MAAMO,MAAM,GAAGN,SAAS,CAAC;;IAEzB;IACA,MAAMO,aAAa,GAAGZ,GAAG,CAAC,IAAI;IAC9B,MAAMa,OAAO,GAAGb,GAAG,CAAC,KAAK;;IAEzB;IACA,MAAMc,kBAAkB,GAAG,MAAAA,CAAA,KAAY;MACrC,IAAI;QACFD,OAAO,CAACE,KAAK,GAAG,IAAG;QACnB,MAAMC,QAAQ,GAAG,MAAMT,IAAI,CAACU,WAAW,CAAC;QACxC,IAAID,QAAQ,CAACE,IAAI,EAAEC,IAAI,KAAK,GAAG,EAAE;UAC/BP,aAAa,CAACG,KAAK,GAAGC,QAAQ,CAACE,IAAI,CAACA,IAAG;QACzC;MACF,CAAC,CAAC,OAAOE,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;QAChCd,SAAS,CAAC,UAAU,EAAE,OAAO;MAC/B,CAAC,SAAS;QACRO,OAAO,CAACE,KAAK,GAAG,KAAI;MACtB;IACF;;IAEA;IACAZ,SAAS,CAAC,MAAM;MACd,IAAIO,KAAK,CAACY,KAAK,CAACC,eAAe,EAAE;QAC/BT,kBAAkB,CAAC;MACrB;IACF,CAAC;;IAED;IACAZ,KAAK,CAAC,MAAMQ,KAAK,CAACY,KAAK,CAACC,eAAe,EAAGA,eAAe,IAAK;MAC5D,IAAIA,eAAe,EAAE;QACnBT,kBAAkB,CAAC;MACrB,CAAC,MAAM;QACLF,aAAa,CAACG,KAAK,GAAG,IAAG;MAC3B;IACF,CAAC;;IAED;IACA,MAAMS,QAAQ,GAAGvB,QAAQ,CAAC,MAAMW,aAAa,CAACG,KAAK,EAAEU,IAAI,EAAED,QAAQ,IAAI,KAAK;IAC5E,MAAME,GAAG,GAAGzB,QAAQ,CAAC,MAAMW,aAAa,CAACG,KAAK,EAAEU,IAAI,EAAEC,GAAG,IAAI,IAAI;IACjE,MAAMC,KAAK,GAAG1B,QAAQ,CAAC,MAAMW,aAAa,CAACG,KAAK,EAAEU,IAAI,EAAEE,KAAK,IAAI,EAAE;;IAEnE;IACA,MAAMC,SAAS,GAAID,KAAK,IAAK;MAC3B,IAAI,CAACA,KAAK,EAAE,OAAO,KAAI;MACvB,OAAOA,KAAK,CAACE,OAAO,CAAC,qBAAqB,EAAE,