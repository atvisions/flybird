{"ast":null,"code":"import \"core-js/modules/esnext.iterator.map.js\";\nimport { computed } from 'vue';\nexport default {\n  __name: 'JobIntentionContent',\n  props: {\n    data: {\n      type: Object,\n      default: () => ({})\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 格式化工作类型\n    const formatJobType = type => {\n      const typeMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return typeMap[type] || '未设置';\n    };\n\n    // 格式化求职状态\n    const formatJobStatus = status => {\n      const statusMap = {\n        'actively_looking': '正在积极找工作',\n        'open_to_offers': '对机会持开放态度',\n        'not_looking': '暂不考虑机会'\n      };\n      return statusMap[status] || '未设置';\n    };\n\n    // 格式化行业\n    const formatIndustries = industries => {\n      if (!industries) return '未设置';\n      return industries.split(',').map(i => i.trim()).join('、');\n    };\n    const __returned__ = {\n      props,\n      formatJobType,\n      formatJobStatus,\n      formatIndustries,\n      computed\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","props","__props","formatJobType","type","typeMap","formatJobStatus","status","statusMap","formatIndustries","industries","split","map","i","trim","join"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-4\">\n    <!-- 数据展示 -->\n    <div v-if=\"data\" class=\"space-y-3\">\n      <!-- 工作类型和求职状态 -->\n      <div class=\"grid grid-cols-2 gap-4\">\n        <div>\n          <div class=\"text-sm text-gray-500\">工作类型</div>\n          <div class=\"mt-1 text-sm text-gray-900\">{{ formatJobType(data.job_type) }}</div>\n        </div>\n        <div>\n          <div class=\"text-sm text-gray-500\">求职状态</div>\n          <div class=\"mt-1 text-sm text-gray-900\">{{ formatJobStatus(data.job_status) }}</div>\n        </div>\n      </div>\n\n      <!-- 期望薪资和城市 -->\n      <div class=\"grid grid-cols-2 gap-4\">\n        <div>\n          <div class=\"text-sm text-gray-500\">期望薪资</div>\n          <div class=\"mt-1 text-sm text-gray-900\">{{ data.expected_salary || '未设置' }}</div>\n        </div>\n        <div>\n          <div class=\"text-sm text-gray-500\">期望城市</div>\n          <div class=\"mt-1 text-sm text-gray-900\">{{ data.expected_city || '未设置' }}</div>\n        </div>\n      </div>\n\n      <!-- 期望行业 -->\n      <div>\n        <div class=\"text-sm text-gray-500\">期望行业</div>\n        <div class=\"mt-1 text-sm text-gray-900\">{{ formatIndustries(data.industries) }}</div>\n      </div>\n    </div>\n\n    <!-- 空状态 -->\n    <div v-else class=\"text-center text-gray-500 text-sm py-4\">\n      暂无求职意向信息，点击编辑按钮开始设置\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: () => ({})\n  }\n})\n\n// 格式化工作类型\nconst formatJobType = (type) => {\n  const typeMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return typeMap[type] || '未设置'\n}\n\n// 格式化求职状态\nconst formatJobStatus = (status) => {\n  const statusMap = {\n    'actively_looking': '正在积极找工作',\n    'open_to_offers': '对机会持开放态度',\n    'not_looking': '暂不考虑机会'\n  }\n  return statusMap[status] || '未设置'\n}\n\n// 格式化行业\nconst formatIndustries = (industries) => {\n  if (!industries) return '未设置'\n  return industries.split(',').map(i => i.trim()).join('、')\n}\n\n</script> "],"mappings":";AA2CA,SAASA,QAAQ,QAAQ,KAAI;;;;;;;;;;;;;IAE7B,MAAMC,KAAK,GAAGC,OAAA;;IAOd;IACA,MAAMC,aAAa,GAAIC,IAAI,IAAK;MAC9B,MAAMC,OAAO,GAAG;QACd,WAAW,EAAE,IAAI;QACjB,WAAW,EAAE,IAAI;QACjB,YAAY,EAAE,IAAI;QAClB,WAAW,EAAE;MACf;MAC