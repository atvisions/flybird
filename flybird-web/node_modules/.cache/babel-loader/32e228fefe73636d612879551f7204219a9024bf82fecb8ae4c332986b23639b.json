{"ast":null,"code":"import { ref, watch } from 'vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'EditBasicDialog',\n  props: {\n    visible: {\n      type: Boolean,\n      default: false\n    },\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['update:visible', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const formRef = ref(null);\n    const form = ref({\n      name: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: '',\n      personal_summary: ''\n    });\n    const rules = {\n      email: [{\n        type: 'email',\n        message: '请输入正确的邮箱地址',\n        trigger: 'blur'\n      }],\n      phone: [{\n        pattern: /^1[3-9]\\d{9}$/,\n        message: '请输入正确的手机号',\n        trigger: 'blur'\n      }]\n    };\n\n    // 监听弹窗显示状态\n    watch(() => props.visible, val => {\n      if (val) {\n        // 初始化表单数据\n        form.value = {\n          name: props.initialData.name || '',\n          gender: props.initialData.gender || '',\n          phone: props.initialData.phone || '',\n          email: props.initialData.email || '',\n          location: props.initialData.location || '',\n          birth_date: props.initialData.birth_date || '',\n          personal_summary: props.initialData.personal_summary || ''\n        };\n      } else {\n        formRef.value?.resetFields();\n      }\n    });\n\n    // 取消\n    const handleCancel = () => {\n      emit('update:visible', false);\n    };\n\n    // 提交\n    const handleSubmit = async () => {\n      if (!formRef.value) return;\n      try {\n        await formRef.value.validate();\n        emit('submit', form.value);\n      } catch (error) {\n        console.error('表单验证失败:', error);\n        ElMessage.error('请检查表单填写是否正确');\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      formRef,\n      form,\n      rules,\n      handleCancel,\n      handleSubmit,\n      ref,\n      watch,\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","ElMessage","props","__props","emit","__emit","formRef","form","name","gender","phone","email","location","birth_date","personal_summary","rules","type","message","trigger","pattern","visible","val","value","initialData","resetFields","handleCancel","handleSubmit","validate","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"visible\"\n    @update:model-value=\"$emit('update:visible', $event)\"\n    title=\"编辑个人资料\"\n    custom-class=\"edit-dialog\"\n    :close-on-click-modal=\"false\"\n    width=\"640px\"\n  >\n    <el-form\n      ref=\"formRef\"\n      :model=\"form\"\n      :rules=\"rules\"\n      label-width=\"80px\"\n      class=\"edit-form\"\n    >\n      <div class=\"grid grid-cols-2 gap-4\">\n        <!-- 姓名 -->\n        <el-form-item label=\"姓名\" prop=\"name\">\n          <el-input v-model=\"form.name\" placeholder=\"请输入姓名\" />\n        </el-form-item>\n\n        <!-- 性别 -->\n        <el-form-item label=\"性别\" prop=\"gender\">\n          <el-select v-model=\"form.gender\" placeholder=\"请选择性别\" class=\"w-full\">\n            <el-option label=\"男\" value=\"male\" />\n            <el-option label=\"女\" value=\"female\" />\n            <el-option label=\"其他\" value=\"other\" />\n          </el-select>\n        </el-form-item>\n\n        <!-- 手机号 -->\n        <el-form-item label=\"手机号\" prop=\"phone\">\n          <el-input v-model=\"form.phone\" placeholder=\"请输入手机号\" />\n        </el-form-item>\n\n        <!-- 邮箱 -->\n        <el-form-item label=\"邮箱\" prop=\"email\">\n          <el-input v-model=\"form.email\" placeholder=\"请输入邮箱\" />\n        </el-form-item>\n\n        <!-- 所在地 -->\n        <el-form-item label=\"所在地\" prop=\"location\">\n          <el-input v-model=\"form.location\" placeholder=\"请输入所在地\" />\n        </el-form-item>\n\n        <!-- 生日 -->\n        <el-form-item label=\"生日\" prop=\"birth_date\">\n          <el-date-picker\n            v-model=\"form.birth_date\"\n            type=\"date\"\n            placeholder=\"请选择生日\"\n            format=\"YYYY-MM-DD\"\n            value-format=\"YYYY-MM-DD\"\n            class=\"w-full\"\n          />\n        </el-form-item>\n      </div>\n\n      <!-- 个人简介 -->\n      <el-form-item label=\"个人简介\" prop=\"personal_summary\">\n        <el-input\n          v-model=\"form.personal_summary\"\n          type=\"textarea\"\n          :rows=\"4\"\n          placeholder=\"请输入个人简介\"\n          resize=\"none\"\n        />\n      </el-form-item>\n    </el-form>\n\n    <template #footer>\n      <div class=\"dialog-footer\">\n        <el-button @click=\"handleCancel\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"loading\">\n          保存\n        </el-button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, watch } from 'vue'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  visible: {\n    type: Boolean,\n    default: false\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['update:visible', 'submit'])\n\nconst formRef = ref(null)\nconst form = ref({\n  name: '',\n  gender: '',\n  phone: '',\n  email: '',\n  location: '',\n  birth_date: '',\n  personal_summary: ''\n})\n\nconst rules = {\n  email: [\n    { type: 'email', message: '请输入正确的邮箱地址', trigger: 'blur' }\n  ],\n  phone: [\n    { pattern: /^1[3-9]\\d{9}$/, message: '请输入正确的手机号', trigger: 'blur' }\n  ]\n}\n\n// 监听弹窗显示状态\nwatch(() => props.visible, (val) => {\n  if (val) {\n    // 初始化表单数据\n    form.value = {\n      name: props.initialData.name || '',\n      gender: props.initialData.gender || '',\n      phone: props.initialData.phone || '',\n      email: props.initialData.email || '',\n      location: props.initialData.location || '',\n      birth_date: props.initialData.birth_date || '',\n      personal_summary: props.initialData.personal_summary || ''\n    }\n  } else {\n    formRef.value?.resetFields()\n  }\n})\n\n// 取消\nconst handleCancel = () => {\n  emit('update:visible', false)\n}\n\n// 提交\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    await formRef.value.validate()\n    emit('submit', form.value)\n  } catch (error) {\n    console.error('表单验证失败:', error)\n    ElMessage.error('请检查表单填写是否正确')\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.edit-dialog {\n  :deep(.el-dialog__body) {\n    padding: 20px 24px;\n  }\n}\n\n.edit-form {\n  :deep(.el-form-item__label) {\n    font-weight: 500;\n  }\n}\n\n.dialog-footer {\n  display: flex;\n  justify-content: flex-end;\n  gap: 12px;\n  padding-top: 8px;\n}\n</style>"],"mappings":"AAoFA,SAASA,GAAG,EAAEC,KAAK,QAAQ,KAAI;AAC/B,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGC,OAAA;IAed,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,OAAO,GAAGP,GAAG,CAAC,IAAI;IACxB,MAAMQ,IAAI,GAAGR,GAAG,CAAC;MACfS,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,gBAAgB,EAAE;IACpB,CAAC;IAED,MAAMC,KAAK,GAAG;MACZJ,KAAK,EAAE,CACL;QAAEK,IAAI,EAAE,OAAO;QAAEC,OAAO,EAAE,YAAY;QAAEC,OAAO,EAAE;MAAO,EACzD;MACDR,KAAK,EAAE,CACL;QAAES,OAAO,EAAE,eAAe;QAAEF,OAAO,EAAE,WAAW;QAAEC,OAAO,EAAE;MAAO;IAEtE;;IAEA;IACAlB,KAAK,CAAC,MAAME,KAAK,CAACkB,OAAO,EAAGC,GAAG,IAAK;MAClC,IAAIA,GAAG,EAAE;QACP;QACAd,IAAI,CAACe,KAAK,GAAG;U