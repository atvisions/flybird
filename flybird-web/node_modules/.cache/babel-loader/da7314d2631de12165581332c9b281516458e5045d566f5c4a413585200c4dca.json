{"ast":null,"code":"import { ref, computed, onMounted, onUnmounted } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { register, sendSmsCode } from '@/api/user';\nimport { SMS_SCENE } from '@/store';\nimport HeadView from '@/components/HeadView.vue';\n\n/**\n * Vuex store 实例\n * @type {import('vuex').Store}\n */\n\nexport default {\n  __name: 'RegisterView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n\n    /**\n     * Vue Router 实例\n     * @type {import('vue-router').Router}\n     */\n    const router = useRouter();\n\n    /**\n     * 表单数据\n     * @type {import('vue').Ref<Object>}\n     */\n    const form = ref({\n      phone: '',\n      password: '',\n      code: '',\n      countdown: 0\n    });\n\n    /**\n     * UI 状态变量\n     */\n    const showPassword = ref(false);\n    const agreed = ref(false);\n    const loading = ref(false);\n    const sendingCode = ref(false);\n\n    /**\n     * 表单验证计算属性\n     * @type {import('vue').ComputedRef<boolean>}\n     */\n    const isFormValid = computed(() => {\n      return form.value.phone && form.value.code && form.value.password && form.value.password.length >= 6 && agreed.value;\n    });\n\n    /**\n     * 切换密码显示状态\n     */\n    const togglePassword = () => {\n      showPassword.value = !showPassword.value;\n    };\n\n    /**\n     * 统一错误处理函数\n     * @param {Error} error - 错误对象\n     * @param {Object} options - 处理选项\n     * @param {string} options.type - 错误类型 ('register'|'sendCode')\n     * @param {Function} options.onRegistered - 已注册回调\n     */\n    const handleError = (error, {\n      type,\n      onRegistered\n    }) => {\n      const errorData = error.response?.data;\n\n      // 处理已注册错误\n      if (errorData?.errors?.phone?.[0]?.includes('已注册')) {\n        showToast('手机号已注册', 'warning');\n        onRegistered();\n        return;\n      }\n\n      // 处理验证码错误\n      if (errorData?.errors?.code?.[0]?.includes('验证码')) {\n        showToast('验证码错误或已过期，请重新获取', 'error');\n        return;\n      }\n\n      // 处理其他业务错误\n      if (errorData?.message) {\n        showToast(errorData.message, 'error');\n        return;\n      }\n\n      // 处理默认错误\n      const defaultMessages = {\n        sendCode: '发送验证码失败，请稍后重试',\n        register: '注册失败，请稍后重试'\n      };\n      showToast(defaultMessages[type], 'error');\n    };\n\n    /**\n     * 获取验证码\n     */\n    const getVerifyCode = async () => {\n      if (!checkNetwork()) return;\n      if (!form.value.phone) {\n        showToast('请输入手机号', 'warning');\n        return;\n      }\n      const phoneRegex = /^1[3-9]\\d{9}$/;\n      if (!phoneRegex.test(form.value.phone)) {\n        showToast('请输入正确的手机号', 'warning');\n        return;\n      }\n      try {\n        sendingCode.value = true;\n        const response = await sendSmsCode({\n          phone: form.value.phone,\n          scene: SMS_SCENE.REGISTER\n        });\n        if (response.data.code === 200) {\n          form.value.countdown = 60;\n          const timer = setInterval(() => {\n            form.value.countdown--;\n            if (form.value.countdown <= 0) {\n              clearInterval(timer);\n            }\n          }, 1000);\n          showToast('验证码已发送', 'success');\n        }\n      } catch (error) {\n        handleError(error, {\n          type: 'sendCode',\n          onRegistered: () => router.push('/login')\n        });\n      } finally {\n        sendingCode.value = false;\n      }\n    };\n\n    /**\n     * 注册处理\n     */\n    const handleRegister = async () => {\n      if (!checkNetwork()) return;\n      if (!isFormValid.value) {\n        showToast('请填写完整信息并同意服务条款', 'warning');\n        return;\n      }\n      const phoneRegex = /^1[3-9]\\d{9}$/;\n      if (!phoneRegex.test(form.value.phone)) {\n        showToast('请输入正确的手机号', 'warning');\n        return;\n      }\n      try {\n        loading.value = true;\n        const registerResponse = await register({\n          phone: form.value.phone,\n          password: form.value.password,\n          code: form.value.code\n        });\n        if (registerResponse.data.code === 200) {\n          try {\n            await store.dispatch('loginWithPassword', {\n              credentials: {\n                phone: form.value.phone,\n                password: form.value.password\n              },\n              remember: true\n            });\n            showToast('注册成功', 'success');\n            await new Promise(resolve => setTimeout(resolve, 100));\n            router.push('/user');\n          } catch (loginError) {\n            showToast('注册成功，请手动登录', 'info');\n            router.push('/login');\n          }\n        }\n      } catch (error) {\n        handleError(error, {\n          type: 'register',\n          onRegistered: () => router.push('/login')\n        });\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    /**\n     * 检查网络连接状态\n     * @returns {boolean} 网络是否可用\n     */\n    const checkNetwork = () => {\n      if (!navigator.onLine) {\n        showToast('网络连接不稳定，请检查网络设置', 'warning');\n        return false;\n      }\n      return true;\n    };\n\n    /**\n     * 网络恢复处理\n     */\n    const handleOnline = () => {\n      showToast('网络已连接', 'success');\n    };\n\n    /**\n     * 网络断开处理\n     */\n    const handleOffline = () => {\n      showToast('网络连接已断开', 'warning');\n    };\n\n    // 生命周期钩子\n    onMounted(() => {\n      window.addEventListener('online', handleOnline);\n      window.addEventListener('offline', handleOffline);\n    });\n    onUnmounted(() => {\n      window.removeEventListener('online', handleOnline);\n      window.removeEventListener('offline', handleOffline);\n    });\n    const __returned__ = {\n      store,\n      router,\n      form,\n      showPassword,\n      agreed,\n      loading,\n      sendingCode,\n      isFormValid,\n      togglePassword,\n      handleError,\n      getVerifyCode,\n      handleRegister,\n      checkNetwork,\n      handleOnline,\n      handleOffline,\n      ref,\n      computed,\n      onMounted,\n      onUnmounted,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get register() {\n        return register;\n      },\n      get sendSmsCode() {\n        return sendSmsCode;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      },\n      HeadView\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","onUnmounted","useStore","useRouter","showToast","register","sendSmsCode","SMS_SCENE","HeadView","store","router","form","phone","password","code","countdown","showPassword","agreed","loading","sendingCode","isFormValid","value","length","togglePassword","handleError","error","type","onRegistered","errorData","response","data","errors","includes","message","defaultMessages","sendCode","getVerifyCode","checkNetwork","phoneRegex","test","scene","REGISTER","timer","setInterval","clearInterval","push","handleRegister","registerResponse","dispatch","credentials","remember","Promise","resolve","setTimeout","loginError","navigator","onLine","handleOnline","handleOffline","window","addEventListener","removeEventListener"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/RegisterView.vue"],"sourcesContent":["<template>\n  <div class=\"flex flex-col min-h-screen\">\n  <HeadView />\n  <main class=\"flex-1 pt-14 relative z-[1] bg-gray-50\">\n    <div class=\"sm:mx-auto sm:w-full sm:max-w-md pt-8\">\n      <h2 class=\"mt-6 text-center text-2xl font-bold leading-9 tracking-tight text-gray-900\">注册账号</h2>\n    </div>\n    <div class=\"mt-10 sm:mx-auto sm:w-full sm:max-w-[480px]\">\n      <div class=\"bg-white px-6 py-12 shadow sm:rounded-lg sm:px-12\">\n        <form class=\"space-y-6\" @submit.prevent=\"handleRegister\">\n          <!-- 手机号输入 -->\n          <div>\n            <label for=\"phone\" class=\"block text-sm font-medium leading-6 text-gray-900\">手机号</label>\n            <div class=\"mt-2\">\n              <input \n                id=\"phone\" \n                v-model=\"form.phone\" \n                type=\"text\" \n                required\n                placeholder=\"请输入手机号\"\n                class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n              />\n            </div>\n          </div>\n\n          <!-- 验证码输入 -->\n          <div>\n            <label for=\"code\" class=\"block text-sm font-medium leading-6 text-gray-900\">验证码</label>\n            <div class=\"mt-2 flex\">\n              <div class=\"flex-grow\">\n                <input \n                  id=\"code\" \n                  v-model=\"form.code\" \n                  type=\"text\" \n                  required\n                  placeholder=\"请输入验证码\"\n                  class=\"block w-full rounded-l-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n                />\n              </div>\n              <button \n                type=\"button\"\n                @click=\"getVerifyCode\"\n                :disabled=\"form.countdown > 0 || sendingCode\"\n                class=\"relative -ml-px whitespace-nowrap inline-flex items-center rounded-r-md px-6 py-2 text-sm font-semibold ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-10 w-[140px]\"\n                :class=\"form.countdown > 0 || sendingCode ? 'text-gray-400 bg-gray-50' : 'text-indigo-600'\"\n              >\n                <svg v-if=\"sendingCode\" class=\"animate-spin -ml-1 mr-2 h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\">\n                  <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n                  <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n                </svg>\n                <span class=\"w-full text-center\">\n                  {{ sendingCode ? '发送中...' : form.countdown > 0 ? `${form.countdown}s` : '获取验证码' }}\n                </span>\n              </button>\n            </div>\n          </div>\n\n          <!-- 密码输入 -->\n          <div>\n            <label for=\"password\" class=\"block text-sm font-medium leading-6 text-gray-900\">密码</label>\n            <div class=\"mt-2 relative\">\n              <input \n                id=\"password\" \n                v-model=\"form.password\" \n                :type=\"showPassword ? 'text' : 'password'\" \n                required\n                placeholder=\"请输入密码\"\n                class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n              />\n              <button \n                type=\"button\" \n                @click=\"togglePassword\"\n                class=\"absolute inset-y-0 right-0 pr-3 flex items-center\"\n              >\n                <svg v-if=\"showPassword\" class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                </svg>\n                <svg v-else class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                </svg>\n              </button>\n            </div>\n          </div>\n\n          <!-- 服务条款 -->\n          <div class=\"flex items-center\">\n            <input \n              id=\"agree-terms\" \n              v-model=\"agreed\" \n              type=\"checkbox\" \n              required\n              class=\"h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600\" \n            />\n            <label for=\"agree-terms\" class=\"ml-3 block text-sm leading-6 text-gray-900\">\n              我已阅读并同意\n              <a href=\"#\" class=\"font-semibold text-indigo-600 hover:text-indigo-500\">服务条款</a>\n              和\n              <a href=\"#\" class=\"font-semibold text-indigo-600 hover:text-indigo-500\">隐私政策</a>\n            </label>\n          </div>\n\n          <!-- 注册按钮 -->\n          <div>\n            <button \n              type=\"submit\" \n              :disabled=\"!isFormValid || loading\"\n              class=\"flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold leading-6 text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              <svg v-if=\"loading\" class=\"animate-spin -ml-1 mr-3 h-5 w-5 text-white\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n                <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n              </svg>\n              {{ loading ? '注册中...' : '注册' }}\n            </button>\n          </div>\n        </form>\n\n        <!-- 登录链接 -->\n        <div>\n          <div class=\"relative mt-10\">\n            <div class=\"absolute inset-0 flex items-center\" aria-hidden=\"true\">\n              <div class=\"w-full border-t border-gray-200\"></div>\n            </div>\n            <div class=\"relative flex justify-center text-sm font-medium leading-6\">\n              <span class=\"bg-white px-6 text-gray-900\">已有账号?</span>\n            </div>\n          </div>\n\n          <div class=\"mt-6\">\n            <router-link \n              to=\"/login\"\n              class=\"flex w-full justify-center rounded-md bg-white px-3 py-1.5 text-sm font-semibold leading-6 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600\"\n            >\n              登录\n            </router-link>\n          </div>\n        </div>\n      </div>\n    </div>\n\n</main>\n</div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, onUnmounted } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { register, sendSmsCode } from '@/api/user'\nimport { SMS_SCENE } from '@/store'\nimport HeadView from '@/components/HeadView.vue'\n\n/**\n * Vuex store 实例\n * @type {import('vuex').Store}\n */\nconst store = useStore()\n\n/**\n * Vue Router 实例\n * @type {import('vue-router').Router}\n */\nconst router = useRouter()\n\n/**\n * 表单数据\n * @type {import('vue').Ref<Object>}\n */\nconst form = ref({\n  phone: '',\n  password: '',\n  code: '',\n  countdown: 0\n})\n\n/**\n * UI 状态变量\n */\nconst showPassword = ref(false)\nconst agreed = ref(false)\nconst loading = ref(false)\nconst sendingCode = ref(false)\n\n/**\n * 表单验证计算属性\n * @type {import('vue').ComputedRef<boolean>}\n */\nconst isFormValid = computed(() => {\n  return form.value.phone && \n         form.value.code && \n         form.value.password && \n         form.value.password.length >= 6 && \n         agreed.value\n})\n\n/**\n * 切换密码显示状态\n */\nconst togglePassword = () => {\n  showPassword.value = !showPassword.value\n}\n\n/**\n * 统一错误处理函数\n * @param {Error} error - 错误对象\n * @param {Object} options - 处理选项\n * @param {string} options.type - 错误类型 ('register'|'sendCode')\n * @param {Function} options.onRegistered - 已注册回调\n */\n const handleError = (error, { type, onRegistered }) => {\n  const errorData = error.response?.data\n  \n  // 处理已注册错误\n  if (errorData?.errors?.phone?.[0]?.includes('已注册')) {\n    showToast('手机号已注册', 'warning')\n    onRegistered()\n    return\n  }\n  \n  // 处理验证码错误\n  if (errorData?.errors?.code?.[0]?.includes('验证码')) {\n    showToast('验证码错误或已过期，请重新获取', 'error')\n    return\n  }\n  \n  // 处理其他业务错误\n  if (errorData?.message) {\n    showToast(errorData.message, 'error')\n    return\n  }\n  \n  // 处理默认错误\n  const defaultMessages = {\n    sendCode: '发送验证码失败，请稍后重试',\n    register: '注册失败，请稍后重试'\n  }\n  showToast(defaultMessages[type], 'error')\n}\n\n/**\n * 获取验证码\n */\nconst getVerifyCode = async () => {\n  if (!checkNetwork()) return\n  \n  if (!form.value.phone) {\n    showToast('请输入手机号', 'warning')\n    return\n  }\n  \n  const phoneRegex = /^1[3-9]\\d{9}$/\n  if (!phoneRegex.test(form.value.phone)) {\n    showToast('请输入正确的手机号', 'warning')\n    return\n  }\n\n  try {\n    sendingCode.value = true\n    const response = await sendSmsCode({\n      phone: form.value.phone,\n      scene: SMS_SCENE.REGISTER\n    })\n    \n    if (response.data.code === 200) {\n      form.value.countdown = 60\n      const timer = setInterval(() => {\n        form.value.countdown--\n        if (form.value.countdown <= 0) {\n          clearInterval(timer)\n        }\n      }, 1000)\n      \n      showToast('验证码已发送', 'success')\n    }\n  } catch (error) {\n    handleError(error, {\n      type: 'sendCode',\n      onRegistered: () => router.push('/login')\n    })\n  } finally {\n    sendingCode.value = false\n  }\n}\n\n/**\n * 注册处理\n */\nconst handleRegister = async () => {\n  if (!checkNetwork()) return\n  \n  if (!isFormValid.value) {\n    showToast('请填写完整信息并同意服务条款', 'warning')\n    return\n  }\n\n  const phoneRegex = /^1[3-9]\\d{9}$/\n  if (!phoneRegex.test(form.value.phone)) {\n    showToast('请输入正确的手机号', 'warning')\n    return\n  }\n\n  try {\n    loading.value = true\n    const registerResponse = await register({\n      phone: form.value.phone,\n      password: form.value.password,\n      code: form.value.code\n    })\n    \n    if (registerResponse.data.code === 200) {\n      try {\n        await store.dispatch('loginWithPassword', {\n          credentials: {\n            phone: form.value.phone,\n            password: form.value.password\n          },\n          remember: true\n        })\n        \n        showToast('注册成功', 'success')\n        await new Promise(resolve => setTimeout(resolve, 100))\n        router.push('/user')\n      } catch (loginError) {\n        showToast('注册成功，请手动登录', 'info')\n        router.push('/login')\n      }\n    }\n  } catch (error) {\n    handleError(error, {\n      type: 'register',\n      onRegistered: () => router.push('/login')\n    })\n  } finally {\n    loading.value = false\n  }\n}\n\n/**\n * 检查网络连接状态\n * @returns {boolean} 网络是否可用\n */\nconst checkNetwork = () => {\n  if (!navigator.onLine) {\n    showToast('网络连接不稳定，请检查网络设置', 'warning')\n    return false\n  }\n  return true\n}\n\n/**\n * 网络恢复处理\n */\nconst handleOnline = () => {\n  showToast('网络已连接', 'success')\n}\n\n/**\n * 网络断开处理\n */\nconst handleOffline = () => {\n  showToast('网络连接已断开', 'warning')\n}\n\n// 生命周期钩子\nonMounted(() => {\n  window.addEventListener('online', handleOnline)\n  window.addEventListener('offline', handleOffline)\n})\n\nonUnmounted(() => {\n  window.removeEventListener('online', handleOnline)\n  window.removeEventListener('offline', handleOffline)\n})\n</script>"],"mappings":"AAkJA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,WAAW,QAAQ,KAAI;AAC1D,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,QAAQ,EAAEC,WAAW,QAAQ,YAAW;AACjD,SAASC,SAAS,QAAQ,SAAQ;AAClC,OAAOC,QAAQ,MAAM,2BAA0B;;AAE/C;AACA;AACA;AACA;;;;;;;;IACA,MAAMC,KAAK,GAAGP,QAAQ,CAAC;;IAEvB;AACA;AACA;AACA;IACA,MAAMQ,MAAM,GAAGP,SAAS,CAAC;;IAEzB;AACA;AACA;AACA;IACA,MAAMQ,IAAI,GAAGb,GAAG,CAAC;MACfc,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,IAAI,EAAE,EAAE;MACRC,SAAS,EAAE;IACb,CAAC;;IAED;AACA;AACA;IACA,MAAMC,YAAY,GAAGlB,GAAG,CAAC,KAAK;IAC9B,MAAMmB,MAAM,GAAGnB,GAAG,CAAC,KAAK;IACxB,MAAMoB,OAAO,GAAGpB,GAAG,CAAC,KAAK;IACzB,MAAMqB,WAAW,GAAGrB,GAAG,CAAC,KAAK;;IAE7B;AACA;AACA;AACA;IACA,MAAMsB,WAAW,GAAGrB,QAAQ,CAAC,MAAM;MACjC,OAAOY,IAAI,CAACU,KAAK,CAACT,KAAK,IAChBD,IAAI,CAACU,KAAK,CAACP,IAAI,IACfH,IAAI,CAACU,KAAK,CAACR,QAAQ,IACnBF,IAAI,CAACU,KAAK,CAACR,QAAQ,CAACS,MAAM,IAAI,CAAC,IAC/BL,MAAM,CAACI,KAAI;IACpB,CAAC;;IAED;AACA;AACA;IACA,MAAME,cAAc,GAAGA,CAAA,KAAM;MAC3BP,YAAY,CAACK,KAAK,GAAG,CAACL,YAAY,CAACK,KAAI;IACzC;;IAEA;AACA;AACA;AACA;AACA;AACA;AACA;IACC,MAAMG,WAAW,GAAGA,CAACC,KAAK,EAAE;MAAEC,IAAI;MAAEC;IAAa,CAAC,KAAK;MACtD,MAAMC,SAAS,GAAGH,KAAK,CAACI,QAAQ,EAAEC,IAAG;;MAErC;MACA,IAAIF,SAAS,EAAEG,MAAM,EAAEnB,KAAK,GAAG,CAAC,CAAC,EAAEoB,QAAQ,CAAC,KAAK,CAAC,EAAE;QAClD5B,SAAS,CAAC,QAAQ,EAAE,SAAS;QAC7BuB,YAAY,CAAC;QACb;MACF;;MAEA;MACA,IAAIC,SAAS,EAAEG,MAAM,EAAEjB,IAAI,GAAG,CAAC,CAAC,EAAEkB,QAAQ,CAAC,KAAK,CAAC,EAAE;QACjD5B,SAAS,CAAC,iBAAiB,EAAE,OAAO;QACpC;MACF;;MAEA;MACA,IAAIwB,SAAS,EAAEK,OAAO,EAAE;QACtB7B,SAAS,CAACwB,SAAS,CAACK,OAAO,EAAE,OAAO;QACpC;MACF;;MAEA;MACA,MAAMC,eAAe,GAAG;QACtBC,QAAQ,EAAE,eAAe;QACzB9B,QAAQ,EA