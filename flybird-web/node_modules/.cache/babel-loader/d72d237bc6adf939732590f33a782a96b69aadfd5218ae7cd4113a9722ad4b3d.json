{"ast":null,"code":"import { computed, ref } from 'vue';\nimport { SparklesIcon, InformationCircleIcon, CheckCircleIcon, ClockIcon, ArrowTrendingUpIcon, StarIcon, ExclamationTriangleIcon, CheckIcon } from '@heroicons/vue/24/outline';\nimport { useWindowSize } from '@vueuse/core';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'AIDialog',\n  props: {\n    modelValue: Boolean,\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    dimensions: {\n      type: Object,\n      default: () => ({})\n    },\n    totalScore: {\n      type: Number,\n      default: 0\n    },\n    remainingOptimizations: {\n      type: Number,\n      required: true\n    },\n    totalOptimizations: {\n      type: Number,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'action'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const store = useStore();\n    const props = __props;\n    const emit = __emit;\n    const {\n      width\n    } = useWindowSize();\n\n    // 弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 总分颜色\n    const scoreColorClass = computed(() => {\n      if (props.totalScore >= 80) return 'text-green-600';\n      if (props.totalScore >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n\n    // 维度名称\n    const getDimensionName = key => {\n      const nameMap = {\n        basic_info: '基本信息',\n        experience: '工作经历',\n        capability: '能力素质',\n        achievement: '个人成就'\n      };\n      return nameMap[key] || key;\n    };\n\n    // 维度分数颜色\n    const getDimensionScoreClass = score => {\n      if (score >= 80) return 'text-green-600';\n      if (score >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    };\n\n    // 维度进度条颜色\n    const getDimensionProgressClass = score => {\n      if (score >= 80) return 'bg-green-500';\n      if (score >= 60) return 'bg-yellow-500';\n      return 'bg-red-500';\n    };\n    const showOptimizing = ref(false);\n\n    // 处理优化\n    const handleOptimize = () => {\n      showOptimizing.value = true;\n      emit('action', 'optimize');\n    };\n\n    // 优化完成\n    const handleOptimizationComplete = () => {\n      setTimeout(() => {\n        showOptimizing.value = false;\n        emit('update:modelValue', false);\n        ElMessage.success('简历优化完成！');\n      }, 1000);\n    };\n\n    // 建议类型名称\n    const getTypeName = type => {\n      const typeMap = {\n        basic_info: '基本信息',\n        work_experience: '工作经历',\n        skill: '技能特长',\n        education: '教育背景',\n        project: '项目经验',\n        achievement: '个人成就'\n      };\n      return typeMap[type] || type;\n    };\n\n    // 建议类型样式\n    const getTypeClass = type => {\n      const classMap = {\n        basic_info: 'bg-blue-50 text-blue-700',\n        work_experience: 'bg-purple-50 text-purple-700',\n        skill: 'bg-green-50 text-green-700',\n        education: 'bg-yellow-50 text-yellow-700',\n        project: 'bg-indigo-50 text-indigo-700',\n        achievement: 'bg-pink-50 text-pink-700'\n      };\n      return classMap[type] || 'bg-gray-50 text-gray-700';\n    };\n\n    // 按重要性和提升分数排序的建议\n    const sortedSuggestions = computed(() => {\n      const importanceOrder = {\n        high: 3,\n        medium: 2,\n        low: 1\n      };\n      return [...props.suggestions].sort((a, b) => {\n        const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance];\n        if (importanceDiff !== 0) return importanceDiff;\n        return b.score_impact - a.score_impact;\n      });\n    });\n\n    // 是否是VIP会员\n    const isVip = computed(() => store.getters.isVip);\n    const __returned__ = {\n      store,\n      props,\n      emit,\n      width,\n      dialogWidth,\n      scoreColorClass,\n      getDimensionName,\n      getDimensionScoreClass,\n      getDimensionProgressClass,\n      showOptimizing,\n      handleOptimize,\n      handleOptimizationComplete,\n      getTypeName,\n      getTypeClass,\n      sortedSuggestions,\n      isVip,\n      computed,\n      ref,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get InformationCircleIcon() {\n        return InformationCircleIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get ArrowTrendingUpIcon() {\n        return ArrowTrendingUpIcon;\n      },\n      get StarIcon() {\n        return StarIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","ref","SparklesIcon","InformationCircleIcon","CheckCircleIcon","ClockIcon","ArrowTrendingUpIcon","StarIcon","ExclamationTriangleIcon","CheckIcon","useWindowSize","useStore","ElMessage","store","props","__props","emit","__emit","width","dialogWidth","value","scoreColorClass","totalScore","getDimensionName","key","nameMap","basic_info","experience","capability","achievement","getDimensionScoreClass","score","getDimensionProgressClass","showOptimizing","handleOptimize","handleOptimizationComplete","setTimeout","success","getTypeName","type","typeMap","work_experience","skill","education","project","getTypeClass","classMap","sortedSuggestions","importanceOrder","high","medium","low","suggestions","sort","a","b","importanceDiff","importance","score_impact","isVip","getters"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/AIDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"AI 优化建议\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n  >\n    <div class=\"space-y-6\">\n      <!-- 总体评分和优化次数 -->\n      <div class=\"bg-gray-50 rounded-lg p-4\">\n        <div class=\"flex items-center justify-between mb-2\">\n          <div class=\"flex items-center space-x-4\">\n            <h3 class=\"text-base font-medium text-gray-900\">总体评分</h3>\n            <div class=\"flex items-center space-x-1 text-sm text-gray-500\">\n              <SparklesIcon class=\"w-4 h-4\" />\n              <span>剩余优化次数：</span>\n              <span class=\"font-medium\" :class=\"{'text-red-600': remainingOptimizations === 0}\">\n                {{ remainingOptimizations }}/{{ totalOptimizations }}\n              </span>\n              <el-tooltip v-if=\"!isVip\" effect=\"dark\" placement=\"top\">\n                <template #content>\n                  <div class=\"text-xs\">\n                    <p>普通用户每月可使用3次</p>\n                    <p class=\"mt-1\">升级会员可享无限次数</p>\n                  </div>\n                </template>\n                <InformationCircleIcon class=\"w-4 h-4 cursor-help\" />\n              </el-tooltip>\n            </div>\n          </div>\n          <span class=\"text-lg font-semibold\" :class=\"scoreColorClass\">{{ totalScore }}分</span>\n        </div>\n        <p class=\"text-sm text-gray-600\">基于各维度权重计算的综合评分</p>\n      </div>\n\n      <!-- AI 优化内容区域 -->\n      <div v-if=\"optimizationResult\" class=\"space-y-6\">\n        <!-- 主要改进点 -->\n        <div class=\"bg-indigo-50 rounded-lg p-4\">\n          <h4 class=\"text-sm font-medium text-indigo-900 mb-2\">主要改进建议</h4>\n          <ul class=\"space-y-1\">\n            <li v-for=\"(improvement, index) in optimizationResult.summary.key_improvements\" \n              :key=\"index\"\n              class=\"text-sm text-indigo-700 flex items-start space-x-2\"\n            >\n              <CheckCircleIcon class=\"w-4 h-4 mt-0.5 flex-shrink-0\" />\n              <span>{{ improvement }}</span>\n            </li>\n          </ul>\n        </div>\n\n        <!-- 各部分优化内容 -->\n        <div class=\"space-y-4\">\n          <template v-for=\"(section, sectionKey) in optimizationResult.preview\" :key=\"sectionKey\">\n            <div v-for=\"(item, itemKey) in section\" :key=\"itemKey\">\n              <div class=\"border rounded-lg mb-4\">\n                <div class=\"bg-gray-50 px-4 py-2 rounded-t-lg flex items-center justify-between\">\n                  <h4 class=\"font-medium text-gray-900\">{{ getSectionTitle(sectionKey, itemKey) }}</h4>\n                  <span class=\"text-xs text-gray-500\">{{ getItemTitle(item) }}</span>\n                </div>\n                <div class=\"p-4 space-y-4\">\n                  <!-- 前后对比 -->\n                  <div class=\"grid grid-cols-2 gap-6\">\n                    <div class=\"space-y-2\">\n                      <div class=\"flex items-center text-sm text-gray-500\">\n                        <ClockIcon class=\"w-4 h-4 mr-1\" />\n                        <span>当前内容</span>\n                      </div>\n                      <div class=\"bg-gray-50 p-3 rounded text-sm text-gray-600\">\n                        {{ item.before }}\n                      </div>\n                    </div>\n                    <div class=\"space-y-2\">\n                      <div class=\"flex items-center text-sm text-green-600\">\n                        <SparklesIcon class=\"w-4 h-4 mr-1\" />\n                        <span>优化建议</span>\n                      </div>\n                      <div class=\"bg-green-50 p-3 rounded text-sm text-gray-800\">\n                        {{ item.after }}\n                      </div>\n                    </div>\n                  </div>\n                  <!-- 改进说明 -->\n                  <div class=\"border-t pt-3\">\n                    <h5 class=\"text-sm font-medium text-gray-700 mb-2\">优化要点：</h5>\n                    <ul class=\"space-y-1\">\n                      <li v-for=\"(change, index) in item.changes\" \n                        :key=\"index\"\n                        class=\"text-sm text-gray-600 flex items-start space-x-2\"\n                      >\n                        <ArrowTrendingUpIcon class=\"w-4 h-4 text-green-500 mt-0.5 flex-shrink-0\" />\n                        <span>{{ change }}</span>\n                      </li>\n                    </ul>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </template>\n        </div>\n\n        <!-- 预期效果 -->\n        <div class=\"bg-green-50 rounded-lg p-4\">\n          <h4 class=\"text-sm font-medium text-green-900 mb-2\">预期效果</h4>\n          <ul class=\"space-y-1\">\n            <li v-for=\"(benefit, index) in optimizationResult.summary.expected_benefits\" \n              :key=\"index\"\n              class=\"text-sm text-green-700 flex items-start space-x-2\"\n            >\n              <StarIcon class=\"w-4 h-4 mt-0.5 flex-shrink-0\" />\n              <span>{{ benefit }}</span>\n            </li>\n          </ul>\n        </div>\n\n        <!-- 确认按钮 -->\n        <div class=\"flex justify-between items-center pt-4 border-t\">\n          <div class=\"text-sm text-gray-500\">\n            <ExclamationTriangleIcon class=\"w-4 h-4 inline mr-1 text-yellow-500\" />\n            确认后将覆盖原有内容\n          </div>\n          <div class=\"flex space-x-3\">\n            <button\n              @click=\"handleCancel\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\"\n            >\n              放弃优化\n            </button>\n            <button\n              @click=\"handleConfirm\"\n              :disabled=\"loading\"\n              class=\"inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-md transition-colors disabled:opacity-50\"\n            >\n              <CheckIcon class=\"w-4 h-4 mr-1.5\" />\n              {{ loading ? '确认中...' : '确认应用' }}\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- 开始优化按钮 -->\n      <div v-else class=\"flex justify-center\">\n        <button\n          @click=\"handleOptimize\"\n          :disabled=\"loading || remainingOptimizations === 0\"\n          class=\"inline-flex items-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\n        >\n          <SparklesIcon class=\"w-5 h-5 mr-2\" />\n          {{ loading ? '优化中...' : '开始AI优化' }}\n        </button>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { computed, ref } from 'vue'\nimport { SparklesIcon, InformationCircleIcon, CheckCircleIcon, ClockIcon, ArrowTrendingUpIcon, StarIcon, ExclamationTriangleIcon, CheckIcon } from '@heroicons/vue/24/outline'\nimport { useWindowSize } from '@vueuse/core'\nimport { useStore } from 'vuex'\nimport { ElMessage } from 'element-plus'\n\nconst store = useStore()\n\nconst props = defineProps({\n  modelValue: Boolean,\n  suggestions: {\n    type: Array,\n    default: () => []\n  },\n  dimensions: {\n    type: Object,\n    default: () => ({})\n  },\n  totalScore: {\n    type: Number,\n    default: 0\n  },\n  remainingOptimizations: {\n    type: Number,\n    required: true\n  },\n  totalOptimizations: {\n    type: Number,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'action'])\n\nconst { width } = useWindowSize()\n\n// 弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 总分颜色\nconst scoreColorClass = computed(() => {\n  if (props.totalScore >= 80) return 'text-green-600'\n  if (props.totalScore >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n})\n\n// 维度名称\nconst getDimensionName = (key) => {\n  const nameMap = {\n    basic_info: '基本信息',\n    experience: '工作经历',\n    capability: '能力素质',\n    achievement: '个人成就'\n  }\n  return nameMap[key] || key\n}\n\n// 维度分数颜色\nconst getDimensionScoreClass = (score) => {\n  if (score >= 80) return 'text-green-600'\n  if (score >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n}\n\n// 维度进度条颜色\nconst getDimensionProgressClass = (score) => {\n  if (score >= 80) return 'bg-green-500'\n  if (score >= 60) return 'bg-yellow-500'\n  return 'bg-red-500'\n}\n\nconst showOptimizing = ref(false)\n\n// 处理优化\nconst handleOptimize = () => {\n  showOptimizing.value = true\n  emit('action', 'optimize')\n}\n\n// 优化完成\nconst handleOptimizationComplete = () => {\n  setTimeout(() => {\n    showOptimizing.value = false\n    emit('update:modelValue', false)\n    ElMessage.success('简历优化完成！')\n  }, 1000)\n}\n\n// 建议类型名称\nconst getTypeName = (type) => {\n  const typeMap = {\n    basic_info: '基本信息',\n    work_experience: '工作经历',\n    skill: '技能特长',\n    education: '教育背景',\n    project: '项目经验',\n    achievement: '个人成就'\n  }\n  return typeMap[type] || type\n}\n\n// 建议类型样式\nconst getTypeClass = (type) => {\n  const classMap = {\n    basic_info: 'bg-blue-50 text-blue-700',\n    work_experience: 'bg-purple-50 text-purple-700',\n    skill: 'bg-green-50 text-green-700',\n    education: 'bg-yellow-50 text-yellow-700',\n    project: 'bg-indigo-50 text-indigo-700',\n    achievement: 'bg-pink-50 text-pink-700'\n  }\n  return classMap[type] || 'bg-gray-50 text-gray-700'\n}\n\n// 按重要性和提升分数排序的建议\nconst sortedSuggestions = computed(() => {\n  const importanceOrder = { high: 3, medium: 2, low: 1 }\n  return [...props.suggestions].sort((a, b) => {\n    const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance]\n    if (importanceDiff !== 0) return importanceDiff\n    return b.score_impact - a.score_impact\n  })\n})\n\n// 是否是VIP会员\nconst isVip = computed(() => store.getters.isVip)\n</script>"],"mappings":"AA8JA,SAASA,QAAQ,EAAEC,GAAG,QAAQ,KAAI;AAClC,SAASC,YAAY,EAAEC,qBAAqB,EAAEC,eAAe,EAAEC,SAAS,EAAEC,mBAAmB,EAAEC,QAAQ,EAAEC,uBAAuB,EAAEC,SAAS,QAAQ,2BAA0B;AAC7K,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGF,QAAQ,CAAC;IAEvB,MAAMG,KAAK,GAAGC,OAAA;IAyBd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAM;MAAEC;IAAM,CAAC,GAAGR,aAAa,CAAC;;IAEhC;IACA,MAAMS,WAAW,GAAGnB,QAAQ,CAAC,MAAM;MACjC,IAAIkB,KAAK,CAACE,KAAK,GAAG,GAAG,EAAE,OAAO,KAAI;MAClC,IAAIF,KAAK,CAACE,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;;IAED;IACA,MAAMC,eAAe,GAAGrB,QAAQ,CAAC,MAAM;MACrC,IAAIc,KAAK,CAACQ,UAAU,IAAI,EAAE,EAAE,OAAO,gBAAe;MAClD,IAAIR,KAAK,CAACQ,UAAU,IAAI,EAAE,EAAE,OAAO,iBAAgB;MACnD,OAAO,cAAa;IACtB,CAAC;;IAED;IACA,MAAMC,gBAAgB,GAAIC,GAAG,IAAK;MAChC,MAAMC,OAAO,GAAG;QACdC,UAAU,EAAE,MAAM;QAClBC,UAAU,EAAE,MAAM;QAClBC,UAAU,EAAE,MAAM;QAClBC,WAAW,EAAE;MACf;MACA,OAAOJ,OAAO,CAACD,GAAG,CAAC,IAAIA,GAAE;IAC3B;;IAEA;IACA,MAAMM,sBAAsB,GAAIC,KAAK,IAAK;MACxC,IAAIA,KAAK,IAAI,EAAE,EAAE,OAAO,gBAAe;MACvC,IAAIA,KAAK,IAAI,EAAE,EAAE,OAAO,iBAAgB;MACxC,OAAO,cAAa;IACtB;;IAEA;IACA,MAAMC,yBAAyB,GAAID,KAAK,IAAK;MAC3C,IAAIA,KAAK,IAAI,EAAE,EAAE,OAAO,cAAa;MACrC,IAAIA,KAAK,IAAI,EAAE,EAAE,OAAO,eAAc;MACtC,OAAO,YAAW;IACpB;IAEA,MAAME,cAAc,GAAGhC,GAAG,CAAC,KAAK;;IAEhC;IACA,MAAMiC,cAAc,GAAGA,CAAA,KAAM;MAC3BD,cAAc,CAACb,KAAK,GAAG,IAAG;MAC1BJ,IAAI,CAAC,QAAQ,EAAE,UAAU;IAC3B;;IAEA;IACA,MAAMmB,0BAA0B,GAAGA,CAAA,KAAM;MACvCC,UAAU,CAAC,MAAM;QACfH,cAAc,CAACb,KAAK,GAAG,KAAI;QAC3BJ,IAAI,CAAC,mBAAmB,EAAE,KAAK;QAC/BJ,SAAS,CAACyB,OAAO,CAAC,SAAS;MAC7B,CAAC,EAAE,IAAI;IACT;;IAEA;IACA,MAAMC,WAAW,GAAIC,IAAI,IAAK;MAC5B,MAAMC,OAAO,GAAG;QACdd,UAAU,EAAE,MAAM;QAClBe,eAAe,EAAE,MAAM;QACvBC,KAAK,EAAE,MAAM;QACbC,SAAS,EAAE,MAAM;QACjBC,OAAO,EAAE,MAAM;QACff,WAAW,EAAE;MACf;MACA,OA