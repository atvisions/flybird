{"ast":null,"code":"import { BriefcaseIcon, UserCircleIcon, CurrencyYenIcon, MapPinIcon, BuildingOfficeIcon, DocumentPlusIcon, AcademicCapIcon } from '@heroicons/vue/24/outline';\nimport { onMounted, watch } from 'vue';\nexport default {\n  __name: 'JobIntentionContent',\n  props: {\n    data: {\n      type: Object,\n      default: () => ({})\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 获取工作类型标签\n    const getJobTypeLabel = value => {\n      const typeMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return typeMap[value] || '未设置';\n    };\n\n    // 获取求职状态标签\n    const getJobStatusLabel = value => {\n      const statusMap = {\n        'actively_looking': '正在积极找工作',\n        'open': '对机会持开放态度',\n        'not_looking': '暂时不找工作'\n      };\n      return statusMap[value] || '未设置';\n    };\n\n    // 获取薪资标签\n    const getSalaryLabel = value => {\n      if (!value) return '未设置';\n      if (typeof value === 'string') return value;\n      return `${value}K/月`;\n    };\n\n    // 格式化城市\n    const formatCity = city => {\n      if (!city) return '未设置';\n      return city.split('-').join('、');\n    };\n\n    // 格式化行业\n    const formatIndustries = industries => {\n      if (!industries) return '未设置';\n      if (Array.isArray(industries)) {\n        return industries.join('、');\n      }\n      return industries.split(',').join('、');\n    };\n\n    // 调试日志\n    onMounted(() => {\n      console.log('JobIntentionContent mounted, data:', props.data);\n    });\n    watch(() => props.data, newData => {\n      console.log('JobIntentionContent data changed:', newData);\n    }, {\n      deep: true\n    });\n    const __returned__ = {\n      props,\n      getJobTypeLabel,\n      getJobStatusLabel,\n      getSalaryLabel,\n      formatCity,\n      formatIndustries,\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get UserCircleIcon() {\n        return UserCircleIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BuildingOfficeIcon() {\n        return BuildingOfficeIcon;\n      },\n      get DocumentPlusIcon() {\n        return DocumentPlusIcon;\n      },\n      get AcademicCapIcon() {\n        return AcademicCapIcon;\n      },\n      onMounted,\n      watch\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["BriefcaseIcon","UserCircleIcon","CurrencyYenIcon","MapPinIcon","BuildingOfficeIcon","DocumentPlusIcon","AcademicCapIcon","onMounted","watch","props","__props","getJobTypeLabel","value","typeMap","getJobStatusLabel","statusMap","getSalaryLabel","formatCity","city","split","join","formatIndustries","industries","Array","isArray","console","log","data","newData","deep"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-3\">\n    <template v-if=\"data\">\n      <!-- 求职状态 -->\n      <div class=\"flex items-center\">\n        <div class=\"w-7 h-7 rounded-md bg-green-50 flex items-center justify-center mr-3\">\n          <UserCircleIcon class=\"w-4 h-4 text-green-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <div class=\"text-xs text-gray-400\">求职状态</div>\n          <div class=\"text-sm text-gray-700 mt-0.5\">{{ getJobStatusLabel(data.job_status) }}</div>\n        </div>\n      </div>\n\n      <!-- 工作类型 -->\n      <div class=\"flex items-center\">\n        <div class=\"w-7 h-7 rounded-md bg-blue-50 flex items-center justify-center mr-3\">\n          <BriefcaseIcon class=\"w-4 h-4 text-blue-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <div class=\"text-xs text-gray-400\">工作类型</div>\n          <div class=\"text-sm text-gray-700 mt-0.5\">{{ getJobTypeLabel(data.job_type) }}</div>\n        </div>\n      </div>\n\n      <!-- 期望薪资 -->\n      <div class=\"flex items-center\">\n        <div class=\"w-7 h-7 rounded-md bg-purple-50 flex items-center justify-center mr-3\">\n          <CurrencyYenIcon class=\"w-4 h-4 text-purple-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <div class=\"text-xs text-gray-400\">期望薪资</div>\n          <div class=\"text-sm text-gray-700 mt-0.5\">{{ getSalaryLabel(data.expected_salary) }}</div>\n        </div>\n      </div>\n\n      <!-- 期望城市 -->\n      <div class=\"flex items-center\">\n        <div class=\"w-7 h-7 rounded-md bg-orange-50 flex items-center justify-center mr-3\">\n          <MapPinIcon class=\"w-4 h-4 text-orange-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <div class=\"text-xs text-gray-400\">期望城市</div>\n          <div class=\"text-sm text-gray-700 mt-0.5\">{{ formatCity(data.city) }}</div>\n        </div>\n      </div>\n\n      <!-- 期望行业 -->\n      <div class=\"flex items-center\">\n        <div class=\"w-7 h-7 rounded-md bg-rose-50 flex items-center justify-center mr-3\">\n          <BuildingOfficeIcon class=\"w-4 h-4 text-rose-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <div class=\"text-xs text-gray-400\">期望行业</div>\n          <div class=\"text-sm text-gray-700 mt-0.5\">{{ formatIndustries(data.industry) }}</div>\n        </div>\n      </div>\n\n      <!-- 期望职位 -->\n      <div class=\"flex items-center\">\n        <div class=\"w-7 h-7 rounded-md bg-cyan-50 flex items-center justify-center mr-3\">\n          <AcademicCapIcon class=\"w-4 h-4 text-cyan-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <div class=\"text-xs text-gray-400\">期望职位</div>\n          <div class=\"text-sm text-gray-700 mt-0.5\">{{ data.position || '未设置' }}</div>\n        </div>\n      </div>\n    </template>\n\n    <!-- 空状态 -->\n    <div v-else class=\"flex flex-col items-center justify-center py-8\">\n      <DocumentPlusIcon class=\"w-12 h-12 text-gray-200\" />\n      <p class=\"mt-2 text-sm text-gray-400\">暂无求职意向，点击编辑按钮添加</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { \n  BriefcaseIcon,\n  UserCircleIcon,\n  CurrencyYenIcon,\n  MapPinIcon,\n  BuildingOfficeIcon,\n  DocumentPlusIcon,\n  AcademicCapIcon\n} from '@heroicons/vue/24/outline'\nimport { onMounted, watch } from 'vue'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: () => ({})\n  }\n})\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const typeMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return typeMap[value] || '未设置'\n}\n\n// 获取求职状态标签\nconst getJobStatusLabel = (value) => {\n  const statusMap = {\n    'actively_looking': '正在积极找工作',\n    'open': '对机会持开放态度',\n    'not_looking': '暂时不找工作'\n  }\n  return statusMap[value] || '未设置'\n}\n\n// 获取薪资标签\nconst getSalaryLabel = (value) => {\n  if (!value) return '未设置'\n  if (typeof value === 'string') return value\n  return `${value}K/月`\n}\n\n// 格式化城市\nconst formatCity = (city) => {\n  if (!city) return '未设置'\n  return city.split('-').join('、')\n}\n\n// 格式化行业\nconst formatIndustries = (industries) => {\n  if (!industries) return '未设置'\n  if (Array.isArray(industries)) {\n    return industries.join('、')\n  }\n  return industries.split(',').join('、')\n}\n\n// 调试日志\nonMounted(() => {\n  console.log('JobIntentionContent mounted, data:', props.data)\n})\n\nwatch(() => props.data, (newData) => {\n  console.log('JobIntentionContent data changed:', newData)\n}, { deep: true })\n</script>\n<style scoped>\n.flex {\n  transition: background-color 0.2s ease;\n}\n\n.flex:hover {\n  @apply bg-gray-50 rounded-lg -mx-2 px-2;\n}\n\n.w-7 {\n  transition: transform 0.2s ease;\n}\n\n.flex:hover .w-7 {\n  transform: scale(1.1);\n}\n</style>"],"mappings":"AA+EA,SACEA,aAAa,EACbC,cAAc,