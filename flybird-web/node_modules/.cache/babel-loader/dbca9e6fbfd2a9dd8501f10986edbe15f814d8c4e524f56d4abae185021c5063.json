ate = '请选择开始时间';\n        isValid = false;\n      }\n      if (!form.value.is_current && !form.value.end_date) {\n        errors.value.end_date = '请选择结束时间或勾选\"至今\"';\n        isValid = false;\n      }\n      if (!form.value.description?.trim()) {\n        errors.value.description = '请输入项目描述';\n        isValid = false;\n      }\n\n      // 日期逻辑验证\n      if (form.value.start_date && form.value.end_date && !form.value.is_current) {\n        const startDate = new Date(form.value.start_date);\n        const endDate = new Date(form.value.end_date);\n        if (endDate < startDate) {\n          errors.value.end_date = '结束时间不能早于开始时间';\n          isValid = false;\n        }\n      }\n      return isValid;\n    };\n\n    // 修改提交处理\n    const handleSubmit = () => {\n      if (!validateForm()) {\n        return;\n      }\n      const formData = _objectSpread(_objectSpread({}, form.value), {}, {\n        end_date: form.value.is_current ? null : form.value.end_date\n      });\n      emit('submit', formData);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      form,\n      errors,\n      handleClose,\n      validateForm,\n      handleSubmit,\n      ref,\n      watch,\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get TransitionChild() {\n        return TransitionChild;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","Dialog","DialogPanel","DialogTitle","TransitionRoot","TransitionChild","XMarkIcon","CalendarIcon","props","__props","emit","__emit","form","name