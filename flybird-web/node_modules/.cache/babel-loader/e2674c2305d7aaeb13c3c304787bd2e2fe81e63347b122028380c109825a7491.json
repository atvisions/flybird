{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { Menu, MenuButton, MenuItem, MenuItems } from '@headlessui/vue';\nimport { Bars3Icon, ChevronDownIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'HeadView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n    const router = useRouter();\n    const mobileMenuOpen = ref(false);\n    const isAuthenticated = computed(() => store.state.isAuthenticated);\n    const userAvatar = computed(() => store.getters.userAvatar);\n    const userName = computed(() => store.getters.userName);\n    const handleLogout = async () => {\n      try {\n        await store.dispatch('logout');\n        router.push('/login');\n      } catch (error) {\n        console.error('Logout failed:', error);\n      }\n    };\n    const __returned__ = {\n      store,\n      router,\n      mobileMenuOpen,\n      isAuthenticated,\n      userAvatar,\n      userName,\n      handleLogout,\n      ref,\n      computed,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get Menu() {\n        return Menu;\n      },\n      get MenuButton() {\n        return MenuButton;\n      },\n      get MenuItem() {\n        return MenuItem;\n      },\n      get MenuItems() {\n        return MenuItems;\n      },\n      get Bars3Icon() {\n        return Bars3Icon;\n      },\n      get ChevronDownIcon() {\n        return ChevronDownIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","useRouter","Menu","MenuButton","MenuItem","MenuItems","Bars3Icon","ChevronDownIcon","store","router","mobileMenuOpen","isAuthenticated","state","userAvatar","getters","userName","handleLogout","dispatch","push","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/components/HeadView.vue"],"sourcesContent":["<template>\n  <header class=\"bg-white shadow-sm lg:static lg:overflow-y-visible\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n      <div class=\"relative flex justify-between xl:grid xl:grid-cols-12 lg:gap-8\">\n        <div class=\"flex md:absolute md:left-0 md:inset-y-0 lg:static xl:col-span-2\">\n          <div class=\"flex-shrink-0 flex items-center\">\n            <router-link to=\"/\" class=\"block\">\n              <img class=\"h-8 w-auto\" src=\"@/assets/logo.png\" alt=\"Logo\" />\n            </router-link>\n          </div>\n        </div>\n        \n        <!-- 用户菜单 -->\n        <div class=\"flex items-center md:absolute md:right-0 md:inset-y-0 lg:hidden\">\n          <button\n            type=\"button\"\n            class=\"-mx-2 rounded-md p-2 inline-flex items-center justify-center text-gray-400 hover:bg-gray-100 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary-500\"\n            @click=\"mobileMenuOpen = true\"\n          >\n            <span class=\"sr-only\">打开菜单</span>\n            <!-- 使用具体的图标组件替代 getIcon -->\n            <Bars3Icon class=\"block h-6 w-6\" aria-hidden=\"true\" />\n          </button>\n        </div>\n\n        <!-- 导航菜单 -->\n        <div class=\"hidden lg:flex lg:items-center lg:justify-end xl:col-span-10\">\n          <div class=\"flex items-center space-x-6\">\n            <template v-if=\"isAuthenticated\">\n              <!-- 用户头像和下拉菜单 -->\n              <Menu as=\"div\" class=\"ml-3 relative\">\n                <div>\n                  <MenuButton class=\"max-w-xs bg-white rounded-full flex items-center text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 lg:p-2 lg:rounded-md lg:hover:bg-gray-50\">\n                    <img class=\"h-8 w-8 rounded-full\" :src=\"userAvatar\" alt=\"\" />\n                    <span class=\"hidden ml-3 text-gray-700 text-sm font-medium lg:block\">\n                      {{ userName }}\n                    </span>\n                    <ChevronDownIcon class=\"hidden flex-shrink-0 ml-1 h-5 w-5 text-gray-400 lg:block\" aria-hidden=\"true\" />\n                  </MenuButton>\n                </div>\n                <!-- 下拉菜单内容 -->\n                <transition\n                  enter-active-class=\"transition ease-out duration-100\"\n                  enter-from-class=\"transform opacity-0 scale-95\"\n                  enter-to-class=\"transform opacity-100 scale-100\"\n                  leave-active-class=\"transition ease-in duration-75\"\n                  leave-from-class=\"transform opacity-100 scale-100\"\n                  leave-to-class=\"transform opacity-0 scale-95\"\n                >\n                  <MenuItems class=\"origin-top-right absolute right-0 mt-2 w-48 rounded-md shadow-lg py-1 bg-white ring-1 ring-black ring-opacity-5 focus:outline-none\">\n                    <!-- 菜单项 -->\n                    <MenuItem v-slot=\"{ active }\">\n                      <router-link to=\"/user\" :class=\"[active ? 'bg-gray-100' : '', 'block px-4 py-2 text-sm text-gray-700']\">\n                        个人中心\n                      </router-link>\n                    </MenuItem>\n                    <MenuItem v-slot=\"{ active }\">\n                      <a href=\"#\" @click.prevent=\"handleLogout\" :class=\"[active ? 'bg-gray-100' : '', 'block px-4 py-2 text-sm text-gray-700']\">\n                        退出登录\n                      </a>\n                    </MenuItem>\n                  </MenuItems>\n                </transition>\n              </Menu>\n            </template>\n            <template v-else>\n              <router-link to=\"/login\" class=\"text-sm font-medium text-gray-900 hover:text-gray-700\">\n                登录\n              </router-link>\n              <router-link to=\"/register\" class=\"text-sm font-medium text-white bg-primary-600 px-4 py-2 rounded-md hover:bg-primary-700\">\n                注册\n              </router-link>\n            </template>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { Menu, MenuButton, MenuItem, MenuItems } from '@headlessui/vue'\nimport {\n  Bars3Icon,\n  ChevronDownIcon\n} from '@heroicons/vue/24/outline'\n\nconst store = useStore()\nconst router = useRouter()\nconst mobileMenuOpen = ref(false)\n\nconst isAuthenticated = computed(() => store.state.isAuthenticated)\nconst userAvatar = computed(() => store.getters.userAvatar)\nconst userName = computed(() => store.getters.userName)\n\nconst handleLogout = async () => {\n  try {\n    await store.dispatch('logout')\n    router.push('/login')\n  } catch (error) {\n    console.error('Logout failed:', error)\n  }\n}\n</script>\n\n<style scoped>\n/* 样式保持不变 */\n</style>"],"mappings":"AAiFA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,IAAI,EAAEC,UAAU,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,iBAAgB;AACtE,SACEC,SAAS,EACTC,eAAc,QACT,2BAA0B;;;;;;;IAEjC,MAAMC,KAAK,GAAGR,QAAQ,CAAC;IACvB,MAAMS,MAAM,GAAGR,SAAS,CAAC;IACzB,MAAMS,cAAc,GAAGZ,GAAG,CAAC,KAAK;IAEhC,MAAMa,eAAe,GAAGZ,QAAQ,CAAC,MAAMS,KAAK,CAACI,KAAK,CAACD,eAAe;IAClE,MAAME,UAAU,GAAGd,QAAQ,CAAC,MAAMS,KAAK,CAACM,OAAO,CAACD,UAAU;IAC1D,MAAME,QAAQ,GAAGhB,QAAQ,CAAC,MAAMS,KAAK,CAACM,OAAO,CAACC,QAAQ;IAEtD,MAAMC,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/B,IAAI;QACF,MAAMR,KAAK,CAACS,QAAQ,CAAC,QAAQ;QAC7BR,MAAM,CAACS,IAAI,CAAC,QAAQ;MACtB,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,gBAAgB,EAAEA,KAAK;MACvC;IACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}