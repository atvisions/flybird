{"ast":null,"code":"import { ref } from 'vue';\nimport { PencilSquareIcon, TrashIcon, PlusIcon, ExclamationTriangleIcon } from '@heroicons/vue/24/outline';\nimport { ALL_MODULES } from '@/constants';\nimport JobIntentionContent from './JobIntentionContent.vue';\nimport WorkExperienceContent from './WorkExperienceContent.vue';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['remove', 'edit', 'edit-item', 'remove-item'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const emit = __emit;\n\n    // 获取模块显示名称\n    const getModuleName = type => {\n      return ALL_MODULES[type] || type;\n    };\n\n    // 删除确认相关\n    const showDeleteConfirm = ref(false);\n    const moduleToDelete = ref(null);\n\n    // 处理移除按钮点击\n    const handleRemove = moduleType => {\n      moduleToDelete.value = moduleType;\n      showDeleteConfirm.value = true;\n    };\n\n    // 确认移除\n    const confirmRemove = () => {\n      if (moduleToDelete.value) {\n        emit('remove', moduleToDelete.value);\n        showDeleteConfirm.value = false;\n        moduleToDelete.value = null;\n      }\n    };\n    const __returned__ = {\n      emit,\n      getModuleName,\n      showDeleteConfirm,\n      moduleToDelete,\n      handleRemove,\n      confirmRemove,\n      ref,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      },\n      get ALL_MODULES() {\n        return ALL_MODULES;\n      },\n      JobIntentionContent,\n      WorkExperienceContent\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","PencilSquareIcon","TrashIcon","PlusIcon","ExclamationTriangleIcon","ALL_MODULES","JobIntentionContent","WorkExperienceContent","emit","__emit","getModuleName","type","showDeleteConfirm","moduleToDelete","handleRemove","moduleType","value","confirmRemove"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"module in activeModules\" :key=\"module.type\" class=\"bg-white rounded-lg shadow\">\n      <div class=\"flex items-center justify-between px-4 py-3\">\n        <h3 class=\"text-base font-medium text-gray-900\">{{ getModuleName(module.type) }}</h3>\n        <div class=\"flex items-center space-x-2\">\n          <button\n            @click=\"$emit('edit', module.type)\"\n            class=\"p-1 hover:bg-gray-100 rounded-full\"\n          >\n            <PencilSquareIcon class=\"w-5 h-5 text-gray-400\" />\n          </button>\n          <button\n            @click=\"handleRemove(module.type)\"\n            class=\"p-1 hover:bg-gray-100 rounded-full\"\n          >\n            <TrashIcon class=\"w-5 h-5 text-gray-400\" />\n          </button>\n        </div>\n      </div>\n      \n      <div class=\"px-4 pb-4\">\n        <div v-if=\"!module.data\" class=\"text-center text-gray-400 py-4\">\n          暂无内容，点击编辑添加\n        </div>\n        <div v-else class=\"text-gray-600\">\n          {{ module.data }}\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 删除确认弹窗 -->\n  <el-dialog\n    v-model=\"showDeleteConfirm\"\n    width=\"400px\"\n    :show-close=\"false\"\n    class=\"delete-confirm-dialog\"\n    destroy-on-close\n  >\n    <div class=\"p-6\">\n      <div class=\"flex items-start space-x-3\">\n        <div class=\"p-2 bg-red-50 rounded-full\">\n          <ExclamationTriangleIcon class=\"w-6 h-6 text-red-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <h3 class=\"text-lg font-medium text-gray-900\">确认移除板块？</h3>\n          <p class=\"mt-2 text-sm text-gray-500\">\n            移除板块后，该板块将移至\"更多模块\"中，您可以随时重新添加。\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"mt-6 flex justify-end space-x-3\">\n        <button\n          @click=\"showDeleteConfirm = false\"\n          class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n        >\n          取消\n        </button>\n        <button\n          @click=\"confirmRemove\"\n          class=\"px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500\"\n        >\n          确认移除\n        </button>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { \n  PencilSquareIcon, \n  TrashIcon,\n  PlusIcon,\n  ExclamationTriangleIcon \n} from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\nimport JobIntentionContent from './JobIntentionContent.vue'\nimport WorkExperienceContent from './WorkExperienceContent.vue'\n\ndefineProps({\n  activeModules: {\n    type: Array,\n    required: true\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['remove', 'edit', 'edit-item', 'remove-item'])\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n\n// 删除确认相关\nconst showDeleteConfirm = ref(false)\nconst moduleToDelete = ref(null)\n\n// 处理移除按钮点击\nconst handleRemove = (moduleType) => {\n  moduleToDelete.value = moduleType\n  showDeleteConfirm.value = true\n}\n\n// 确认移除\nconst confirmRemove = () => {\n  if (moduleToDelete.value) {\n    emit('remove', moduleToDelete.value)\n    showDeleteConfirm.value = false\n    moduleToDelete.value = null\n  }\n}\n</script>\n\n<style scoped>\n.delete-confirm-dialog :deep(.el-dialog__body) {\n  @apply p-0;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .delete-confirm-dialog {\n    margin: 0 !important;\n  }\n  \n  .p-6 {\n    @apply p-4;\n  }\n}\n</style>"],"mappings":"AAyEA,SAASA,GAAG,QAAQ,KAAI;AACxB,SACEC,gBAAgB,EAChBC,SAAS,EACTC,QAAQ,EACRC,uBAAuB,QAClB,2BAA0B;AACjC,SAASC,WAAW,QAAQ,aAAY;AACxC,OAAOC,mBAAmB,MAAM,2BAA0B;AAC1D,OAAOC,qBAAqB,MAAM,6BAA4B;;;;;;;;;;;;;;;;;;;IAa9D,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,aAAa,GAAIC,IAAI,IAAK;MAC9B,OAAON,WAAW,CAACM,IAAI,CAAC,IAAIA,IAAG;IACjC;;IAEA;IACA,MAAMC,iBAAiB,GAAGZ,GAAG,CAAC,KAAK;IACnC,MAAMa,cAAc,GAAGb,GAAG,CAAC,IAAI;;IAE/B;IACA,MAAMc,YAAY,GAAIC,UAAU,IAAK;MACnCF,cAAc,CAACG,KAAK,GAAGD,UAAS;MAChCH,iBAAiB,CAACI,KAAK,GAAG,IAAG;IAC/B;;IAEA;IACA,MAAMC,aAAa,GAAGA,CAAA,KAAM;MAC1B,IAAIJ,cAAc,CAACG,KAAK,EAAE;QACxBR,IAAI,CAAC,QAAQ,EAAEK,cAAc,CAACG,KAAK;QACnCJ,iBAAiB,CAACI,KAAK,GAAG,KAAI;QAC9BH,cAAc,CAACG,KAAK,GAAG,IAAG;MAC5B;IACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}