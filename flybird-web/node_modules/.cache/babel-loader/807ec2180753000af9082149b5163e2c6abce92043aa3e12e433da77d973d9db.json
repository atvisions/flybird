{"ast":null,"code":"import { ref, computed, nextTick, watch } from 'vue';\nimport { ElMessage, ElLoading } from 'element-plus';\nimport request, { API_PATHS } from '@/utils/request';\nimport defaultAvatarImage from '@/assets/images/default-avatar.png';\nimport { useStore } from 'vuex';\nimport { profile } from '@/api/profile';\nimport { PencilIcon, PhoneIcon, EnvelopeIcon, MapPinIcon, BriefcaseIcon, ClockIcon, CurrencyYenIcon, DocumentTextIcon, CameraIcon, UserIcon, CalendarIcon, ChevronDownIcon, ChevronUpIcon, CakeIcon, PencilSquareIcon } from '@heroicons/vue/24/outline';\n// 从 store 获取头像\n\nexport default {\n  __name: 'BasicInfo',\n  props: {\n    resumeData: {\n      type: Object,\n      required: true\n    },\n    loading: Boolean,\n    bioExpanded: Boolean,\n    showBioExpandButton: Boolean,\n    getBioText: String\n  },\n  emits: ['update:resumeData', 'edit', 'toggleBioExpand'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const store = useStore();\n    const loading = ref(false);\n    const loadingInstance = ref(null);\n    const avatarUrl = computed(() => store.getters.getUserAvatar);\n    // 处理图片加载错误\n    const handleImageError = e => {\n      e.target.src = defaultAvatarImage;\n    };\n    const props = __props;\n    const emit = __emit;\n    const fileInput = ref(null);\n\n    // 修改调试日志方式\n    const logResumeData = () => {\n      const plainData = {\n        name: props.resumeData.name,\n        gender: props.resumeData.gender,\n        phone: props.resumeData.phone,\n        email: props.resumeData.email,\n        location: props.resumeData.location,\n        birth_date: props.resumeData.birth_date,\n        personal_summary: props.resumeData.personal_summary,\n        created_at: props.resumeData.created_at,\n        updated_at: props.resumeData.updated_at\n      };\n      console.log('BasicInfo data:', plainData);\n    };\n\n    // 监听数据变化\n    watch(() => props.resumeData, newVal => {\n      console.log('BasicInfo received data:', newVal);\n    }, {\n      deep: true,\n      immediate: true\n    });\n\n    // 处理文件上传\n    const handleFileChange = async event => {\n      const file = event.target.files[0];\n      if (!file) return;\n      try {\n        loading.value = true;\n        const response = await profile.uploadAvatar(file);\n        if (response.data?.code === 200) {\n          ElMessage.success('头像上传成功');\n          // 刷新用户信息以获取新的头像URL\n          await store.dispatch('fetchUserInfo');\n          // 清空文件输入框\n          event.target.value = '';\n        } else {\n          throw new Error(response.data?.message || '上传失败');\n        }\n      } catch (error) {\n        console.error('头像上传失败:', error);\n        ElMessage.error(error.response?.data?.message || '头像上传失败，请稍后重试');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 添加一个计算属性来获取带时间戳的头像 URL\n    const currentAvatarUrl = computed(() => {\n      const baseUrl = store.getters.getUserAvatar;\n      return baseUrl + '?t=' + Date.now();\n    });\n\n    // 触发文件选择\n    const triggerUpload = () => {\n      fileInput.value.click();\n    };\n\n    // 性别显示文本\n    const genderText = computed(() => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[props.resumeData.gender] || '未设置性别';\n    });\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return date.toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'long',\n        day: 'numeric'\n      });\n    };\n\n    // 处理编辑按钮点击\n    const handleEdit = () => {\n      console.log('点击编辑按钮, 当前数据:', props.resumeData);\n      emit('edit');\n    };\n\n    // 处理展开/收起\n    const toggleBioExpand = () => {\n      emit('toggleBioExpand');\n    };\n\n    // 计算年龄的函数\n    const calculateAge = birthDate => {\n      if (!birthDate) return '';\n      const birth = new Date(birthDate);\n      const today = new Date();\n      let age = today.getFullYear() - birth.getFullYear();\n      const monthDiff = today.getMonth() - birth.getMonth();\n\n      // 如果还没到生日，年龄减1\n      if (monthDiff < 0 || monthDiff === 0 && today.getDate() < birth.getDate()) {\n        age--;\n      }\n      return `${age}岁`;\n    };\n\n    // 格式化性别显示\n    const formatGender = gender => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[gender] || '未填写';\n    };\n\n    // 格式化基本信息\n    const formatBasicInfo = computed(() => {\n      const info = props.resumeData || {};\n      return {\n        name: info.name || '未填写',\n        gender: formatGender(info.gender),\n        phone: info.phone || '未填写',\n        email: info.email || '未填写',\n        location: info.location || '未填写',\n        age: calculateAge(info.birth_date) || '未填写',\n        personal_summary: info.personal_summary || '未填写'\n      };\n    });\n    const handleAvatarUpload = async file => {\n      try {\n        loading.value = true;\n        const response = await profile.uploadAvatar(file);\n        if (response.data?.code === 200) {\n          ElMessage.success('头像上传成功');\n          await store.dispatch('fetchUserInfo');\n        } else {\n          throw new Error(response.data?.message || '上传失败');\n        }\n      } catch (error) {\n        console.error('头像上传失败:', error);\n        ElMessage.error(error.response?.data?.message || '头像上传失败，请稍后重试');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      store,\n      loading,\n      loadingInstance,\n      avatarUrl,\n      handleImageError,\n      props,\n      emit,\n      fileInput,\n      logResumeData,\n      handleFileChange,\n      currentAvatarUrl,\n      triggerUpload,\n      genderText,\n      formatDate,\n      handleEdit,\n      toggleBioExpand,\n      calculateAge,\n      formatGender,\n      formatBasicInfo,\n      handleAvatarUpload,\n      ref,\n      computed,\n      nextTick,\n      watch,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElLoading() {\n        return ElLoading;\n      },\n      get request() {\n        return request;\n      },\n      get API_PATHS() {\n        return API_PATHS;\n      },\n      get defaultAvatarImage() {\n        return defaultAvatarImage;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get profile() {\n        return profile;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get PhoneIcon() {\n        return PhoneIcon;\n      },\n      get EnvelopeIcon() {\n        return EnvelopeIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },\n      get CameraIcon() {\n        return CameraIcon;\n      },\n      get UserIcon() {\n        return UserIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get ChevronDownIcon() {\n        return ChevronDownIcon;\n      },\n      get ChevronUpIcon() {\n        return ChevronUpIcon;\n      },\n      get CakeIcon() {\n        return CakeIcon;\n      },\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","nextTick","watch","ElMessage","ElLoading","request","API_PATHS","defaultAvatarImage","useStore","profile","PencilIcon","PhoneIcon","EnvelopeIcon","MapPinIcon","BriefcaseIcon","ClockIcon","CurrencyYenIcon","DocumentTextIcon","CameraIcon","UserIcon","CalendarIcon","ChevronDownIcon","ChevronUpIcon","CakeIcon","PencilSquareIcon","store","loading","loadingInstance","avatarUrl","getters","getUserAvatar","handleImageError","e","target","src","props","__props","emit","__emit","fileInput","logResumeData","plainData","name","resumeData","gender","phone","email","location","birth_date","personal_summary","created_at","updated_at","console","log","newVal","deep","immediate","handleFileChange","event","file","files","value","response","uploadAvatar","data","code","success","dispatch","Error","message","error","currentAvatarUrl","baseUrl","Date","now","triggerUpload","click","genderText","genderMap","male","female","other","formatDate","dateString","date","toLocaleDateString","year","month","day","handleEdit","toggleBioExpand","calculateAge","birthDate","birth","today","age","getFullYear","monthDiff","getMonth","getDate","formatGender","formatBasicInfo","info","handleAvatarUpload"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <!-- 移除有问题的调试信息 -->\n      <!-- <pre class=\"hidden\">{{ JSON.stringify(resumeData, null, 2) }}</pre> -->\n      \n      <div class=\"p-4\">\n        <div class=\"flex items-start space-x-5\">\n          <!-- 头像部分 -->\n          <div class=\"relative group\">\n            <img \n                :src=\"avatarUrl\" \n                class=\"w-20 h-20 rounded-full object-cover border-2 border-white shadow\"\n                alt=\"用户头像\"\n                @error=\"handleImageError\"\n                />\n                <!-- 性别图标 -->\n                <div class=\"absolute -bottom-1 -right-1 bg-white rounded-full p-1 shadow\">\n                  <svg v-if=\"resumeData.gender === 'male'\" class=\"w-4 h-4 text-blue-500\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M12 2C9.243 2 7 4.243 7 7v2h10V7c0-2.757-2.243-5-5-5zM9 11H7v9c0 1.654 1.346 3 3 3h4c1.654 0 3-1.346 3-3v-9h-2v9c0 .552-.448 1-1 1h-4c-.552 0-1-.448-1-1v-9z\"/>\n                  </svg>\n                  <svg v-else-if=\"resumeData.gender === 'female'\" class=\"w-4 h-4 text-pink-500\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M12 2C9.243 2 7 4.243 7 7v2h10V7c0-2.757-2.243-5-5-5zM9 11H7v5h10v-5h-2v3H9v-3z\"/>\n                  </svg>\n                </div>\n                <div \n                @click=\"triggerUpload\"\n                class=\"absolute inset-0 flex items-center justify-center rounded-full bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-200\"\n                >\n                  <template v-if=\"loading\">\n                    <div class=\"animate-spin rounded-full h-8 w-8 border-2 border-white border-t-transparent\"></div>\n                  </template>\n                  <template v-else>\n                    <CameraIcon class=\"w-8 h-8 text-white\" />\n                  </template>\n                </div>\n                <input\n                ref=\"fileInput\"\n                type=\"file\"\n                accept=\"image/*\"\n                class=\"hidden\"\n                @change=\"handleFileChange\"\n                />\n          </div>\n  \n          <!-- 用户信息 -->\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center justify-between mb-3\">\n              <h2 class=\"text-lg font-medium text-gray-900\">\n                {{ resumeData.name || '未设置姓名' }}\n              </h2>\n              <div class=\"flex items-center space-x-2\">\n                <!-- 使用 heroicons 的编辑图标 -->\n                <button\n                  @click=\"handleEdit\"\n                  class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200\"\n                  title=\"编辑基本信息\"\n                >\n                  <PencilSquareIcon class=\"w-5 h-5 text-gray-500 hover:text-gray-700\" />\n                </button>\n              </div>\n            </div>\n  \n            <!-- 基本信息列表 -->\n            <div class=\"grid grid-cols-2 gap-3\">\n              <!-- 手机号 -->\n              <div class=\"flex items-center text-gray-600\">\n                <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm truncate\">{{ resumeData.phone || '未设置手机号' }}</span>\n              </div>\n  \n              <!-- 邮箱 -->\n              <div class=\"flex items-center text-gray-600\">\n                <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm truncate\">{{ resumeData.email || '未设置邮箱' }}</span>\n              </div>\n  \n              <!-- 所在地 -->\n              <div class=\"flex items-center text-gray-600\">\n                <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm truncate\">{{ resumeData.location || '未设置所在地' }}</span>\n              </div>\n  \n              <!-- 年龄 (使用图标) -->\n              <div class=\"flex items-center text-gray-600\">\n                <CakeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm truncate\">{{ formatBasicInfo.age }}</span>\n              </div>\n            </div>\n  \n            <!-- 个人简介 -->\n            <div class=\"mt-3\">\n              <div class=\"flex items-center text-gray-600 mb-2\">\n                <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm font-medium\">个人简介</span>\n              </div>\n              <div class=\"bg-gray-50 rounded-md p-4\">\n                <div class=\"relative\">\n                  <template v-if=\"resumeData.personal_summary\">\n                    <p \n                      class=\"text-sm text-gray-600 leading-relaxed min-h-[4.5em] line-clamp-3\"\n                      :class=\"{ 'line-clamp-none': bioExpanded }\"\n                    >\n                      {{ resumeData.personal_summary }}\n                    </p>\n                    <button\n                      v-if=\"showBioExpandButton\"\n                      @click=\"toggleBioExpand\"\n                      class=\"text-xs text-primary-600 hover:text-primary-700 mt-2 inline-flex items-center\"\n                    >\n                      {{ bioExpanded ? '收起' : '展开全部' }}\n                      <ChevronDownIcon \n                        v-if=\"!bioExpanded\" \n                        class=\"w-4 h-4 ml-0.5\" \n                      />\n                      <ChevronUpIcon \n                        v-else \n                        class=\"w-4 h-4 ml-0.5\" \n                      />\n                    </button>\n                  </template>\n                  <p \n                    v-else \n                    class=\"text-sm text-gray-400 text-center min-h-[4.5em] flex items-center justify-center\"\n                  >\n                    你还没有设置个人简介\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed, nextTick, watch } from 'vue'\nimport { ElMessage , ElLoading } from 'element-plus'\nimport request, { API_PATHS } from '@/utils/request'  \nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nimport { profile } from '@/api/profile'\nconst store = useStore()\nconst loading = ref(false)\nconst loadingInstance = ref(null)\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon,\n  UserIcon,\n  CalendarIcon,\n  ChevronDownIcon,\n  ChevronUpIcon,\n  CakeIcon,\n  PencilSquareIcon\n} from '@heroicons/vue/24/outline'\n// 从 store 获取头像\nconst avatarUrl = computed(() => store.getters.getUserAvatar)\n// 处理图片加载错误\nconst handleImageError = (e) => {\n  e.target.src = defaultAvatarImage\n}\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean,\n  bioExpanded: Boolean,\n  showBioExpandButton: Boolean,\n  getBioText: String\n})\n\nconst emit = defineEmits(['update:resumeData', 'edit', 'toggleBioExpand'])\nconst fileInput = ref(null)\n\n// 修改调试日志方式\nconst logResumeData = () => {\n  const plainData = {\n    name: props.resumeData.name,\n    gender: props.resumeData.gender,\n    phone: props.resumeData.phone,\n    email: props.resumeData.email,\n    location: props.resumeData.location,\n    birth_date: props.resumeData.birth_date,\n    personal_summary: props.resumeData.personal_summary,\n    created_at: props.resumeData.created_at,\n    updated_at: props.resumeData.updated_at\n  }\n  console.log('BasicInfo data:', plainData)\n}\n\n// 监听数据变化\nwatch(() => props.resumeData, (newVal) => {\n  console.log('BasicInfo received data:', newVal)\n}, { deep: true, immediate: true })\n\n// 处理文件上传\nconst handleFileChange = async (event) => {\n  const file = event.target.files[0]\n  if (!file) return\n\n  try {\n    loading.value = true\n    const response = await profile.uploadAvatar(file)\n    \n    if (response.data?.code === 200) {\n      ElMessage.success('头像上传成功')\n      // 刷新用户信息以获取新的头像URL\n      await store.dispatch('fetchUserInfo')\n      // 清空文件输入框\n      event.target.value = ''\n    } else {\n      throw new Error(response.data?.message || '上传失败')\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error)\n    ElMessage.error(error.response?.data?.message || '头像上传失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 添加一个计算属性来获取带时间戳的头像 URL\nconst currentAvatarUrl = computed(() => {\n  const baseUrl = store.getters.getUserAvatar\n  return baseUrl + '?t=' + Date.now()\n})\n\n// 触发文件选择\nconst triggerUpload = () => {\n  fileInput.value.click()\n}\n\n// 性别显示文本\nconst genderText = computed(() => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[props.resumeData.gender] || '未设置性别'\n})\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return date.toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'long',\n    day: 'numeric'\n  })\n}\n\n// 处理编辑按钮点击\nconst handleEdit = () => {\n  console.log('点击编辑按钮, 当前数据:', props.resumeData)\n  emit('edit')\n}\n\n// 处理展开/收起\nconst toggleBioExpand = () => {\n  emit('toggleBioExpand')\n}\n\n// 计算年龄的函数\nconst calculateAge = (birthDate) => {\n  if (!birthDate) return ''\n  \n  const birth = new Date(birthDate)\n  const today = new Date()\n  \n  let age = today.getFullYear() - birth.getFullYear()\n  const monthDiff = today.getMonth() - birth.getMonth()\n  \n  // 如果还没到生日，年龄减1\n  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {\n    age--\n  }\n  \n  return `${age}岁`\n}\n\n// 格式化性别显示\nconst formatGender = (gender) => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[gender] || '未填写'\n}\n\n// 格式化基本信息\nconst formatBasicInfo = computed(() => {\n  const info = props.resumeData || {}\n  return {\n    name: info.name || '未填写',\n    gender: formatGender(info.gender),\n    phone: info.phone || '未填写',\n    email: info.email || '未填写',\n    location: info.location || '未填写',\n    age: calculateAge(info.birth_date) || '未填写',\n    personal_summary: info.personal_summary || '未填写'\n  }\n})\n\nconst handleAvatarUpload = async (file) => {\n  try {\n    loading.value = true\n    const response = await profile.uploadAvatar(file)\n    \n    if (response.data?.code === 200) {\n      ElMessage.success('头像上传成功')\n      await store.dispatch('fetchUserInfo')\n    } else {\n      throw new Error(response.data?.message || '上传失败')\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error)\n    ElMessage.error(error.response?.data?.message || '头像上传失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n</script>"],"mappings":"AAyIA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACnD,SAASC,SAAS,EAAGC,SAAS,QAAQ,cAAa;AACnD,OAAOC,OAAO,IAAIC,SAAS,QAAQ,iBAAiB;AACpD,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,OAAO,QAAQ,eAAc;AAItC,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAU,EACVC,QAAQ,EACRC,YAAY,EACZC,eAAe,EACfC,aAAa,EACbC,QAAQ,EACRC,gBAAe,QACV,2BAA0B;AACjC;;;;;;;;;;;;;;;;;;;;IApBA,MAAMC,KAAK,GAAGjB,QAAQ,CAAC;IACvB,MAAMkB,OAAO,GAAG3B,GAAG,CAAC,KAAK;IACzB,MAAM4B,eAAe,GAAG5B,GAAG,CAAC,IAAI;IAmBhC,MAAM6B,SAAS,GAAG5B,QAAQ,CAAC,MAAMyB,KAAK,CAACI,OAAO,CAACC,aAAa;IAC5D;IACA,MAAMC,gBAAgB,GAAIC,CAAC,IAAK;MAC9BA,CAAC,CAACC,MAAM,CAACC,GAAG,GAAG3B,kBAAiB;IAClC;IACA,MAAM4B,KAAK,GAAGC,OAAA;IAWd,MAAMC,IAAI,GAAGC,MAAA;IACb,MAAMC,SAAS,GAAGxC,GAAG,CAAC,IAAI;;IAE1B;IACA,MAAMyC,aAAa,GAAGA,CAAA,KAAM;MAC1B,MAAMC,SAAS,GAAG;QAChBC,IAAI,EAAEP,KAAK,CAACQ,UAAU,CAACD,IAAI;QAC3BE,MAAM,EAAET,KAAK,CAACQ,UAAU,CAACC,MAAM;QAC/BC,KAAK,EAAEV,KAAK,CAACQ,UAAU,CAACE,KAAK;QAC7BC,KAAK,EAAEX,KAAK,CAACQ,UAAU,CAACG,KAAK;QAC7BC,QAAQ,EAAEZ,KAAK,CAACQ,UAAU,CAACI,QAAQ;QACnCC,UAAU,EAAEb,KAAK,CAACQ,UAAU,CAACK,UAAU;QACvCC,gBAAgB,EAAEd,KAAK,CAACQ,UAAU,CAACM,gBAAgB;QACnDC,UAAU,EAAEf,KAAK,CAACQ,UAAU,CAACO,UAAU;QACvCC,UAAU,EAAEhB,KAAK,CAACQ,UAAU,CAACQ;MAC/B;MACAC,OAAO,CAACC,GAAG,CAAC,iBAAiB,EAAEZ,SAAS;IAC1C;;IAEA;IACAvC,KAAK,CAAC,MAAMiC,KAAK,CAACQ,UAAU,EAAGW,MAAM,IAAK;MACxCF,OAAO,CAACC,GAAG,CAAC,0BAA0B,EAAEC,MAAM;IAChD,CAAC,EAAE;MAAEC,IAAI,EAAE,IAAI;MAAEC,SAAS,EAAE;IAAK,CAAC;;IAElC;IACA,MAAMC,gBAAgB,GAAG,MAAOC,KAAK,IAAK;MACxC,MAAMC,IAAI,GAAGD,KAAK,CAACzB,MAAM,CAAC2B,KAAK,CAAC,CAAC;MACjC,IAAI,CAACD,IAAI,EAAE;MAEX,IAAI;QACFjC,OAAO,CAACmC,KAAK,GAAG,IAAG;QACnB,MAAMC,QAAQ,GAAG,MAAMrD,OAAO,CAACsD,YAAY,CAACJ,IAAI;QAEhD,IAAIG,QAAQ,CAACE,IAAI,EAAEC,IAAI,KAAK,GAAG,EAAE;UAC/B9D,SAAS,CAAC+D,OAAO,CAAC,QAAQ;UAC1B;UACA,MAAMzC,KAAK,CAAC0C,QAAQ,CAAC,eAAe;UACpC;UACAT,KAAK,CAACzB,MAAM,CAAC4B,KAAK,GAAG,EAAC;QACxB,CAAC,MAAM;UACL,MAAM,IAAIO,KAAK,CAACN,