{"ast":null,"code":"import { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { auth } from '@/api/auth';\nimport { showToast } from '@/components/ToastMessage';\nimport { SMS_SCENE } from '@/store';\nexport default {\n  setup() {\n    const router = useRouter();\n    const form = ref({\n      phone: '',\n      code: '',\n      password: '',\n      confirmPassword: ''\n    });\n    const isSubmitting = ref(false);\n    const countdown = ref(0);\n    let timer = null;\n\n    // 发送验证码\n    const handleSendCode = async () => {\n      try {\n        if (!form.value.phone) {\n          showToast('请输入手机号', 'warning');\n          return;\n        }\n        await auth.sendResetCode(form.value.phone);\n        showToast('验证码已发送', 'success');\n        countdown.value = 60;\n        timer = setInterval(() => {\n          countdown.value--;\n          if (countdown.value <= 0) {\n            clearInterval(timer);\n          }\n        }, 1000);\n      } catch (error) {\n        showToast(error.message || '发送验证码失败', 'error');\n      }\n    };\n\n    // 提交重置密码\n    const handleSubmit = async () => {\n      try {\n        if (!form.value.phone || !form.value.code || !form.value.password) {\n          showToast('请填写完整信息', 'warning');\n          return;\n        }\n        if (!form.value.confirmPassword) {\n          showToast('请确认密码', 'warning');\n          return;\n        }\n        if (form.value.password !== form.value.confirmPassword) {\n          showToast('两次输入的密码不一致', 'warning');\n          return;\n        }\n        isSubmitting.value = true;\n        await auth.resetPassword({\n          phone: form.value.phone,\n          code: form.value.code,\n          password: form.value.password,\n          confirmPassword: form.value.confirmPassword\n        });\n        showToast('密码重置成功', 'success');\n        router.push('/login');\n      } catch (error) {\n        showToast(error.message || '重置密码失败', 'error');\n      } finally {\n        isSubmitting.value = false;\n      }\n    };\n    return {\n      form,\n      isSubmitting,\n      countdown,\n      handleSendCode,\n      handleSubmit\n    };\n  }\n};","map":{"version":3,"names":["ref","useRouter","auth","showToast","SMS_SCENE","setup","router","form","phone","code","password","confirmPassword","isSubmitting","countdown","timer","handleSendCode","value","sendResetCode","setInterval","clearInterval","error","message","handleSubmit","resetPassword","push"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/ResetPasswordView.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8\">\n    <div class=\"max-w-md w-full space-y-8\">\n      <div>\n        <h2 class=\"mt-6 text-center text-3xl font-extrabold text-gray-900\">重置密码</h2>\n      </div>\n      <form class=\"mt-8 space-y-6\" @submit.prevent=\"handleSubmit\">\n        <!-- 手机号输入 -->\n        <div>\n          <label for=\"phone\" class=\"block text-sm font-medium text-gray-700\">手机号</label>\n          <div class=\"mt-1 relative rounded-md shadow-sm\">\n            <input \n              type=\"text\" \n              v-model=\"form.phone\"\n              required\n              class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm\"\n            >\n          </div>\n        </div>\n\n        <!-- 验证码输入 -->\n        <div>\n          <label for=\"code\" class=\"block text-sm font-medium text-gray-700\">验证码</label>\n          <div class=\"mt-1 flex rounded-md shadow-sm\">\n            <input \n              type=\"text\" \n              v-model=\"form.code\"\n              required\n              class=\"flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-l-md border border-gray-300 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm\"\n            >\n            <button \n              type=\"button\"\n              @click=\"handleSendCode\"\n              :disabled=\"countdown > 0\"\n              class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-r-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50\"\n            >\n              {{ countdown > 0 ? `${countdown}s` : '获取验证码' }}\n            </button>\n          </div>\n        </div>\n\n        <!-- 新密码输入 -->\n        <div>\n          <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">新密码</label>\n          <div class=\"mt-1\">\n            <input \n              type=\"password\" \n              v-model=\"form.password\"\n              required\n              class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm\"\n            >\n          </div>\n        </div>\n\n        <!-- 确认密码输入 -->\n        <div>\n          <label for=\"confirmPassword\" class=\"block text-sm font-medium text-gray-700\">确认密码</label>\n          <div class=\"mt-1\">\n            <input \n              type=\"password\" \n              v-model=\"form.confirmPassword\"\n              required\n              class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm\"\n            >\n          </div>\n        </div>\n\n        <div>\n          <button \n            type=\"submit\"\n            :disabled=\"isSubmitting\"\n            class=\"w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500\"\n          >\n            {{ isSubmitting ? '提交中...' : '重置密码' }}\n          </button>\n        </div>\n      </form>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { ref } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { auth } from '@/api/auth'\nimport { showToast } from '@/components/ToastMessage'\nimport { SMS_SCENE } from '@/store'\n\nexport default {\n  setup() {\n    const router = useRouter()\n    const form = ref({\n      phone: '',\n      code: '',\n      password: '',\n      confirmPassword: ''\n    })\n    const isSubmitting = ref(false)\n    const countdown = ref(0)\n    let timer = null\n\n    // 发送验证码\n    const handleSendCode = async () => {\n      try {\n        if (!form.value.phone) {\n          showToast('请输入手机号', 'warning')\n          return\n        }\n\n        await auth.sendResetCode(form.value.phone)\n        \n        showToast('验证码已发送', 'success')\n        countdown.value = 60\n        timer = setInterval(() => {\n          countdown.value--\n          if (countdown.value <= 0) {\n            clearInterval(timer)\n          }\n        }, 1000)\n      } catch (error) {\n        showToast(error.message || '发送验证码失败', 'error')\n      }\n    }\n\n    // 提交重置密码\n    const handleSubmit = async () => {\n      try {\n        if (!form.value.phone || !form.value.code || !form.value.password) {\n          showToast('请填写完整信息', 'warning')\n          return\n        }\n\n        if (!form.value.confirmPassword) {\n          showToast('请确认密码', 'warning')\n          return\n        }\n\n        if (form.value.password !== form.value.confirmPassword) {\n          showToast('两次输入的密码不一致', 'warning')\n          return\n        }\n\n        isSubmitting.value = true\n\n        await auth.resetPassword({\n          phone: form.value.phone,\n          code: form.value.code,\n          password: form.value.password,\n          confirmPassword: form.value.confirmPassword\n        })\n\n        showToast('密码重置成功', 'success')\n        router.push('/login')\n      } catch (error) {\n        showToast(error.message || '重置密码失败', 'error')\n      } finally {\n        isSubmitting.value = false\n      }\n    }\n\n    return {\n      form,\n      isSubmitting,\n      countdown,\n      handleSendCode,\n      handleSubmit\n    }\n  }\n}\n</script>"],"mappings":"AAkFA,SAASA,GAAE,QAAS,KAAI;AACxB,SAASC,SAAQ,QAAS,YAAW;AACrC,SAASC,IAAG,QAAS,YAAW;AAChC,SAASC,SAAQ,QAAS,2BAA0B;AACpD,SAASC,SAAQ,QAAS,SAAQ;AAElC,eAAe;EACbC,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIL,SAAS,CAAC;IACzB,MAAMM,IAAG,GAAIP,GAAG,CAAC;MACfQ,KAAK,EAAE,EAAE;MACTC,IAAI,EAAE,EAAE;MACRC,QAAQ,EAAE,EAAE;MACZC,eAAe,EAAE;IACnB,CAAC;IACD,MAAMC,YAAW,GAAIZ,GAAG,CAAC,KAAK;IAC9B,MAAMa,SAAQ,GAAIb,GAAG,CAAC,CAAC;IACvB,IAAIc,KAAI,GAAI,IAAG;;IAEf;IACA,MAAMC,cAAa,GAAI,MAAAA,CAAA,KAAY;MACjC,IAAI;QACF,IAAI,CAACR,IAAI,CAACS,KAAK,CAACR,KAAK,EAAE;UACrBL,SAAS,CAAC,QAAQ,EAAE,SAAS;UAC7B;QACF;QAEA,MAAMD,IAAI,CAACe,aAAa,CAACV,IAAI,CAACS,KAAK,CAACR,KAAK;QAEzCL,SAAS,CAAC,QAAQ,EAAE,SAAS;QAC7BU,SAAS,CAACG,KAAI,GAAI,EAAC;QACnBF,KAAI,GAAII,WAAW,CAAC,MAAM;UACxBL,SAAS,CAACG,KAAK,EAAC;UAChB,IAAIH,SAAS,CAACG,KAAI,IAAK,CAAC,EAAE;YACxBG,aAAa,CAACL,KAAK;UACrB;QACF,CAAC,EAAE,IAAI;MACT,EAAE,OAAOM,KAAK,EAAE;QACdjB,SAAS,CAACiB,KAAK,CAACC,OAAM,IAAK,SAAS,EAAE,OAAO;MAC/C;IACF;;IAEA;IACA,MAAMC,YAAW,GAAI,MAAAA,CAAA,KAAY;MAC/B,IAAI;QACF,IAAI,CAACf,IAAI,CAACS,KAAK,CAACR,KAAI,IAAK,CAACD,IAAI,CAACS,KAAK,CAACP,IAAG,IAAK,CAACF,IAAI,CAACS,KAAK,CAACN,QAAQ,EAAE;UACjEP,SAAS,CAAC,SAAS,EAAE,SAAS;UAC9B;QACF;QAEA,IAAI,CAACI,IAAI,CAACS,KAAK,CAACL,eAAe,EAAE;UAC/BR,SAAS,CAAC,OAAO,EAAE,SAAS;UAC5B;QACF;QAEA,IAAII,IAAI,CAACS,KAAK,CAACN,QAAO,KAAMH,IAAI,CAACS,KAAK,CAACL,eAAe,EAAE;UACtDR,SAAS,CAAC,YAAY,EAAE,SAAS;UACjC;QACF;QAEAS,YAAY,CAACI,KAAI,GAAI,IAAG;QAExB,MAAMd,IAAI,CAACqB,aAAa,CAAC;UACvBf,KAAK,EAAED,IAAI,CAACS,KAAK,CAACR,KAAK;UACvBC,IAAI,EAAEF,IAAI,CAACS,KAAK,CAACP,IAAI;UACrBC,QAAQ,EAAEH,IAAI,CAACS,KAAK,CAACN,QAAQ;UAC7BC,eAAe,EAAEJ,IAAI,CAACS,KAAK,CAACL;QAC9B,CAAC;QAEDR,SAAS,CAAC,QAAQ,EAAE,SAAS;QAC7BG,MAAM,CAACkB,IAAI,CAAC,QAAQ;MACtB,EAAE,OAAOJ,KAAK,EAAE;QACdjB