py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              <svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z\" />\n              </svg>\n              设置\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 账户安全 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户安全</h2>\n        </div>\n        \n        <div class=\"p-6 space-y-6\">\n          <!-- 手机号 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">手机号</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">{{ maskPhone(phone) }}</p>\n            </div>\n            <button @click=\"openPhoneModal\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              更换手机号\n            </button>\n          </div>\n\n          <!-- 密码 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">登录密码</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">用于保护账号安全</p>\n            </div>\n            <button @click=\"openPasswordModal\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              修改密码\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 账户注销 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户注销</h2>\n        </div>\n        \n        <div class=\"p-6\">\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-red-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">账户注销</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">注销后，账户将被永久删除且无法恢复</p>\n            </div>\n            <button @click=\"openDeleteConfirm\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-red-600 hover:text-red-700 \n              transition-colors rounded-md hover:bg-red-50\">\n              注销账户\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 各种弹窗 -->\n      <Teleport to=\"body\">\n        <!-- 昵称设置弹窗 -->\n        <NicknameModal\n          v-if=\"showNicknameModal\"\n          v-model=\"nickname.value\"\n          :loading=\"nickname.loading\"\n          :onUpdate=\"nickname.handleUpdate\"\n          :onClose=\"closeNicknameModal\"\n        />\n\n        <!-- 手机号修改弹窗 -->\n        <PhoneModal\n          v-if=\"showPhoneModal\"\n          v-model:phone=\"phoneManager.value\"\n          v-model:code=\"phoneManager.code\"\n          :loading=\"phoneManager.loading\"\n          :countdown=\"phoneManager.countdown\"\n          :onSendCode=\"phoneManager.handleSendCode\"\n          :onUpdate=\"phoneManager.handleUpdate\"\n          :onClose=\"closePhoneModal\"\n        />\n\n        <!-- 密码修改弹窗 -->\n        <ChangePasswordDialog\n          v-model=\"showPasswordModal\"\n          @success=\"handlePasswordSuccess\"\n        />\n\n        <!-- 账户注销确认弹窗 -->\n        <DeleteConfirmModal\n          v-if=\"showDeleteConfirm\"\n          v-model=\"deleteAccount.password\"\n          :loading=\"deleteAccount.loading\"\n          :onConfirm=\"deleteAccount.handleDelete\"\n          :onClose=\"closeDeleteConfirm\"\n        />\n      </Teleport>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { useDeleteAccount } from '@/composables/useDeleteAccount'\nimport { useNickname } from '@/composables/useNickname'\nimport { usePhone } from '@/composables/usePhone'\nimport NicknameModal from '@/components/modals/NicknameModal.vue'\nimport PhoneModal from '@/components/modals/PhoneModal.vue'\nimport ChangePasswordDialog from '@/components/dialogs/ChangePasswordDialog.vue'\nimport DeleteConfirmModal from '@/components/modals/DeleteConfirmModal.vue'\n\nconst store = useStore()\nconst router = useRouter()\n\n// 基础信息\nconst username = computed(() => store.state.userInfo?.username || '未设置')\nconst uid = computed(() => store.state.userInfo?.uid || '暂无')\nconst phone = computed(() => store.state.userInfo?.phone || '')\n\n// 使用 composables\nconst nickname = useNickname()\nconst phoneManager = usePhone()\nconst deleteAccount = useDeleteAccount()\n\n// 工具方法\nconst maskPhone = (phone) => {\n  if (!phone) return '未绑定'\n  return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n// 弹窗状态\nconst showNicknameModal = ref(false)\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\nconst showDeleteConfirm = ref(false)\n\n// 打开弹窗的方法\nconst openNicknameModal = () => {\n  nickname.value = store.state.userInfo?.username || ''\n  showNicknameModal.value = true\n}\n\nconst openPhoneModal = () => {\n  phoneManager.value = ''\n  phoneManager.code = ''\n  showPhoneModal.value = true\n}\n\nconst openPasswordModal = () => {\n  showPasswordModal.value = true\n}\n\nconst openDeleteConfirm = () => {\n  deleteAccount.password = ''\n  showDeleteConfirm.value = true\n}\n\n// 关闭弹窗的方法\nconst closeNicknameModal = () => {\n  showNicknameModal.value = false\n  nickname.value = ''\n  nickname.loading.value = false\n}\n\nconst closePhoneModal = () => {\n  showPhoneModal.value = false\n  phoneManager.value = ''\n  phoneManager.code = ''\n}\n\nconst closePasswordModal = () => {\n  showPasswordModal.value = false\n}\n\nconst closeDeleteConfirm = () => {\n  showDeleteConfirm.value = false\n  deleteAccount.password = ''\n}\n\n// 处理成功回调\nconst handlePasswordSuccess = () => {\n  closePasswordModal()\n  showToast('密码修改成功', 'success')\n}\n</script>"],"mappings":"AA+JA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,QAAQ,QAAQ,MAAK;AA