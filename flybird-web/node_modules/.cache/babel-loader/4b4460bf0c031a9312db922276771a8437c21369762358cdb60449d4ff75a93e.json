{"ast":null,"code":"import { computed, ref } from 'vue';\nimport { SparklesIcon, InformationCircleIcon, ChartBarIcon } from '@heroicons/vue/24/outline';\nimport { useWindowSize } from '@vueuse/core';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'AIDialog',\n  props: {\n    modelValue: Boolean,\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    totalScore: {\n      type: Number,\n      default: 0\n    },\n    remainingOptimizations: {\n      type: Number,\n      required: true\n    },\n    totalOptimizations: {\n      type: Number,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'action'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const store = useStore();\n    const {\n      width\n    } = useWindowSize();\n\n    // 弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 总分颜色\n    const scoreColorClass = computed(() => {\n      if (props.totalScore >= 80) return 'text-green-600';\n      if (props.totalScore >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n\n    // 建议类型样式\n    const getTypeClass = type => {\n      const classMap = {\n        basic_info: 'bg-blue-50 text-blue-700',\n        work_experience: 'bg-purple-50 text-purple-700',\n        skill: 'bg-green-50 text-green-700',\n        education: 'bg-yellow-50 text-yellow-700',\n        project: 'bg-indigo-50 text-indigo-700',\n        achievement: 'bg-pink-50 text-pink-700'\n      };\n      return classMap[type] || 'bg-gray-50 text-gray-700';\n    };\n\n    // 建议类型名称\n    const getTypeName = type => {\n      const typeMap = {\n        basic_info: '基本信息',\n        work_experience: '工作经历',\n        skill: '技能特长',\n        education: '教育背景',\n        project: '项目经验',\n        achievement: '个人成就'\n      };\n      return typeMap[type] || type;\n    };\n\n    // 按重要性和提升分数排序的建议\n    const sortedSuggestions = computed(() => {\n      const importanceOrder = {\n        high: 3,\n        medium: 2,\n        low: 1\n      };\n      return [...props.suggestions].sort((a, b) => {\n        const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance];\n        if (importanceDiff !== 0) return importanceDiff;\n        return b.score_impact - a.score_impact;\n      });\n    });\n\n    // 是否是VIP会员\n    const isVip = computed(() => store.getters.isVip);\n\n    // 处理优化\n    const handleOptimize = () => {\n      showOptimizing.value = true;\n      emit('action', 'optimize');\n    };\n\n    // 处理优化确认\n    const handleOptimizationConfirm = optimizationId => {\n      emit('action', 'confirm', optimizationId);\n    };\n\n    // 处理优化取消\n    const handleOptimizationCancel = () => {\n      showOptimizing.value = false;\n    };\n    const __returned__ = {\n      props,\n      emit,\n      store,\n      width,\n      dialogWidth,\n      scoreColorClass,\n      getTypeClass,\n      getTypeName,\n      sortedSuggestions,\n      isVip,\n      handleOptimize,\n      handleOptimizationConfirm,\n      handleOptimizationCancel,\n      computed,\n      ref,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get InformationCircleIcon() {\n        return InformationCircleIcon;\n      },\n      get ChartBarIcon() {\n        return ChartBarIcon;\n      },\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","ref","SparklesIcon","InformationCircleIcon","ChartBarIcon","useWindowSize","useStore","ElMessage","props","__props","emit","__emit","store","width","dialogWidth","value","scoreColorClass","totalScore","getTypeClass","type","classMap","basic_info","work_experience","skill","education","project","achievement","getTypeName","typeMap","sortedSuggestions","importanceOrder","high","medium","low","suggestions","sort","a","b","importanceDiff","importance","score_impact","isVip","getters","handleOptimize","showOptimizing","handleOptimizationConfirm","optimizationId","handleOptimizationCancel"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/AIDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"AI 优化建议\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n  >\n    <!-- 头部：评分和次数 -->\n    <div class=\"bg-gray-50 rounded-lg p-4 mb-6\">\n      <div class=\"flex items-center justify-between\">\n        <div class=\"flex items-center space-x-4\">\n          <div>\n            <h3 class=\"text-base font-medium text-gray-900\">简历评分</h3>\n            <p class=\"text-sm text-gray-500 mt-1\">基于专业标准的综合评估</p>\n          </div>\n          <span class=\"text-3xl font-semibold\" :class=\"scoreColorClass\">\n            {{ totalScore }}\n            <span class=\"text-base\">分</span>\n          </span>\n        </div>\n        <div class=\"text-right\">\n          <div class=\"flex items-center text-sm text-gray-500 mb-1\">\n            <SparklesIcon class=\"w-4 h-4 mr-1\" />\n            <span>本月剩余优化次数</span>\n            <el-tooltip v-if=\"!isVip\" effect=\"dark\" placement=\"top\">\n              <template #content>\n                <div class=\"text-xs\">\n                  <p>普通用户每月可使用3次</p>\n                  <p class=\"mt-1\">升级会员可享无限次数</p>\n                </div>\n              </template>\n              <InformationCircleIcon class=\"w-4 h-4 ml-1 cursor-help\" />\n            </el-tooltip>\n          </div>\n          <div class=\"text-2xl font-medium\" :class=\"{'text-red-600': remainingOptimizations === 0}\">\n            {{ remainingOptimizations }}/{{ totalOptimizations }}\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 改进建议列表 -->\n    <div class=\"space-y-4 mb-6\">\n      <div class=\"flex items-center justify-between\">\n        <h3 class=\"text-base font-medium text-gray-900\">待改进项</h3>\n        <span class=\"text-sm text-gray-500\">按优先级排序</span>\n      </div>\n      <div class=\"space-y-3\">\n        <div \n          v-for=\"(suggestion, index) in sortedSuggestions\" \n          :key=\"index\"\n          class=\"bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-300 transition-colors\"\n        >\n          <div class=\"flex items-start space-x-3\">\n            <div \n              class=\"flex-shrink-0 w-2 h-2 mt-2 rounded-full\"\n              :class=\"{\n                'bg-red-500': suggestion.importance === 'high',\n                'bg-yellow-500': suggestion.importance === 'medium',\n                'bg-blue-500': suggestion.importance === 'low'\n              }\"\n            ></div>\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <span class=\"text-xs font-medium px-2 py-0.5 rounded\" \n                  :class=\"getTypeClass(suggestion.type)\">\n                  {{ getTypeName(suggestion.type) }}\n                </span>\n                <span class=\"text-sm text-gray-700\">{{ suggestion.message }}</span>\n              </div>\n              <div class=\"flex items-center mt-2 text-xs text-gray-500\">\n                <ChartBarIcon class=\"w-4 h-4 mr-1\" />\n                <span>预计提升：</span>\n                <span class=\"text-primary-600 font-medium ml-1\">+{{ suggestion.score_impact }}分</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 底部按钮 -->\n    <div class=\"flex justify-center\">\n      <button\n        @click=\"startOptimize\"\n        :disabled=\"loading || remainingOptimizations === 0\"\n        class=\"group relative inline-flex items-center px-8 py-3 text-base font-medium text-white bg-gradient-to-r from-primary-600 to-purple-600 rounded-lg transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed hover:from-primary-700 hover:to-purple-700\"\n      >\n        <SparklesIcon class=\"w-5 h-5 mr-2 animate-pulse\" />\n        <span>{{ loading ? '优化中...' : '开始AI优化' }}</span>\n      </button>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { computed, ref } from 'vue'\nimport { SparklesIcon, InformationCircleIcon, ChartBarIcon } from '@heroicons/vue/24/outline'\nimport { useWindowSize } from '@vueuse/core'\nimport { useStore } from 'vuex'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  suggestions: {\n    type: Array,\n    default: () => []\n  },\n  totalScore: {\n    type: Number,\n    default: 0\n  },\n  remainingOptimizations: {\n    type: Number,\n    required: true\n  },\n  totalOptimizations: {\n    type: Number,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'action'])\n\nconst store = useStore()\nconst { width } = useWindowSize()\n\n// 弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 总分颜色\nconst scoreColorClass = computed(() => {\n  if (props.totalScore >= 80) return 'text-green-600'\n  if (props.totalScore >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n})\n\n// 建议类型样式\nconst getTypeClass = (type) => {\n  const classMap = {\n    basic_info: 'bg-blue-50 text-blue-700',\n    work_experience: 'bg-purple-50 text-purple-700',\n    skill: 'bg-green-50 text-green-700',\n    education: 'bg-yellow-50 text-yellow-700',\n    project: 'bg-indigo-50 text-indigo-700',\n    achievement: 'bg-pink-50 text-pink-700'\n  }\n  return classMap[type] || 'bg-gray-50 text-gray-700'\n}\n\n// 建议类型名称\nconst getTypeName = (type) => {\n  const typeMap = {\n    basic_info: '基本信息',\n    work_experience: '工作经历',\n    skill: '技能特长',\n    education: '教育背景',\n    project: '项目经验',\n    achievement: '个人成就'\n  }\n  return typeMap[type] || type\n}\n\n// 按重要性和提升分数排序的建议\nconst sortedSuggestions = computed(() => {\n  const importanceOrder = { high: 3, medium: 2, low: 1 }\n  return [...props.suggestions].sort((a, b) => {\n    const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance]\n    if (importanceDiff !== 0) return importanceDiff\n    return b.score_impact - a.score_impact\n  })\n})\n\n// 是否是VIP会员\nconst isVip = computed(() => store.getters.isVip)\n\n// 处理优化\nconst handleOptimize = () => {\n  showOptimizing.value = true\n  emit('action', 'optimize')\n}\n\n// 处理优化确认\nconst handleOptimizationConfirm = (optimizationId) => {\n  emit('action', 'confirm', optimizationId)\n}\n\n// 处理优化取消\nconst handleOptimizationCancel = () => {\n  showOptimizing.value = false\n}\n</script>"],"mappings":"AAkGA,SAASA,QAAQ,EAAEC,GAAG,QAAQ,KAAI;AAClC,SAASC,YAAY,EAAEC,qBAAqB,EAAEC,YAAY,QAAQ,2BAA0B;AAC5F,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGC,OAAA;IAqBd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,KAAK,GAAGN,QAAQ,CAAC;IACvB,MAAM;MAAEO;IAAM,CAAC,GAAGR,aAAa,CAAC;;IAEhC;IACA,MAAMS,WAAW,GAAGd,QAAQ,CAAC,MAAM;MACjC,IAAIa,KAAK,CAACE,KAAK,GAAG,GAAG,EAAE,OAAO,KAAI;MAClC,IAAIF,KAAK,CAACE,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;;IAED;IACA,MAAMC,eAAe,GAAGhB,QAAQ,CAAC,MAAM;MACrC,IAAIQ,KAAK,CAACS,UAAU,IAAI,EAAE,EAAE,OAAO,gBAAe;MAClD,IAAIT,KAAK,CAACS,UAAU,IAAI,EAAE,EAAE,OAAO,iBAAgB;MACnD,OAAO,cAAa;IACtB,CAAC;;IAED;IACA,MAAMC,YAAY,GAAIC,IAAI,IAAK;MAC7B,MAAMC,QAAQ,GAAG;QACfC,UAAU,EAAE,0BAA0B;QACtCC,eAAe,EAAE,8