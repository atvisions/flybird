{"ast":null,"code":"import { Edit, Delete } from '@element-plus/icons-vue';\nimport JobIntentionContent from './JobIntentionContent.vue';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['edit', 'remove'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const __returned__ = {\n      get Edit() {\n        return Edit;\n      },\n      get Delete() {\n        return Delete;\n      },\n      JobIntentionContent\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["Edit","Delete","JobIntentionContent"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"module in activeModules\" :key=\"module.id\" class=\"bg-white rounded-lg shadow\">\n      <!-- 模块头部 -->\n      <div class=\"flex items-center justify-between px-4 py-3 border-b\">\n        <div class=\"flex items-center space-x-2\">\n          <component :is=\"module.icon\" class=\"w-5 h-5 text-gray-500\" />\n          <h3 class=\"text-base font-medium\">{{ module.name }}</h3>\n        </div>\n        <div class=\"flex items-center space-x-2\">\n          <!-- 编辑按钮 -->\n          <el-button\n            type=\"primary\"\n            link\n            :icon=\"Edit\"\n            @click=\"$emit('edit', module.id, module.data)\"\n          >\n            编辑\n          </el-button>\n          <!-- 移除按钮 -->\n          <el-button\n            type=\"danger\"\n            link\n            :icon=\"Delete\"\n            @click=\"$emit('remove', module.id)\"\n          >\n            移除\n          </el-button>\n        </div>\n      </div>\n\n      <!-- 模块内容 -->\n      <div class=\"p-4\">\n        <!-- 求职意向内容 -->\n        <JobIntentionContent\n          v-if=\"module.type === 'job_intention'\"\n          :data=\"module.data\"\n        />\n        <!-- 其他模块的默认内容 -->\n        <slot v-else :name=\"module.id\" :data=\"module.data\">\n          <div v-if=\"module.data\" class=\"text-gray-600\">\n            {{ JSON.stringify(module.data) }}\n          </div>\n          <div v-else class=\"text-gray-400 text-center py-4\">\n            暂无内容，点击编辑添加\n          </div>\n        </slot>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { Edit, Delete } from '@element-plus/icons-vue'\nimport JobIntentionContent from './JobIntentionContent.vue'\n\ndefineProps({\n  activeModules: {\n    type: Array,\n    required: true\n  },\n  loading: Boolean\n})\n\ndefineEmits(['edit', 'remove'])\n</script>\n\n<style scoped>\n.module-header {\n  @apply flex items-center justify-between px-4 py-3 border-b;\n}\n\n.module-title {\n  @apply flex items-center space-x-2;\n}\n\n.module-actions {\n  @apply flex items-center space-x-2;\n}\n\n.module-content {\n  @apply p-4;\n}\n\n.empty-content {\n  @apply text-gray-400 text-center py-4;\n}\n</style>"],"mappings":"AAsDA,SAASA,IAAI,EAAEC,MAAM,QAAQ,yBAAwB;AACrD,OAAOC,mBAAmB,MAAM,2BAA0B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}