{"ast":null,"code":"import { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage } from 'element-plus';\nimport { auth } from '@/api/auth';\nimport { SMS_SCENE } from '@/constants';\nexport default {\n  __name: 'RegisterView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(false);\n    const countdown = ref(0);\n\n    // 移除 username，只保留必要的字段\n    const formData = ref({\n      phone: '',\n      code: '',\n      password: '',\n      confirm_password: ''\n    });\n\n    // 获取验证码\n    const handleGetCode = async () => {\n      try {\n        if (!formData.value.phone) {\n          ElMessage.warning('请输入手机号');\n          return;\n        }\n        await auth.sendSmsCode({\n          phone: formData.value.phone,\n          scene: SMS_SCENE.REGISTER\n        });\n        ElMessage.success('验证码已发送');\n        countdown.value = 60;\n        const timer = setInterval(() => {\n          countdown.value--;\n          if (countdown.value <= 0) {\n            clearInterval(timer);\n          }\n        }, 1000);\n      } catch (error) {\n        console.error('获取验证码失败:', error);\n        ElMessage.error(error.message || '获取验证码失败');\n      }\n    };\n\n    // 提交注册\n    const handleSubmit = async () => {\n      try {\n        loading.value = true;\n\n        // 表单验证\n        if (formData.value.password !== formData.value.confirm_password) {\n          ElMessage.error('两次输入的密码不一致');\n          return;\n        }\n        await auth.register({\n          phone: formData.value.phone,\n          code: formData.value.code,\n          password: formData.value.password,\n          confirm_password: formData.value.confirm_password\n        });\n        ElMessage.success('注册成功');\n        router.push('/login');\n      } catch (error) {\n        console.error('注册失败:', error);\n        ElMessage.error(error.message || '注册失败');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      router,\n      loading,\n      countdown,\n      formData,\n      handleGetCode,\n      handleSubmit,\n      ref,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get auth() {\n        return auth;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","useRouter","ElMessage","auth","SMS_SCENE","router","loading","countdown","formData","phone","code","password","confirm_password","handleGetCode","value","warning","sendSmsCode","scene","REGISTER","success","timer","setInterval","clearInterval","error","console","message","handleSubmit","register","push"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/RegisterView.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-gray-50\">\n    <div class=\"sm:mx-auto sm:w-full sm:max-w-md\">\n      <h2 class=\"mt-6 text-center text-3xl font-extrabold text-gray-900\">\n        注册账号\n      </h2>\n    </div>\n\n    <div class=\"mt-8 sm:mx-auto sm:w-full sm:max-w-md\">\n      <div class=\"bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10\">\n        <form class=\"space-y-6\" @submit.prevent=\"handleSubmit\">\n          <!-- 手机号 -->\n          <div>\n            <label for=\"phone\" class=\"block text-sm font-medium text-gray-700\">\n              手机号\n            </label>\n            <div class=\"mt-1\">\n              <input\n                id=\"phone\"\n                v-model=\"formData.phone\"\n                type=\"tel\"\n                required\n                class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary-500 focus:border-primary-500 sm:text-sm\"\n              />\n            </div>\n          </div>\n\n          <!-- 验证码 -->\n          <div>\n            <label for=\"code\" class=\"block text-sm font-medium text-gray-700\">\n              验证码\n            </label>\n            <div class=\"mt-1 flex space-x-2\">\n              <input\n                id=\"code\"\n                v-model=\"formData.code\"\n                type=\"text\"\n                required\n                class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary-500 focus:border-primary-500 sm:text-sm\"\n              />\n              <button\n                type=\"button\"\n                :disabled=\"countdown > 0\"\n                @click=\"handleGetCode\"\n                class=\"inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n              >\n                {{ countdown > 0 ? `${countdown}s` : '获取验证码' }}\n              </button>\n            </div>\n          </div>\n\n          <!-- 密码 -->\n          <div>\n            <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">\n              密码\n            </label>\n            <div class=\"mt-1\">\n              <input\n                id=\"password\"\n                v-model=\"formData.password\"\n                type=\"password\"\n                required\n                class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary-500 focus:border-primary-500 sm:text-sm\"\n              />\n            </div>\n          </div>\n\n          <!-- 确认密码 -->\n          <div>\n            <label for=\"confirm_password\" class=\"block text-sm font-medium text-gray-700\">\n              确认密码\n            </label>\n            <div class=\"mt-1\">\n              <input\n                id=\"confirm_password\"\n                v-model=\"formData.confirm_password\"\n                type=\"password\"\n                required\n                class=\"appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary-500 focus:border-primary-500 sm:text-sm\"\n              />\n            </div>\n          </div>\n\n          <div>\n            <button\n              type=\"submit\"\n              :disabled=\"loading\"\n              class=\"w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              {{ loading ? '注册中...' : '注册' }}\n            </button>\n          </div>\n\n          <div class=\"text-sm text-center\">\n            <router-link to=\"/login\" class=\"font-medium text-primary-600 hover:text-primary-500\">\n              已有账号？立即登录\n            </router-link>\n          </div>\n        </form>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { ElMessage } from 'element-plus'\nimport { auth } from '@/api/auth'\nimport { SMS_SCENE } from '@/constants'\n\nconst router = useRouter()\nconst loading = ref(false)\nconst countdown = ref(0)\n\n// 移除 username，只保留必要的字段\nconst formData = ref({\n  phone: '',\n  code: '',\n  password: '',\n  confirm_password: ''\n})\n\n// 获取验证码\nconst handleGetCode = async () => {\n  try {\n    if (!formData.value.phone) {\n      ElMessage.warning('请输入手机号')\n      return\n    }\n    \n    await auth.sendSmsCode({\n      phone: formData.value.phone,\n      scene: SMS_SCENE.REGISTER\n    })\n    \n    ElMessage.success('验证码已发送')\n    countdown.value = 60\n    const timer = setInterval(() => {\n      countdown.value--\n      if (countdown.value <= 0) {\n        clearInterval(timer)\n      }\n    }, 1000)\n  } catch (error) {\n    console.error('获取验证码失败:', error)\n    ElMessage.error(error.message || '获取验证码失败')\n  }\n}\n\n// 提交注册\nconst handleSubmit = async () => {\n  try {\n    loading.value = true\n    \n    // 表单验证\n    if (formData.value.password !== formData.value.confirm_password) {\n      ElMessage.error('两次输入的密码不一致')\n      return\n    }\n    \n    await auth.register({\n      phone: formData.value.phone,\n      code: formData.value.code,\n      password: formData.value.password,\n      confirm_password: formData.value.confirm_password\n    })\n    \n    ElMessage.success('注册成功')\n    router.push('/login')\n  } catch (error) {\n    console.error('注册失败:', error)\n    ElMessage.error(error.message || '注册失败')\n  } finally {\n    loading.value = false\n  }\n}\n</script>"],"mappings":"AAyGA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,cAAa;AACvC,SAASC,IAAI,QAAQ,YAAW;AAChC,SAASC,SAAS,QAAQ,aAAY;;;;;;;IAEtC,MAAMC,MAAM,GAAGJ,SAAS,CAAC;IACzB,MAAMK,OAAO,GAAGN,GAAG,CAAC,KAAK;IACzB,MAAMO,SAAS,GAAGP,GAAG,CAAC,CAAC;;IAEvB;IACA,MAAMQ,QAAQ,GAAGR,GAAG,CAAC;MACnBS,KAAK,EAAE,EAAE;MACTC,IAAI,EAAE,EAAE;MACRC,QAAQ,EAAE,EAAE;MACZC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACA,MAAMC,aAAa,GAAG,MAAAA,CAAA,KAAY;MAChC,IAAI;QACF,IAAI,CAACL,QAAQ,CAACM,KAAK,CAACL,KAAK,EAAE;UACzBP,SAAS,CAACa,OAAO,CAAC,QAAQ;UAC1B;QACF;QAEA,MAAMZ,IAAI,CAACa,WAAW,CAAC;UACrBP,KAAK,EAAED,QAAQ,CAACM,KAAK,CAACL,KAAK;UAC3BQ,KAAK,EAAEb,SAAS,CAACc;QACnB,CAAC;QAEDhB,SAAS,CAACiB,OAAO,CAAC,QAAQ;QAC1BZ,SAAS,CAACO,KAAK,GAAG,EAAC;QACnB,MAAMM,KAAK,GAAGC,WAAW,CAAC,MAAM;UAC9Bd,SAAS,CAACO,KAAK,EAAC;UAChB,IAAIP,SAAS,CAACO,KAAK,IAAI,CAAC,EAAE;YACxBQ,aAAa,CAACF,KAAK;UACrB;QACF,CAAC,EAAE,IAAI;MACT,CAAC,CAAC,OAAOG,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,UAAU,EAAE