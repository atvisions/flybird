$setup.inactiveModules.length > 0 ? (_openBlock(), _createElementBlock(\"div\", _hoisted_3, [_createElementVNode(\"div\", _hoisted_4, [_cache[4] || (_cache[4] = _createElementVNode(\"h3\", {\n    class: \"text-sm font-medium text-gray-900\"\n  }, \"添加更多模块\", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_5, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.inactiveModules, module => {\n    return _openBlock(), _createElementBlock(\"button\", {\n      key: module.type,\n      onClick: $event => $setup.handleAddModule(module.type),\n      class: \"inline-flex items-center px-3 py-1.5 text-sm text-gray-600 bg-gray-50 hover:bg-gray-100 rounded border border-gray-200\"\n    }, [_createTextVNode(_toDisplayString($setup.getModuleName(module.type)) + \" \", 1 /* TEXT */), _createVNode($setup[\"PlusIcon\"], {\n      class: \"w-4 h-4 ml-1 text-gray-400\"\n    })], 8 /* PROPS */, _hoisted_6);\n  }), 128 /* KEYED_FRAGMENT */))])])])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 工作经历编辑弹窗 \"), $setup.currentModule?.type === 'work_experience' ? (_openBlock(), _createBlock($setup[\"EditWorkExperienceDialog\"], {\n    key: 1,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), $setup.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock($setup[\"EditJobIntentionDialog\"], {\n    key: 2,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), $setup.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock($setup[\"EditBasicDialog\"], {\n    key: 3,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createVNode($setup[\"AIOptimizeDialog\"], {\n    modelValue: $setup.showAIOptimizeDialog,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showAIOptimizeDialog = $event),\n    \"profile-data\": $setup.profileData,\n    onApply: $setup.handleAIOptimize\n  }, null, 8 /* PROPS */, [\"modelValue\", \"profile-data\"])])]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","$setup","resumeData","basicInfo","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onUpdate","handleUpdate","onToggleBioExpand","toggleBioExpand","completionData","profileData","_createCommentVNode","activeModules","modulesLoading","handleEditModule","onRemove","handleModuleRemove","onEditItem","editItem","onRemoveItem","removeItem","inactiveModules","length","_hoisted_3","_hoisted_4","_hoisted_5","_Fragment","_renderList","module","type","onClick","$event","handleAddModule","_createTextVNode","_toDisplayString","getModuleName","_hoisted_6","currentModule","_createBlock","modelValue","showEditModal","_cache","editFormData","onSubmit","handleSubmit","showAIOptimizeDialog","onApply","handleAIOptimize"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @update=\"handleUpdate\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"loading\"\n      />\n\n      <!-- 激活的模块列表 -->\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :loading=\"loading || modulesLoading\"\n        @edit=\"handleEditModule\"\n        @remove=\"handleModuleRemove\"\n        @edit-item=\"editItem\"\n        @remove-item=\"removeItem\"\n      />\n\n      <!-- 未激活的模块按钮组 -->\n      <div v-if=\"inactiveModules.length > 0\" class=\"bg-white rounded-lg shadow\">\n        <div class=\"px-4 py-3\">\n          <h3 class=\"text-sm font-medium text-gray-900\">添加更多模块</h3>\n          <div class=\"mt-3 flex flex-wrap gap-2\">\n            <button\n              v-for=\"module in inactiveModules\"\n              :key=\"module.type\"\n              @click=\"handleAddModule(module.type)\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm text-gray-600 bg-gray-50 hover:bg-gray-100 rounded border border-gray-200\"\n            >\n              {{ getModuleName(module.type) }}\n              <PlusIcon class=\"w-4 h-4 ml-1 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch, computed } from 'vue'\nimport { useModules } from './composables/useModules'\nimport profile from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { PlusIcon } from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\nimport AIOptimizeDialog from './dialogs/AIOptimizeDialog.vue'\n\n// 使用模块管理\nconst { \n  loading: modulesLoading,\n  activeModules,\n  inactiveModules,\n  fetchModulesData,\n  addModule,\n  removeModule\n} = useModules()\n\n// 当前编辑的模块\nconst currentModule = ref(null)\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\nconst loading = ref(false)\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 用户基本信息\nconst userInfo = ref({\n  name: '',\n  username: '',\n  avatar: '',\n  phone: '',\n  email: '',\n  gender: '',\n  birth_date: '',\n  location: '',\n  personal_summary: ''\n})\n\n// 基本信息（用于 BasicInfo 组件）\nconst basicInfo = ref({})\n\n// 档案数据\nconst profileData = ref({\n  basic_info: {\n    name: '',\n    name_en: '',\n    personal_summary: '',\n    personal_summary_en: '',\n    gender: '',\n    phone: '',\n    email: '',\n    location: '',\n    birth_date: ''\n  },\n  job_intention: {\n    job_type: '',\n    job_status: '',\n    expected_salary: '',\n    expected_city: '',\n    industries: ''\n  },\n  work_experiences: [],\n  educations: [],\n  skills: []\n})\n\n// 完整度数据\nconst completionData = ref({\n  total_score: 0,\n  dimensions: {},\n  suggestions: []\n})\n\n// 添加缺失的响应式变量\nconst showAIOptimizeDialog = ref(false)\n\n// 处理 Bio 展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 定义组件的 emits\ndefineEmits([\n  'update:modelValue',\n  'edit',\n  'add',\n  'remove',\n  'edit-item',\n  'remove-item'\n])\n\n// 获取用户数据\nconst fetchUserData = async () => {\n  try {\n    loading.value = true\n    // 重新获取布局\n    await fetchLayout()\n    \n    // 获取基本信息\n    const basicResponse = await profile.getBasicInfo()\n    if (basicResponse.data?.code === 200) {\n      const { user, basic_info } = basicResponse.data.data\n      \n      // 更新用户信息\n      userInfo.value = {\n        ...user,\n        ...basic_info,\n        avatar: basic_info?.avatar || user?.avatar\n      }\n      \n      // 更新基本信息（用于 BasicInfo 组件）\n      basicInfo.value = {\n        ...userInfo.value\n      }\n    }\n\n    // 获取工作经历数据\n    const workResponse = await profile.workExperience.list()\n    if (workResponse.data?.code === 200) {\n      // 更新工作经历模块数据\n      const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n      if (workExperienceModule) {\n        workExperienceModule.data = workResponse.data.data || []\n      }\n    }\n\n    // 获取求职意向数据\n    const intentionResponse = await profile.jobIntention.get()\n    if (intentionResponse.data?.code === 200) {\n      const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n      if (jobIntentionModule) {\n        jobIntentionModule.data = intentionResponse.data.data || {}\n      }\n    }\n\n    // 获取完整度数据\n    await fetchCompleteness()\n    \n  } catch (error) {\n    console.error('获取数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 获取完整度数据\nconst fetchCompleteness = async () => {\n  try {\n    const response = await profile.getCompleteness()\n    if (response.data?.code === 200) {\n      completionData.value = {\n        total_score: response.data.data.total_score || 0,\n        dimensions: response.data.data.dimensions || {},\n        suggestions: response.data.data.suggestions || []\n      }\n    }\n  } catch (error) {\n    console.error('获取完整度失败:', error)\n  }\n}\n\n// 更新模块数据\nconst updateModules = (data) => {\n  const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n  if (jobIntentionModule) {\n    jobIntentionModule.data = data.job_intention || {}\n  }\n\n  const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n  if (workExperienceModule) {\n    workExperienceModule.data = data.work_experiences || []\n  }\n}\n\n// 处理数据更新\nconst handleDataUpdate = async () => {\n  await fetchUserData()\n}\n\n// 初始化数据\nonMounted(async () => {\n  await fetchModulesData()\n})\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchUserData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    loading.value = true\n    \n    if (currentModule.value?.type === 'basic_info') {\n      // 基本信息保存\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchUserData()\n      } else {\n        throw new Error(response.data?.message || '保存失败')\n      }\n    } else if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.workExperience.update(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchUserData()\n        } else {\n          throw new Error(response.data?.message || '更新失败')\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.workExperience.add(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchUserData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.jobIntention.update(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchUserData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.type === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\n// 处理 AI 优化结果\nconst handleAIOptimize = (optimizedData) => {\n  Object.entries(optimizedData).forEach(([key, value]) => {\n    const [category, field] = key.split('.')\n    if (category && field) {\n      if (!profileData.value[category]) {\n        profileData.value[category] = {}\n      }\n      profileData.value[category][field] = value\n    } else {\n      profileData.value[key] = value\n    }\n  })\n}\n\n// 添加更新处理方法\nconst handleUpdate = async () => {\n  await fetchUserData()\n}\n\n// 处理模块移除\nconst handleModuleRemove = async (moduleType) => {\n  await removeModule(moduleType)\n}\n\n// 处理添加模块\nconst handleAddModule = async (moduleType) => {\n  await addModule(moduleType)\n}\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;EAH5CC,GAAA;EA+B6CD,KAAK,EAAC;;;EACtCA,KAAK,EAAC;AAAW;;EAEfA,KAAK,EAAC;AAA2B;mBAlChD;;uBAEEE,mBAAA,CA+EM,OA/ENC,UA+EM,GA9EJC,mBAAA,CA6EM,OA7ENC,UA6EM,GA5EJC,YAAA,CAQEC,MAAA;IAPCC,UAAU,EAAED,MAAA,CAAAE,SAAS;IACrBC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBC,WAAW,EAAEJ,MAAA,CAAAI,WAAW;IACxBC,mBAAmB,EAAEL,MAAA,CAAAK,mBAAmB;IACxCC,MAAI,EAAEN,MAAA,CAAAO,UAAU;IAChBC,QAAM,EAAER,MAAA,CAAAS,YAAY;IACpBC,iBAAe,EAAEV,MAAA,CAAAW;4FAGpBZ,YAAA,CAIEC,MAAA;IAHC,iBAAe,EAAEA,MAAA,CAAAY,cAAc;IAC/B,cAAY,EAAEZ,MAAA,CAAAa,WAAW;IACzBV,OAAO,EAAEH,MAAA,CAAAG;2EAGZW,mBAAA,aAAgB,EAChBf,YAAA,CAOEC,MAAA;IANC,gBAAc,EAAEA,MAAA,CAAAe,aAAa;IAC7BZ,OAAO,EAAEH,MAAA,CAAAG,OAAO,IAAIH,MAAA,CAAAgB,cAAc;IAClCV,MAAI,EAAEN,MAAA,CAAAiB,gBAAgB;IACtBC,QAAM,EAAElB,MAAA,CAAAmB,kBAAkB;IAC1BC,UAAS,EAAEpB,MAAA,CAAAqB,QAAQ;IACnBC,YAAW,EAAEtB,MAAA,CAAAuB;0DAGhBT,mBAAA,eAAkB,EACPd,MAAA,CAAAwB,eAAe,CAACC,MAAM,Q,cAAjC9B,mBAAA,CAeM,OAfN+B,UAeM,GAdJ7B,mBAAA,CAaM,OAbN8B,UAaM,G,0BAZJ9B,mBAAA,CAAyD;IAArDJ,KAAK,EAAC;EAAmC,GAAC,QAAM,sBACpDI,mBAAA,CAUM,OAVN+B,UAUM,I,kBATJjC,mBAAA,CAQSkC,SAAA,QA3CrBC,WAAA,CAoC+B9B,MAAA,CAAAwB,eAAe,EAAzBO,MAAM;yBADfpC,mBAAA,CAQS;MANND,GAAG,EAAEqC,MAAM,CAACC,IAAI;MAChBC,OAAK,EAAAC,MAAA,IAAElC,MAAA,CAAAmC,eAAe,CAACJ,MAAM,CAACC,IAAI;MACnCvC,KAAK,EAAC;QAvCpB2C,gBAAA,CAAAC,gBAAA,CAyCiBrC,MAAA,CAAAsC,aAAa,CAACP,MAAM,CAACC,IAAI,KAAI,GAChC,iBAAAjC,YAAA,CAA+CC,MAAA;MAArCP,KAAK,EAAC;IAA4B,G,iBA1C1D8C,UAAA;0CAAAzB,mBAAA,gBAgDMA,mBAAA,cAAiB,EAETd,MAAA,CAAAwC,aAAa,EAAER,IAAI,0B,cAD3BS,YAAA,CAMEzC,MAAA;IAvDRN,GAAA;IAAAgD,UAAA,EAmDiB1C,MAAA,CAAA2C,aAAa;IAnD9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IAmDiBlC,MAAA,CAAA2C,aAAa,GAAAT,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAA6C,YAAY;IAC1B1C,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChB2C,QAAM,EAAE9C,MAAA,CAAA+C;wEAtDjBjC,mBAAA,gBAyDMA,mBAAA,cAAiB,EAETd,MAAA,CAAAwC,aAAa,EAAER,IAAI,wB,cAD3BS,YAAA,CAMEzC,MAAA;IAhERN,GAAA;IAAAgD,UAAA,EA4DiB1C,MAAA,CAAA2C,aAAa;IA5D9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IA4DiBlC,MAAA,CAAA2C,aAAa,GAAAT,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAA6C,YAAY;IAC1B1C,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChB2C,QAAM,EAAE9C,MAAA,CAAA+C;wEA/DjBjC,mBAAA,gBAkEMA,mBAAA,cAAiB,EAETd,MAAA,CAAAwC,aAAa,EAAER,IAAI,qB,cAD3BS,YAAA,CAMEzC,MAAA;IAzERN,GAAA;IAAAgD,UAAA,EAqEiB1C,MAAA,CAAA2C,aAAa;IArE9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IAqEiBlC,MAAA,CAAA2C,aAAa,GAAAT,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAA6C,YAAY;IAC1B1C,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChB2C,QAAM,EAAE9C,MAAA,CAAA+C;wEAxEjBjC,mBAAA,gBA2EMf,YAAA,CAIEC,MAAA;IA/ER0C,UAAA,EA4EiB1C,MAAA,CAAAgD,oBAAoB;IA5ErC,uBAAAJ,MAAA,QAAAA,MAAA,MAAAV,MAAA,IA4EiBlC,MAAA,CAAAgD,oBAAoB,GAAAd,MAAA;IAC5B,cAAY,EAAElC,MAAA,CAAAa,WAAW;IACzBoC,OAAK,EAAEjD,MAAA,CAAAkD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}