  class: \"text-sm text-gray-500\"\n};\nconst _hoisted_21 = {\n  class: \"flex space-x-3\"\n};\nconst _hoisted_22 = [\"disabled\"];\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  const _component_el_dialog = _resolveComponent(\"el-dialog\");\n  return _openBlock(), _createBlock(_component_el_dialog, {\n    modelValue: $setup.dialogVisible,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.dialogVisible = $event),\n    width: $setup.dialogWidth,\n    fullscreen: $setup.isMobile,\n    \"close-on-click-modal\": false,\n    \"show-close\": false,\n    class: \"optimize-dialog\",\n    \"destroy-on-close\": \"\"\n  }, {\n    default: _withCtx(() => [_createCommentVNode(\" 主容器 \"), _createElementVNode(\"div\", _hoisted_1, [_createCommentVNode(\" 头部 \"), _createElementVNode(\"div\", _hoisted_2, [_createElementVNode(\"div\", _hoisted_3, [_cache[3] || (_cache[3] = _createElementVNode(\"h3\", {\n      class: \"text-lg font-medium text-gray-900\"\n    }, \"AI 优化\", -1 /* HOISTED */)), $setup.isOptimizing ? (_openBlock(), _createElementBlock(\"div\", _hoisted_4, [_cache[1] || (_cache[1] = _createElementVNode(\"span\", null, \"已完成\", -1 /* HOISTED */)), _createElementVNode(\"span\", _hoisted_5, _toDisplayString($setup.completedCount), 1 /* TEXT */), _cache[2] || (_cache[2] = _createElementVNode(\"span\", null, \"/\", -1 /* HOISTED */)), _createElementVNode(\"span\", null, _toDisplayString($setup.totalFields), 1 /* TEXT */)])) : _createCommentVNode(\"v-if\", true)]), _createElementVNode(\"button\", {\n      onClick: $setup.handleClose,\n      class: \"text-gray-400 hover:text-gray-500\"\n    }, [_createVNode($setup[\"XMarkIcon\"], {\n      class: \"h-6 w-6\"\n    })])]), _createCommentVNode(\" 内容区域 \"), _createElementVNode(\"div\", _hoisted_6, [_createElementVNode(\"div\", _hoisted_7, [_createCommentVNode(\" 表格容器 \"), _createElementVNode(\"div\", _hoisted_8, [_createCommentVNode(\" 表格头部 \"), _cache[5] || (_cache[5] = _createElementVNode(\"div\", {\n      class: \"sticky top-0 z-10 bg-gray-50 border-b border-gray-200\"\n    }, [_createElementVNode(\"div\", {\n      class: \"grid grid-cols-12 gap-0\"\n    }, [_createElementVNode(\"div\", {\n      class: \"col-span-2 py-3 px-4 text-left text-sm font-medium text-gray-900\"\n    }, \"字段\"), _createElementVNode(\"div\", {\n      class: \"col-span-4 py-3 px-4 text-left text-sm font-medium text-gray-900\"\n    }, \"当前内容\"), _createElementVNode(\"div\", {\n      class: \"col-span-5 py-3 px-4 text-left text-sm font-medium text-gray-900\"\n    }, \"优化建议\"), _createElementVNode(\"div\", {\n      class: \"col-span-1 py-3 px-4 text-center text-sm font-medium text-gray-900\"\n    }, \"状态\")])], -1 /* HOISTED */)), _createCommentVNode(\" 表格内容 \"), _createElementVNode(\"div\", _hoisted_9, [_createVNode(_TransitionGroup, {\n      name: \"list\",\n      tag: \"div\"\n    }, {\n      default: _withCtx(() => [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.displayFields, field => {\n        return _openBlock(), _createElementBlock(\"div\", {\n          key: field.name,\n          class: \"grid grid-cols-12 gap-0 border-b border-gray-100 hover:bg-gray-50 field-row\"\n        }, [_createCommentVNode(\" 字段名 \"), _createElementVNode(\"div\", _hoisted_10, _toDisplayString(field.label), 1 /* TEXT */), _createCommentVNode(\" 当前内容 \"), _createElementVNode(\"div\", _hoisted_11, [_createElementVNode(\"div\", _hoisted_12, _toDisplayString(field.currentValue || '未填写'), 1 /* TEXT */)]), _createCommentVNode(\" 优化建议 \"), _createElementVNode(\"div\", _hoisted_13, [_createElementVNode(\"div\", _hoisted_14, [field.status === 'processing' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_15, [...(_cache[4] || (_cache[4] = [_createElementVNode(\"div\", {\n          class: \"animate-spin rounded-full h-4 w-4 border-2 border-gray-300 border-t-blue-600\"\n        }, null, -1 /* HOISTED */), _createElementVNode(\"span\", null, \"优化中...\", -1 /* HOISTED */)]))])) : (_openBlock(), _createElementBlock(_Fragment, {\n          key: 1\n        }, [_createTextVNode(_toDisplayString(field.optimizedValue || '等待优化'), 1 /* TEXT */)], 64 /* STABLE_FRAGMENT */))])]), _createCommentVNode(\" 状态 \"), _createElementVNode(\"div\", _hoisted_16, [field.status === 'success' ? (_openBlock(), _createBlock($setup[\"CheckCircleIcon\"], {\n          key: 0,\n          class: \"w-5 h-5 text-green-500\"\n        })) : field.status === 'failed' ? (_openBlock(), _createBlock($setup[\"XCircleIcon\"], {\n          key: 1,\n          class: \"w-5 h-5 text-red-500\"\n        })) : field.status === 'processing' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_17)) : (_openBlock(), _createBlock($setup[\"MinusCircleIcon\"], {\n          key: 3,\n          class: \"w-5 h-5 text-gray-300\"\n        }))])]);\n      }), 128 /* KEYED_FRAGMENT */))]),\n      _: 1 /* STABLE */\n    })])])], 512 /* NEED_PATCH */)]), _createCommentVNode(\" 底部 \"), _createElementVNode(\"div\", _hoisted_18, [_createElementVNode(\"div\", _hoisted_19, [_createElementVNode(\"div\", _hoisted_20, _toDisplayString($setup.footerText), 1 /* TEXT */), _createElementVNode(\"div\", _hoisted_21, [_createElementVNode(\"button\", {\n      onClick: $setup.handleClose,\n      class: \"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n    }, \" 取消 \"), !$setup.isOptimizing ? (_openBlock(), _createElementBlock(\"button\", {\n      key: 0,\n      onClick: $setup.startOptimize,\n      class: \"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700\"\n    }, \" 一键优化 \")) : (_openBlock(), _createElementBlock(\"button\", {\n      key: 1,\n      onClick: $setup.handleApply,\n      disabled: !$setup.hasOptimized,\n      class: \"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed\"\n    }, \" 应用优化 \", 8 /* PROPS */, _hoisted_22))])])])])]),\n    _: 1 /* STABLE */\n  }, 8 /* PROPS */, [\"modelValue\", \"width\", \"fullscreen\"]);\n}","map":{"version":3,"names":["class","key","ref","_createBlock","_component_el_dialog","modelValue","$setup","dialogVisible","_cache","$event","width","dialogWidth","fullscreen","isMobile","default","_withCtx","_createCommentVNode","_createElementVNode","_hoisted_1","_hoisted_2","_hoisted_3","isOptimizing","_createElementBlock","_hoisted_4","_hoisted_5","_toDisplayString","completedCount","totalFields","onClick","handleClose","_createVNode","_hoisted_6","_hoisted_7","_hoisted_8","_hoisted_9","_TransitionGroup","name","tag","_Fragment","_renderList","displayFields","field","_hoisted_10","label","_hoisted_11","_hoisted_12","currentValue","_hoisted_13","_hoisted_14","status","_hoisted_15","_createTextVNode","optimizedValue","_hoisted_16","_hoisted_17","_","_hoisted_18","_hoisted_19","_hoisted_20","footerText","_hoisted_21","startOptimize","handleApply","disabled","hasOptimized","_hoisted_22"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/AIOptimizeDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    v-model=\"dialogVisible\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    class=\"optimize-dialog\"\n    destroy-on-close\n  >\n    <!-- 主容器 -->\n    <div class=\"flex flex-col h-[700px] bg-white\">\n      <!-- 头部 -->\n      <div class=\"flex items-center justify-between px-6 py-4 border-b border-gray-200\">\n        <div class=\"flex items-center space-x-3\">\n          <h3 class=\"text-lg font-medium text-gray-900\">AI 优化</h3>\n          <div v-if=\"isOptimizing\" class=\"flex items-center space-x-1 text-sm text-gray-500\">\n            <span>已完成</span>\n            <span class=\"font-medium text-blue-600\">{{ completedCount }}</span>\n            <span>/</span>\n            <span>{{ totalFields }}</span>\n          </div>\n        </div>\n        <button\n          @click=\"handleClose\"\n          class=\"text-gray-400 hover:text-gray-500\"\n        >\n          <XMarkIcon class=\"h-6 w-6\" />\n        </button>\n      </div>\n\n      <!-- 内容区域 -->\n      <div class=\"flex-1 overflow-hidden\">\n        <div ref=\"scrollContainer\" class=\"h-full overflow-y-auto\">\n          <!-- 表格容器 -->\n          <div class=\"min-w-full\">\n            <!-- 表格头部 -->\n            <div class=\"sticky top-0 z-10 bg-gray-50 border-b border-gray-200\">\n              <div class=\"grid grid-cols-12 gap-0\">\n                <div class=\"col-span-2 py-3 px-4 text-left text-sm font-medium text-gray-900\">字段</div>\n                <div class=\"col-span-4 py-3 px-4 text-left text-sm font-medium text-gray-900\">当前内容</div>\n                <div class=\"col-span-5 py-3 px-4 text-left text-sm font-medium text-gray-900\">优化建议</div>\n                <div class=\"col-span-1 py-3 px-4 text-center text-sm font-medium text-gray-900\">状态</div>\n              </div>\n            </div>\n\n            <!-- 表格内容 -->\n            <div class=\"bg-white\">\n              <TransitionGroup name=\"list\" tag=\"div\">\n                <div \n                  v-for=\"field in displayFields\" \n                  :key=\"field.name\"\n                  class=\"grid grid-cols-12 gap-0 border-b border-gray-100 hover:bg-gray-50 field-row\"\n                >\n                  <!-- 字段名 -->\n                  <div class=\"col-span-2 py-3 px-4 text-sm text-gray-900\">\n                    {{ field.label }}\n                  </div>\n                  \n                  <!-- 当前内容 -->\n                  <div class=\"col-span-4 py-3 px-4 text-sm text-gray-500\">\n                    <div class=\"break-words\">\n                      {{ field.currentValue || '未填写' }}\n                    </div>\n                  </div>\n                  \n                  <!-- 优化建议 -->\n                  <div class=\"col-span-5 py-3 px-4 text-sm text-gray-900\">\n                    <div class=\"break-words\">\n                      <template v-if=\"field.status === 'processing'\">\n                        <div class=\"flex items-center space-x-2 text-gray-500\">\n                          <div class=\"animate-spin rounded-full h-4 w-4 border-2 border-gray-300 border-t-blue-600\"></div>\n                          <span>优化中...</span>\n                        </div>\n                      </template>\n                      <template v-else>\n                        {{ field.optimizedValue || '等待优化' }}\n                      </template>\n                    </div>\n                  </div>\n                  \n                  <!-- 状态 -->\n                  <div class=\"col-span-1 py-3 px-4 flex items-center justify-center\">\n                    <template v-if=\"field.status === 'success'\">\n                      <CheckCircleIcon class=\"w-5 h-5 text-green-500\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'failed'\">\n                      <XCircleIcon class=\"w-5 h-5 text-red-500\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'processing'\">\n                      <div class=\"animate-spin rounded-full h-5 w-5 border-2 border-gray-300 border-t-blue-600\"></div>\n                    </template>\n                    <template v-else>\n                      <MinusCircleIcon class=\"w-5 h-5 text-gray-300\" />\n                    </template>\n                  </div>\n                </div>\n              </TransitionGroup>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 底部 -->\n      <div class=\"px-6 py-4 border-t border-gray-200\">\n        <div class=\"flex justify-between items-center\">\n          <div class=\"text-sm text-gray-500\">\n            {{ footerText }}\n          </div>\n          <div class=\"flex space-x-3\">\n            <button\n              @click=\"handleClose\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n            >\n              取消\n            </button>\n            <button v-if=\"!isOptimizing\"\n              @click=\"startOptimize\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700\"\n            >\n              一键优化\n            </button>\n            <button v-else\n              @click=\"handleApply\"\n              :disabled=\"!hasOptimized\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              应用优化\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, nextTick } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { \n  XMarkIcon, \n  CheckCircleIcon, \n  XCircleIcon,\n  MinusCircleIcon\n} from '@heroicons/vue/24/solid'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  profileData: {\n    type: Object,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'apply'])\n\n// 简化字段配置，只保留中文字段\nconst fieldConfig = [\n  // 基本信息\n  { name: 'basic_info.name', label: '姓名', group: '基本信息' },\n  { name: 'basic_info.gender', label: '性别', group: '基本信息' },\n  { name: 'basic_info.birth_date', label: '出生日期', group: '基本信息' },\n  { name: 'basic_info.phone', label: '手机号码', group: '基本信息' },\n  { name: 'basic_info.email', label: '电子邮箱', group: '基本信息' },\n  { name: 'basic_info.location', label: '所在地', group: '基本信息' },\n  { name: 'basic_info.personal_summary', label: '个人简介', group: '基本信息' },\n  \n  // 求职意向\n  { name: 'job_intention.job_type', label: '工作类型', group: '求职意向' },\n  { name: 'job_intention.job_status', label: '求职状态', group: '求职意向' },\n  { name: 'job_intention.expected_salary', label: '期望薪资', group: '求职意向' },\n  { name: 'job_intention.expected_city', label: '期望城市', group: '求职意向' },\n  { name: 'job_intention.industries', label: '期望行业', group: '求职意向' },\n\n  // 工作经历\n  { name: 'work_experiences', label: '工作经历', group: '工作经历', isArray: true, fields: [\n    { name: 'company', label: '公司名称' },\n    { name: 'position', label: '职位名称' },\n    { name: 'department', label: '所在部门' },\n    { name: 'start_date', label: '开始时间' },\n    { name: 'end_date', label: '结束时间' },\n    { name: 'description', label: '工作描述' },\n    { name: 'achievements', label: '工作成就' },\n    { name: 'technologies', label: '技术栈' }\n  ]},\n\n  // 教育经历\n  { name: 'educations', label: '教育经历', group: '教育经历', isArray: true, fields: [\n    { name: 'school', label: '学校名称' },\n    { name: 'major', label: '专业' },\n    { name: 'degree', label: '学位' },\n    { name: 'start_date', label: '开始时间' },\n    { name: 'end_date', label: '结束时间' },\n    { name: 'description', label: '在校经历' }\n  ]},\n\n  // 技能特长\n  { name: 'skills', label: '技能特长', group: '技能特长', isArray: true, fields: [\n    { name: 'name', label: '技能名称' },\n    { name: 'level', label: '掌握程度' },\n    { name: 'description', label: '技能描述' }\n  ]},\n\n  // 证书成就\n  { name: 'certificates', label: '证书成就', group: '证书成就', isArray: true, fields: [\n    { name: 'name', label: '证书名称' },\n    { name: 'issuing_authority', label: '发证机构' },\n    { name: 'issue_date', label: '获得日期' },\n    { name: 'description', label: '证书描述' }\n  ]},\n\n  // 项目经历\n  { name: 'projects', label: '项目经历', group: '项目经历', isArray: true, fields: [\n    { name: 'name', label: '项目名称' },\n    { name: 'role', label: '担任角色' },\n    { name: 'start_date', label: '开始时间' },\n    { name: 'end_date', label: '结束时间' },\n    { name: 'description', label: '项目描述' },\n    { name: 'achievements', label: '项目成就' },\n    { name: 'technologies', label: '使用技术' }\n  ]}\n]\n\n// 模拟 AI 优化结果 - 根据字段类型提供不同的优化策略\nconst mockOptimize = async (field, value) => {\n  if (!value) return null\n\n  const optimizations = {\n    // 基本信息优化\n    name_en: value => value.toLowerCase().replace(/\\b\\w/g, l => l.toUpperCase()),\n    personal_summary: value => `我是一名经验丰富的${value.includes('开发') ? '开发工程师' : '专业人士'}，${value}`,\n    personal_summary_en: value => `I am an experienced ${value.includes('developer') ? 'developer' : 'professional'} ${value}`,\n\n    // 求职意向优化\n    expected_salary: value => value.includes('面议') ? '根据经验和能力，期望薪资15k-25k' : value,\n    industries: value => value.split(',').map(i => i.trim()).join('、'),\n\n    // 工作经历优化\n    description: value => value.replace(/^我/, '').replace(/。$/, '，工作中注重团队协作和技术创新。'),\n    description_en: value => `Responsible for ${value}. Focus on team collaboration and technical innovation.`,\n    achievements: value => value ? `${value}，为团队和公司创造了显著价值。` : '通过技术创新和流程优化，提升了团队工作效率，获得领导和同事的一致好评。',\n    achievements_en: value => value ? `${value}. Created significant value for the team and company.` : 'Improved team efficiency through technical innovation and process optimization.',\n    technologies: value => value ? value.split(',').sort().join(', ') : '',\n\n    // 技能特长优化\n    'skills.description': value => `精通${value}，有丰富的实践经验。`,\n    'skills.level': value => value === '熟悉' ? '精通' : value\n  }\n\n  // 模拟 API 延迟\n  await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 2000))\n\n  // 根据字段名返回优化结果\n  const fieldKey = field.name.split('.').pop()\n  return optimizations[fieldKey] ? \n    optimizations[fieldKey](value) : \n    `${value}（已优化）`\n}\n\n// 处理字段数据\nconst processFields = () => {\n  const result = []\n  \n  // 确保 profileData 存在且有效\n  if (!props.profileData) {\n    console.warn('profileData is undefined')\n    return result\n  }\n\n  fieldConfig.forEach(field => {\n    if (field.isArray) {\n      // 处理数组类型的字段（如工作经历、教育经历）\n      const items = props.profileData[field.name] || []\n      items.forEach((item, index) => {\n        if (field.fields) {\n          // 如果有子字段（如工作经历的详细信息）\n          field.fields.forEach(subField => {\n            result.push({\n              ...subField,\n              label: `${field.label} ${index + 1} - ${subField.label}`,\n              currentValue: item?.[subField.name] || '',\n              group: field.group,\n              optimizedValue: '',\n              status: 'pending'\n            })\n          })\n        } else {\n          // 如果是简单数组（如技能特长）\n          result.push({\n            ...field,\n            currentValue: item || '',\n            optimizedValue: '',\n            status: 'pending'\n          })\n        }\n      })\n    } else {\n      // 处理普通字段，从嵌套对象中获取值\n      let currentValue = ''\n      const [category, key] = field.name.split('.')  // 使用点号分割而不是下划线\n      if (category && key) {\n        // 处理嵌套字段，如 basic_info.name\n        currentValue = props.profileData[category]?.[key] || ''\n      } else {\n        currentValue = props.profileData[field.name] || ''\n      }\n\n      result.push({\n        ...field,\n        currentValue,\n        optimizedValue: '',\n        status: 'pending'\n      })\n    }\n  })\n\n  return result\n}\n\nconst fields = ref(processFields())\n\n// 计算属性\nconst displayFields = computed(() => {\n  return fields.value.sort((a, b) => {\n    if (a.status === 'pending' && b.status !== 'pending') return 1\n    if (a.status !== 'pending' && b.status === 'pending') return -1\n    return 0\n  })\n})\n\nconst completedCount = computed(() => \n  fields.value.filter(f => ['success', 'failed'].includes(f.status)).length\n)\n\nconst totalFields = computed(() => fields.value.length)\n\nconst hasOptimized = computed(() => \n  fields.value.some(f => f.status === 'success')\n)\n\n// 添加优化状态标志\nconst isOptimizing = ref(false)\n\n// 修改底部文本\nconst footerText = computed(() => {\n  if (!isOptimizing.value) return '点击\"一键优化\"开始AI优化'\n  if (hasOptimized.value) return '优化完成后，您可以选择应用建议的内容'\n  return '正在优化中，请稍候...'\n})\n\n// 添加滚动容器的引用\nconst scrollContainer = ref(null)\n\n// 修改开始优化方法，添加滚动逻辑\nconst startOptimize = async () => {\n  isOptimizing.value = true\n  for (const field of fields.value) {\n    if (!field.currentValue) continue\n    \n    field.status = 'processing'\n    try {\n      const optimized = await mockOptimize(field, field.currentValue)\n      if (optimized) {\n        field.optimizedValue = optimized\n        field.status = 'success'\n        \n        // 等待DOM更新\n        await nextTick()\n        \n        // 找到下一个待优化的字段的索引\n        const currentIndex = displayFields.value.findIndex(f => f.name === field.name)\n        const nextField = displayFields.value[currentIndex + 1]\n        \n        // 如果有下一个字段，滚动到该字段\n        if (nextField) {\n          const fieldElements = scrollContainer.value.querySelectorAll('.field-row')\n          const nextElement = fieldElements[currentIndex + 1]\n          if (nextElement) {\n            nextElement.scrollIntoView({ \n              behavior: 'smooth', \n              block: 'center'\n            })\n          }\n        }\n      } else {\n        field.status = 'pending'\n      }\n    } catch (error) {\n      console.error('优化失败:', error)\n      field.status = 'failed'\n    }\n  }\n}\n\n// 修改处理关闭方法\nconst handleClose = () => {\n  if (isOptimizing.value) {\n    // 如果正在优化，提示用户是否确认关闭\n    if (confirm('正在优化中，确定要关闭吗？')) {\n      isOptimizing.value = false\n      dialogVisible.value = false\n    }\n  } else {\n    dialogVisible.value = false\n  }\n}\n\n// 处理应用优化\nconst handleApply = () => {\n  const optimizedData = {}\n  fields.value.forEach(field => {\n    if (field.status === 'success') {\n      optimizedData[field.name] = field.optimizedValue\n    }\n  })\n  emit('apply', optimizedData)\n  handleClose()\n}\n\n// 添加回对话框控制代码\nconst dialogVisible = computed({\n  get: () => props.modelValue,\n  set: (value) => emit('update:modelValue', value)\n})\n\n// 响应式布局\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  return '1000px'  // 增加宽度以适应内容\n})\n\n// 移除 onMounted 中的自动开始优化\nonMounted(() => {\n  // 移除 startOptimize() 调用，等待用户点击\"一键优化\"按钮\n})\n\n// 修改表格列宽度\nconst columnWidths = {\n  label: 'w-[120px] min-w-[120px]',\n  content: 'w-[200px] min-w-[200px]',\n  suggestion: 'min-w-[300px] flex-1',\n  status: 'w-[60px] min-w-[60px]'\n}\n</script>\n\n<style scoped>\n/* 动画效果 */\n.list-move,\n.list-enter-active,\n.list-leave-active {\n  transition: all 0.5s ease;\n}\n\n.list-enter-from,\n.list-leave-to {\n  opacity: 0;\n  transform: translateY(30px);\n}\n\n.list-leave-active {\n  position: absolute;\n}\n\n/* 滚动条美化 */\n.overflow-y-auto {\n  scrollbar-width: thin;\n  scrollbar-color: rgba(0, 0, 0, 0.2) transparent;\n}\n\n.overflow-y-auto::-webkit-scrollbar {\n  width: 6px;\n}\n\n.overflow-y-auto::-webkit-scrollbar-track {\n  background: transparent;\n}\n\n.overflow-y-auto::-webkit-scrollbar-thumb {\n  background-color: rgba(0, 0, 0, 0.2);\n  border-radius: 3px;\n}\n\n/* 文本换行 */\n.break-words {\n  word-break: break-word;\n  overflow-wrap: break-word;\n}\n\n/* 添加平滑滚动 */\n.overflow-y-auto {\n  scroll-behavior: smooth;\n}\n\n/* 优化滚动体验 */\n.field-row {\n  scroll-margin: 100px; /* 确保滚动时有足够的上下文 */\n}\n</style> "],"mappings":";;EAWSA,KAAK,EAAC;AAAkC;;EAEtCA,KAAK,EAAC;AAAsE;;EAC1EA,KAAK,EAAC;AAA6B;;EAdhDC,GAAA;EAgBmCD,KAAK,EAAC;;;EAEvBA,KAAK,EAAC;AAA2B;;EAcxCA,KAAK,EAAC;AAAwB;;EAC5BE,GAAG,EAAC,iBAAiB;EAACF,KAAK,EAAC;;;EAE1BA,KAAK,EAAC;AAAY;;EAYhBA,KAAK,EAAC;AAAU;;EAQVA,KAAK,EAAC;AAA4C;;EAKlDA,KAAK,EAAC;AAA4C;;EAChDA,KAAK,EAAC;AAAa;;EAMrBA,KAAK,EAAC;AAA4C;;EAChDA,KAAK,EAAC;AAAa;;EApE5CC,GAAA;EAsE6BD,KAAK,EAAC;;;EAYZA,KAAK,EAAC;AAAuD;;EAlFpFC,GAAA;EA0F2BD,KAAK,EAAC;;;EActBA,KAAK,EAAC;AAAoC;;EACxCA,KAAK,EAAC;AAAmC;;EACvCA,KAAK,EAAC;AAAuB;;EAG7BA,KAAK,EAAC;AAAgB;oBA7GrC;;;uBACEG,YAAA,CAoIYC,oBAAA;IArIdC,UAAA,EAEaC,MAAA,CAAAC,aAAa;IAF1B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAEaH,MAAA,CAAAC,aAAa,GAAAE,MAAA;IACrBC,KAAK,EAAEJ,MAAA,CAAAK,WAAW;IAClBC,UAAU,EAAEN,MAAA,CAAAO,QAAQ;IA