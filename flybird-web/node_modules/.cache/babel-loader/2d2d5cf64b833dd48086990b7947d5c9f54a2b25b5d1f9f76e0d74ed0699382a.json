{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.find.js\";\nimport { ref, watch, onMounted, nextTick } from 'vue';\nimport { PencilSquareIcon, TrashIcon, PlusIcon, ExclamationTriangleIcon, BriefcaseIcon, BanknotesIcon, MapPinIcon, BuildingOfficeIcon, CalendarIcon, DocumentTextIcon, TrophyIcon } from '@heroicons/vue/24/outline';\nimport { ALL_MODULES } from '@/constants';\nimport JobIntentionContent from './JobIntentionContent.vue';\nimport WorkExperienceContent from './WorkExperienceContent.vue';\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions';\nimport { Dialog, DialogPanel, DialogTitle, TransitionRoot, TransitionChild } from '@headlessui/vue';\nimport EducationContent from './EducationContent.vue';\nimport EditEducationDialog from '../dialogs/EditEducationDialog.vue';\nimport { ElMessage } from 'element-plus';\nimport profile from '@/api/profile';\nimport { useModules } from '../composables/useModules';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    inactiveModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    },\n    fetchModulesData: {\n      type: Function,\n      required: true\n    }\n  },\n  emits: ['remove', 'edit', 'edit-item', 'remove-item'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 获取模块显示名称\n    const getModuleName = type => {\n      return ALL_MODULES[type] || type;\n    };\n\n    // 删除相关状态\n    const showDeleteConfirm = ref(false);\n    const itemToDelete = ref(null);\n\n    // 处理删除\n    const handleRemoveItem = async (type, itemId) => {\n      if (type === 'work_experience' || type === 'education') {\n        itemToDelete.value = {\n          type,\n          id: itemId\n        };\n        showDeleteConfirm.value = true;\n      }\n    };\n\n    // 确认删除\n    const confirmDelete = async () => {\n      try {\n        if (itemToDelete.value) {\n          if (itemToDelete.value.type === 'work_experience') {\n            await profile.workExperience.delete(itemToDelete.value.id);\n          } else if (itemToDelete.value.type === 'education') {\n            await profile.education.delete(itemToDelete.value.id);\n          }\n          showDeleteConfirm.value = false;\n          itemToDelete.value = null;\n          await props.fetchModulesData();\n          ElMessage.success('删除成功');\n        }\n      } catch (error) {\n        console.error('删除失败:', error);\n        ElMessage.error('删除失败，请稍后重试');\n      }\n    };\n\n    // 监听模块变化\n    watch(() => props.activeModules, newModules => {\n      console.log('ModuleList - 活动模块更新:', {\n        active: newModules,\n        workExperience: newModules.find(m => m.type === 'work_experience')?.data,\n        jobIntention: newModules.find(m => m.type === 'job_intention')?.data\n      });\n    }, {\n      deep: true\n    });\n\n    // 格式化薪资显示\n    const formatSalary = salary => {\n      if (!salary) return '未设置';\n      const [min, max] = salary.split('-');\n      if (min && max) {\n        return `${min}-${max}K/月`;\n      }\n      return `${salary}K/月`;\n    };\n\n    // 获取到岗时间显示\n    const getArrivalTime = time => {\n      const timeMap = {\n        'immediately': '随时到岗',\n        'within_1_week': '1周内',\n        'within_1_month': '1个月内',\n        'within_3_months': '3个月内',\n        'negotiable': '待商议'\n      };\n      return timeMap[time] || '未设置';\n    };\n\n    // 获取工作性质显示\n    const getJobNature = nature => {\n      const natureMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return natureMap[nature] || '未设置';\n    };\n\n    // 获取工作类型显示\n    const getWorkType = type => {\n      const typeMap = {\n        'office': '办公室工作',\n        'remote': '远程工作',\n        'hybrid': '混合办公',\n        'flexible': '灵活办公'\n      };\n      return typeMap[type] || '未设置';\n    };\n\n    // 获取求职状态显示\n    const getJobStatus = status => {\n      const statusMap = {\n        'actively_looking': '积极找工作',\n        'open_to_offers': '考虑机会',\n        'not_looking': '暂不找工作'\n      };\n      return statusMap[status] || '未设置';\n    };\n\n    // 获取求职状态颜色\n    const getJobStatusColor = status => {\n      const colorMap = {\n        'actively_looking': 'bg-green-500',\n        // 积极找工作\n        'open_to_offers': 'bg-yellow-500',\n        // 考虑机会\n        'not_looking': 'bg-gray-500' // 暂不找工作\n      };\n      return colorMap[status] || 'bg-gray-300';\n    };\n\n    // 获取工作类型标签\n    const getJobTypeLabel = value => {\n      const typeMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return typeMap[value] || '未设置';\n    };\n\n    // 获取求职状态标签\n    const getJobStatusLabel = value => {\n      const statusMap = {\n        'actively_looking': '积极找工作',\n        'open_to_offers': '考虑机会',\n        'not_looking': '暂不找工作'\n      };\n      return statusMap[value] || '未设置';\n    };\n\n    // 获取薪资标签\n    const getSalaryLabel = value => {\n      const option = SALARY_OPTIONS.find(opt => opt.value === value);\n      return option ? option.label : '未设置';\n    };\n\n    // 格式化城市显示\n    const formatCity = city => {\n      if (!city) return '未设置';\n      return city.split(',').join('、');\n    };\n\n    // 格式化行业显示\n    const formatIndustries = industries => {\n      if (!industries) return [];\n      return typeof industries === 'string' ? industries.split(',') : industries;\n    };\n\n    // 格式化日期显示\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;\n    };\n\n    // 处理编辑\n    const handleEdit = (type, item) => {\n      if (type === 'job_intention' || type === 'education') {\n        // 找到对应模块的数据\n        const moduleData = props.activeModules.find(m => m.type === type);\n        emit('edit-item', type, item || moduleData?.data);\n      } else {\n        emit('edit-item', type, item);\n      }\n    };\n\n    // 处理顶部编辑按钮点击\n    const handleModuleEdit = type => {\n      console.log('ModuleList handleModuleEdit:', type);\n      // 直接调用 handleEdit，传入 type 和 null 表示新增\n      handleEdit(type, null);\n    };\n\n    // 处理添加按钮点击\n    const handleAdd = type => {\n      console.log('ModuleList handleAdd:', type);\n      // 直接调用 handleEdit，传入 type 和 null 表示新增\n      handleEdit(type, null);\n    };\n\n    // 添加一个 key 来强制更新教育组件\n    const educationKey = ref(0);\n\n    // 修改提交处理\n    const handleSubmit = async data => {\n      try {\n        if (currentModule.value?.type === 'education') {\n          loading.value = true;\n          try {\n            const requestData = {\n              school: data.school.trim(),\n              major: data.major.trim(),\n              degree: data.degree,\n              start_date: data.start_date,\n              end_date: data.end_date,\n              is_current: data.is_current,\n              description: data.description?.trim() || '',\n              achievements: data.achievements?.trim() || ''\n            };\n            let response;\n            if (data.id) {\n              response = await profile.education.update(data.id, requestData);\n            } else {\n              response = await profile.education.add(requestData);\n            }\n            if (response?.data?.code === 200) {\n              showEditModal.value = false;\n              await props.fetchModulesData();\n              ElMessage.success(data.id ? '更新成功' : '添加成功');\n            } else {\n              throw new Error(response?.data?.message || '操作失败');\n            }\n          } catch (error) {\n            console.error('保存失败:', error);\n            ElMessage.error(error.message || '保存失败，请稍后重试');\n          }\n        }\n      } catch (error) {\n        console.error('保存失败:', error);\n        ElMessage.error(error.message || '保存失败，请稍后重试');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 在 script setup 的开头添加这些变量\n    const currentModule = ref(null);\n    const editFormData = ref({});\n    const showEditModal = ref(false);\n    const loading = ref(false);\n\n    // 添加初始化数据的调用\n    onMounted(async () => {\n      // 调用父组件的 fetchModulesData\n      await props.fetchModulesData();\n    });\n\n    // 监听对话框关闭\n    watch(showEditModal, newVal => {\n      if (!newVal) {\n        currentModule.value = null;\n        editFormData.value = {};\n      }\n    });\n\n    // 监听模块数据变化\n    watch(() => props.activeModules, async newModules => {\n      const educationModule = newModules?.find(m => m.type === 'education');\n      if (educationModule?.data) {\n        // 强制组件重新渲染\n        await nextTick();\n        educationKey.value++;\n        console.log('【ModuleList】模块数据变化:', {\n          时间: new Date().toISOString(),\n          模块数量: newModules?.length,\n          教育模块: educationModule,\n          当前key: educationKey.value\n        });\n      }\n    }, {\n      deep: true,\n      immediate: true\n    });\n    const __returned__ = {\n      props,\n      emit,\n      getModuleName,\n      showDeleteConfirm,\n      itemToDelete,\n      handleRemoveItem,\n      confirmDelete,\n      formatSalary,\n      getArrivalTime,\n      getJobNature,\n      getWorkType,\n      getJobStatus,\n      getJobStatusColor,\n      getJobTypeLabel,\n      getJobStatusLabel,\n      getSalaryLabel,\n      formatCity,\n      formatIndustries,\n      formatDate,\n      handleEdit,\n      handleModuleEdit,\n      handleAdd,\n      educationKey,\n      handleSubmit,\n      currentModule,\n      editFormData,\n      showEditModal,\n      loading,\n      ref,\n      watch,\n      onMounted,\n      nextTick,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      },\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get BanknotesIcon() {\n        return BanknotesIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BuildingOfficeIcon() {\n        return BuildingOfficeIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },\n      get TrophyIcon() {\n        return TrophyIcon;\n      },\n      get ALL_MODULES() {\n        return ALL_MODULES;\n      },\n      JobIntentionContent,\n      WorkExperienceContent,\n      get JOB_TYPE_OPTIONS() {\n        return JOB_TYPE_OPTIONS;\n      },\n      get JOB_STATUS_OPTIONS() {\n        return JOB_STATUS_OPTIONS;\n      },\n      get SALARY_OPTIONS() {\n        return SALARY_OPTIONS;\n      },\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get TransitionChild() {\n        return TransitionChild;\n      },\n      EducationContent,\n      EditEducationDialog,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get profile() {\n        return profile;\n      },\n      get useModules() {\n        return useModules;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","onMounted","nextTick","PencilSquareIcon","TrashIcon","PlusIcon","ExclamationTriangleIcon","BriefcaseIcon","BanknotesIcon","MapPinIcon","BuildingOfficeIcon","CalendarIcon","DocumentTextIcon","TrophyIcon","ALL_MODULES","JobIntentionContent","WorkExperienceContent","JOB_TYPE_OPTIONS","JOB_STATUS_OPTIONS","SALARY_OPTIONS","Dialog","DialogPanel","DialogTitle","TransitionRoot","TransitionChild","EducationContent","EditEducationDialog","ElMessage","profile","useModules","props","__props","emit","__emit","getModuleName","type","showDeleteConfirm","itemToDelete","handleRemoveItem","itemId","value","id","confirmDelete","workExperience","delete","education","fetchModulesData","success","error","console","activeModules","newModules","log","active","find","m","data","jobIntention","deep","formatSalary","salary","min","max","split","getArrivalTime","time","timeMap","getJobNature","nature","natureMap","getWorkType","typeMap","getJobStatus","status","statusMap","getJobStatusColor","colorMap","getJobTypeLabel","getJobStatusLabel","getSalaryLabel","option","opt","label","formatCity","city","join","formatIndustries","industries","formatDate","dateString","date","Date","getFullYear","String","getMonth","padStart","handleEdit","item","moduleData","handleModuleEdit","handleAdd","educationKey","handleSubmit","currentModule","loading","requestData","school","trim","major","degree","start_date","end_date","is_current","description","achievements","response","update","add","code","showEditModal","Error","message","editFormData","newVal","educationModule","时间","toISOString","模块数量","length","教育模块","当前key","immediate"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"module in activeModules\" :key=\"module.type\" class=\"bg-white rounded-lg shadow\">\n      <div class=\"flex items-center justify-between px-4 py-3\">\n        <h3 class=\"text-base font-medium text-gray-900\">{{ module.name }}</h3>\n        <div class=\"flex items-center space-x-2\">\n          <button\n            @click=\"handleModuleEdit(module.type)\"\n            class=\"p-1 hover:bg-gray-100 rounded-full\"\n          >\n            <PencilSquareIcon class=\"w-5 h-5 text-gray-400\" />\n          </button>\n          <button\n            @click=\"handleRemove(module.type)\"\n            class=\"p-1 hover:bg-gray-100 rounded-full\"\n          >\n            <TrashIcon class=\"w-5 h-5 text-gray-400\" />\n          </button>\n        </div>\n      </div>\n      \n      <div class=\"px-4 pb-4\">\n        <!-- 求职意向模块 -->\n        <template v-if=\"module.type === 'job_intention' && module.data\">\n          <div class=\"text-gray-600\">\n            <!-- 求职状态标识 -->\n            <div class=\"flex items-center space-x-2 mb-3\">\n              <div \n                class=\"w-2 h-2 rounded-full\"\n                :class=\"getJobStatusColor(module.data.job_status)\"\n              ></div>\n              <span class=\"text-sm font-medium\">\n                {{ getJobStatusLabel(module.data.job_status) }}\n              </span>\n            </div>\n\n            <!-- 主要信息卡片 -->\n            <div class=\"bg-gray-50 rounded-lg p-4 space-y-4\">\n              <!-- 工作类型和薪资 -->\n              <div class=\"flex justify-between items-start\">\n                <div class=\"flex items-start space-x-3\">\n                  <BriefcaseIcon class=\"w-5 h-5 text-blue-500 mt-0.5\" />\n                  <div>\n                    <div class=\"text-sm text-gray-500\">期望职位</div>\n                    <div class=\"font-medium mt-1\">{{ getJobTypeLabel(module.data.job_type) }}</div>\n                  </div>\n                </div>\n                <div class=\"flex items-start space-x-3\">\n                  <BanknotesIcon class=\"w-5 h-5 text-emerald-500 mt-0.5\" />\n                  <div class=\"text-right\">\n                    <div class=\"text-sm text-gray-500\">期望薪资</div>\n                    <div class=\"font-medium mt-1 text-emerald-600\">\n                      {{ module.data.expected_salary }}\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <!-- 期望城市 -->\n              <div class=\"flex items-start space-x-3\">\n                <MapPinIcon class=\"w-5 h-5 text-red-500 mt-0.5\" />\n                <div>\n                  <div class=\"text-sm text-gray-500\">期望城市</div>\n                  <div class=\"font-medium mt-1\">\n                    {{ formatCity(module.data.expected_city) }}\n                  </div>\n                </div>\n              </div>\n\n              <!-- 期望行业 -->\n              <div v-if=\"module.data.industries\" class=\"flex items-start space-x-3\">\n                <BuildingOfficeIcon class=\"w-5 h-5 text-purple-500 mt-0.5\" />\n                <div class=\"flex-1\">\n                  <div class=\"text-sm text-gray-500 mb-2\">期望行业</div>\n                  <div class=\"flex flex-wrap gap-2\">\n                    <span \n                      v-for=\"industry in formatIndustries(module.data.industries)\" \n                      :key=\"industry\"\n                      class=\"inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-purple-50 text-purple-700\"\n                    >\n                      {{ industry }}\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </template>\n\n        <!-- 工作经历模块 -->\n        <template v-else-if=\"module.type === 'work_experience' && module.data\">\n          <div class=\"relative space-y-0\">\n            <!-- 时间线 -->\n            <div class=\"absolute left-[0.5625rem] top-3 bottom-3 w-px bg-gray-200\"></div>\n\n            <!-- 工作经历列表 -->\n            <div \n              v-for=\"(exp, index) in module.data\" \n              :key=\"index\" \n              class=\"relative pl-12 pb-6\"\n            >\n              <!-- 时间节点 -->\n              <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n              \n              <!-- 内容卡片 -->\n              <div class=\"bg-gray-50 rounded-lg border border-gray-100 p-4 hover:shadow-sm transition-shadow\">\n                <!-- 头部信息 -->\n                <div class=\"flex items-center justify-between mb-3\">\n                  <div class=\"flex-1\">\n                    <div class=\"text-sm text-gray-500\">\n                      {{ formatDate(exp.start_date) }} - {{ exp.end_date ? formatDate(exp.end_date) : '至今' }}\n                    </div>\n                    <div class=\"flex items-center justify-between mt-1.5\">\n                      <span class=\"text-base font-medium text-gray-900\">{{ exp.company }}</span>\n                      <div class=\"flex items-center space-x-2\">\n                        <button\n                          @click=\"handleEdit(module.type, exp)\"\n                          class=\"p-1 hover:bg-white rounded-full transition-colors\"\n                        >\n                          <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n                        </button>\n                        <button\n                          @click=\"handleRemoveItem(module.type, exp.id)\"\n                          class=\"p-1 hover:bg-white rounded-full transition-colors\"\n                        >\n                          <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n                        </button>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                <!-- 职位 -->\n                <div class=\"text-sm font-medium text-blue-600 mb-3\">\n                  {{ exp.position }}\n                </div>\n\n                <!-- 工作内容 -->\n                <div class=\"space-y-2\">\n                  <div class=\"flex items-center space-x-2\">\n                    <DocumentTextIcon class=\"w-4 h-4 text-gray-400\" />\n                    <span class=\"text-sm text-gray-500\">工作内容</span>\n                  </div>\n                  <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n                    {{ exp.description }}\n                  </div>\n                </div>\n\n                <!-- 工作成果 -->\n                <div v-if=\"exp.achievements\" class=\"mt-3 space-y-2\">\n                  <div class=\"flex items-center space-x-2\">\n                    <TrophyIcon class=\"w-4 h-4 text-yellow-500\" />\n                    <span class=\"text-sm text-gray-500\">工作成果</span>\n                  </div>\n                  <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n                    {{ exp.achievements }}\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <!-- 添加按钮 -->\n            <div class=\"relative pl-12\">\n              <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n              <button\n                @click=\"handleAdd(module.type)\"\n                class=\"w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n              >\n                <PlusIcon class=\"w-4 h-4 mr-2\" />\n                添加工作经历\n              </button>\n            </div>\n          </div>\n        </template>\n\n        <!-- 教育经历模块 -->\n        <template v-else-if=\"module.type === 'education' && module.data\">\n          <EducationContent \n            :key=\"educationKey\"\n            :data=\"module.data\"\n            @edit=\"item => handleEdit('education', item)\"\n            @delete=\"id => handleRemoveItem('education', id)\"\n            @add=\"() => handleEdit('education', null)\"\n          />\n        </template>\n\n        <!-- 默认显示 -->\n        <div v-else-if=\"!module.data\" class=\"text-center text-gray-400 py-4\">\n          暂无内容，点击编辑添加\n        </div>\n        <div v-else class=\"text-gray-600\">\n          {{ module.data }}\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 删除确认弹窗 -->\n  <TransitionRoot :show=\"showDeleteConfirm\" as=\"template\">\n    <Dialog as=\"div\" class=\"relative z-50\" @close=\"showDeleteConfirm = false\">\n      <!-- 背景遮罩 -->\n      <TransitionChild\n        as=\"template\"\n        enter=\"duration-300 ease-out\"\n        enter-from=\"opacity-0\"\n        enter-to=\"opacity-100\"\n        leave=\"duration-200 ease-in\"\n        leave-from=\"opacity-100\"\n        leave-to=\"opacity-0\"\n      >\n        <div class=\"fixed inset-0 bg-black/25\" />\n      </TransitionChild>\n\n      <!-- 对话框 -->\n      <div class=\"fixed inset-0 overflow-y-auto\">\n        <div class=\"flex min-h-full items-center justify-center p-4 text-center\">\n          <TransitionChild\n            as=\"template\"\n            enter=\"duration-300 ease-out\"\n            enter-from=\"opacity-0 scale-95\"\n            enter-to=\"opacity-100 scale-100\"\n            leave=\"duration-200 ease-in\"\n            leave-from=\"opacity-100 scale-100\"\n            leave-to=\"opacity-0 scale-95\"\n          >\n            <DialogPanel class=\"w-full max-w-md transform overflow-hidden rounded-xl bg-white text-left align-middle shadow-xl transition-all\">\n              <div class=\"p-6\">\n                <div class=\"flex items-start space-x-3\">\n                  <div class=\"p-2 bg-red-50 rounded-full flex-shrink-0\">\n                    <ExclamationTriangleIcon class=\"w-6 h-6 text-red-600\" />\n                  </div>\n                  <div class=\"flex-1\">\n                    <DialogTitle as=\"h3\" class=\"text-lg font-medium text-gray-900\">\n                      确认删除教育经历？\n                    </DialogTitle>\n                    <p class=\"mt-2 text-sm text-gray-500\">\n                      删除后将无法恢复，请确认是否继续。\n                    </p>\n                  </div>\n                </div>\n                \n                <div class=\"mt-6 flex justify-end space-x-3\">\n                  <button\n                    type=\"button\"\n                    @click=\"showDeleteConfirm = false\"\n                    class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n                  >\n                    取消\n                  </button>\n                  <button\n                    type=\"button\"\n                    @click=\"confirmDelete\"\n                    class=\"px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500\"\n                  >\n                    确认删除\n                  </button>\n                </div>\n              </div>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n\n  <!-- 添加教育经历编辑弹窗 -->\n  <EditEducationDialog\n    v-if=\"currentModule?.type === 'education'\"\n    v-model=\"showEditModal\"\n    :initial-data=\"editFormData\"\n    :loading=\"loading\"\n    @submit=\"handleSubmit\"\n  />\n</template>\n\n<script setup>\nimport { ref, watch, onMounted, nextTick } from 'vue'\nimport { \n  PencilSquareIcon, \n  TrashIcon,\n  PlusIcon,\n  ExclamationTriangleIcon,\n  BriefcaseIcon,\n  BanknotesIcon,\n  MapPinIcon,\n  BuildingOfficeIcon,\n  CalendarIcon,\n  DocumentTextIcon,\n  TrophyIcon\n} from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\nimport JobIntentionContent from './JobIntentionContent.vue'\nimport WorkExperienceContent from './WorkExperienceContent.vue'\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  TransitionRoot,\n  TransitionChild\n} from '@headlessui/vue'\nimport EducationContent from './EducationContent.vue'\nimport EditEducationDialog from '../dialogs/EditEducationDialog.vue'\nimport { ElMessage } from 'element-plus'\nimport profile from '@/api/profile'\nimport { useModules } from '../composables/useModules'\n\nconst props = defineProps({\n  activeModules: {\n    type: Array,\n    required: true\n  },\n  inactiveModules: {\n    type: Array,\n    required: true\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  },\n  fetchModulesData: {\n    type: Function,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['remove', 'edit', 'edit-item', 'remove-item'])\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n\n// 删除相关状态\nconst showDeleteConfirm = ref(false)\nconst itemToDelete = ref(null)\n\n// 处理删除\nconst handleRemoveItem = async (type, itemId) => {\n  if (type === 'work_experience' || type === 'education') {\n    itemToDelete.value = { type, id: itemId }\n    showDeleteConfirm.value = true\n  }\n}\n\n// 确认删除\nconst confirmDelete = async () => {\n  try {\n    if (itemToDelete.value) {\n      if (itemToDelete.value.type === 'work_experience') {\n        await profile.workExperience.delete(itemToDelete.value.id)\n      } else if (itemToDelete.value.type === 'education') {\n        await profile.education.delete(itemToDelete.value.id)\n      }\n      \n      showDeleteConfirm.value = false\n      itemToDelete.value = null\n      await props.fetchModulesData()\n      ElMessage.success('删除成功')\n    }\n  } catch (error) {\n    console.error('删除失败:', error)\n    ElMessage.error('删除失败，请稍后重试')\n  }\n}\n\n// 监听模块变化\nwatch(() => props.activeModules, (newModules) => {\n  console.log('ModuleList - 活动模块更新:', {\n    active: newModules,\n    workExperience: newModules.find(m => m.type === 'work_experience')?.data,\n    jobIntention: newModules.find(m => m.type === 'job_intention')?.data\n  })\n}, { deep: true })\n\n// 格式化薪资显示\nconst formatSalary = (salary) => {\n  if (!salary) return '未设置'\n  const [min, max] = salary.split('-')\n  if (min && max) {\n    return `${min}-${max}K/月`\n  }\n  return `${salary}K/月`\n}\n\n// 获取到岗时间显示\nconst getArrivalTime = (time) => {\n  const timeMap = {\n    'immediately': '随时到岗',\n    'within_1_week': '1周内',\n    'within_1_month': '1个月内',\n    'within_3_months': '3个月内',\n    'negotiable': '待商议'\n  }\n  return timeMap[time] || '未设置'\n}\n\n// 获取工作性质显示\nconst getJobNature = (nature) => {\n  const natureMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return natureMap[nature] || '未设置'\n}\n\n// 获取工作类型显示\nconst getWorkType = (type) => {\n  const typeMap = {\n    'office': '办公室工作',\n    'remote': '远程工作',\n    'hybrid': '混合办公',\n    'flexible': '灵活办公'\n  }\n  return typeMap[type] || '未设置'\n}\n\n// 获取求职状态显示\nconst getJobStatus = (status) => {\n  const statusMap = {\n    'actively_looking': '积极找工作',\n    'open_to_offers': '考虑机会',\n    'not_looking': '暂不找工作'\n  }\n  return statusMap[status] || '未设置'\n}\n\n// 获取求职状态颜色\nconst getJobStatusColor = (status) => {\n  const colorMap = {\n    'actively_looking': 'bg-green-500',      // 积极找工作\n    'open_to_offers': 'bg-yellow-500',       // 考虑机会\n    'not_looking': 'bg-gray-500'             // 暂不找工作\n  }\n  return colorMap[status] || 'bg-gray-300'\n}\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const typeMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return typeMap[value] || '未设置'\n}\n\n// 获取求职状态标签\nconst getJobStatusLabel = (value) => {\n  const statusMap = {\n    'actively_looking': '积极找工作',\n    'open_to_offers': '考虑机会',\n    'not_looking': '暂不找工作'\n  }\n  return statusMap[value] || '未设置'\n}\n\n// 获取薪资标签\nconst getSalaryLabel = (value) => {\n  const option = SALARY_OPTIONS.find(opt => opt.value === value)\n  return option ? option.label : '未设置'\n}\n\n// 格式化城市显示\nconst formatCity = (city) => {\n  if (!city) return '未设置'\n  return city.split(',').join('、')\n}\n\n// 格式化行业显示\nconst formatIndustries = (industries) => {\n  if (!industries) return []\n  return typeof industries === 'string' ? industries.split(',') : industries\n}\n\n// 格式化日期显示\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`\n}\n\n// 处理编辑\nconst handleEdit = (type, item) => {\n  if (type === 'job_intention' || type === 'education') {\n    // 找到对应模块的数据\n    const moduleData = props.activeModules.find(m => m.type === type)\n    emit('edit-item', type, item || moduleData?.data)\n  } else {\n    emit('edit-item', type, item)\n  }\n}\n\n// 处理顶部编辑按钮点击\nconst handleModuleEdit = (type) => {\n  console.log('ModuleList handleModuleEdit:', type)\n  // 直接调用 handleEdit，传入 type 和 null 表示新增\n  handleEdit(type, null)\n}\n\n// 处理添加按钮点击\nconst handleAdd = (type) => {\n  console.log('ModuleList handleAdd:', type)\n  // 直接调用 handleEdit，传入 type 和 null 表示新增\n  handleEdit(type, null)\n}\n\n// 添加一个 key 来强制更新教育组件\nconst educationKey = ref(0)\n\n// 修改提交处理\nconst handleSubmit = async (data) => {\n  try {\n    if (currentModule.value?.type === 'education') {\n      loading.value = true\n      \n      try {\n        const requestData = {\n          school: data.school.trim(),\n          major: data.major.trim(),\n          degree: data.degree,\n          start_date: data.start_date,\n          end_date: data.end_date,\n          is_current: data.is_current,\n          description: data.description?.trim() || '',\n          achievements: data.achievements?.trim() || ''\n        }\n\n        let response;\n        if (data.id) {\n          response = await profile.education.update(data.id, requestData)\n        } else {\n          response = await profile.education.add(requestData)\n        }\n\n        if (response?.data?.code === 200) {\n          showEditModal.value = false\n          await props.fetchModulesData()\n          ElMessage.success(data.id ? '更新成功' : '添加成功')\n        } else {\n          throw new Error(response?.data?.message || '操作失败')\n        }\n      } catch (error) {\n        console.error('保存失败:', error)\n        ElMessage.error(error.message || '保存失败，请稍后重试')\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 在 script setup 的开头添加这些变量\nconst currentModule = ref(null)\nconst editFormData = ref({})\nconst showEditModal = ref(false)\nconst loading = ref(false)\n\n// 添加初始化数据的调用\nonMounted(async () => {\n  // 调用父组件的 fetchModulesData\n  await props.fetchModulesData()\n})\n\n// 监听对话框关闭\nwatch(showEditModal, (newVal) => {\n  if (!newVal) {\n    currentModule.value = null\n    editFormData.value = {}\n  }\n})\n\n// 监听模块数据变化\nwatch(() => props.activeModules, async (newModules) => {\n  const educationModule = newModules?.find(m => m.type === 'education')\n  if (educationModule?.data) {\n    // 强制组件重新渲染\n    await nextTick()\n    educationKey.value++\n    console.log('【ModuleList】模块数据变化:', {\n      时间: new Date().toISOString(),\n      模块数量: newModules?.length,\n      教育模块: educationModule,\n      当前key: educationKey.value\n    })\n  }\n}, { deep: true, immediate: true })\n</script>\n\n<style scoped>\n.delete-confirm-dialog :deep(.el-dialog__body) {\n  @apply p-0;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .delete-confirm-dialog {\n    margin: 0 !important;\n  }\n  \n  .p-6 {\n    @apply p-4;\n  }\n}\n\n/* 添加渐变效果 */\n.bg-gray-50 {\n  background: linear-gradient(to right, #f9fafb, #f3f4f6);\n}\n\n/* 悬停效果 */\n.hover\\:bg-gray-200:hover {\n  @apply bg-gray-200 transition-colors duration-200;\n}\n\n/* 优化卡片样式 */\n.border-gray-100 {\n  border-color: rgba(229, 231, 235, 0.5);\n}\n\n/* 优化阴影效果 */\n.hover\\:shadow-sm:hover {\n  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);\n}\n\n/* 优化文本行高 */\n.leading-relaxed {\n  line-height: 1.6