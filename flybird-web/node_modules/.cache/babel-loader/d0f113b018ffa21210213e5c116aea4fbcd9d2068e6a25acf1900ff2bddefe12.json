{"ast":null,"code":"import { Dialog, DialogPanel, DialogTitle, TransitionChild, TransitionRoot } from '@headlessui/vue';\nimport { XMarkIcon, EyeIcon, EyeSlashIcon } from '@heroicons/vue/24/outline';\nimport { useChangePassword } from '@/composables/useChangePassword';\nexport default {\n  __name: 'ChangePasswordDialog',\n  props: {\n    modelValue: {\n      type: Boolean,\n      required: true\n    }\n  },\n  emits: ['update:modelValue', 'success'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const {\n      currentPassword,\n      newPassword,\n      confirmPassword,\n      showCurrentPassword,\n      showNewPassword,\n      showConfirmPassword,\n      loading,\n      changePassword,\n      resetForm\n    } = useChangePassword();\n    const handleClose = () => {\n      resetForm();\n      emit('update:modelValue', false);\n    };\n    const handleSubmit = async () => {\n      const success = await changePassword();\n      if (success) {\n        emit('success');\n        emit('update:modelValue', false);\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      currentPassword,\n      newPassword,\n      confirmPassword,\n      showCurrentPassword,\n      showNewPassword,\n      showConfirmPassword,\n      loading,\n      changePassword,\n      resetForm,\n      handleClose,\n      handleSubmit,\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get TransitionChild() {\n        return TransitionChild;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get EyeIcon() {\n        return EyeIcon;\n      },\n      get EyeSlashIcon() {\n        return EyeSlashIcon;\n      },\n      get useChangePassword() {\n        return useChangePassword;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["Dialog","DialogPanel","DialogTitle","TransitionChild","TransitionRoot","XMarkIcon","EyeIcon","EyeSlashIcon","useChangePassword","props","__props","emit","__emit","currentPassword","newPassword","confirmPassword","showCurrentPassword","showNewPassword","showConfirmPassword","loading","changePassword","resetForm","handleClose","handleSubmit","success"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/components/dialogs/ChangePasswordDialog.vue"],"sourcesContent":["<template>\n  <TransitionRoot appear :show=\"modelValue\" as=\"template\">\n    <Dialog as=\"div\" class=\"relative z-50\" @close=\"handleClose\">\n      <!-- 背景遮罩 -->\n      <TransitionChild\n        as=\"template\"\n        enter=\"duration-300 ease-out\"\n        enter-from=\"opacity-0\"\n        enter-to=\"opacity-100\"\n        leave=\"duration-200 ease-in\"\n        leave-from=\"opacity-100\"\n        leave-to=\"opacity-0\"\n      >\n        <div class=\"fixed inset-0 bg-black/25\" />\n      </TransitionChild>\n\n      <!-- 对话框 -->\n      <div class=\"fixed inset-0 overflow-y-auto\">\n        <div class=\"flex min-h-full items-center justify-center p-4 text-center\">\n          <TransitionChild\n            as=\"template\"\n            enter=\"duration-300 ease-out\"\n            enter-from=\"opacity-0 scale-95\"\n            enter-to=\"opacity-100 scale-100\"\n            leave=\"duration-200 ease-in\"\n            leave-from=\"opacity-100 scale-100\"\n            leave-to=\"opacity-0 scale-95\"\n          >\n            <DialogPanel class=\"w-full max-w-md transform overflow-hidden rounded-xl bg-white text-left align-middle shadow-xl transition-all\">\n              <!-- 头部 -->\n              <DialogTitle as=\"div\" class=\"flex items-center justify-between px-6 py-4 border-b border-gray-200\">\n                <h3 class=\"text-lg font-medium text-gray-900\">修改密码</h3>\n                <button\n                  @click=\"handleClose\"\n                  class=\"rounded-full p-1 hover:bg-gray-100 transition-colors\"\n                >\n                  <XMarkIcon class=\"w-5 h-5 text-gray-400\" />\n                </button>\n              </DialogTitle>\n\n              <!-- 表单内容 -->\n              <div class=\"px-6 py-4\">\n                <form @submit.prevent=\"handleSubmit\" class=\"space-y-4\">\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">当前密码</label>\n                    <div class=\"relative\">\n                      <input\n                        :type=\"showCurrentPassword ? 'text' : 'password'\"\n                        v-model=\"currentPassword\"\n                        class=\"w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n                        placeholder=\"请输入当前密码\"\n                      />\n                      <button\n                        type=\"button\"\n                        class=\"absolute inset-y-0 right-0 px-3 flex items-center\"\n                        @click=\"showCurrentPassword = !showCurrentPassword\"\n                      >\n                        <EyeIcon v-if=\"!showCurrentPassword\" class=\"h-5 w-5 text-gray-400\" />\n                        <EyeSlashIcon v-else class=\"h-5 w-5 text-gray-400\" />\n                      </button>\n                    </div>\n                  </div>\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">新密码</label>\n                    <div class=\"relative\">\n                      <input\n                        :type=\"showNewPassword ? 'text' : 'password'\"\n                        v-model=\"newPassword\"\n                        class=\"w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n                        placeholder=\"请输入新密码\"\n                      />\n                      <button\n                        type=\"button\"\n                        class=\"absolute inset-y-0 right-0 px-3 flex items-center\"\n                        @click=\"showNewPassword = !showNewPassword\"\n                      >\n                        <EyeIcon v-if=\"!showNewPassword\" class=\"h-5 w-5 text-gray-400\" />\n                        <EyeSlashIcon v-else class=\"h-5 w-5 text-gray-400\" />\n                      </button>\n                    </div>\n                    <p class=\"mt-1 text-xs text-gray-500\">\n                      密码必须包含大小写字母和数字，长度在8-20位之间\n                    </p>\n                  </div>\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">确认新密码</label>\n                    <div class=\"relative\">\n                      <input\n                        :type=\"showConfirmPassword ? 'text' : 'password'\"\n                        v-model=\"confirmPassword\"\n                        class=\"w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n                        placeholder=\"请再次输入新密码\"\n                      />\n                      <button\n                        type=\"button\"\n                        class=\"absolute inset-y-0 right-0 px-3 flex items-center\"\n                        @click=\"showConfirmPassword = !showConfirmPassword\"\n                      >\n                        <EyeIcon v-if=\"!showConfirmPassword\" class=\"h-5 w-5 text-gray-400\" />\n                        <EyeSlashIcon v-else class=\"h-5 w-5 text-gray-400\" />\n                      </button>\n                    </div>\n                  </div>\n                </form>\n              </div>\n\n              <!-- 底部按钮 -->\n              <div class=\"px-6 py-4 bg-gray-50 border-t border-gray-200\">\n                <div class=\"flex justify-end space-x-3\">\n                  <button\n                    type=\"button\"\n                    @click=\"handleClose\"\n                    class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50\"\n                  >\n                    取消\n                  </button>\n                  <button\n                    type=\"submit\"\n                    @click=\"handleSubmit\"\n                    :disabled=\"!currentPassword || !newPassword || !confirmPassword || loading\"\n                    class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                  >\n                    {{ loading ? '提交中...' : '确认' }}\n                  </button>\n                </div>\n              </div>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { Dialog, DialogPanel, DialogTitle, TransitionChild, TransitionRoot } from '@headlessui/vue'\nimport { XMarkIcon, EyeIcon, EyeSlashIcon } from '@heroicons/vue/24/outline'\nimport { useChangePassword } from '@/composables/useChangePassword'\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'success'])\n\nconst {\n  currentPassword,\n  newPassword,\n  confirmPassword,\n  showCurrentPassword,\n  showNewPassword,\n  showConfirmPassword,\n  loading,\n  changePassword,\n  resetForm\n} = useChangePassword()\n\nconst handleClose = () => {\n  resetForm()\n  emit('update:modelValue', false)\n}\n\nconst handleSubmit = async () => {\n  const success = await changePassword()\n  if (success) {\n    emit('success')\n    emit('update:modelValue', false)\n  }\n}\n</script> "],"mappings":"AAuIA,SAASA,MAAM,EAAEC,WAAW,EAAEC,WAAW,EAAEC,eAAe,EAAEC,cAAc,QAAQ,iBAAgB;AAClG,SAASC,SAAS,EAAEC,OAAO,EAAEC,YAAY,QAAQ,2BAA0B;AAC3E,SAASC,iBAAiB,QAAQ,iCAAgC;;;;;;;;;;;;;;;IAElE,MAAMC,KAAK,GAAGC,OAAA;IAOd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAM;MACJC,eAAe;MACfC,WAAW;MACXC,eAAe;MACfC,mBAAmB;MACnBC,eAAe;MACfC,mBAAmB;MACnBC,OAAO;MACPC,cAAc;MACdC;IACF,CAAC,GAAGb,iBAAiB,CAAC;IAEtB,MAAMc,WAAW,GAAGA,CAAA,KAAM;MACxBD,SAAS,CAAC;MACVV,IAAI,CAAC,mBAAmB,EAAE,KAAK;IACjC;IAEA,MAAMY,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/B,MAAMC,OAAO,GAAG,MAAMJ,cAAc,CAAC;MACrC,IAAII,OAAO,EAAE;QACXb,IAAI,CAAC,SAAS;QACdA,IAAI,CAAC,mBAAmB,EAAE,KAAK;MACjC;IACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}