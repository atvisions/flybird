me\" placeholder=\"请输入姓名\" />\n        </el-form-item>\n\n        <!-- 性别 -->\n        <el-form-item label=\"性别\" prop=\"gender\">\n          <el-select v-model=\"form.gender\" placeholder=\"请选择性别\" class=\"w-full\">\n            <el-option label=\"男\" value=\"male\" />\n            <el-option label=\"女\" value=\"female\" />\n            <el-option label=\"其他\" value=\"other\" />\n          </el-select>\n        </el-form-item>\n\n        <!-- 手机号 -->\n        <el-form-item label=\"手机号\" prop=\"phone\">\n          <el-input v-model=\"form.phone\" placeholder=\"请输入手机号\" />\n        </el-form-item>\n\n        <!-- 邮箱 -->\n        <el-form-item label=\"邮箱\" prop=\"email\">\n          <el-input v-model=\"form.email\" placeholder=\"请输入邮箱\" />\n        </el-form-item>\n\n        <!-- 所在地 -->\n        <el-form-item label=\"所在地\" prop=\"location\">\n          <el-input v-model=\"form.location\" placeholder=\"请输入所在地\" />\n        </el-form-item>\n\n        <!-- 生日 -->\n        <el-form-item label=\"生日\" prop=\"birth_date\">\n          <el-date-picker\n            v-model=\"form.birth_date\"\n            type=\"date\"\n            placeholder=\"请选择生日\"\n            format=\"YYYY-MM-DD\"\n            value-format=\"YYYY-MM-DD\"\n            class=\"w-full\"\n          />\n        </el-form-item>\n\n        <!-- 个人简介 -->\n        <el-form-item label=\"个人简介\" prop=\"personal_summary\">\n          <el-input\n            v-model=\"form.personal_summary\"\n            type=\"textarea\"\n            :rows=\"4\"\n            placeholder=\"请输入个人简介\"\n          />\n        </el-form-item>\n      </el-form>\n    </div>\n\n    <!-- Footer -->\n    <template #footer>\n      <div class=\"border-t border-gray-200 px-6 py-4\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-5