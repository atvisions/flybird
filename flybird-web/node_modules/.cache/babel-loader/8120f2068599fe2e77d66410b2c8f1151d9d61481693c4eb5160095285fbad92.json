{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { changePhone, changePassword, sendSmsCode, deleteAccount } from '@/api/user';\nimport { auth } from '@/api/auth';\nexport default {\n  __name: 'AccountSettings',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const showWeChatBindModal = ref(false);\n    const store = useStore();\n    const router = useRouter();\n\n    // 用户信息 - 使用 computed\n    const userInfo = computed(() => store.getters.getUserInfo || {});\n    // 从 store 中获取用户手机号\n    const userPhone = computed(() => store.getters.getUserPhone);\n\n    // 模态框显示状态\n    const showPhoneModal = ref(false);\n    const showPasswordModal = ref(false);\n    const showDeleteConfirm = ref(false);\n    const passwordLoading = ref(false);\n    const deleteConfirmPassword = ref('');\n    const deleteLoading = ref(false);\n    const sendingCode = ref(false);\n\n    // 手机号相关状态\n    const showold_password = ref(false);\n    const showNewPassword = ref(false);\n    const showConfirmPassword = ref(false);\n\n    // 表单数据\n    const phoneForm = ref({\n      newPhone: '',\n      verifyCode: '',\n      countdown: 0\n    });\n    const passwordForm = ref({\n      oldPassword: '',\n      newPassword: '',\n      confirmPassword: ''\n    });\n\n    // 工具函数：信息脱敏\n    const maskPhone = userPhone => {\n      if (!userPhone) return '';\n      return userPhone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2');\n    };\n    const maskWechat = wechat => {\n      if (!wechat) return '';\n      return wechat.substring(0, 3) + '***' + wechat.substring(wechat.length - 3);\n    };\n\n    // 关闭密码修改对话框\n    const closePasswordDialog = () => {\n      showPasswordModal.value = false;\n      passwordForm.value = {\n        oldPassword: '',\n        newPassword: '',\n        confirmPassword: ''\n      };\n    };\n    // 注销账户\n    const handleDeleteAccount = async () => {\n      if (!deleteConfirmPassword.value) {\n        showToast('请输入密码以确认注销', 'warning');\n        return;\n      }\n      try {\n        deleteLoading.value = true;\n        const response = await deleteAccount({\n          password: deleteConfirmPassword.value\n        });\n        if (response.data?.code === 200) {\n          showToast('账号已注销成功', 'success');\n          showDeleteConfirm.value = false;\n          deleteConfirmPassword.value = '';\n\n          // 清除登录状态并跳转\n          await store.dispatch('logout');\n          router.push({\n            path: '/login',\n            query: {\n              source: 'account_deleted'\n            }\n          });\n        } else {\n          throw new Error(response.data?.message || '注销失败');\n        }\n      } catch (error) {\n        console.error('注销账号失败:', error);\n        const errorMessage = error.response?.data?.message || error.response?.data?.errors?.password?.[0] || error.message || '注销账号失败，请检查密码是否正确';\n        showToast(errorMessage, 'error');\n      } finally {\n        deleteLoading.value = false;\n      }\n    };\n\n    // 关闭注销对话框\n    const closeDeleteDialog = () => {\n      showDeleteConfirm.value = false;\n      deleteConfirmPassword.value = '';\n    };\n    // 发送手机验证码\n    const sendPhoneCode = async () => {\n      if (!phoneForm.value.newPhone) {\n        showToast('请输入新手机号', 'warning');\n        return;\n      }\n\n      // 手机号格式验证\n      const phoneRegex = /^1[3-9]\\d{9}$/;\n      if (!phoneRegex.test(phoneForm.value.newPhone)) {\n        showToast('请输入正确的手机号格式', 'warning');\n        return;\n      }\n      try {\n        sendingCode.value = true;\n        const response = await auth.sendVerifyCode({\n          phone: phoneForm.value.newPhone,\n          scene: 'change_phone'\n        });\n        if (response.data?.code === 200) {\n          // 开始倒计时\n          phoneForm.value.countdown = 60;\n          const timer = setInterval(() => {\n            phoneForm.value.countdown--;\n            if (phoneForm.value.countdown <= 0) {\n              clearInterval(timer);\n            }\n          }, 1000);\n          showToast('验证码已发送', 'success');\n        } else {\n          throw new Error(response.data?.message || '发送验证码失败');\n        }\n      } catch (error) {\n        console.error('发送验证码失败:', error);\n        const errorMessage = error.response?.data?.message || error.response?.data?.non_field_errors?.[0] || '发送验证码失败，请稍后重试';\n        showToast(errorMessage, 'error');\n      } finally {\n        sendingCode.value = false;\n      }\n    };\n    // 更换手机号\n    const handlePhoneChange = async () => {\n      if (!phoneForm.value.newPhone) {\n        showToast('请输入新手机号', 'warning');\n        return;\n      }\n\n      // 手机号格式验证\n      const phoneRegex = /^1[3-9]\\d{9}$/;\n      if (!phoneRegex.test(phoneForm.value.newPhone)) {\n        showToast('请输入正确的手机号格式', 'warning');\n        return;\n      }\n      if (!phoneForm.value.verifyCode) {\n        showToast('请输入验证码', 'warning');\n        return;\n      }\n      try {\n        const response = await changePhone({\n          phone: phoneForm.value.newPhone,\n          code: phoneForm.value.verifyCode\n        });\n        if (response.data?.code === 200) {\n          showToast('手机号更换成功，请重新登录', 'success');\n          showPhoneModal.value = false;\n          // 清空表单\n          phoneForm.value = {\n            newPhone: '',\n            verifyCode: '',\n            countdown: 0\n          };\n\n          // 登出并跳转到登录页\n          await store.dispatch('logout');\n          router.push({\n            path: '/login',\n            query: {\n              redirect: router.currentRoute.value.fullPath\n            }\n          });\n        } else {\n          throw new Error(response.data?.message || '更换手机号失败');\n        }\n      } catch (error) {\n        console.error('更换手机号失败:', error);\n        // 添加更详细的错误信息输出\n        console.error('Error response:', error.response?.data);\n        const errorMessage = error.response?.data?.message || error.response?.data?.non_field_errors?.[0] || error.response?.data?.new_phone?.[0] // 添加新手机号字段的错误\n        || error.response?.data?.code?.[0] // 添加验证码字段的错误\n        || '更换手机号失败，请稍后重试';\n        showToast(errorMessage, 'error');\n      }\n    };\n\n    // 修改密码\n    const handlePasswordChange = async () => {\n      try {\n        // 表单验证\n        if (!passwordForm.value.old_password) {\n          showToast('请输入当前密码', 'warning');\n          return;\n        }\n        if (!passwordForm.value.newPassword) {\n          showToast('请输入新密码', 'warning');\n          return;\n        }\n        if (!passwordForm.value.confirmPassword) {\n          showToast('请确认新密码', 'warning');\n          return;\n        }\n        if (passwordForm.value.newPassword !== passwordForm.value.confirmPassword) {\n          showToast('两次输入的新密码不一致', 'warning');\n          return;\n        }\n        if (passwordForm.value.newPassword.length < 6) {\n          showToast('新密码长度不能少于6位', 'warning');\n          return;\n        }\n        if (passwordForm.value.old_password === passwordForm.value.newPassword) {\n          showToast('新密码不能与当前密码相同', 'warning');\n          return;\n        }\n        passwordLoading.value = true;\n        const response = await changePassword({\n          old_password: passwordForm.value.old_password,\n          new_password: passwordForm.value.newPassword,\n          confirm_password: passwordForm.value.confirmPassword\n        });\n        if (response.data?.code === 200) {\n          showToast('密码修改成功，请重新登录', 'success');\n          showPasswordModal.value = false;\n\n          // 清空表单\n          passwordForm.value = {\n            oldPassword: '',\n            newPassword: '',\n            confirmPassword: ''\n          };\n\n          // 登出并跳转\n          await store.dispatch('logout');\n          router.push('/login');\n        } else {\n          throw new Error(response.data?.message || '修改失败');\n        }\n      } catch (error) {\n        console.error('修改密码失败:', error);\n        const errorMessage = error.response?.data?.message || error.response?.data?.errors?.old_password?.[0] || error.response?.data?.errors?.new_password?.[0] || error.response?.data?.errors?.confirm_password?.[0] || error.message || '修改密码失败，请检查当前密码是否正确';\n        showToast(errorMessage, 'error');\n      } finally {\n        passwordLoading.value = false;\n      }\n    };\n    const __returned__ = {\n      showWeChatBindModal,\n      store,\n      router,\n      userInfo,\n      userPhone,\n      showPhoneModal,\n      showPasswordModal,\n      showDeleteConfirm,\n      passwordLoading,\n      deleteConfirmPassword,\n      deleteLoading,\n      sendingCode,\n      showold_password,\n      showNewPassword,\n      showConfirmPassword,\n      phoneForm,\n      passwordForm,\n      maskPhone,\n      maskWechat,\n      closePasswordDialog,\n      handleDeleteAccount,\n      closeDeleteDialog,\n      sendPhoneCode,\n      handlePhoneChange,\n      handlePasswordChange,\n      ref,\n      computed,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get changePhone() {\n        return changePhone;\n      },\n      get changePassword() {\n        return changePassword;\n      },\n      get sendSmsCode() {\n        return sendSmsCode;\n      },\n      get deleteAccount() {\n        return deleteAccount;\n      },\n      get auth() {\n        return auth;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","useRouter","showToast","changePhone","changePassword","sendSmsCode","deleteAccount","auth","showWeChatBindModal","store","router","userInfo","getters","getUserInfo","userPhone","getUserPhone","showPhoneModal","showPasswordModal","showDeleteConfirm","passwordLoading","deleteConfirmPassword","deleteLoading","sendingCode","showold_password","showNewPassword","showConfirmPassword","phoneForm","newPhone","verifyCode","countdown","passwordForm","oldPassword","newPassword","confirmPassword","maskPhone","replace","maskWechat","wechat","substring","length","closePasswordDialog","value","handleDeleteAccount","response","password","data","code","dispatch","push","path","query","source","Error","message","error","console","errorMessage","errors","closeDeleteDialog","sendPhoneCode","phoneRegex","test","sendVerifyCode","phone","scene","timer","setInterval","clearInterval","non_field_errors","handlePhoneChange","redirect","currentRoute","fullPath","new_phone","handlePasswordChange","old_password","new_password","confirm_password"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/AccountSettings.vue"],"sourcesContent":["<template>\n    <div class=\"space-y-6\">\n      <!-- 账户安全 -->\n      <section class=\"bg-white rounded-lg p-6 shadow\">\n        <h2 class=\"text-lg font-medium text-gray-900 mb-6\">账户安全</h2>\n        \n        <!-- 手机号 -->\n        <div class=\"space-y-6\">\n          <div class=\"flex items-center justify-between py-4 border-b\">\n            <div>\n              <h3 class=\"text-base font-medium text-gray-900\">手机号</h3>\n              <p class=\"mt-1 text-sm text-gray-500\">{{ maskPhone(userPhone) }}</p>\n            </div>\n            <button @click=\"showPhoneModal = true\"\n              class=\"px-4 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors\">\n              更换手机号\n            </button>\n          </div>\n  \n          <!-- 微信绑定 -->\n            <div class=\"flex items-center justify-between py-4 border-b\">\n            <div>\n                <h3 class=\"text-base font-medium text-gray-900\">微信绑定</h3>\n                <p class=\"mt-1 text-sm text-gray-500\">\n                {{ userInfo.wechat ? `已绑定微信号：${maskWechat(userInfo.wechat)}` : '未绑定' }}\n                </p>\n            </div>\n            <button \n                @click=\"handleWechatBinding\"\n                class=\"px-4 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors\"\n            >\n                {{ userInfo.wechat ? '更换绑定' : '立即绑定' }}\n            </button>\n            </div>\n            <!-- 添加微信登录弹窗 -->\n            <WeChatLoginModal\n            :visible=\"showWeChatBindModal\"\n            :bind-mode=\"true\"\n            @close=\"showWeChatBindModal = false\"\n            @bind-success=\"handleWeChatBindSuccess\"\n            />\n\n  \n          <!-- 登录密码 -->\n          <div class=\"flex items-center justify-between py-4 border-b\">\n            <div>\n              <h3 class=\"text-base font-medium text-gray-900\">登录密码</h3>\n              <p class=\"mt-1 text-sm text-gray-500\">定期更换密码可以帮助保护账号安全</p>\n            </div>\n            <button @click=\"showPasswordModal = true\"\n              class=\"px-4 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors\">\n              修改密码\n            </button>\n          </div>\n        </div>\n      </section>\n  \n      <!-- 账号注销 -->\n      <section class=\"bg-white rounded-lg p-6 shadow\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"flex-shrink-0\">\n            <svg class=\"h-6 w-6 text-red-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n            </svg>\n          </div>\n          <div class=\"flex-grow\">\n            <h3 class=\"text-base font-medium text-gray-900\">注销账号</h3>\n            <p class=\"mt-1 text-sm text-gray-500\">\n              注销后，您的所有数据将被永久删除且无法恢复。请谨慎操作。\n            </p>\n            <button @click=\"showDeleteConfirm = true\"\n              class=\"mt-4 px-4 py-2 text-sm font-medium text-red-600 hover:text-red-700 transition-colors border border-red-600 rounded-md\">\n              注销账号\n            </button>\n          </div>\n        </div>\n      </section>\n          <!-- 更换手机号弹窗 -->\n    <div v-if=\"showPhoneModal\"\n      class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity flex items-center justify-center z-50\">\n      <div class=\"bg-white rounded-lg shadow-xl max-w-md w-full mx-4\">\n        <div class=\"p-6\">\n          <h3 class=\"text-lg font-medium text-gray-900 mb-4\">更换手机号</h3>\n          <!-- 添加当前手机号显示 -->\n      <div class=\"mb-6 p-4 bg-gray-50 rounded-md\">\n        <p class=\"text-sm text-gray-500\">当前手机号：{{ maskPhone(userPhone) }}</p>\n      </div>\n          <form @submit.prevent=\"handlePhoneChange\" class=\"space-y-4\">\n            <div>\n              <label for=\"newPhone\" class=\"block text-sm font-medium text-gray-700\">新手机号</label>\n              <input type=\"tel\" id=\"newPhone\" v-model=\"phoneForm.newPhone\"\n                class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\" />\n            </div>\n            <div>\n              <label for=\"verifyCode\" class=\"block text-sm font-medium text-gray-700\">验证码</label>\n              <div class=\"mt-1 flex rounded-md shadow-sm\">\n                <input type=\"text\" id=\"verifyCode\" v-model=\"phoneForm.verifyCode\"\n                  class=\"block w-full rounded-l-md border-gray-300 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\" />\n                  <button type=\"button\" @click=\"sendPhoneCode\"\n                    class=\"relative inline-flex items-center whitespace-nowrap rounded-r-md border border-gray-300 bg-gray-50 px-6 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500\">\n                    {{ phoneForm.countdown > 0 ? `${phoneForm.countdown}s` : '获取验证码' }}\n                </button>\n              </div>\n            </div>\n          </form>\n        </div>\n        <div class=\"bg-gray-50 px-6 py-4 flex justify-end space-x-3 rounded-b-lg\">\n          <button @click=\"showPhoneModal = false\"\n            class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\">\n            取消\n          </button>\n          <button @click=\"handlePhoneChange\"\n            class=\"px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-md transition-colors\">\n            确认更换\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- 修改密码弹窗 -->\n    <div v-if=\"showPasswordModal\"\n      class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity flex items-center justify-center z-50\">\n      <div class=\"bg-white rounded-lg shadow-xl max-w-md w-full mx-4\">\n        <div class=\"p-6\">\n          <h3 class=\"text-lg font-medium text-gray-900 mb-4\">修改密码</h3>\n          <form @submit.prevent=\"handlePasswordChange\" class=\"space-y-4\">\n            <!-- 当前密码 -->\n            <div>\n              <label for=\"old_password\" class=\"block text-sm font-medium text-gray-700\">当前密码</label>\n              <div class=\"mt-1 relative\">\n                <input :type=\"showold_password ? 'text' : 'password'\" \n                  id=\"old_password\" \n                  v-model=\"passwordForm.old_password\"\n                  class=\"block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\" \n                />\n                <button type=\"button\" \n                  @click=\"showold_password = !showold_password\"\n                  class=\"absolute inset-y-0 right-0 pr-3 flex items-center\">\n                  <svg v-if=\"showold_password\" class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                  </svg>\n                  <svg v-else class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                  </svg>\n                </button>\n              </div>\n            </div>\n\n            <!-- 新密码 -->\n            <div>\n              <label for=\"newPassword\" class=\"block text-sm font-medium text-gray-700\">新密码</label>\n              <div class=\"mt-1 relative\">\n                <input :type=\"showNewPassword ? 'text' : 'password'\" \n                  id=\"newPassword\" \n                  v-model=\"passwordForm.newPassword\"\n                  class=\"block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\" \n                />\n                <button type=\"button\" \n                  @click=\"showNewPassword = !showNewPassword\"\n                  class=\"absolute inset-y-0 right-0 pr-3 flex items-center\">\n                  <svg v-if=\"showNewPassword\" class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                  </svg>\n                  <svg v-else class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                  </svg>\n                </button>\n              </div>\n            </div>\n\n            <!-- 确认新密码 -->\n            <div>\n              <label for=\"confirmPassword\" class=\"block text-sm font-medium text-gray-700\">确认新密码</label>\n              <div class=\"mt-1 relative\">\n                <input :type=\"showConfirmPassword ? 'text' : 'password'\" \n                  id=\"confirmPassword\" \n                  v-model=\"passwordForm.confirmPassword\"\n                  class=\"block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\" \n                />\n                <button type=\"button\" \n                  @click=\"showConfirmPassword = !showConfirmPassword\"\n                  class=\"absolute inset-y-0 right-0 pr-3 flex items-center\">\n                  <svg v-if=\"showConfirmPassword\" class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                  </svg>\n                  <svg v-else class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                      d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                  </svg>\n                </button>\n              </div>\n            </div>\n          </form>\n        </div>\n        <div class=\"bg-gray-50 px-6 py-4 flex justify-end space-x-3 rounded-b-lg\">\n          <button @click=\"closePasswordDialog\"\n            class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\">\n            取消\n          </button>\n          <button @click=\"handlePasswordChange\"\n            class=\"inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\n            :disabled=\"passwordLoading\">\n            <svg v-if=\"passwordLoading\" class=\"animate-spin -ml-1 mr-2 h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\">\n              <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n              <path class=\"opacity-75\" fill=\"currentColor\"\n                d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\">\n              </path>\n            </svg>\n            {{ passwordLoading ? '修改中...' : '确认修改' }}\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- 注销确认弹窗 -->\n    <div v-if=\"showDeleteConfirm\"\n      class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity flex items-center justify-center z-50\">\n      <div class=\"bg-white rounded-lg shadow-xl max-w-md w-full mx-4\">\n        <div class=\"p-6\">\n          <div class=\"flex items-start space-x-3 mb-4\">\n            <div class=\"flex-shrink-0\">\n              <svg class=\"h-6 w-6 text-red-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                  d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n              </svg>\n            </div>\n            <div>\n              <h3 class=\"text-lg font-medium text-gray-900\">确认注销账号？</h3>\n              <p class=\"mt-2 text-sm text-gray-500\">\n                此操作将永久删除您的账号和所有相关数据，且无法恢复。请输入您的密码以确认。\n              </p>\n            </div>\n          </div>\n\n          <div class=\"mt-4\">\n            <label for=\"deletePassword\" class=\"block text-sm font-medium text-gray-700\">\n              请输入密码确认\n            </label>\n            <div class=\"mt-1\">\n              <input type=\"password\" id=\"deletePassword\" v-model=\"deleteConfirmPassword\"\n                class=\"block w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm\"\n                placeholder=\"请输入您的登录密码\" />\n            </div>\n          </div>\n        </div>\n\n        <div class=\"bg-gray-50 px-6 py-4 flex justify-end space-x-3 rounded-b-lg\">\n          <button @click=\"closeDeleteDialog\"\n            class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\">\n            取消\n          </button>\n          <button @click=\"handleDeleteAccount\"\n            class=\"inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\n            :disabled=\"!deleteConfirmPassword || deleteLoading\">\n            <svg v-if=\"deleteLoading\" class=\"animate-spin -ml-1 mr-2 h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\">\n              <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n              <path class=\"opacity-75\" fill=\"currentColor\"\n                d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\">\n              </path>\n            </svg>\n            {{ deleteLoading ? '注销中...' : '确认注销' }}\n          </button>\n        </div>\n      </div>\n    </div>\n\n\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { \n  changePhone, \n  changePassword, \n  sendSmsCode, \n  deleteAccount\n} from '@/api/user'\nimport { auth } from '@/api/auth'\n\nconst showWeChatBindModal = ref(false)\n\n\nconst store = useStore()\nconst router = useRouter()\n\n// 用户信息 - 使用 computed\nconst userInfo = computed(() => store.getters.getUserInfo || {})\n// 从 store 中获取用户手机号\nconst userPhone = computed(() => store.getters.getUserPhone)\n\n// 模态框显示状态\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\nconst showDeleteConfirm = ref(false)\nconst passwordLoading = ref(false)\nconst deleteConfirmPassword = ref('')\nconst deleteLoading = ref(false)\nconst sendingCode = ref(false)\n\n// 手机号相关状态\nconst showold_password = ref(false)\nconst showNewPassword = ref(false)\nconst showConfirmPassword = ref(false)\n\n// 表单数据\nconst phoneForm = ref({\n  newPhone: '',\n  verifyCode: '',\n  countdown: 0\n})\n\n\nconst passwordForm = ref({\n  oldPassword: '',\n  newPassword: '',\n  confirmPassword: ''\n})\n\n// 工具函数：信息脱敏\nconst maskPhone = (userPhone) => {\n  if (!userPhone) return ''\n  return userPhone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n\nconst maskWechat = (wechat) => {\n  if (!wechat) return ''\n  return wechat.substring(0, 3) + '***' + wechat.substring(wechat.length - 3)\n}\n\n// 关闭密码修改对话框\nconst closePasswordDialog = () => {\n  showPasswordModal.value = false\n  passwordForm.value = {\n    oldPassword: '',\n    newPassword: '',\n    confirmPassword: ''\n  }\n}\n// 注销账户\nconst handleDeleteAccount = async () => {\n  if (!deleteConfirmPassword.value) {\n    showToast('请输入密码以确认注销', 'warning')\n    return\n  }\n\n  try {\n    deleteLoading.value = true\n    const response = await deleteAccount({\n      password: deleteConfirmPassword.value\n    })\n\n    if (response.data?.code === 200) {\n      showToast('账号已注销成功', 'success')\n      showDeleteConfirm.value = false\n      deleteConfirmPassword.value = ''\n      \n      // 清除登录状态并跳转\n      await store.dispatch('logout')\n      router.push({\n        path: '/login',\n        query: { source: 'account_deleted' }\n      })\n    } else {\n      throw new Error(response.data?.message || '注销失败')\n    }\n  } catch (error) {\n    console.error('注销账号失败:', error)\n    const errorMessage = error.response?.data?.message \n      || error.response?.data?.errors?.password?.[0]\n      || error.message \n      || '注销账号失败，请检查密码是否正确'\n    showToast(errorMessage, 'error')\n  } finally {\n    deleteLoading.value = false\n  }\n}\n\n// 关闭注销对话框\nconst closeDeleteDialog = () => {\n  showDeleteConfirm.value = false\n  deleteConfirmPassword.value = ''\n}\n// 发送手机验证码\nconst sendPhoneCode = async () => {\n  if (!phoneForm.value.newPhone) {\n    showToast('请输入新手机号', 'warning')\n    return\n  }\n\n  // 手机号格式验证\n  const phoneRegex = /^1[3-9]\\d{9}$/\n  if (!phoneRegex.test(phoneForm.value.newPhone)) {\n    showToast('请输入正确的手机号格式', 'warning')\n    return\n  }\n\n  try {\n    sendingCode.value = true\n    const response = await auth.sendVerifyCode({\n      phone: phoneForm.value.newPhone,\n      scene: 'change_phone'\n    })\n    \n    if (response.data?.code === 200) {\n      // 开始倒计时\n      phoneForm.value.countdown = 60\n      const timer = setInterval(() => {\n        phoneForm.value.countdown--\n        if (phoneForm.value.countdown <= 0) {\n          clearInterval(timer)\n        }\n      }, 1000)\n      \n      showToast('验证码已发送', 'success')\n    } else {\n      throw new Error(response.data?.message || '发送验证码失败')\n    }\n  } catch (error) {\n    console.error('发送验证码失败:', error)\n    const errorMessage = error.response?.data?.message \n      || error.response?.data?.non_field_errors?.[0]\n      || '发送验证码失败，请稍后重试'\n    showToast(errorMessage, 'error')\n  } finally {\n    sendingCode.value = false\n  }\n}\n// 更换手机号\nconst handlePhoneChange = async () => {\n  if (!phoneForm.value.newPhone) {\n    showToast('请输入新手机号', 'warning')\n    return\n  }\n\n  // 手机号格式验证\n  const phoneRegex = /^1[3-9]\\d{9}$/\n  if (!phoneRegex.test(phoneForm.value.newPhone)) {\n    showToast('请输入正确的手机号格式', 'warning')\n    return\n  }\n\n  if (!phoneForm.value.verifyCode) {\n    showToast('请输入验证码', 'warning')\n    return\n  }\n\n  try {\n    const response = await changePhone({\n      phone: phoneForm.value.newPhone,\n      code: phoneForm.value.verifyCode\n    })\n\n    if (response.data?.code === 200) {\n      showToast('手机号更换成功，请重新登录', 'success')\n      showPhoneModal.value = false\n      // 清空表单\n      phoneForm.value = {\n        newPhone: '',\n        verifyCode: '',\n        countdown: 0\n      }\n\n      // 登出并跳转到登录页\n      await store.dispatch('logout')\n      router.push({\n        path: '/login',\n        query: { redirect: router.currentRoute.value.fullPath }\n      })\n    } else {\n      throw new Error(response.data?.message || '更换手机号失败')\n    }\n  } catch (error) {\n    console.error('更换手机号失败:', error)\n    // 添加更详细的错误信息输出\n    console.error('Error response:', error.response?.data)\n    \n    const errorMessage = error.response?.data?.message \n      || error.response?.data?.non_field_errors?.[0]\n      || error.response?.data?.new_phone?.[0]  // 添加新手机号字段的错误\n      || error.response?.data?.code?.[0]  // 添加验证码字段的错误\n      || '更换手机号失败，请稍后重试'\n    showToast(errorMessage, 'error')\n  }\n}\n\n// 修改密码\nconst handlePasswordChange = async () => {\n  try {\n    // 表单验证\n    if (!passwordForm.value.old_password) {\n      showToast('请输入当前密码', 'warning')\n      return\n    }\n    if (!passwordForm.value.newPassword) {\n      showToast('请输入新密码', 'warning')\n      return\n    }\n    if (!passwordForm.value.confirmPassword) {\n      showToast('请确认新密码', 'warning')\n      return\n    }\n    if (passwordForm.value.newPassword !== passwordForm.value.confirmPassword) {\n      showToast('两次输入的新密码不一致', 'warning')\n      return\n    }\n    if (passwordForm.value.newPassword.length < 6) {\n      showToast('新密码长度不能少于6位', 'warning')\n      return\n    }\n    if (passwordForm.value.old_password === passwordForm.value.newPassword) {\n      showToast('新密码不能与当前密码相同', 'warning')\n      return\n    }\n\n    passwordLoading.value = true\n    const response = await changePassword({\n      old_password: passwordForm.value.old_password,\n      new_password: passwordForm.value.newPassword,\n      confirm_password: passwordForm.value.confirmPassword\n    })\n\n    if (response.data?.code === 200) {\n      showToast('密码修改成功，请重新登录', 'success')\n      showPasswordModal.value = false\n      \n      // 清空表单\n      passwordForm.value = {\n        oldPassword: '',\n        newPassword: '',\n        confirmPassword: ''\n      }\n      \n      // 登出并跳转\n      awa