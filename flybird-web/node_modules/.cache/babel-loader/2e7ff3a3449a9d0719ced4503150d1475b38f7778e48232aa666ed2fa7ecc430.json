{"ast":null,"code":"import { computed } from 'vue';\nimport { SparklesIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'AIDialog',\n  props: {\n    modelValue: {\n      type: Boolean,\n      required: true\n    },\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['update:modelValue', 'action'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const visible = computed({\n      get: () => props.modelValue,\n      set: val => emit('update:modelValue', val)\n    });\n    const handleAction = (type, suggestion) => {\n      emit('action', {\n        type,\n        suggestion\n      });\n    };\n    const __returned__ = {\n      props,\n      emit,\n      visible,\n      handleAction,\n      computed,\n      get SparklesIcon() {\n        return SparklesIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","SparklesIcon","props","__props","emit","__emit","visible","get","modelValue","set","val","handleAction","type","suggestion"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/AIDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/AIDialog.vue -->\n<template>\n    <el-dialog\n      v-model=\"visible\"\n      title=\"AI 优化建议\"\n      width=\"640px\"\n    >\n      <div v-loading=\"loading\" class=\"min-h-[200px]\">\n        <template v-if=\"suggestions.length\">\n          <div \n            v-for=\"(suggestion, index) in suggestions\" \n            :key=\"index\"\n            class=\"mb-4 p-4 bg-gray-50 rounded-lg\"\n          >\n            <div class=\"flex items-start space-x-3\">\n              <SparklesIcon class=\"w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5\" />\n              <div class=\"flex-1\">\n                <h4 class=\"text-sm font-medium text-gray-900 mb-2\">\n                  {{ suggestion.title }}\n                </h4>\n                <p class=\"text-sm text-gray-600\">\n                  {{ suggestion.content }}\n                </p>\n                <div class=\"mt-3 flex items-center space-x-3\">\n                  <el-button \n                    size=\"small\"\n                    @click=\"handleAction('apply', suggestion)\"\n                  >\n                    应用建议\n                  </el-button>\n                  <el-button \n                    size=\"small\"\n                    text\n                    @click=\"handleAction('ignore', suggestion)\"\n                  >\n                    忽略\n                  </el-button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </template>\n        <div v-else class=\"text-center py-8 text-gray-500\">\n          暂无优化建议\n        </div>\n      </div>\n  \n      <template #footer>\n        <div class=\"flex justify-end\">\n          <el-button @click=\"visible = false\">关闭</el-button>\n        </div>\n      </template>\n    </el-dialog>\n  </template>\n  \n  <script setup>\n  import { computed } from 'vue'\n  import { SparklesIcon } from '@heroicons/vue/24/outline'\n  \n  const props = defineProps({\n    modelValue: {\n      type: Boolean,\n      required: true\n    },\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  })\n  \n  const emit = defineEmits(['update:modelValue', 'action'])\n  \n  const visible = computed({\n    get: () => props.modelValue,\n    set: (val) => emit('update:modelValue', val)\n  })\n  \n  const handleAction = (type, suggestion) => {\n    emit('action', { type, suggestion })\n  }\n  </script>"],"mappings":"AAwDE,SAASA,QAAQ,QAAQ,KAAI;AAC7B,SAASC,YAAY,QAAQ,