jectURL(img.src);\n            // 最小尺寸要求：100x100\n            if (img.width < 100 || img.height < 100) {\n              reject(new Error('图片尺寸太小，请上传至少 100x100 像素的图片'));\n              return;\n            }\n            // 最大尺寸要求：4000x4000\n            if (img.width > 4000 || img.height > 4000) {\n              reject(new Error('图片尺寸太大，请上传不超过 4000x4000 像素的图片'));\n              return;\n            }\n            resolve();\n          };\n          img.onerror = () => reject(new Error('图片加载失败，请重试'));\n        });\n      } catch (error) {\n        ElMessage.error(error.message);\n        event.target.value = '';\n        return;\n      }\n\n      // 准备上传数据\n      const formData = new FormData();\n      formData.append('file', file);\n      try {\n        // 显示上传中提示\n        loadingInstance.value = ElLoading.service({\n          lock: true,\n          text: '头像上传中...',\n          background: 'rgba(0, 0, 0, 0.7)'\n        });\n\n        // 生成一个随机的 boundary\n        const boundary = `----WebKitFormBoundary${Math.random().toString(16).slice(2)}`;\n        const response = await request({\n          url: '/api/v1/users/profile/avatar/upload/',\n          method: 'post',\n          data: formData,\n          headers: {\n            'Content-Type': `multipart/form-data; boundary=${boundary}`,\n            'Accept': 'application/json'\n          },\n          transformRequest: [data => {\n            // 让浏览器自动处理 FormData\n            if (data instanceof FormData) {\n              return data;\n            }\n            return data;\n          }]\n        });\n        console.log('Upload response:', response);\n        if (response.data && response.data.code === 200) {\n          const avatarPath = response.data.data.avatar;\n          // 更新 store 中的用户信息\n          store.commit('SET_USER_INFO', {\n            avatar: avatarPath\n          });\n\n          // 更新本地数据\n          emit('update:resumeData', _objectSpread(_objectSpread({}, props.resumeData), {}, {\n            avata