"map":{"version":3,"names":["ref","computed","ElMessage","ElLoading","request","API_PATHS","defaultAvatarImage","useStore","PencilIcon","PhoneIcon","EnvelopeIcon","MapPinIcon","BriefcaseIcon","ClockIcon","CurrencyYenIcon","DocumentTextIcon","CameraIcon","store","loadingInstance","avatarUrl","getters","getUserAvatar","handleImageError","e","target","src","props","__props","emit","__emit","fileInput","handleFileChange","event","file","files","allowedTypes","includes","type","error","value","maxSize","size","Promise","resolve","reject","img","Image","URL","createObjectURL","onload","revokeObjectURL","width","height","Error","onerror","message","formData","FormData","append","service","lock","text","background","boundary","Math","random","toString","slice","response","url","method","data","headers","transformRequest","console","log","code","avatarPath","avatar","commit","_objectSpread","resumeData","success","close","triggerUpload","click"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <div class=\"p-4\">\n        <div class=\"flex items-start space-x-5\">\n          <!-- 头像部分 -->\n          <div class=\"relative group\">\n            <img \n                :src=\"avatarUrl\" \n                class=\"w-20 h-20 rounded-full object-cover border-2 border-white shadow\"\n                alt=\"用户头像\"\n                @error=\"handleImageError\"\n                />\n                <div \n                @click=\"triggerUpload\"\n                class=\"absolute inset-0 flex items-center justify-center rounded-full bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-200\"\n                >\n                <CameraIcon class=\"w-8 h-8 text-white\" />\n                </div>\n                <input\n                ref=\"fileInput\"\n                type=\"file\"\n                accept=\"image/*\"\n                class=\"hidden\"\n                @change=\"handleFileChange\"\n                />\n          </div>\n  \n          <!-- 用户信息 -->\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center justify-between mb-3\">\n              <h2 class=\"text-lg font-medium text-gray-900\">\n                <template v-if=\"resumeData.name\">\n                  {{ resumeData.name }}\n                </template>\n                <span v-else class=\"text-sm text-gray-400\">未设置姓名</span>\n              </h2>\n              <button\n                @click=\"$emit('edit')\"\n                class=\"inline-flex items-center px-2.5 py-1 text-xs font-medium text-primary-600 hover:text-primary-700 border border-primary-600 hover:border-primary-700 rounded\"\n              >\n                <PencilIcon class=\"w-3.5 h-3.5 mr-1\" />\n                编辑资料\n              </button>\n            </div>\n  \n            <!-- 基本信息列表 -->\n            <div class=\"grid grid-cols-2 gap-3\">\n              <!-- 手机号 -->\n              <div class=\"flex items-center text-gray-600\">\n                <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.phone\">\n                  <span class=\"text-sm truncate\">{{ resumeData.phone }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置手机号</span>\n              </div>\n  \n              <!-- 邮箱 -->\n              <div class=\"flex items-center text-gray-600\">\n                <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.email\">\n                  <span class=\"text-sm truncate\">{{ resumeData.email }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置邮箱</span>\n              </div>\n  \n              <!-- 所在地 -->\n              <div class=\"flex items-center text-gray-600\">\n                <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.location\">\n                  <span class=\"text-sm truncate\">{{ resumeData.location }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置所在地</span>\n              </div>\n  \n              <!-- 求职状态 -->\n              <div class=\"flex items-center text-gray-600\">\n                <BriefcaseIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.jobStatus\">\n                  <span class=\"text-sm truncate\">{{ resumeData.jobStatus }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置求职状态</span>\n              </div>\n  \n              <!-- 工作年限 -->\n              <div class=\"flex items-center text-gray-600\">\n                <ClockIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.workYears\">\n                  <span class=\"text-sm truncate\">{{ resumeData.workYears }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置工作年限</span>\n              </div>\n  \n              <!-- 期望薪资 -->\n              <div class=\"flex items-center text-gray-600\">\n                <CurrencyYenIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.expectedSalary\">\n                  <span class=\"text-sm truncate\">{{ resumeData.expectedSalary }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置期望薪资</span>\n              </div>\n            </div>\n  \n            <!-- 个人简介 -->\n            <div class=\"mt-3\">\n              <div class=\"flex items-center text-gray-600 mb-1\">\n                <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm font-medium\">个人简介</span>\n              </div>\n              <template v-if=\"resumeData.bio\">\n                <p class=\"text-sm text-gray-600 leading-relaxed line-clamp-2\">\n                  {{ resumeData.bio }}\n                </p>\n              </template>\n              <p v-else class=\"text-sm text-gray-400 leading-relaxed\">\n                未设置个人简介\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed } from 'vue'\nimport { ElMessage , ElLoading } from 'element-plus'\nimport request, { API_PATHS } from '@/utils/request'  \nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nconst store = useStore()\nconst loadingInstance = ref(null)\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon\n} from '@heroicons/vue/24/outline'\n// 从 store 获取头像\nconst avatarUrl = computed(() => store.getters.getUserAvatar)\n// 处理图片加载错误\nconst handleImageError = (e) => {\n  e.target.src = defaultAvatarImage\n}\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:resumeData'])\nconst fileInput = ref(null)\n\n// 处理文件上传\nconst handleFileChange = async (event) => {\n  const file = event.target.files[0]\n  if (!file) return\n\n  // 文件类型验证\n  const allowedTypes = ['image/jpeg', 'image/png', 'image/gif']\n  if (!allowedTypes.includes(file.type)) {\n    ElMessage.error('请上传 JPG、PNG 或 GIF 格式的图片')\n    event.target.value = ''\n    return\n  }\n\n  // 文件大小验证 (5MB)\n  const maxSize = 5 * 1024 * 1024\n  if (file.size > maxSize) {\n    ElMessage.error('图片大小不能超过 5MB')\n    event.target.value = ''\n    return\n  }\n\n  // 图片尺寸验证\n  try {\n    await new Promise((resolve, reject) => {\n      const img = new Image()\n      img.src = URL.createObjectURL(file)\n      img.onload = () => {\n        URL.revokeObjectURL(img.src)\n        // 最小尺寸要求：100x100\n        if (img.width < 100 || img.height < 100) {\n          reject(new Error('图片尺寸太小，请上传至少 100x100 像素的图片'))\n          return\n        }\n        // 最大尺寸要求：4000x4000\n        if (img.width > 4000 || img.height > 4000) {\n          reject(new Error('图片尺寸太大，请上传不超过 4000x4000 像素的图片'))\n          return\n        }\n        resolve()\n      }\n      img.onerror = () => reject(new Error('图片加载失败，请重试'))\n    })\n  } catch (error) {\n    ElMessage.error(error.message)\n    event.target.value = ''\n    return\n  }\n\n  // 准备上传数据\n  const formData = new FormData()\n  formData.append('file', file)\n\n  try {\n    // 显示上传中提示\n    loadingInstance.value = ElLoading.service({\n      lock: true,\n      text: '头像上传中...',\n      background: 'rgba(0, 0, 0, 0.7)'\n    })\n\n    // 生成一个随机的 boundary\n    const boundary = `----WebKitFormBoundary${Math.random().toString(16).slice(2)}`\n\n    const response = await request({\n      url: '/api/v1/users/profile/avatar/upload/',\n      method: 'post',\n      data: formData,\n      headers: {\n        'Content-Type': `multipart/form-data; boundary=${boundary}`,\n        'Accept': 'application/json'\n      },\n      transformRequest: [\n        (data) => {\n          // 让浏览器自动处理 FormData\n          if (data instanceof FormData) {\n            return data\n          }\n          return data\n        }\n      ]\n    })\n\n    console.log('Upload response:', response)\n\n    if (response.data && response.data.code === 200) {\n      const avatarPath = response.data.data.avatar\n      // 更新 store 中的用户信息\n      store.commit('SET_USER_INFO', {\n        avatar: avatarPath\n      })\n\n      // 更新本地数据\n      emit('update:resumeData', {\n        ...props.resumeData,\n        avatar: avatarPath\n      })\n\n      ElMessage.success('头像上传成功')\n    } else {\n      throw new Error(response.data?.message || '上传失败')\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error.response?.data || error)\n    ElMessage.error(error.response?.data?.message || error.message || '头像上传失败，请重试')\n  } finally {\n    // 关闭加载提示\n    loadingInstance.value?.close()\n    loadingInstance.value = null\n    // 清空文件输入框\n    event.target.value = ''\n  }\n}\n\n\n// 触发文件选择\nconst triggerUpload = () => {\n  fileInput.value.click()\n}\n</script>"],"mappings":";AA6HA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,SAAS,EAAGC,SAAS,QAAQ,cAAa;AACnD,OAAOC,OAAO,IAAIC,SAAS,QAAQ,iBAAiB;AACpD,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAG9B,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAS,QACJ,2BAA0B;AACjC;;;;;;;;;;;;;;;;;IAbA,MAAMC,KAAK,GAAGV,QAAQ,CAAC;IACvB,MAAMW,eAAe,GAAGlB,GAAG,CAAC,IAAI;IAahC,MAAMmB,SAAS,GAAGlB,QAAQ,CAAC,MAAMgB,KAAK,CAACG,OAAO,CAACC,aAAa;IAC5D;IACA,MAAMC,gBAAgB,GAAIC,CAAC,IAAK;MAC9BA,CAAC,CAACC,MAAM,CAACC,GAAG,GAAGnB,kBAAiB;IAClC;IACA,MAAMoB,KAAK,GAAGC,OAAA;IAQd,MAAMC,IAAI,GAAGC,MAAA;IACb,MAAMC,SAAS,GAAG9B,GAAG,CAAC,IAAI;;IAE1B;IACA,MAAM+B,gBAAgB,GAAG,MAAOC,KAAK,IAAK;MACxC,MAAMC,IAAI,GAAGD,KAAK,CAACR,MAAM,CAACU,KAAK,CAAC,CAAC;MACjC,IAAI,CAACD,IAAI,EAAE;;MAEX;MACA,MAAME,YAAY,GAAG,CAAC,YAAY,EAAE,WAAW,EAAE,WAAW;MAC5D,IAAI,CAACA,YAAY,CAACC,QAAQ,CAACH,IAAI,CAACI,IAAI,CAAC,EAAE;QACrCnC,SAAS,CAACoC,KAAK,CAAC,yBAAyB;QACzCN,KAAK,CAACR,MAAM,CAACe,KAAK,GAAG,EAAC;QACtB;MACF;;MAEA;MACA,MAAMC,OAAO,GAAG,CAAC,GAAG,IAAI,GAAG,IAAG;MAC9B,IAAIP,IAAI,CAACQ,IAAI,GAAGD,OAAO,EAAE;QACvBtC,SAAS,CAACoC,KAAK,CAAC,cAAc;QAC9BN,KAAK,CAACR,MAAM,CAACe,KAAK,GAAG,EAAC;QACtB;MACF;;MAEA;MACA,IAAI;QACF,MAAM,IAAIG,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;UACrC,MAAMC,GAAG,GAAG,IAAIC,KAAK,CAAC;UACtBD,GAAG,CAACpB,GAAG,GAAGsB,GAAG,CAACC,eAAe,CAACf,IAAI;UAClCY,GAAG,CAACI,MAAM,GAAG,MAAM;YACjBF,GAAG,CAACG,eAAe,CAACL,GAAG,CAACpB,GAAG;YAC3B;YACA,IAAIoB,GAAG,CAACM,KAAK,GAAG,GAAG,IAAIN,GAAG,CAACO,MAAM,GAAG,GAAG,EAAE;cACvCR,MAAM,CAAC,IAAIS,KAAK,CAAC,4BAA4B,CAAC;cAC9C;YACF;YACA;YACA