{"ast":null,"code":"import { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { XMarkIcon } from '@heroicons/vue/24/outline';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'EditWorkExperienceDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 表单引用\n    const formRef = ref(null);\n\n    // 表单数据\n    const form = ref({\n      company: '',\n      position: '',\n      department: '',\n      date_range: [],\n      is_current: false,\n      description: '',\n      achievements: '',\n      technologies: ''\n    });\n\n    // 禁用未来日期\n    const disabledDate = time => {\n      return time.getTime() > Date.now();\n    };\n\n    // 提交表单\n    const handleSubmit = () => {\n      // 只在有工作描述内容时才验证长度\n      const description = form.value.description?.trim();\n      if (description && description.length < 50) {\n        ElMessage.warning('工作描述如果填写，需要至少50个字符');\n        return;\n      }\n\n      // 只包含后端模型中存在的字段\n      const formData = {\n        company: form.value.company?.trim(),\n        position: form.value.position?.trim(),\n        department: form.value.department?.trim(),\n        start_date: form.value.date_range?.[0] || null,\n        end_date: form.value.date_range?.[1] || null,\n        is_current: form.value.is_current || false,\n        description: description || '',\n        achievements: form.value.achievements?.trim(),\n        technologies: form.value.technologies?.trim()\n      };\n\n      // 如果是编辑模式，添加 id\n      if (props.initialData.id) {\n        formData.id = props.initialData.id;\n      }\n      console.log('表单提交的数据:', formData);\n      console.log('表单原始值:', form.value);\n      emit('submit', formData);\n    };\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      console.log('工作经历初始数据:', newVal);\n      if (newVal) {\n        form.value = {\n          company: newVal.company || '',\n          position: newVal.position || '',\n          department: newVal.department || '',\n          date_range: newVal.start_date && newVal.end_date ? [newVal.start_date, newVal.end_date] : newVal.start_date ? [newVal.start_date, null] : [],\n          is_current: newVal.is_current || false,\n          description: newVal.description || '',\n          achievements: newVal.achievements || '',\n          technologies: newVal.technologies || ''\n        };\n        console.log('工作经历表单数据:', form.value);\n      }\n    }, {\n      immediate: true\n    });\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n\n    // 根据屏幕宽度设置弹窗宽度\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 处理关闭对话框\n    const handleClose = () => {\n      emit('update:modelValue', false);\n    };\n\n    // 日期快捷选项\n    const dateShortcuts = [{\n      text: '最近一年',\n      value: () => {\n        const end = new Date();\n        const start = new Date();\n        start.setFullYear(start.getFullYear() - 1);\n        return [start, end];\n      }\n    }, {\n      text: '最近两年',\n      value: () => {\n        const end = new Date();\n        const start = new Date();\n        start.setFullYear(start.getFullYear() - 2);\n        return [start, end];\n      }\n    }];\n    const __returned__ = {\n      props,\n      emit,\n      formRef,\n      form,\n      disabledDate,\n      handleSubmit,\n      width,\n      isMobile,\n      dialogWidth,\n      handleClose,\n      dateShortcuts,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","XMarkIcon","ElMessage","props","__props","emit","__emit","formRef","form","company","position","department","date_range","is_current","description","achievements","technologies","disabledDate","time","getTime","Date","now","handleSubmit","value","trim","length","warning","formData","start_date","end_date","initialData","id","console","log","newVal","immediate","width","isMobile","dialogWidth","handleClose","dateShortcuts","text","end","start","setFullYear","getFullYear"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditWorkExperienceDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    @close=\"handleClose\"\n    class=\"edit-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- Header -->\n      <div class=\"dialog-header\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-lg font-medium text-gray-900\">\n            {{ initialData.id ? '编辑工作经历' : '添加工作经历' }}\n          </h3>\n          <!-- 移动端显示关闭按钮 -->\n          <button\n            v-if=\"isMobile\"\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- Body -->\n      <div class=\"dialog-body\">\n        <el-form\n          ref=\"formRef\"\n          :model=\"form\"\n        >\n          <form @submit.prevent=\"handleSubmit\" class=\"space-y-4 sm:space-y-5\">\n            <!-- 两列布局 -->\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5\">\n              <!-- 公司名称 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">公司名称</label>\n                <el-form-item prop=\"company\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.company\"\n                    type=\"text\"\n                    placeholder=\"请输入公司名称\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 职位名称 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">职位名称</label>\n                <el-form-item prop=\"position\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.position\"\n                    type=\"text\"\n                    placeholder=\"请输入职位名称\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 部门 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">所在部门</label>\n                <el-form-item prop=\"department\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.department\"\n                    type=\"text\"\n                    placeholder=\"请输入所在部门\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 工作时间 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">工作时间</label>\n                <el-form-item prop=\"date_range\" class=\"mb-0\">\n                  <el-date-picker\n                    v-model=\"form.date_range\"\n                    type=\"daterange\"\n                    range-separator=\"至\"\n                    start-placeholder=\"开始日期\"\n                    end-placeholder=\"结束日期\"\n                    format=\"YYYY-MM-DD\"\n                    value-format=\"YYYY-MM-DD\"\n                    :shortcuts=\"dateShortcuts\"\n                    :disabled-date=\"disabledDate\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n            </div>\n\n            <!-- 工作内容 -->\n            <div class=\"space-y-4\">\n              <!-- 工作描述 -->\n              <div class=\"space-y-2\">\n                <div class=\"flex justify-between items-center\">\n                  <label class=\"block text-sm font-medium text-gray-700\">工作描述</label>\n                  <span class=\"text-xs text-gray-500\">\n                    {{ form.description?.length || 0 }}/50 字符\n                    <span \n                      :class=\"[\n                        form.description?.length >= 50 \n                          ? 'text-green-600' \n                          : 'text-red-600'\n                      ]\"\n                    >\n                      {{ form.description?.length >= 50 ? '(已达标)' : `(还需 ${50 - (form.description?.length || 0)} 字符)` }}\n                    </span>\n                  </span>\n                </div>\n                <div class=\"text-xs text-gray-500\">请详细描述您的工作内容、职责和具体项目经验</div>\n                <el-form-item prop=\"description\" class=\"mb-0\">\n                  <el-input\n                    v-model=\"form.description\"\n                    type=\"textarea\"\n                    :rows=\"4\"\n                    placeholder=\"请详细描述您的工作内容和职责，包括：\n1. 主要负责的工作内容和职责范围\n2. 参与或负责的具体项目\n3. 解决的主要问题和挑战\n4. 工作成果和影响\"\n                    resize=\"none\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 工作成就 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">工作成就</label>\n                <el-form-item prop=\"achievements\" class=\"mb-0\">\n                  <el-input\n                    v-model=\"form.achievements\"\n                    type=\"textarea\"\n                    :rows=\"3\"\n                    placeholder=\"请描述您在该岗位的主要成就\"\n                    resize=\"none\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 技术栈 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">技术栈</label>\n                <el-form-item prop=\"technologies\" class=\"mb-0\">\n                  <el-input\n                    v-model=\"form.technologies\"\n                    type=\"textarea\"\n                    :rows=\"2\"\n                    placeholder=\"请列出您在工作中使用的主要技术栈\"\n                    resize=\"none\"\n                    class=\"!w-full\"\n                  />\n                </el-form-item>\n              </div>\n            </div>\n          </form>\n        </el-form>\n      </div>\n\n      <!-- Footer -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-3 sm:px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-3 sm:px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { XMarkIcon } from '@heroicons/vue/24/outline'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单引用\nconst formRef = ref(null)\n\n// 表单数据\nconst form = ref({\n  company: '',\n  position: '',\n  department: '',\n  date_range: [],\n  is_current: false,\n  description: '',\n  achievements: '',\n  technologies: ''\n})\n\n// 禁用未来日期\nconst disabledDate = (time) => {\n  return time.getTime() > Date.now()\n}\n\n// 提交表单\nconst handleSubmit = () => {\n  // 只在有工作描述内容时才验证长度\n  const description = form.value.description?.trim()\n  if (description && description.length < 50) {\n    ElMessage.warning('工作描述如果填写，需要至少50个字符')\n    return\n  }\n\n  // 只包含后端模型中存在的字段\n  const formData = {\n    company: form.value.company?.trim(),\n    position: form.value.position?.trim(),\n    department: form.value.department?.trim(),\n    start_date: form.value.date_range?.[0] || null,\n    end_date: form.value.date_range?.[1] || null,\n    is_current: form.value.is_current || false,\n    description: description || '',\n    achievements: form.value.achievements?.trim(),\n    technologies: form.value.technologies?.trim()\n  }\n\n  // 如果是编辑模式，添加 id\n  if (props.initialData.id) {\n    formData.id = props.initialData.id\n  }\n\n  console.log('表单提交的数据:', formData)\n  console.log('表单原始值:', form.value)\n\n  emit('submit', formData)\n}\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    console.log('工作经历初始数据:', newVal)\n    if (newVal) {\n      form.value = {\n        company: newVal.company || '',\n        position: newVal.position || '',\n        department: newVal.department || '',\n        date_range: newVal.start_date && newVal.end_date \n          ? [newVal.start_date, newVal.end_date]\n          : newVal.start_date \n            ? [newVal.start_date, null] \n            : [],\n        is_current: newVal.is_current || false,\n        description: newVal.description || '',\n        achievements: newVal.achievements || '',\n        technologies: newVal.technologies || ''\n      }\n      console.log('工作经历表单数据:', form.value)\n    }\n  },\n  { immediate: true }\n)\n\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\n\n// 根据屏幕宽度设置弹窗宽度\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 处理关闭对话框\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n\n// 日期快捷选项\nconst dateShortcuts = [\n  {\n    text: '最近一年',\n    value: () => {\n      const end = new Date()\n      const start = new Date()\n      start.setFullYear(start.getFullYear() - 1)\n      return [start, end]\n    }\n  },\n  {\n    text: '最近两年',\n    value: () => {\n      const end = new Date()\n      const start = new Date()\n      start.setFullYear(start.getFullYear() - 2)\n      return [start, end]\n    }\n  }\n]\n</script>\n\n<style>\n.edit-dialog {\n  @apply max-h-screen flex flex-col;\n}\n\n.edit-dialog :deep(.el-dialog__body) {\n  @apply flex-1 overflow-y-auto;\n}\n\n.edit-dialog :deep(.el-dialog__footer) {\n  @apply sticky bottom-0 bg-gray-50 z-10;\n}\n\n/* 移动端样式 */\n@media (max-width: 640px) {\n  .edit-dialog {\n    margin: 0 !important;\n  }\n\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    height: calc(100vh - 120px);\n    overflow-y: auto;\n  }\n\n  .el-form-item {\n    @apply mb-3;\n  }\n\n  /* 调整输入框在移动端的大小 */\n  input, select, textarea {\n    @apply text-base py-2.5;\n  }\n}\n\n/* 桌面端样式 */\n@media (min-width: 641px) {\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    max-height: calc(80vh - 120px);\n    overflow-y: auto;\n  }\n}\n</style> "],"mappings":"AAiMA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,OAAO,GAAGV,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMW,IAAI,GAAGX,GAAG,CAAC;MACfY,OAAO,EAAE,EAAE;MACXC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,UAAU,EAAE,EAAE;MACdC,UAAU,EAAE,KAAK;MACjBC,WAAW,EAAE,EAAE;MACfC,YAAY,EAAE,EAAE;MAChBC,YAAY,EAAE;IAChB,CAAC;;IAED;IACA,MAAMC,YAAY,GAAIC,IAAI,IAAK;MAC7B,OAAOA,IAAI,CAACC,OAAO,CAAC,CAAC,GAAGC,IAAI,CAACC,GAAG,CAAC;IACnC;;IAEA;IACA,MAAMC,YAAY,GAAGA,CAAA,KAAM;MACzB;MACA,MAAMR,WAAW,GAAGN,IAAI,CAACe,KAAK,CAACT,WAAW,EAAEU,IAAI,CAAC;MACjD,IAAIV,WAAW,IAAIA,WAAW,CAACW,MAAM,GAAG,EAAE,EAAE;QAC1CvB,SAAS,CAACwB,OAAO,CAAC,oBAAoB;QACtC;MACF;;MAEA;MACA,MAAMC,QAAQ,GAAG;QACflB,OAAO,EAAED,IAAI,CAACe,KAAK,CAACd,OAAO,EAAEe,IAAI,CAAC,CAAC;QACnCd,QAAQ,EAAEF,IAAI,CAACe,KAAK,CAACb,QAAQ,EAAEc,IAAI,CAAC,CAAC;QACrCb,UAAU,EAAEH,IAAI,CAACe,KAAK,CAACZ,UAAU,EAAEa,IAAI,CAAC,CAAC;QACzCI,UAAU,EAAEpB,IAAI,CAACe,KAAK,CAACX,UAAU,GAAG,CAAC,CAAC,IAAI,IAAI;QAC9CiB,QAAQ,EAAErB,IAAI,CAACe,KAAK,CAACX,UAAU,GAAG,CAAC,CAAC,IAAI,IAAI;QAC5CC,UAAU,EAAEL,IAAI,CAACe,KAAK,CAACV,UAAU,IAAI,KAAK;QAC1CC,WAAW,EAAEA,WAAW,IAAI,EAAE;QAC9BC,YAAY,EAAEP,IAAI,CAACe,KAAK,CAACR,YAAY,EAAES,IAAI,CAAC,CAAC;QAC7CR,YAAY,EAAER,IAAI,CAACe,KAAK,CAACP,YAAY,EAAEQ,IAAI,CAAC;MAC9C;;MAEA;MACA,IAAIrB,KAAK,CAAC2B,WAAW,CAACC,EAAE,EAAE;QACxBJ,QAAQ,CAACI,EAAE,GAAG5B,KAAK,CAAC2B,WAAW,CAACC,EAAC;MACnC;MAEAC,OAAO,CAACC,GAAG,CAAC,UAAU,EAAEN,QAAQ;MAChCK,OAAO,CAACC,GAAG,CAAC,QA