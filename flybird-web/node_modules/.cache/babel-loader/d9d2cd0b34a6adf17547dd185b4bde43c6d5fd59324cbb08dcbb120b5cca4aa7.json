{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/esnext.iterator.map.js\";\nimport { watch, computed } from 'vue';\nimport { PencilSquareIcon, TrashIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'WorkExperienceContent',\n  props: {\n    data: {\n      type: Array,\n      default: () => []\n    }\n  },\n  emits: ['edit', 'remove'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 格式化日期范围\n    const formatDateRange = (startDate, endDate, isCurrent) => {\n      if (!startDate) return '';\n      const start = new Date(startDate).toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'numeric'\n      });\n      if (isCurrent) {\n        return `${start} - 至今`;\n      }\n      if (endDate) {\n        const end = new Date(endDate).toLocaleDateString('zh-CN', {\n          year: 'numeric',\n          month: 'numeric'\n        });\n        return `${start} - ${end}`;\n      }\n      return start;\n    };\n\n    // 添加计算工作时长的函数\n    const calculateDuration = (startDate, endDate, isCurrent) => {\n      if (!startDate) return '';\n      const start = new Date(startDate);\n      const end = isCurrent ? new Date() : endDate ? new Date(endDate) : null;\n      if (!end) return '';\n      const years = end.getFullYear() - start.getFullYear();\n      const months = end.getMonth() - start.getMonth();\n      let totalMonths = years * 12 + months;\n      if (end.getDate() < start.getDate()) {\n        totalMonths--;\n      }\n      const finalYears = Math.floor(totalMonths / 12);\n      const finalMonths = totalMonths % 12;\n      let duration = '';\n      if (finalYears > 0) {\n        duration += `${finalYears}年`;\n      }\n      if (finalMonths > 0) {\n        duration += `${finalMonths}个月`;\n      }\n      return duration;\n    };\n\n    // 添加计算属性处理工作经历数据\n    const workExperiences = computed(() => {\n      return props.data?.map(item => _objectSpread(_objectSpread({}, item), {}, {\n        duration: calculateDuration(item.start_date, item.end_date, item.is_current)\n      })) || [];\n    });\n\n    // 监听数据变化\n    watch(() => props.data, newVal => {\n      // 移除所有 console.log\n    }, {\n      immediate: true\n    });\n    const __returned__ = {\n      props,\n      formatDateRange,\n      calculateDuration,\n      workExperiences,\n      watch,\n      computed,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["watch","computed","PencilSquareIcon","TrashIcon","props","__props","formatDateRange","startDate","endDate","isCurrent","start","Date","toLocaleDateString","year","month","end","calculateDuration","years","getFullYear","months","getMonth","totalMonths","getDate","finalYears","Math","floor","finalMonths","duration","workExperiences","data","map","item","_objectSpread","start_date","end_date","is_current","newVal","immediate"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/WorkExperienceContent.vue"],"sourcesContent":["<template>\n  <div class=\"relative\">\n    <!-- 时间线 -->\n    <div class=\"absolute left-2 top-4 bottom-4 w-0.5 bg-gray-200\"></div>\n\n    <div \n      v-for=\"item in data\" \n      :key=\"item.id\" \n      class=\"relative pl-10 pb-8 last:pb-0\"\n    >\n      <!-- 时间线圆点 -->\n      <div class=\"absolute left-0 w-4 h-4 bg-white rounded-full border-2 border-blue-500 top-1.5\">\n        <div class=\"absolute inset-1 bg-blue-500 rounded-full\"></div>\n      </div>\n\n      <!-- 标题栏 -->\n      <div class=\"flex items-center justify-between mb-2 bg-white rounded-lg\">\n        <div class=\"flex-1 min-w-0\">\n          <h4 class=\"text-base font-medium text-gray-900 break-words\">\n            {{ item.company }}\n            <span class=\"text-sm font-normal text-gray-500 ml-2\">{{ item.position }}</span>\n          </h4>\n        </div>\n        <div class=\"flex items-center space-x-2\">\n          <!-- 编辑按钮 -->\n          <button\n            @click=\"$emit('edit', item)\"\n            class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200 group relative\"\n          >\n            <PencilSquareIcon class=\"w-5 h-5 text-gray-500 hover:text-gray-700\" />\n            <div class=\"absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none transition-opacity duration-150\">\n              编辑\n            </div>\n          </button>\n          <!-- 删除按钮 -->\n          <button\n            @click=\"$emit('remove', item.id)\"\n            class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200 group relative\"\n          >\n            <TrashIcon class=\"w-5 h-5 text-gray-500 hover:text-red-600\" />\n            <div class=\"absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none transition-opacity duration-150\">\n              删除\n            </div>\n          </button>\n        </div>\n      </div>\n\n      <!-- 时间信息 -->\n      <div class=\"text-sm text-gray-500 mb-2\">\n        <span class=\"text-sm text-gray-500\">\n          {{ formatDateRange(item.start_date, item.end_date, item.is_current) }}\n          <span v-if=\"item.duration\" class=\"ml-1\">({{ item.duration }})</span>\n        </span>\n      </div>\n\n      <!-- 工作内容 -->\n      <div class=\"space-y-2 text-sm text-gray-600\">\n        <div v-if=\"item.description\" class=\"whitespace-pre-wrap\">{{ item.description }}</div>\n        <div v-if=\"item.achievements\" class=\"whitespace-pre-wrap\">\n          <div class=\"font-medium text-gray-700 mb-1\">主要成就：</div>\n          {{ item.achievements }}\n        </div>\n        <div v-if=\"item.technologies\" class=\"whitespace-pre-wrap\">\n          <div class=\"font-medium text-gray-700 mb-1\">相关技术：</div>\n          {{ item.technologies }}\n        </div>\n      </div>\n    </div>\n\n    <!-- 空状态 -->\n    <div \n      v-if=\"!data || data.length === 0\" \n      class=\"text-gray-400 text-center py-8 relative z-10 bg-white\"\n    >\n      暂无工作经历，点击上方添加按钮新增\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { watch, computed } from 'vue'\nimport { \n  PencilSquareIcon, \n  TrashIcon \n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    default: () => []\n  }\n})\n\ndefineEmits(['edit', 'remove'])\n\n// 格式化日期范围\nconst formatDateRange = (startDate, endDate, isCurrent) => {\n  if (!startDate) return ''\n  \n  const start = new Date(startDate).toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'numeric'\n  })\n  \n  if (isCurrent) {\n    return `${start} - 至今`\n  }\n  \n  if (endDate) {\n    const end = new Date(endDate).toLocaleDateString('zh-CN', {\n      year: 'numeric',\n      month: 'numeric'\n    })\n    return `${start} - ${end}`\n  }\n  \n  return start\n}\n\n// 添加计算工作时长的函数\nconst calculateDuration = (startDate, endDate, isCurrent) => {\n  if (!startDate) return ''\n  \n  const start = new Date(startDate)\n  const end = isCurrent ? new Date() : (endDate ? new Date(endDate) : null)\n  \n  if (!end) return ''\n  \n  const years = end.getFullYear() - start.getFullYear()\n  const months = end.getMonth() - start.getMonth()\n  \n  let totalMonths = years * 12 + months\n  if (end.getDate() < start.getDate()) {\n    totalMonths--\n  }\n  \n  const finalYears = Math.floor(totalMonths / 12)\n  const finalMonths = totalMonths % 12\n  \n  let duration = ''\n  if (finalYears > 0) {\n    duration += `${finalYears}年`\n  }\n  if (finalMonths > 0) {\n    duration += `${finalMonths}个月`\n  }\n  \n  return duration\n}\n\n// 添加计算属性处理工作经历数据\nconst workExperiences = computed(() => {\n  return props.data?.map(item => ({\n    ...item,\n    duration: calculateDuration(item.start_date, item.end_date, item.is_current)\n  })) || []\n})\n\n// 监听数据变化\nwatch(() => props.data, (newVal) => {\n  // 移除所有 console.log\n}, { immediate: true })\n</script>\n\n<style scoped>\n/* 时间线动画 */\n.absolute {\n  transition: all 0.3s ease;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .pl-10 {\n    @apply pl-8;\n  }\n  \n  .absolute.left-0 {\n    @apply -left-0.5;\n  }\n}\n</style> "],"mappings":";;AAgFA,SAASA,KAAK,EAAEC,QAAQ,QAAQ,KAAI;AACpC,SACEC,gBAAgB,EAChBC,SAAS,QACJ,2BAA0B;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;;IASd;IACA,MAAMC,eAAe,GAAGA,CAACC,SAAS,EAAEC,OAAO,EAAEC,SAAS,KAAK;MACzD,IAAI,CAACF,SAAS,EAAE,OAAO,EAAC;MAExB,MAAMG,KAAK,GAAG,IAAIC,IAAI,CAACJ,SAAS,CAAC,CAACK,kBAAkB,CAAC,OAAO,EAAE;QAC5DC,IAAI,EAAE,SAAS;QACfC,KAAK,EAAE;MACT,CAAC;MAED,IAAIL,SAAS,EAAE;QACb,OAAO,GAAGC,KAAK,OAAM;MACvB;MAEA,IAAIF,OAAO,EAAE;QACX,MAAMO,GAAG,GAAG,IAAIJ,IAAI,CAACH,OAAO,CAAC,CAACI,kBAAkB,CAAC,OAAO,EAAE;UACxDC,IAAI,EAAE,SAAS;UACfC,KAAK,EAAE;QACT,CAAC;QACD,OAAO,GAAGJ,KAAK,MAAMK,GAAG,EAAC;MAC3B;MAEA,OAAOL,KAAI;IACb;;IAEA;IACA,MAAMM,iBAAiB,GAAGA,CAACT,SAAS,EAAEC,OAAO,EAAEC,SAAS,KAAK;MAC3D,IAAI,CAACF,SAAS,EAAE,OAAO,EAAC;MAExB,MAAMG,KAAK,GAAG,IAAIC,IAAI,CAACJ,SAAS;MAChC,MAAMQ,GAAG,GAAGN,SAAS,GAAG,IAAIE,IAAI,CAAC,CAAC,GAAIH,OAAO,GAAG,IAAIG,IAAI,CAACH,OAAO,CAAC,GAAG,IAAI;MAExE,IAAI,CAACO,GAAG,EAAE,OAAO,EAAC;MAElB,MAAME,KAAK,GAAGF,GAAG,CAACG,WAAW,CAAC,CAAC,GAAGR,KAAK,CAACQ,WAAW,CAAC;MACpD,MAAMC,MAAM,GAAGJ,GAAG,CAACK,QAAQ,CAAC,CAAC,GAAGV,KAAK,CAACU,QAAQ,CAAC;MAE/C,IAAIC,WAAW,GAAGJ,KAAK,GAAG,EAAE,GAAGE,MAAK;MACpC,IAAIJ,GAAG,CAACO,OAAO,CAAC,CAAC,GAAGZ,KAAK,CAACY,OAAO,CAAC,CAAC,EAAE;QACnCD,WAAW,EAAC;MACd;MAEA,MAAME,UAAU,GAAGC,IAAI,CAACC,KAAK,CAACJ,WAAW,GAAG,EAAE;MAC9C,MAAMK,WAAW,GAAGL,WAAW,GAAG