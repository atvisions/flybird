{"ast":null,"code":"import { ref, computed, onMounted, onUnmounted } from 'vue';\nimport { SparklesIcon, DocumentMagnifyingGlassIcon, DocumentCheckIcon, PencilSquareIcon, CheckCircleIcon, ClockIcon, ArrowTrendingUpIcon, StarIcon, CheckIcon, ExclamationTriangleIcon } from '@heroicons/vue/24/outline';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'AIOptimizingDialog',\n  props: {\n    modelValue: Boolean,\n    optimizationResult: {\n      type: Object,\n      default: null\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'complete', 'confirm', 'cancel'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 当前状态：optimizing-优化中，preview-预览确认\n    const status = ref('optimizing');\n\n    // 优化阶段定义\n    const phases = [{\n      name: '分析',\n      icon: DocumentMagnifyingGlassIcon,\n      title: '正在分析简历内容',\n      description: 'AI 正在深度分析您的简历内容和结构'\n    }, {\n      name: '优化',\n      icon: PencilSquareIcon,\n      title: '正在优化内容',\n      description: 'AI 正在根据行业标准优化简历表达'\n    }, {\n      name: '校对',\n      icon: DocumentCheckIcon,\n      title: '正在校对完善',\n      description: 'AI 正在校对并完善细节'\n    }, {\n      name: '完成',\n      icon: CheckCircleIcon,\n      title: '优化完成',\n      description: '您的简历已经焕然一新'\n    }];\n    const currentPhaseIndex = ref(0);\n    const progress = ref(0);\n    const optimizationLogs = ref(['开始简历优化...', '正在加载 AI 模型...']);\n\n    // 当前阶段信息\n    const currentPhase = computed(() => phases[currentPhaseIndex.value]);\n\n    // 模拟优化过程\n    let progressInterval;\n    let phaseInterval;\n    const startOptimization = () => {\n      // 进度更新\n      progressInterval = setInterval(() => {\n        if (progress.value < 100) {\n          progress.value += 1;\n        } else {\n          clearInterval(progressInterval);\n          // 完成后切换到预览状态\n          status.value = 'preview';\n        }\n      }, 600);\n\n      // 阶段更新\n      phaseInterval = setInterval(() => {\n        if (currentPhaseIndex.value < phases.length - 1) {\n          currentPhaseIndex.value += 1;\n          // 添加日志\n          optimizationLogs.value.push(phases[currentPhaseIndex.value].description);\n        } else {\n          clearInterval(phaseInterval);\n        }\n      }, 15000); // 每15秒切换一个阶段\n    };\n    onMounted(() => {\n      status.value = 'optimizing';\n      startOptimization();\n    });\n    onUnmounted(() => {\n      clearInterval(progressInterval);\n      clearInterval(phaseInterval);\n    });\n\n    // 获取章节标题\n    const getSectionTitle = (section, key) => {\n      const titles = {\n        basic_info: {\n          personal_summary: '个人简介'\n        },\n        work_experiences: '工作经历',\n        educations: '教育背景',\n        skills: '专业技能',\n        certificates: '证书认证',\n        languages: '语言能力',\n        portfolios: '项目作品'\n      };\n      return titles[section]?.[key] || titles[section] || key;\n    };\n\n    // 获取项目标题\n    const getItemTitle = item => {\n      if (item.name) return item.name;\n      if (item.title) return item.title;\n      if (item.company) return `${item.company} - ${item.position}`;\n      if (item.school) return `${item.school} - ${item.major}`;\n      return '';\n    };\n\n    // 处理取消\n    const handleCancel = () => {\n      ElMessage.info('已取消本次优化');\n      emit('cancel');\n      emit('update:modelValue', false);\n    };\n\n    // 处理确认\n    const handleConfirm = () => {\n      emit('confirm', props.optimizationResult.optimization_id);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      status,\n      phases,\n      currentPhaseIndex,\n      progress,\n      optimizationLogs,\n      currentPhase,\n      get progressInterval() {\n        return progressInterval;\n      },\n      set progressInterval(v) {\n        progressInterval = v;\n      },\n      get phaseInterval() {\n        return phaseInterval;\n      },\n      set phaseInterval(v) {\n        phaseInterval = v;\n      },\n      startOptimization,\n      getSectionTitle,\n      getItemTitle,\n      handleCancel,\n      handleConfirm,\n      ref,\n      computed,\n      onMounted,\n      onUnmounted,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get DocumentMagnifyingGlassIcon() {\n        return DocumentMagnifyingGlassIcon;\n      },\n      get DocumentCheckIcon() {\n        return DocumentCheckIcon;\n      },\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get ArrowTrendingUpIcon() {\n        return ArrowTrendingUpIcon;\n      },\n      get StarIcon() {\n        return StarIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","onUnmounted","SparklesIcon","DocumentMagnifyingGlassIcon","DocumentCheckIcon","PencilSquareIcon","CheckCircleIcon","ClockIcon","ArrowTrendingUpIcon","StarIcon","CheckIcon","ExclamationTriangleIcon","ElMessage","props","__props","emit","__emit","status","phases","name","icon","title","description","currentPhaseIndex","progress","optimizationLogs","currentPhase","value","progressInterval","phaseInterval","startOptimization","setInterval","clearInterval","length","push","getSectionTitle","section","key","titles","basic_info","personal_summary","work_experiences","educations","skills","certificates","languages","portfolios","getItemTitle","item","company","position","school","major","handleCancel","info","handleConfirm","optimizationResult","optimization_id"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIOptimizingDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    :show-close=\"false\"\n    :close-on-click-modal=\"false\"\n    :close-on-press-escape=\"false\"\n    width=\"900px\"\n    class=\"ai-optimizing-dialog\"\n  >\n    <!-- 优化中的动画和进度 -->\n    <div v-if=\"status === 'optimizing'\" class=\"space-y-8 py-6\">\n      <!-- AI 动画区域 -->\n      <div class=\"relative h-48 flex items-center justify-center\">\n        <!-- 中心光环 -->\n        <div class=\"absolute w-32 h-32 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full opacity-20 animate-pulse\"></div>\n        \n        <!-- 旋转光环 -->\n        <div class=\"absolute w-40 h-40 border-4 border-indigo-500/30 rounded-full animate-spin-slow\"></div>\n        <div class=\"absolute w-48 h-48 border-4 border-purple-500/20 rounded-full animate-spin-reverse\"></div>\n        \n        <!-- AI 图标 -->\n        <div class=\"relative z-10\">\n          <SparklesIcon class=\"w-16 h-16 text-indigo-600 animate-float\" />\n        </div>\n\n        <!-- 扫描线效果 -->\n        <div class=\"absolute inset-0 overflow-hidden\">\n          <div class=\"absolute w-full h-1 bg-gradient-to-r from-transparent via-indigo-500 to-transparent top-0 animate-scan\"></div>\n        </div>\n      </div>\n\n      <!-- 优化状态 -->\n      <div class=\"text-center space-y-4\">\n        <h3 class=\"text-xl font-medium text-gray-900\">\n          {{ currentPhase.title }}\n        </h3>\n        <p class=\"text-sm text-gray-500\">{{ currentPhase.description }}</p>\n      </div>\n\n      <!-- 进度条 -->\n      <div class=\"space-y-2\">\n        <div class=\"flex justify-between text-sm\">\n          <span class=\"text-gray-500\">优化进度</span>\n          <span class=\"text-indigo-600 font-medium\">{{ progress }}%</span>\n        </div>\n        <div class=\"h-2 bg-gray-100 rounded-full overflow-hidden\">\n          <div \n            class=\"h-full bg-gradient-to-r from-indigo-500 to-purple-500 transition-all duration-500 rounded-full\"\n            :style=\"{ width: `${progress}%` }\"\n          ></div>\n        </div>\n      </div>\n\n      <!-- 优化阶段指示器 -->\n      <div class=\"flex justify-between\">\n        <div \n          v-for=\"(phase, index) in phases\" \n          :key=\"index\"\n          class=\"flex flex-col items-center space-y-2\"\n        >\n          <div \n            class=\"w-8 h-8 rounded-full flex items-center justify-center transition-colors\"\n            :class=\"[\n              currentPhaseIndex >= index \n                ? 'bg-indigo-600 text-white' \n                : 'bg-gray-100 text-gray-400'\n            ]\"\n          >\n            <component \n              :is=\"phase.icon\" \n              class=\"w-4 h-4\"\n            />\n          </div>\n          <span \n            class=\"text-xs\"\n            :class=\"[\n              currentPhaseIndex >= index \n                ? 'text-indigo-600' \n                : 'text-gray-400'\n            ]\"\n          >\n            {{ phase.name }}\n          </span>\n        </div>\n      </div>\n\n      <!-- 实时日志 -->\n      <div class=\"bg-gray-50 rounded-lg p-4 h-24 overflow-y-auto\">\n        <div \n          v-for=\"(log, index) in optimizationLogs\" \n          :key=\"index\"\n          class=\"text-sm\"\n          :class=\"{\n            'text-gray-500': index !== optimizationLogs.length - 1,\n            'text-indigo-600': index === optimizationLogs.length - 1\n          }\"\n        >\n          {{ log }}\n        </div>\n      </div>\n    </div>\n\n    <!-- 优化结果预览 -->\n    <div v-else-if=\"status === 'preview'\" class=\"space-y-6\">\n      <div class=\"border-b border-gray-200 pb-4\">\n        <h3 class=\"text-lg font-medium text-gray-900\">AI 优化结果预览</h3>\n        <p class=\"mt-1 text-sm text-gray-500\">\n          AI 已完成简历内容优化，请查看以下优化内容并确认是否应用\n        </p>\n      </div>\n\n      <!-- 主要改进点 -->\n      <div class=\"bg-indigo-50 rounded-lg p-4\">\n        <h4 class=\"text-sm font-medium text-indigo-900 mb-2\">主要改进</h4>\n        <ul class=\"space-y-1\">\n          <li v-for=\"(improvement, index) in optimizationResult.summary.key_improvements\" \n            :key=\"index\"\n            class=\"text-sm text-indigo-700 flex items-start space-x-2\"\n          >\n            <CheckCircleIcon class=\"w-4 h-4 mt-0.5 flex-shrink-0\" />\n            <span>{{ improvement }}</span>\n          </li>\n        </ul>\n      </div>\n\n      <!-- 各部分优化内容 -->\n      <div class=\"space-y-4\">\n        <template v-for=\"(section, sectionKey) in optimizationResult.preview\" :key=\"sectionKey\">\n          <div v-for=\"(item, itemKey) in section\" :key=\"itemKey\">\n            <div class=\"border rounded-lg mb-4\">\n              <div class=\"bg-gray-50 px-4 py-2 rounded-t-lg flex items-center justify-between\">\n                <h4 class=\"font-medium text-gray-900\">{{ getSectionTitle(sectionKey, itemKey) }}</h4>\n                <span class=\"text-xs text-gray-500\">{{ getItemTitle(item) }}</span>\n              </div>\n              <div class=\"p-4 space-y-4\">\n                <!-- 前后对比 -->\n                <div class=\"grid grid-cols-2 gap-6\">\n                  <div class=\"space-y-2\">\n                    <div class=\"flex items-center text-sm text-gray-500\">\n                      <ClockIcon class=\"w-4 h-4 mr-1\" />\n                      <span>优化前</span>\n                    </div>\n                    <div class=\"bg-gray-50 p-3 rounded text-sm text-gray-600\">\n                      {{ item.before }}\n                    </div>\n                  </div>\n                  <div class=\"space-y-2\">\n                    <div class=\"flex items-center text-sm text-green-600\">\n                      <SparklesIcon class=\"w-4 h-4 mr-1\" />\n                      <span>优化后</span>\n                    </div>\n                    <div class=\"bg-green-50 p-3 rounded text-sm text-gray-800\">\n                      {{ item.after }}\n                    </div>\n                  </div>\n                </div>\n                <!-- 改进说明 -->\n                <div class=\"border-t pt-3\">\n                  <h5 class=\"text-sm font-medium text-gray-700 mb-2\">优化要点：</h5>\n                  <ul class=\"space-y-1\">\n                    <li v-for=\"(change, index) in item.changes\" \n                      :key=\"index\"\n                      class=\"text-sm text-gray-600 flex items-start space-x-2\"\n                    >\n                      <ArrowTrendingUpIcon class=\"w-4 h-4 text-green-500 mt-0.5 flex-shrink-0\" />\n                      <span>{{ change }}</span>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </div>\n        </template>\n      </div>\n\n      <!-- 预期效果 -->\n      <div class=\"bg-green-50 rounded-lg p-4\">\n        <h4 class=\"text-sm font-medium text-green-900 mb-2\">预期效果</h4>\n        <ul class=\"space-y-1\">\n          <li v-for=\"(benefit, index) in optimizationResult.summary.expected_benefits\" \n            :key=\"index\"\n            class=\"text-sm text-green-700 flex items-start space-x-2\"\n          >\n            <StarIcon class=\"w-4 h-4 mt-0.5 flex-shrink-0\" />\n            <span>{{ benefit }}</span>\n          </li>\n        </ul>\n      </div>\n\n      <!-- 确认操作按钮 -->\n      <div class=\"flex justify-between items-center pt-4 border-t\">\n        <div class=\"text-sm text-gray-500\">\n          <ExclamationTriangleIcon class=\"w-4 h-4 inline mr-1 text-yellow-500\" />\n          确认后将覆盖原有内容\n        </div>\n        <div class=\"flex space-x-3\">\n          <button\n            @click=\"handleCancel\"\n            class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\"\n          >\n            放弃优化\n          </button>\n          <button\n            @click=\"handleConfirm\"\n            :disabled=\"loading\"\n            class=\"inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-md transition-colors disabled:opacity-50\"\n          >\n            <CheckIcon class=\"w-4 h-4 mr-1.5\" />\n            {{ loading ? '确认中...' : '确认应用' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, onUnmounted } from 'vue'\nimport { \n  SparklesIcon, DocumentMagnifyingGlassIcon, DocumentCheckIcon,\n  PencilSquareIcon, CheckCircleIcon, ClockIcon, ArrowTrendingUpIcon,\n  StarIcon, CheckIcon, ExclamationTriangleIcon\n} from '@heroicons/vue/24/outline'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  optimizationResult: {\n    type: Object,\n    default: null\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'complete', 'confirm', 'cancel'])\n\n// 当前状态：optimizing-优化中，preview-预览确认\nconst status = ref('optimizing')\n\n// 优化阶段定义\nconst phases = [\n  {\n    name: '分析',\n    icon: DocumentMagnifyingGlassIcon,\n    title: '正在分析简历内容',\n    description: 'AI 正在深度分析您的简历内容和结构'\n  },\n  {\n    name: '优化',\n    icon: PencilSquareIcon,\n    title: '正在优化内容',\n    description: 'AI 正在根据行业标准优化简历表达'\n  },\n  {\n    name: '校对',\n    icon: DocumentCheckIcon,\n    title: '正在校对完善',\n    description: 'AI 正在校对并完善细节'\n  },\n  {\n    name: '完成',\n    icon: CheckCircleIcon,\n    title: '优化完成',\n    description: '您的简历已经焕然一新'\n  }\n]\n\nconst currentPhaseIndex = ref(0)\nconst progress = ref(0)\nconst optimizationLogs = ref([\n  '开始简历优化...',\n  '正在加载 AI 模型...'\n])\n\n// 当前阶段信息\nconst currentPhase = computed(() => phases[currentPhaseIndex.value])\n\n// 模拟优化过程\nlet progressInterval\nlet phaseInterval\n\nconst startOptimization = () => {\n  // 进度更新\n  progressInterval = setInterval(() => {\n    if (progress.value < 100) {\n      progress.value += 1\n    } else {\n      clearInterval(progressInterval)\n      // 完成后切换到预览状态\n      status.value = 'preview'\n    }\n  }, 600)\n\n  // 阶段更新\n  phaseInterval = setInterval(() => {\n    if (currentPhaseIndex.value < phases.length - 1) {\n      currentPhaseIndex.value += 1\n      // 添加日志\n      optimizationLogs.value.push(phases[currentPhaseIndex.value].description)\n    } else {\n      clearInterval(phaseInterval)\n    }\n  }, 15000) // 每15秒切换一个阶段\n}\n\nonMounted(() => {\n  status.value = 'optimizing'\n  startOptimization()\n})\n\nonUnmounted(() => {\n  clearInterval(progressInterval)\n  clearInterval(phaseInterval)\n})\n\n// 获取章节标题\nconst getSectionTitle = (section, key) => {\n  const titles = {\n    basic_info: {\n      personal_summary: '个人简介'\n    },\n    work_experiences: '工作经历',\n    educations: '教育背景',\n    skills: '专业技能',\n    certificates: '证书认证',\n    languages: '语言能力',\n    portfolios: '项目作品'\n  }\n  return titles[section]?.[key] || titles[section] || key\n}\n\n// 获取项目标题\nconst getItemTitle = (item) => {\n  if (item.name) return item.name\n  if (item.title) return item.title\n  if (item.company) return `${item.company} - ${item.position}`\n  if (item.school) return `${item.school} - ${item.major}`\n  return ''\n}\n\n// 处理取消\nconst handleCancel = () => {\n  ElMessage.info('已取消本次优化')\n  emit('cancel')\n  emit('update:modelValue', false)\n}\n\n// 处理确认\nconst handleConfirm = () => {\n  emit('confirm', props.optimizationResult.optimization_id)\n}\n</script>\n\n<style>\n.animate-spin-slow {\n  animation: spin 8s linear infinite;\n}\n\n.animate-spin-reverse {\n  animation: spin 12s linear infinite reverse;\n}\n\n.animate-float {\n  animation: float 3s ease-in-out infinite;\n}\n\n.animate-scan {\n  animation: scan 2s linear infinite;\n}\n\n@keyframes float {\n  0%, 100% {\n    transform: translateY(0);\n  }\n  50% {\n    transform: translateY(-10px);\n  }\n}\n\n@keyframes scan {\n  0% {\n    transform: translateY(0);\n  }\n  100% {\n    transform: translateY(100%);\n  }\n}\n\n/* 自定义滚动条样式 */\n.ai-optimizing-dia