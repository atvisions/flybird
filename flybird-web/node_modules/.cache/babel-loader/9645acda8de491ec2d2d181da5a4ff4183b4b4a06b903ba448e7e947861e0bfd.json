{"ast":null,"code":"import { computed, onMounted, watch } from 'vue';\nimport { Edit, Delete } from '@element-plus/icons-vue';\nexport default {\n  __name: 'WorkExperienceContent',\n  props: {\n    data: {\n      type: Array,\n      default: () => []\n    }\n  },\n  emits: ['edit', 'remove'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 格式化日期范围\n    const formatDateRange = (startDate, endDate, isCurrent) => {\n      if (!startDate) return '';\n      const start = new Date(startDate).toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'numeric'\n      });\n      if (isCurrent) {\n        return `${start} - 至今`;\n      }\n      if (endDate) {\n        const end = new Date(endDate).toLocaleDateString('zh-CN', {\n          year: 'numeric',\n          month: 'numeric'\n        });\n        return `${start} - ${end}`;\n      }\n      return start;\n    };\n\n    // 添加数据监听\n    watch(() => props.data, newData => {\n      console.log('WorkExperienceContent data changed:', newData);\n      if (newData) {\n        console.log('数据长度:', newData.length);\n        console.log('数据内容:', newData);\n      }\n    }, {\n      immediate: true,\n      deep: true\n    });\n    const __returned__ = {\n      props,\n      emit,\n      formatDateRange,\n      computed,\n      onMounted,\n      watch,\n      get Edit() {\n        return Edit;\n      },\n      get Delete() {\n        return Delete;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","onMounted","watch","Edit","Delete","props","__props","emit","__emit","formatDateRange","startDate","endDate","isCurrent","start","Date","toLocaleDateString","year","month","end","data","newData","console","log","length","immediate","deep"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/WorkExperienceContent.vue"],"sourcesContent":["<template>\n  <div class=\"work-experience-content\">\n    <!-- 添加调试信息 -->\n    <div class=\"text-xs text-gray-400 mb-2\">\n      Debug: {{ data ? `${data.length} 条记录` : 'No data' }}\n      <pre class=\"text-xs\">{{ JSON.stringify(data, null, 2) }}</pre>\n    </div>\n\n    <!-- 工作经历列表 -->\n    <div v-if=\"data && data.length > 0\" class=\"space-y-2\">\n      <div v-for=\"item in data\" :key=\"item.id\" \n        class=\"flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors\">\n        <!-- 左侧信息 -->\n        <div class=\"flex-1 min-w-0\">\n          <div class=\"flex items-center space-x-2\">\n            <span class=\"font-medium text-gray-900\">{{ item.company }}</span>\n            <span class=\"text-gray-500\">·</span>\n            <span class=\"text-gray-600\">{{ item.position }}</span>\n          </div>\n          <div class=\"text-sm text-gray-500 mt-1\">\n            {{ formatDateRange(item.start_date, item.end_date, item.is_current) }}\n            <span v-if=\"item.duration\" class=\"ml-1\">({{ item.duration }})</span>\n          </div>\n        </div>\n        \n        <!-- 右侧按钮 -->\n        <div class=\"flex items-center space-x-2 ml-4\">\n          <el-button\n            type=\"primary\"\n            link\n            :icon=\"Edit\"\n            @click=\"$emit('edit', item)\"\n          >\n            编辑\n          </el-button>\n          <el-button\n            type=\"danger\"\n            link\n            :icon=\"Delete\"\n            @click=\"$emit('remove', item.id)\"\n          >\n            删除\n          </el-button>\n        </div>\n      </div>\n    </div>\n    \n    <!-- 空状态 -->\n    <div v-else class=\"text-gray-400 text-center py-4\">\n      暂无工作经历，点击上方添加按钮新增\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { computed, onMounted, watch } from 'vue'\nimport { Edit, Delete } from '@element-plus/icons-vue'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    default: () => []\n  }\n})\n\nconst emit = defineEmits(['edit', 'remove'])\n\n// 格式化日期范围\nconst formatDateRange = (startDate, endDate, isCurrent) => {\n  if (!startDate) return ''\n  \n  const start = new Date(startDate).toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'numeric'\n  })\n  \n  if (isCurrent) {\n    return `${start} - 至今`\n  }\n  \n  if (endDate) {\n    const end = new Date(endDate).toLocaleDateString('zh-CN', {\n      year: 'numeric',\n      month: 'numeric'\n    })\n    return `${start} - ${end}`\n  }\n  \n  return start\n}\n\n// 添加数据监听\nwatch(() => props.data, (newData) => {\n  console.log('WorkExperienceContent data changed:', newData)\n  if (newData) {\n    console.log('数据长度:', newData.length)\n    console.log('数据内容:', newData)\n  }\n}, { immediate: true, deep: true })\n</script>\n\n<style scoped>\n.work-experience-content {\n  @apply space-y-4;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .work-experience-content {\n    @apply space-y-3;\n  }\n}\n</style> "],"mappings":"AAuDA,SAASA,QAAQ,EAAEC,SAAS,EAAEC,KAAK,QAAQ,KAAI;AAC/C,SAASC,IAAI,EAAEC,MAAM,QAAQ,yBAAwB;;;;;;;;;;;;;;;IAErD,MAAMC,KAAK,GAAGC,OAAA;IAOd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,eAAe,GAAGA,CAACC,SAAS,EAAEC,OAAO,EAAEC,SAAS,KAAK;MACzD,IAAI,CAACF,SAAS,EAAE,OAAO,EAAC;MAExB,MAAMG,KAAK,GAAG,IAAIC,IAAI,CAACJ,SAAS,CAAC,CAACK,kBAAkB,CAAC,OAAO,EAAE;QAC5DC,IAAI,EAAE,SAAS;QACfC,KAAK,EAAE;MACT,CAAC;MAED,IAAIL,SAAS,EAAE;QACb,OAAO,GAAGC,KAAK,OAAM;MACvB;MAEA,IAAIF,OAAO,EAAE;QACX,MAAMO,GAAG,GAAG,IAAIJ,IAAI,CAACH,OAAO,CAAC,CAACI,kBAAkB,CAAC,OAAO,EAAE;UACxDC,IAAI,EAAE,SAAS;UACfC,KAAK,EAAE;QACT,CAAC;QACD,OAAO,GAAGJ,KAAK,MAAMK,GAAG,EAAC;MAC3B;MAEA,OAAOL,KAAI;IACb;;IAEA;IACAX,KAAK,CAAC,MAAMG,KAAK,CAACc,IAAI,EAAGC,OAAO,IAAK;MACnCC,OAAO,CAACC,GAAG,CAAC,qCAAqC,EAAEF,OAAO;MAC1D,IAAIA,OAAO,EAAE;QACXC,OAAO,CAACC,GAAG,CAAC,OAAO,EAAEF,OAAO,CAACG,MAAM;QACnCF,OAAO,CAACC,GAAG,CAAC,OAAO,EAAEF,OAAO;MAC