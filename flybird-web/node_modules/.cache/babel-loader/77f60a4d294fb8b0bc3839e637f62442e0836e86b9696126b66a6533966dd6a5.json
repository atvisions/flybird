n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), $setup.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock($setup[\"EditBasicDialog\"], {\n    key: 3,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.profileLoading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createVNode($setup[\"AIOptimizeDialog\"], {\n    modelValue: $setup.showAIOptimizeDialog,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showAIOptimizeDialog = $event),\n    \"profile-data\": $setup.profileData,\n    onApply: $setup.handleAIOptimize\n  }, null, 8 /* PROPS */, [\"modelValue\", \"profile-data\"])])]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","$setup","resumeData","basicInfo","loading","profileLoading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onUpdate","handleUpdate","onToggleBioExpand","toggleBioExpand","_ctx","completionData","profileData","_createCommentVNode","activeModules","inactiveModules","modulesLoading","handleEditModule","onRemove","handleModuleRemove","onEditItem","editItem","onRemoveItem","removeItem","length","_hoisted_3","_hoisted_4","_hoisted_5","_Fragment","_renderList","module","type","onClick","$event","handleAddModule","_createTextVNode","_toDisplayString","getModuleName","_hoisted_6","currentModule","_createBlock","modelValue","showEditModal","_cache","editFormData","onSubmit","handleSubmit","showAIOptimizeDialog","onApply","handleAIOptimize"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"profileLoading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @update=\"handleUpdate\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"profileLoading\"\n      />\n\n      <!-- 激活的模块列表 -->\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"modulesLoading\"\n        @edit=\"handleEditModule\"\n        @remove=\"handleModuleRemove\"\n        @edit-item=\"editItem\"\n        @remove-item=\"removeItem\"\n      />\n\n      <!-- 未激活的模块按钮组 -->\n      <div v-if=\"inactiveModules.length > 0\" class=\"bg-white rounded-lg shadow\">\n        <div class=\"px-4 py-3\">\n          <h3 class=\"text-sm font-medium text-gray-900\">添加更多模块</h3>\n          <div class=\"mt-3 flex flex-wrap gap-2\">\n            <button\n              v-for=\"module in inactiveModules\"\n              :key=\"module.type\"\n              @click=\"handleAddModule(module.type)\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm text-gray-600 bg-gray-50 hover:bg-gray-100 rounded border border-gray-200\"\n            >\n              {{ getModuleName(module.type) }}\n              <PlusIcon class=\"w-4 h-4 ml-1 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch, computed } from 'vue'\nimport { useModules } from './composables/useModules'\nimport { useProfileData } from './composables/useProfileData'\nimport { profile } from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { PlusIcon } from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\nimport AIOptimizeDialog from './dialogs/AIOptimizeDialog.vue'\n\n// 使用模块管理\nconst { \n  loading: modulesLoading,\n  activeModules,\n  inactiveModules,\n  fetchModulesData,\n  addModule,\n  removeModule\n} = useModules()\n\nconst {\n  loading: profileLoading,\n  basicInfo,\n  profileData,\n  fetchBasicInfo,\n  fetchModuleData\n} = useProfileData()\n\n// 当前编辑的模块\nconst currentModule = ref(null)\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 添加缺失的响应式变量\nconst showAIOptimizeDialog = ref(false)\n\n// 处理 Bio 展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 定义组件的 emits\ndefineEmits([\n  'update:modelValue',\n  'edit',\n  'add',\n  'remove',\n  'edit-item',\n  'remove-item'\n])\n\n// 初始化数据\nonMounted(async () => {\n  try {\n    // 获取基本信息\n    await fetchBasicInfo()\n    console.log('基本信息:', basicInfo.value)\n    \n    // 获取模块数据\n    await fetchModulesData()\n  } catch (error) {\n    console.error('初始化数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  }\n})\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchUserData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    if (currentModule.value?.type === 'basic_info') {\n      // 基本信息保存\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        // 重新获取基本信息\n        await fetchBasicInfo()\n      } else {\n        throw new Error(response.data?.message || '保存失败')\n      }\n    } else if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.workExperience.update(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchModulesData()\n        } else {\n          throw new Error(response.data?.message || '更新失败')\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.workExperience.add(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchModulesData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.jobIntention.update(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchModulesData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.type === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\n// 处理 AI 优化结果\nconst handleAIOptimize = (optimizedData) => {\n  Object.entries(optimizedData).forEach(([key, value]) => {\n    const [category, field] = key.split('.')\n    if (category && field) {\n      if (!profileData.value[category]) {\n        profileData.value[category] = {}\n      }\n      profileData.value[category][field] = value\n    } else {\n      profileData.value[key] = value\n    }\n  })\n}\n\n// 添加更新处理方法\nconst handleUpdate = async () => {\n  await fetchBasicInfo()\n  await fetchModulesData()\n}\n\n// 处理模块移除\nconst handleModuleRemove = async (moduleType) => {\n  await removeModule(moduleType)\n}\n\n// 处理添加模块\nconst handleAddModule = async (moduleType) => {\n  await addModule(moduleType)\n}\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;EAH5CC,GAAA;EAgC6CD,KAAK,EAAC;;;EACtCA,KAAK,EAAC;AAAW;;EAEfA,KAAK,EAAC;AAA2B;mBAnChD;;uBAEEE,mBAAA,CAgFM,OAhFNC,UAgFM,GA/EJC,mBAAA,CA8EM,OA9ENC,UA8EM,GA7EJC,YAAA,CAQEC,MAAA;IAPCC,UAAU,EAAED,MAAA,CAAAE,SAAS;IACrBC,OAAO,EAAEH,MAAA,CAAAI,cAAc;IACvBC,WAAW,EAAEL,MAAA,CAAAK,WAAW;IACxBC,mBAAmB,EAAEN,MAAA,CAAAM,mBAAmB;IACxCC,MAAI,EAAEP,MAAA,CAAAQ,UAAU;IAChBC,QAAM,EAAET,MAAA,CAAAU,YAAY;IACpBC,iBAAe,EAAEX,MAAA,CAAAY;4FAGpBb,YAAA,CAIEC,MAAA;IAHC,iBAAe,EAAEa,IAAA,CAAAC,cAAc;IAC/B,cAAY,EAAEd,MAAA,CAAAe,WAAW;IACzBZ,OAAO,EAAEH,MAAA,CAAAI;2EAGZY,mBAAA,aAAgB,EAChBjB,YAAA,CAQEC,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAAiB,aAAa;IAC7B,kBAAgB,EAAEjB,MAAA,CAAAkB,eAAe;IACjCf,OAAO,EAAEH,MAAA,CAAAmB,cAAc;IACvBZ,MAAI,EAAEP,MAAA,CAAAoB,gBAAgB;IACtBC,QAAM,EAAErB,MAAA,CAAAsB,kBAAkB;IAC1BC,UAAS,EAAEvB,MAAA,CAAAwB,QAAQ;IACnBC,YAAW,EAAEzB,MAAA,CAAA0B;8EAGhBV,mBAAA,eAAkB,EACPhB,MAAA,CAAAkB,eAAe,CAACS,MAAM,Q,cAAjChC,mBAAA,CAeM,OAfNiC,UAeM,GAdJ/B,mBAAA,CAaM,OAbNgC,UAaM,G,0BAZJhC,mBAAA,CAAyD;IAArDJ,KAAK,EAAC;EAAmC,GAAC,QAAM,sBACpDI,mBAAA,CAUM,OAVNiC,UAUM,I,kBATJnC,mBAAA,CAQSoC,SAAA,QA5CrBC,WAAA,CAqC+BhC,MAAA,CAAAkB,eAAe,EAAzBe,MAAM;yBADftC,mBAAA,CAQS;MANND,GAAG,EAAEuC,MAAM,CAACC,IAAI;MAChBC,OAAK,EAAAC,MAAA,IAAEpC,MAAA,CAAAqC,eAAe,CAACJ,MAAM,CAACC,IAAI;MACnCzC,KAAK,EAAC;QAxCpB6C,gBAAA,CAAAC,gBAAA,CA0CiBvC,MAAA,CAAAwC,aAAa,CAACP,MAAM,CAACC,IAAI,KAAI,GAChC,iBAAAnC,YAAA,CAA+CC,MAAA;MAArCP,KAAK,EAAC;IAA4B,G,iBA3C1DgD,UAAA;0CAAAzB,mBAAA,gBAiDMA,mBAAA,cAAiB,EAEThB,MAAA,CAAA0C,aAAa,EAAER,IAAI,0B,cAD3BS,YAAA,CAME3C,MAAA;IAxDRN,GAAA;IAAAkD,UAAA,EAoDiB5C,MAAA,CAAA6C,aAAa;IApD9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IAoDiBpC,MAAA,CAAA6C,aAAa,GAAAT,MAAA;IACrB,cAAY,EAAEpC,MAAA,CAAA+C,YAAY;IAC1B5C,OAAO,EAAEH,MAAA,CAAAI,cAAc;IACvB4C,QAAM,EAAEhD,MAAA,CAAAiD;wEAvDjBjC,mBAAA,gBA0DMA,mBAAA,cAAiB,EAEThB,MAAA,CAAA0C,aAAa,EAAER,IAAI,wB,cAD3BS,YAAA,CAME3C,MAAA;IAjERN,GAAA;IAAAkD,UAAA,EA6DiB5C,MAAA,CAAA6C,aAAa;IA7D9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IA6DiBpC,MAAA,CAAA6C,aAAa,GAAAT,MAAA;IACrB,cAAY,EAAEpC,MAAA,CAAA+C,YAAY;IAC1B5C,OAAO,EAAEH,MAAA,CAAAI,cAAc;IACvB4C,QAAM,EAAEhD,MAAA,CAAAiD;wEAhEjBjC,mBAAA,gBAmEMA,mBAAA,cAAiB,EAEThB,MAAA,CAAA0C,aAAa,EAAER,IAAI,qB,cAD3BS,YAAA,CAME3C,MAAA;IA1ERN,GAAA;IAAAkD,UAAA,EAsEiB5C,MAAA,CAAA6C,aAAa;IAtE9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAV,MAAA,IAsEiBpC,MAAA,CAAA6C,aAAa,GAAAT,MAAA;IACrB,cAAY,EAAEpC,MAAA,CAAA+C,YAAY;IAC1B5C,OAAO,EAAEH,MAAA,CAAAI,cAAc;IACvB4C,QAAM,EAAEhD,MAAA,CAAAiD;wEAzEjBjC,mBAAA,gBA4EMjB,YAAA,CAIEC,MAAA;IAhFR4C,UAAA,EA6EiB5C,MAAA,CAAAkD,oBAAoB;IA7ErC,uBAAAJ,MAAA,QAAAA,MAAA,MAAAV,MAAA,IA6EiBpC,MAAA,CAAAkD,oBAAoB,GAAAd,MAAA;IAC5B,cAAY,EAAEpC,MAAA,CAAAe,WAAW;IACzBoC,OAAK,EAAEnD,MAAA,CAAAoD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}