{"ast":null,"code":"import { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue';\nimport { CheckIcon, ChevronUpDownIcon, ChevronDownIcon } from '@heroicons/vue/20/solid';\nimport { useFormValidation } from '../composables/useFormValidation';\nimport { ElMessage } from 'element-plus';\n\n// 性别选项\n\nexport default {\n  __name: 'EditBasicDialog',\n  props: {\n    modelValue: {\n      type: Boolean,\n      default: false\n    },\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const genderOptions = [{\n      label: '男',\n      value: 'male'\n    }, {\n      label: '女',\n      value: 'female'\n    }, {\n      label: '其他',\n      value: 'other'\n    }];\n    const {\n      width\n    } = useWindowSize();\n\n    // 判断是否为移动端\n    const isMobile = computed(() => width.value < 640);\n\n    // 根据屏幕宽度设置弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n    const props = __props;\n    const emit = __emit;\n    const form = ref({\n      name: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: '',\n      personal_summary: ''\n    });\n    const {\n      rules,\n      validateForm\n    } = useFormValidation();\n    const formRef = ref(null);\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      if (newVal) {\n        console.log('Dialog received initial data:', newVal);\n        form.value = {\n          name: newVal.name || '',\n          gender: newVal.gender || '',\n          phone: newVal.phone || '',\n          email: newVal.email || '',\n          location: newVal.location || '',\n          birth_date: newVal.birth_date || '',\n          personal_summary: newVal.personal_summary || ''\n        };\n        console.log('Dialog form data updated:', form.value);\n      }\n    }, {\n      immediate: true,\n      deep: true\n    });\n\n    // 添加调试日志\n    watch(form, newVal => {\n      console.log('Form changed:', newVal);\n    }, {\n      deep: true\n    });\n\n    // 处理提交\n    const handleSubmit = async () => {\n      try {\n        console.log('开始验证表单:', {\n          formRef: formRef.value,\n          formData: form.value\n        });\n        const {\n          valid,\n          errors\n        } = await validateForm(formRef.value, form.value);\n        console.log('验证结果:', {\n          valid,\n          errors\n        });\n        if (!valid) {\n          // 显示具体的错误信息\n          ElMessage.error(errors.join('\\n'));\n          return;\n        }\n        emit('submit', form.value);\n      } catch (error) {\n        console.error('表单提交失败:', error);\n        ElMessage.error('提交失败，请稍后重试');\n      }\n    };\n    const handleClose = () => {\n      emit('update:modelValue', false);\n    };\n    const __returned__ = {\n      genderOptions,\n      width,\n      isMobile,\n      dialogWidth,\n      props,\n      emit,\n      form,\n      rules,\n      validateForm,\n      formRef,\n      handleSubmit,\n      handleClose,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get ChevronUpDownIcon() {\n        return ChevronUpDownIcon;\n      },\n      get ChevronDownIcon() {\n        return ChevronDownIcon;\n      },\n      get useFormValidation() {\n        return useFormValidation;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","Listbox","ListboxButton","ListboxOptions","ListboxOption","CheckIcon","ChevronUpDownIcon","ChevronDownIcon","useFormValidation","ElMessage","genderOptions","label","value","width","isMobile","dialogWidth","props","__props","emit","__emit","form","name","gender","phone","email","location","birth_date","personal_summary","rules","validateForm","formRef","initialData","newVal","console","log","immediate","deep","handleSubmit","formData","valid","errors","error","join","handleClose"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n    @close=\"handleClose\"\n    class=\"relative\"\n  >\n    <!-- Header -->\n    <template #header>\n      <div class=\"border-b border-gray-200 px-6 py-5\">\n        <h3 class=\"text-lg font-medium text-gray-900\">编辑基本信息</h3>\n      </div>\n    </template>\n\n    <!-- Body -->\n    <div class=\"px-6 py-5\">\n      <el-form\n        ref=\"formRef\"\n        :model=\"form\"\n        :rules=\"rules\"\n      >\n        <form @submit.prevent=\"handleSubmit\" class=\"space-y-5\">\n          <!-- 两列布局 -->\n          <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n            <!-- 姓名输入框 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">姓名</label>\n              <div class=\"relative\">\n                <el-form-item prop=\"name\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.name\"\n                    type=\"text\"\n                    placeholder=\"请输入姓名\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n            </div>\n\n            <!-- 性别 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">性别</label>\n              <el-form-item prop=\"gender\" class=\"mb-0\">\n                <div class=\"relative\">\n                  <select\n                    v-model=\"form.gender\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500 appearance-none\"\n                  >\n                    <option value=\"\">请选择性别</option>\n                    <option value=\"male\">男</option>\n                    <option value=\"female\">女</option>\n                    <option value=\"other\">其他</option>\n                  </select>\n                  <div class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-2\">\n                    <ChevronDownIcon class=\"h-5 w-5 text-gray-400\" />\n                  </div>\n                </div>\n              </el-form-item>\n            </div>\n\n            <!-- 手机号码 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">手机号码</label>\n              <el-form-item prop=\"phone\" class=\"mb-0\">\n                <input\n                  v-model=\"form.phone\"\n                  type=\"tel\"\n                  placeholder=\"请输入手机号码\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                />\n              </el-form-item>\n            </div>\n\n            <!-- 邮箱 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">邮箱</label>\n              <el-form-item prop=\"email\" class=\"mb-0\">\n                <input\n                  v-model=\"form.email\"\n                  type=\"email\"\n                  placeholder=\"请输入邮箱\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                />\n              </el-form-item>\n            </div>\n\n            <!-- 所在地 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">所在地</label>\n              <el-form-item prop=\"location\" class=\"mb-0\">\n                <input\n                  v-model=\"form.location\"\n                  type=\"text\"\n                  placeholder=\"请输入所在地\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                />\n              </el-form-item>\n            </div>\n\n            <!-- 生日 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">生日</label>\n              <el-form-item prop=\"birth_date\" class=\"mb-0\">\n                <el-date-picker\n                  v-model=\"form.birth_date\"\n                  type=\"date\"\n                  placeholder=\"请选择生日\"\n                  format=\"YYYY-MM-DD\"\n                  value-format=\"YYYY-MM-DD\"\n                  class=\"!w-full\"\n                  :popper-class=\"'my-date-picker'\"\n                />\n              </el-form-item>\n            </div>\n          </div>\n\n          <!-- 个人简介 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">个人简介</label>\n            <el-form-item prop=\"personal_summary\" class=\"mb-0\">\n              <textarea\n                v-model=\"form.personal_summary\"\n                :rows=\"isMobile ? 3 : 4\"\n                placeholder=\"请简要介绍一下自己...\"\n                class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n              ></textarea>\n            </el-form-item>\n          </div>\n        </form>\n      </el-form>\n    </div>\n\n    <!-- Footer -->\n    <template #footer>\n      <div class=\"border-t border-gray-200 px-6 py-4\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue'\nimport { CheckIcon, ChevronUpDownIcon, ChevronDownIcon } from '@heroicons/vue/20/solid'\nimport { useFormValidation } from '../composables/useFormValidation'\nimport { ElMessage } from 'element-plus'\n\n// 性别选项\nconst genderOptions = [\n  { label: '男', value: 'male' },\n  { label: '女', value: 'female' },\n  { label: '其他', value: 'other' }\n]\n\nconst { width } = useWindowSize()\n\n// 判断是否为移动端\nconst isMobile = computed(() => width.value < 640)\n\n// 根据屏幕宽度设置弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    default: false\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst form = ref({\n  name: '',\n  gender: '',\n  phone: '',\n  email: '',\n  location: '',\n  birth_date: '',\n  personal_summary: ''\n})\n\nconst { rules, validateForm } = useFormValidation()\nconst formRef = ref(null)\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    if (newVal) {\n      console.log('Dialog received initial data:', newVal)\n      form.value = {\n        name: newVal.name || '',\n        gender: newVal.gender || '',\n        phone: newVal.phone || '',\n        email: newVal.email || '',\n        location: newVal.location || '',\n        birth_date: newVal.birth_date || '',\n        personal_summary: newVal.personal_summary || ''\n      }\n      console.log('Dialog form data updated:', form.value)\n    }\n  },\n  { immediate: true, deep: true }\n)\n\n// 添加调试日志\nwatch(form, (newVal) => {\n  console.log('Form changed:', newVal)\n}, { deep: true })\n\n// 处理提交\nconst handleSubmit = async () => {\n  try {\n    console.log('开始验证表单:', {\n      formRef: formRef.value,\n      formData: form.value\n    })\n    const { valid, errors } = await validateForm(formRef.value, form.value)\n    console.log('验证结果:', { valid, errors })\n    if (!valid) {\n      // 显示具体的错误信息\n      ElMessage.error(errors.join('\\n'))\n      return\n    }\n    emit('submit', form.value)\n  } catch (error) {\n    console.error('表单提交失败:', error)\n    ElMessage.error('提交失败，请稍后重试')\n  }\n}\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n</script>\n\n<style>\n/* 隐藏 el-form-item 的默认样式 */\n.el-form-item__error {\n  display: none;\n}\n\n/* 日期选择器样式 */\n.my-date-picker {\n  @apply bg-white rounded-lg shadow-lg border border-gray-200;\n}\n\n.my-date-picker .el-picker-panel__content {\n  @apply p-2;\n}\n\n.my-date-picker .el-date-picker__header {\n  @apply mb-4;\n}\n\n.my-date-picker .el-date-picker__header-label {\n  @apply text-gray-900 font-medium;\n}\n\n.my-date-picker .el-picker-panel__icon-btn {\n  @apply text-gray-500 hover:text-primary-600;\n}\n\n.my-date-picker .el-date-table th {\n  @apply text-gray-500 font-normal;\n}\n\n.my-date-picker .el-date-table td {\n  @apply text-gray-700;\n}\n\n.my-date-picker .el-date-table td.available:hover {\n  @apply text-primary-600;\n}\n\n.my-date-picker .el-date-table td.current:not(.disabled) {\n  @apply bg-primary-600 text-white rounded;\n}\n\n/* 日期选择器输入框样式 */\n.el-input__wrapper {\n  @apply !shadow-none bg-gray-50 rounded-md;\n  box-shadow: none !important;\n}\n\n.el-input__inner {\n  @apply !bg-gray-50;\n}\n\n/* 下拉框样式 */\nselect {\n  background-image: none;\n}\n\nselect:focus {\n  @apply ring-2 ring-primary-500 ring-offset-0 border-primary-500;\n}\n</style>"],"mappings":"AAiKA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,OAAO,EAAEC,aAAa,EAAEC,cAAc,EAAEC,aAAa,QAAQ,iBAAgB;AACtF,SAASC,SAAS,EAAEC,iBAAiB,EAAEC,eAAe,QAAQ,yBAAwB;AACtF,SAASC,iBAAiB,QAAQ,kCAAiC;AACnE,SAASC,SAAS,QAAQ,cAAa;;AAEvC;;;;;;;;;;;;;;;;;;;;;;;;IACA,MAAMC,aAAa,GAAG,CACpB;MAAEC,KAAK,EAAE,GAAG;MAAEC,KAAK,EAAE;IAAO,CAAC,EAC7B;MAAED,KAAK,EAAE,GAAG;MAAEC,KAAK,EAAE;IAAS,CAAC,EAC/B;MAAED,KAAK,EAAE,IAAI;MAAEC,KAAK,EAAE;IAAQ,EAChC;IAEA,MAAM;MAAEC;IAAM,CAAC,GAAGb,aAAa,CAAC;;IAEhC;IACA,MAAMc,QAAQ,GAAGhB,QAAQ,CAAC,MAAMe,KAAK,CAACD,KAAK,GAAG,GAAG;;IAEjD;IACA,MAAMG,WAAW,GAAGjB,QAAQ,CAAC,MAAM;MACjC,IAAIe,KAAK,CAACD,