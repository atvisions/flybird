         birth_date: form.value.birth_date,\n          phone: form.value.phone?.trim(),\n          email: form.value.email?.trim(),\n          location: form.value.location?.trim(),\n          personal_summary: form.value.personal_summary?.trim()\n        };\n\n        // 使用 store action 更新基本信息\n        await store.dispatch('updateBasicInfo', {\n          type: 'basic',\n          data: submitData\n        });\n        showToast('保存成功');\n        emit('submit', submitData);\n        handleClose();\n      } catch (error) {\n        if (error.name === 'ValidationError') {\n          showToast('请检查表单填写是否正确', 'error');\n        } else {\n          console.error('保存失败:', error);\n          showToast(error.message || '保存失败，请稍后重试', 'error');\n        }\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 表单验证规则\n    const rules = {\n      name: [{\n        required: true,\n        message: '请输入姓名',\n        trigger: 'blur'\n      }, {\n        min: 2,\n        max: 20,\n        message: '长度在 2 到 20 个字符',\n        trigger: 'blur'\n      }],\n      phone: [{\n        required: true,\n        message: '请输入手机号',\n        trigger: 'blur'\n      }, {\n        pattern: /^1[3-9]\\d{9}$/,\n        message: '请输入正确的手机号',\n        trigger: 'blur'\n      }],\n      email: [{\n        type: 'email',\n        message: '请输入正确的邮箱地址',\n        trigger: 'blur'\n      }],\n      birth_date: [{\n        required: true,\n        message: '请选择出生日期',\n        trigger: 'change'\n      }]\n    };\n\n    // 性别选项\n    const GENDER_OPTIONS = [{\n      value: '',\n      label: '请选择'\n    }, {\n      value: 'male',\n      label: '男'\n    }, {\n      value: 'female',\n      label: '女'\n    }, {\n      value: 'other',\n      label: '其他'\n    }];\n\n    // 获取性别显示文本\n    const getGenderLabel = gender => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[gender] || '请选择';\n    };\n\n    // 响应式布局相关\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 处理关闭对话框\n    const handleClose = () => {\n      form.value = _objectSpread({}, props.initialData); // 重置表单\n      emit('update:modelValue', false);\n    };\n    const __returned__ = {\n      store,\n      props,\n      emit,\n      formRef,\n      loading,\n      form,\n      handleSubmit,\n      rules,\n      GENDER_OPTIONS,\n      getGenderLabel,\n      width,\n      isMobile,\n      dialogWidth,\n      handleClose,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get ChevronUpDownIcon() {\n        return ChevronUpDownIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","useStore","showToast","XMarkIcon","ChevronUpDownIcon","CheckIcon","CalendarIcon","Listbox","ListboxButton","ListboxOptions","ListboxOption","store","props","__props","emit","__emit","formRef","loading","form","name","gender","phone","email","location","birth_date","personal_summary","initialData","newVal","storeData","_objectSpread","state","basicInfo","userInfo","value","Date","toISOString","split","immediate","handleSubmit","validate","submitData","trim","dispatch","type","data","handleClose","error","console","message","rules","required","trigger","min","max","pattern","GENDER_OPTIONS","label","getGenderLabel","genderMap","male","female","other","width","isMobile","dialogWidth"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    @close=\"handleClose\"\n    class=\"edit-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- Header -->\n      <div class=\"dialog-header\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-lg font-medium text-gray-900\">编辑基本信息</h3>\n          <!-- 移动端显示关闭按钮 -->\n          <button\n            v-if=\"isMobile\"\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- Body -->\n      <div class=\"dialog-body  pt-4 pb-6\">\n        <el-form\n          ref=\"formRef\"\n          :model=\"form\"\n          :disabled=\"loading\"\n        >\n          <form @submit.prevent=\"handleSubmit\" class=\"space-y-4 sm:space-y-5\">\n            <!-- 两列布局 -->\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5\">\n              <!-- 姓名 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">姓名</label>\n                <el-form-item prop=\"name\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.name\"\n                    type=\"text\"\n                    placeholder=\"请输入姓名\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 性别 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">性别</label>\n                <el-form-item prop=\"gender\" class=\"mb-0\">\n                  <Listbox v-model=\"form.gender\">\n                    <div class=\"relative w-full\">\n                      <ListboxButton class=\"relative w-full cursor-default rounded-md border border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-left shadow-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\">\n                        <span class=\"block truncate\">{{ getGenderLabel(form.gender) }}</span>\n                        <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2\">\n                          <ChevronUpDownIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                        </span>\n                      </ListboxButton>\n\n                      <transition\n                        leave-active-class=\"transition ease-in duration-100\"\n                        leave-from-class=\"opacity-100\"\n                        leave-to-class=\"opacity-0\"\n                      >\n                        <ListboxOptions class=\"absolute z-10 mt-1 w-full overflow-auto rounded-md bg-white py-1 text-base shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none sm:text-sm\">\n                          <ListboxOption\n                            v-for=\"option in GENDER_OPTIONS\"\n                            :key=\"option.value\"\n                            :value=\"option.value\"\n                            v-slot=\"{ active, selected }\"\n                          >\n                            <div :class=\"[\n                              active ? 'bg-gray-100 text-gray-900' : 'text-gray-700',\n                              'relative cursor-default select-none py-2 pl-3 pr-9'\n                            ]\">\n                              <span :class=\"[selected ? 'font-semibold' : 'font-normal', 'block truncate']\">\n                                {{ option.label }}\n                              </span>\n                              <span v-if=\"selected\" :class=\"[active ? 'text-gray-900' : 'text-gray-600', 'absolute inset-y-0 right-0 flex items-center pr-4']\">\n                                <CheckIcon class=\"h-5 w-5\" aria-hidden=\"true\" />\n                              </span>\n                            </div>\n                          </ListboxOption>\n                        </ListboxOptions>\n                      </transition>\n                    </div>\n                  </Listbox>\n                </el-form-item>\n              </div>\n\n              <!-- 手机号 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">手机号</label>\n                <el-form-item prop=\"phone\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.phone\"\n                    type=\"tel\"\n                    placeholder=\"请输入手机号\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 邮箱 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">邮箱</label>\n                <el-form-item prop=\"email\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.email\"\n                    type=\"email\"\n                    placeholder=\"请输入邮箱\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 所在地 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">所在地</label>\n                <el-form-item prop=\"location\" class=\"mb-0\">\n                  <input\n                    v-model=\"form.location\"\n                    type=\"text\"\n                    placeholder=\"请输入所在地\"\n                    class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                  />\n                </el-form-item>\n              </div>\n\n              <!-- 出生日期 -->\n              <div class=\"space-y-2\">\n                <label class=\"block text-sm font-medium text-gray-700\">出生日期</label>\n                <el-form-item prop=\"birth_date\" class=\"mb-0\">\n                  <div class=\"relative w-full\">\n                    <input\n                      v-model=\"form.birth_date\"\n                      type=\"date\"\n                      class=\"!w-full block rounded-md border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-left shadow-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                    />\n                    <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2\">\n                      <CalendarIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                    </span>\n                  </div>\n                </el-form-item>\n              </div>\n            </div>\n\n            <!-- 个人简介 -->\n            <div class=\"space-y-2\">\n              <label class=\"block text-sm font-medium text-gray-700\">个人简介</label>\n              <el-form-item prop=\"personal_summary\" class=\"mb-0\">\n                <textarea\n                  v-model=\"form.personal_summary\"\n                  rows=\"4\"\n                  placeholder=\"请输入个人简介\"\n                  class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n                ></textarea>\n              </el-form-item>\n            </div>\n          </form>\n        </el-form>\n      </div>\n\n      <!-- Footer -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-3 sm:px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-3 sm:px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { useStore } from 'vuex'\nimport { showToast } from '@/components/ToastMessage'\nimport { XMarkIcon, ChevronUpDownIcon, CheckIcon, CalendarIcon } from '@heroicons/vue/24/outline'\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue'\n\nconst store = useStore()\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\nconst formRef = ref(null)\nconst loading = ref(false)\n\n// 表单数据\nconst form = ref({\n  name: '',\n  gender: '',\n  phone: '',\n  email: '',\n  location: '',\n  birth_date: '',\n  personal_summary: ''\n})\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    if (newVal) {\n      // 合并 store 中的数据和传入的初始数据\n      const storeData = {\n        ...store.state.basicInfo,\n        ...store.state.userInfo\n      }\n      form.value = {\n        ...storeData,\n        ...newVal,\n        // 确保日期格式正确\n        birth_date: newVal.birth_date ? new Date(newVal.birth_date).toISOString().split('T')[0] : ''\n      }\n    }\n  },\n  { immediate: true }\n)\n\n// 提交表单\nconst handleSubmit = async () => {\n  try {\n    // 表单验证\n    await formRef.value.validate()\n    \n    loading.value = true\n    \n    // 准备提交的数据\n    const submitData = {\n      name: form.value.name?.trim(),\n      gender: form.value.gender,\n      birth_date: form.value.birth_date,\n      phone: form.value.phone?.trim(),\n      email: form.value.email?.trim(),\n      location: form.value.location?.trim(),\n      personal_summary: form.value.personal_summary?.trim()\n    }\n\n    // 使用 store action 更新基本信息\n    await store.dispatch('updateBasicInfo', {\n      type: 'basic',\n      data: submitData\n    })\n\n    showToast('保存成功')\n    emit('submit', submitData)\n    handleClose()\n  } catch (error) {\n    if (error.name === 'ValidationError') {\n      showToast('请检查表单填写是否正确', 'error')\n    } else {\n      console.error('保存失败:', error)\n      showToast(error.message || '保存失败，请稍后重试', 'error')\n    }\n  } finally {\n    loading.value = false\n  }\n}\n\n// 表单验证规则\nconst rules = {\n  name: [\n    { required: true, message: '请输入姓名', trigger: 'blur' },\n    { min: 2, max: 20, message: '长度在 2 到 20 个字符', trigger: 'blur' }\n  ],\n  phone: [\n    { required: true, message: '请输入手机号', trigger: 'blur' },\n    { pattern: /^1[3-9]\\d{9}$/, message: '请输入正确的手机号', trigger: 'blur' }\n  ],\n  email: [\n    { type: 'email', message: '请输入正确的邮箱地址', trigger: 'blur' }\n  ],\n  birth_date: [\n    { required: true, message: '请选择出生日期', trigger: 'change' }\n  ]\n}\n\n// 性别选项\nconst GENDER_OPTIONS = [\n  { value: '', label: '请选择' },\n  { value: 'male', label: '男' },\n  { value: 'female', label: '女' },\n  { value: 'other', label: '其他' }\n]\n\n// 获取性别显示文本\nconst getGenderLabel = (gender) => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[gender] || '请选择'\n}\n\n// 响应式布局相关\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 处理关闭对话框\nconst handleClose = () => {\n  form.value = { ...props.initialData }  // 重置表单\n  emit('update:modelValue', false)\n}\n</script>\n\n<style>\n.edit-dialog {\n  @apply max-h-screen flex flex-col;\n}\n\n.edit-dialog :deep(.el-dialog__body) {\n  @apply flex-1 overflow-y-auto;\n}\n\n.edit-dialog :deep(.el-dialog__footer) {\n  @apply sticky bottom-0 bg-gray-50 z-10;\n}\n\n/* 移动端样式 */\n@media (max-width: 640px) {\n  .edit-dialog {\n    margin: 0 !important;\n  }\n\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    height: calc(100vh - 120px);\n    overflow-y: auto;\n  }\n\n  .dialog-body {\n    @apply px-4;  /* 减小内边距 */\n  }\n\n  /* 在移动端时所有输入框占满整行 */\n  .grid {\n    @apply grid-cols-1 gap-3;\n  }\n\n  /* 调整输入框在移动端的大小和间距 */\n  input, select, textarea {\n    @apply text-base py-3;  /* 增加高度使触摸更容易 */\n  }\n\n  /* 调整标签和输入框的间距 */\n  .space-y-2 {\n    @apply space-y-1.5;\n  }\n\n  /* 调整表单项之间的间距 */\n  .space-y-4 {\n    @apply space-y-3;\n  }\n\n  /* 确保底部按钮有足够的大小和间距 */\n  .dialog-footer button {\n    @apply py-2.5 px-4 text-base;\n  }\n}\n\n/* 桌面端样式 */\n@media (min-width: 641px) {\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    max-height: calc(80vh - 120px);\n    overflow-y: auto;\n  }\n}\n\n/* 通用样式 */\n.dialog-header {\n  @apply px-6 pt-4 pb-0 border-b border-gray-200;\n}\n</style>"],"mappings":";AAkMA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,SAAS,EAAEC,iBAAiB,EAAEC,SAAS,EAAEC,YAAY,QAAQ,2BAA0B;AAChG,SAASC,OAAO,EAAEC,aAAa,EAAEC,cAAc,EAAEC,aAAa,QAAQ,iBAAgB;;;;;;;;;;;;;;;;;IAEtF,MAAMC,KAAK,GAAGV,QAAQ,CAAC;IACvB,MAAMW,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;IACb,MAAMC,OAAO,GAAGnB,GAAG,CAAC,IAAI;IACxB,MAAMoB,OAAO,GAAGpB,GAAG,CAAC,KAAK;;IAEzB;IACA,MAAMqB,IAAI,GAAGrB,GAAG,CAAC;MACfsB,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACA1B,KAAK,CACH,MAAMa,KAAK,CAACc,WAAW,EACtBC,MAAM,IAAK;MACV,IAAIA,MAAM,EAAE;QACV;QACA,MAAMC,SAAS,GAAAC,aAAA,CAAAA,aAAA,KACVlB,KAAK,CAACmB,KAAK,CAACC,SAAS,GACrBpB,KAAK,CAACmB,KAAK,CAACE,QAAO,CACxB;QACAd,IAAI,CAACe,KAAK,GAAAJ,aAAA,CAAAA,aAAA,CAAAA,aAAA,KACLD,SAAS,GACTD,MAAM;UACT;UACAH,UAAU,EAAEG,MAAM,CAACH,UAAU,GAAG,IAAIU,IAAI,CAACP,MAAM,CAACH,UAAU,CAAC,CAACW,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC,GAAG;QAAC,EAC7F;MACF;IACF,CAAC,EACD;MAAEC,SAAS,EAAE;IAAK,CACpB;;IAEA;IACA,MAAMC,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/B,IAAI;QACF;QACA,MAAMtB,OAAO,CAACiB,KAAK,CAACM,QAAQ,CAAC;QAE7BtB,OAAO,CAACgB,KAAK,GAAG,IAAG;;QAEnB;QACA,MAAMO,UAAU,GAAG;UACjBrB,IAAI,EAAED,IAAI,CAACe,KAAK,CAACd,IAAI,EAAEsB,IAAI,CAAC,CAAC;UAC7BrB,MAAM,EAAEF,IAAI,CAACe,KAAK,CAACb,MAAM;UACzBI,UAAU,EAAEN,IAAI,CAACe,KAAK,CAACT,UAAU;UACjCH,KAAK,EAAEH,IAAI,CAACe,KAAK,CAACZ,KAAK,EAAEoB,IAAI,CAAC,CAAC;UAC/BnB,KAAK,EAAEJ,IAAI,CAACe,KAAK,CAACX,KAAK,EAAEmB,IAAI,CAAC,CAAC;UAC/BlB,QAAQ,EAAEL,IAAI,CAACe,KAAK,CAACV,QAAQ,EAAEkB,IAAI,CAAC,CAAC;UACrChB,gBAAgB,EAAEP,IAAI,CAACe,KAAK,CAACR,gBAAgB,EAAEgB,IAAI,CAAC;QACtD;;QAEA;QACA,MAAM9B,KAAK,