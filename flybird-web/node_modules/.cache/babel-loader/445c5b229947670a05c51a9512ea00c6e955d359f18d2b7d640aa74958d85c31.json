{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, ArrowTopRightOnSquareIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'SocialLinkContent',\n  props: {\n    data: {\n      type: Array,\n      required: true,\n      default: () => [],\n      validator(value) {\n        console.log('SocialLinkContent 接收到的数据:', {\n          value,\n          isArray: Array.isArray(value),\n          length: value?.length\n        });\n        return Array.isArray(value);\n      }\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n    const __returned__ = {\n      props,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get ArrowTopRightOnSquareIcon() {\n        return ArrowTopRightOnSquareIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","ArrowTopRightOnSquareIcon","props","__props"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/SocialLinkContent.vue"],"sourcesContent":["<template>\n  <div class=\"text-gray-600\">\n    <!-- 调试信息 -->\n    <div v-if=\"true\" class=\"mb-4 p-2 bg-gray-100 rounded text-xs\">\n      接收到的数据: {{ JSON.stringify(data) }}<br>\n      数据类型: {{ typeof data }}<br>\n      是否为数组: {{ Array.isArray(data) }}<br>\n      数据长度: {{ data.length }}<br>\n      数据内容: {{ JSON.stringify(data, null, 2) }}\n    </div>\n\n    <div class=\"space-y-4\">\n      <!-- 社交主页列表 -->\n      <div v-if=\"!data || data.length === 0\" class=\"text-center text-gray-400 py-4\">\n        暂无社交主页，点击下方按钮添加\n      </div>\n      <div v-for=\"(social, index) in data\" :key=\"index\" \n        class=\"bg-gray-50 rounded-lg border border-gray-100 p-4 hover:shadow-sm transition-all\"\n      >\n        <!-- 社交平台头部 -->\n        <div class=\"flex items-start justify-between mb-3\">\n          <div class=\"flex-1 min-w-0\">\n            <h4 class=\"text-base font-medium text-gray-900 break-words\">\n              {{ social.platform_display || social.platform }}\n            </h4>\n            <a \n              :href=\"social.url\" \n              target=\"_blank\"\n              class=\"text-sm text-blue-600 hover:text-blue-800 mt-1 inline-flex items-center\"\n            >\n              访问链接\n              <ArrowTopRightOnSquareIcon class=\"w-4 h-4 ml-1\" />\n            </a>\n          </div>\n          <div class=\"flex items-center space-x-2 ml-4\">\n            <button\n              @click=\"$emit('edit', social)\"\n              class=\"p-1 hover:bg-white rounded-full transition-colors\"\n            >\n              <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n            </button>\n            <button\n              @click=\"$emit('delete', social.id)\"\n              class=\"p-1 hover:bg-white rounded-full transition-colors\"\n            >\n              <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n        \n        <!-- 社交平台描述 -->\n        <div v-if=\"social.description\" class=\"text-sm text-gray-600 mt-2 whitespace-pre-wrap\">\n          {{ social.description }}\n        </div>\n      </div>\n    </div>\n    \n    <!-- 添加按钮 -->\n    <button\n      @click=\"$emit('add')\"\n      class=\"mt-4 w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n    >\n      <PlusIcon class=\"w-4 h-4 mr-2\" />\n      添加社交主页\n    </button>\n  </div>\n</template>\n\n<script setup>\nimport { PencilSquareIcon, TrashIcon, PlusIcon, ArrowTopRightOnSquareIcon } from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    required: true,\n    default: () => [],\n    validator(value) {\n      console.log('SocialLinkContent 接收到的数据:', {\n        value,\n        isArray: Array.isArray(value),\n        length: value?.length\n      })\n      return Array.isArray(value)\n    }\n  }\n})\n\ndefineEmits(['edit', 'delete', 'add'])\n</script> "],"mappings":"AAqEA,SAASA,gBAAgB,EAAEC,SAAS,EAAEC,QAAQ,EAAEC,yBAAyB,QAAQ,2BAA0B;;;;;;;;;;;;;;;;;;;;;;;IAE3G,MAAMC,KAAK,GAAGC,OAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}