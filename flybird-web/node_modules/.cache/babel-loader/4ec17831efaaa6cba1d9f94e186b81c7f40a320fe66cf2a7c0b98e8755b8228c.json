l = url => {\n      try {\n        new URL(url);\n        return true;\n      } catch {\n        return false;\n      }\n    };\n\n    // 提交处理\n    const handleSubmit = () => {\n      if (!validateForm()) {\n        return;\n      }\n      const formData = _objectSpread(_objectSpread({}, form.value), {}, {\n        platform: form.value.platform.trim(),\n        url: form.value.url.trim(),\n        description: form.value.description?.trim() || ''\n      });\n\n      // 如果是新建，不传 id\n      if (!formData.id) {\n        delete formData.id;\n      }\n      emit('submit', formData);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      form,\n      errors,\n      handleClose,\n      validateForm,\n      isValidUrl,\n      handleSubmit,\n      ref,\n      watch,\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get TransitionChild() {\n        return TransitionChild;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","Dialog","DialogPanel","DialogTitle","TransitionRoot","TransitionChild","XMarkIcon","props","__props","emit","__emit","form","id","platform","url","description","errors","initialData","newVal","value","immediate","deep","handleClose","validateForm","isValid","trim","isValidUrl","URL","handleSubmit","formData","_objectSpread"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditSocialLinkDialog.vue"],"sourcesContent":["<template>\n  <TransitionRoot appear :show=\"modelValue\" as=\"template\">\n    <Dialog as=\"div\" @close=\"handleClose\" class=\"relative z-50\">\n      <TransitionChild\n        as=\"template\"\n        enter=\"duration-300 ease-out\"\n        enter-from=\"opacity-0\"\n        enter-to=\"opacity-100\"\n        leave=\"duration-200 ease-in\"\n        leave-from=\"opacity-100\"\n        leave-to=\"opacity-0\"\n      >\n        <div class=\"fixed inset-0 bg-black bg-opacity-25\" />\n      </TransitionChild>\n\n      <div class=\"fixed inset-0 overflow-y-auto\">\n        <div class=\"flex min-h-full items-center justify-center p-4 text-center\">\n          <TransitionChild\n            as=\"template\"\n            enter=\"duration-300 ease-out\"\n            enter-from=\"opacity-0 scale-95\"\n            enter-to=\"opacity-100 scale-100\"\n            leave=\"duration-200 ease-in\"\n            leave-from=\"opacity-100 scale-100\"\n            leave-to=\"opacity-0 scale-95\"\n          >\n            <DialogPanel class=\"w-full max-w-md transform overflow-hidden rounded-2xl bg-white text-left align-middle shadow-xl transition-all\">\n              <form @submit.prevent=\"handleSubmit\">\n                <div class=\"p-6 space-y-4\">\n                  <!-- 标题 -->\n                  <DialogTitle as=\"h3\" class=\"text-lg font-medium leading-6 text-gray-900 flex items-center justify-between\">\n                    {{ initialData?.id ? '编辑社交主页' : '添加社交主页' }}\n                    <button\n                      type=\"button\"\n                      class=\"rounded-full p-1 hover:bg-gray-100 transition-colors\"\n                      @click=\"handleClose\"\n                    >\n                      <XMarkIcon class=\"w-5 h-5 text-gray-400\" />\n                    </button>\n                  </DialogTitle>\n\n                  <!-- 平台名称 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      平台名称 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <select\n                      v-model=\"form.platform\"\n                      required\n                      :class=\"[\n                        'w-full rounded-lg border py-2.5 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/10',\n                        errors.platform ? 'border-red-300 focus:border-red-500' : 'border-gray-300 focus:border-blue-500'\n                      ]\"\n                    >\n                      <option value=\"\">请选择平台</option>\n                      <option value=\"weibo\">新浪微博</option>\n                      <option value=\"zhihu\">知乎</option>\n                      <option value=\"douyin\">抖音</option>\n                      <option value=\"bilibili\">Bilibili</option>\n                      <option value=\"github\">GitHub</option>\n                      <option value=\"website\">个人网站</option>\n                      <option value=\"other\">其他</option>\n                    </select>\n                    <p v-if=\"errors.platform\" class=\"text-sm text-red-500 mt-1\">{{ errors.platform }}</p>\n                  </div>\n\n                  <!-- 链接地址 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      链接地址 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <input\n                      type=\"url\"\n                      v-model=\"form.url\"\n                      required\n                      :class=\"[\n                        'w-full rounded-lg border py-2.5 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/10',\n                        errors.url ? 'border-red-300 focus:border-red-500' : 'border-gray-300 focus:border-blue-500'\n                      ]\"\n                      placeholder=\"请输入完整的链接地址\"\n                    />\n                    <p v-if=\"errors.url\" class=\"text-sm text-red-500 mt-1\">{{ errors.url }}</p>\n                  </div>\n\n                  <!-- 链接描述 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      链接描述\n                    </label>\n                    <el-input\n                      v-model=\"form.description\"\n                      type=\"textarea\"\n                      :rows=\"4\"\n                      placeholder=\"请描述该社交主页的内容（选填）\"\n                      :class=\"[\n                        '!w-full',\n                        errors.description ? 'is-error' : ''\n                      ]\"\n                    />\n                    <p v-if=\"errors.description\" class=\"text-sm text-red-500 mt-1\">{{ errors.description }}</p>\n                  </div>\n\n                  <!-- 底部按钮 -->\n                  <div class=\"flex justify-end space-x-3 pt-6\">\n                    <button\n                      type=\"button\"\n                      @click=\"handleClose\"\n                      class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n                    >\n                      取消\n                    </button>\n                    <button\n                      type=\"submit\"\n                      :disabled=\"loading\"\n                      class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                    >\n                      {{ loading ? '保存中...' : '确认' }}\n                    </button>\n                  </div>\n                </div>\n              </form>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { ref, watch } from 'vue'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  TransitionRoot,\n  TransitionChild\n} from '@headlessui/vue'\nimport { XMarkIcon } from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单数据\nconst form = ref({\n  id: null,\n  platform: '',\n  url: '',\n  description: ''\n})\n\n// 错误状态\nconst errors = ref({\n  platform: '',\n  url: '',\n  description: ''\n})\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newVal) => {\n  if (newVal) {\n    form.value = {\n      id: newVal.id || null,\n      platform: newVal.platform || '',\n      url: newVal.url || '',\n      description: newVal.description || ''\n    }\n  }\n}, { immediate: true, deep: true })\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n\n// 验证表单\nconst validateForm = () => {\n  let isValid = true\n  errors.value = {\n    platform: '',\n    url: '',\n    description: ''\n  }\n\n  if (!form.value.platform?.trim()) {\n    errors.value.platform = '请输入平台名称'\n    isValid = false\n  }\n\n  if (!form.value.url?.trim()) {\n    errors.value.url = '请输入链接地址'\n    isValid = false\n  } else if (!isValidUrl(form.value.url)) {\n    errors.value.url = '请输入有效的链接地址'\n    isValid = false\n  }\n\n  return isValid\n}\n\n// 验证 URL\nconst isValidUrl = (url) => {\n  try {\n    new URL(url)\n    return true\n  } catch {\n    return false\n  }\n}\n\n// 提交处理\nconst handleSubmit = () => {\n  if (!validateForm()) {\n    return\n  }\n\n  const formData = {\n    ...form.value,\n    platform: form.value.platform.trim(),\n    url: form.value.url.trim(),\n    description: form.value.description?.trim() || ''\n  }\n\n  // 如果是新建，不传 id\n  if (!formData.id) {\n    delete formData.id\n  }\n\n  emit('submit', formData)\n}\n</script> "],"mappings":";AAkIA,SAASA,GAAG,EAAEC,KAAK,QAAQ,KAAI;AAC/B,SACEC,MAAM,EACNC,WAAW,EACXC,WAAW,EACXC,cAAc,EACdC,eAAc,QACT,iBAAgB;AACvB,SAASC,SAAS,