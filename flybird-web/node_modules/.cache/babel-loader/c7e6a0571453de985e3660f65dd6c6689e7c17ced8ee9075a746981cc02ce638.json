{"ast":null,"code":"import { createVNode as _createVNode, createCommentVNode as _createCommentVNode, openBlock as _openBlock, createBlock as _createBlock, createElementVNode as _createElementVNode, createElementBlock as _createElementBlock } from \"vue\";\nconst _hoisted_1 = {\n  class: \"container mx-auto\"\n};\nconst _hoisted_2 = {\n  class: \"max-w-4xl mx-auto space-y-4\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createElementVNode(\"div\", _hoisted_2, [_createVNode($setup[\"BasicInfo\"], {\n    resumeData: $setup.basicInfo,\n    loading: $setup.loading,\n    bioExpanded: $setup.bioExpanded,\n    showBioExpandButton: $setup.showBioExpandButton,\n    onEdit: $setup.handleEdit,\n    onToggleBioExpand: _ctx.toggleBioExpand\n  }, null, 8 /* PROPS */, [\"resumeData\", \"loading\", \"bioExpanded\", \"showBioExpandButton\", \"onToggleBioExpand\"]), _createVNode($setup[\"ResumeStatus\"], {\n    \"completion-data\": $setup.completionData,\n    \"profile-data\": $setup.profileData,\n    loading: $setup.loading\n  }, null, 8 /* PROPS */, [\"completion-data\", \"profile-data\", \"loading\"]), _createVNode($setup[\"ModuleList\"], {\n    \"active-modules\": $setup.activeModules,\n    loading: $setup.loading,\n    onEdit: $setup.handleEditModule,\n    onAdd: $setup.addItem,\n    onRemove: $setup.removeModule,\n    onEditItem: $setup.editItem,\n    onRemoveItem: $setup.removeItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onAdd\", \"onRemove\"]), _createVNode($setup[\"AddModule\"], {\n    \"inactive-modules\": $setup.inactiveModules,\n    loading: $setup.loading,\n    onActivate: $setup.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"]), _createCommentVNode(\" 工作经历编辑弹窗 \"), $setup.currentModule?.type === 'work_experience' ? (_openBlock(), _createBlock($setup[\"EditWorkExperienceDialog\"], {\n    key: 0,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), $setup.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock($setup[\"EditJobIntentionDialog\"], {\n    key: 1,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), $setup.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock($setup[\"EditBasicDialog\"], {\n    key: 2,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true)])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","$setup","resumeData","basicInfo","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onToggleBioExpand","_ctx","toggleBioExpand","completionData","profileData","activeModules","handleEditModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","onRemoveItem","removeItem","inactiveModules","onActivate","activateModule","_createCommentVNode","currentModule","type","_createBlock","key","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"loading\"\n      />\n\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :loading=\"loading\"\n        @edit=\"handleEditModule\"\n        @add=\"addItem\"\n        @remove=\"removeModule\"\n        @edit-item=\"editItem\"\n        @remove-item=\"removeItem\"\n      />\n\n      <AddModule\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"loading\"\n        @activate=\"activateModule\"\n      />\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport { useModules } from './composables/useModules'\nimport { profile } from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\n\n// 状态管理\nconst { \n  activeModules, \n  currentModule, \n  inactiveModules, \n  addItem, \n  removeModule, \n  activateModule \n} = useModules()\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\nconst loading = ref(false)\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 基本信息数据\nconst basicInfo = ref({})\n\n// 档案数据\nconst profileData = ref({\n  basic_info: {\n    name: '',\n    name_en: '',\n    personal_summary: '',\n    personal_summary_en: '',\n    gender: '',\n    phone: '',\n    email: '',\n    location: '',\n    birth_date: ''\n  },\n  job_intention: {\n    job_type: '',\n    job_status: '',\n    expected_salary: '',\n    expected_city: '',\n    industries: ''\n  },\n  work_experiences: [],\n  educations: [],\n  skills: []\n})\n\n// 完整度数据\nconst completionData = ref({\n  total_score: 0,\n  dimensions: {\n    basic_info: { score: 0, weight: 0.3 },\n    experience: { score: 0, weight: 0.3 },\n    capability: { score: 0, weight: 0.2 },\n    achievement: { score: 0, weight: 0.2 }\n  },\n  suggestions: []\n})\n\n// 获取档案数据\nconst fetchProfileData = async () => {\n  try {\n    loading.value = true\n    \n    // 获取完整度评分\n    const completenessResponse = await profile.getCompleteness()\n    if (completenessResponse.data?.code === 200) {\n      const completenessData = completenessResponse.data.data\n      completionData.value = {\n        total_score: completenessData.total_score || 0,\n        dimensions: {\n          basic_info: completenessData.dimensions?.basic_info || { score: 0, weight: 0.3 },\n          experience: completenessData.dimensions?.experience || { score: 0, weight: 0.3 },\n          capability: completenessData.dimensions?.capability || { score: 0, weight: 0.2 },\n          achievement: completenessData.dimensions?.achievement || { score: 0, weight: 0.2 }\n        },\n        suggestions: completenessData.suggestions || []\n      }\n    }\n\n    // 获取档案数据\n    const response = await profile.getComplete()\n    if (response.data?.code === 200) {\n      const data = response.data.data\n      \n      // 更新档案数据\n      profileData.value = {\n        basic_info: data.basic_info || profileData.value.basic_info,\n        job_intention: data.job_intention || profileData.value.job_intention,\n        work_experiences: data.work_experiences || [],\n        educations: data.educations || [],\n        skills: data.skills || []\n      }\n\n      // 更新基本信息\n      basicInfo.value = data.basic_info || {}\n\n      // 更新活动模块数据\n      const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n      if (jobIntentionModule) {\n        jobIntentionModule.data = data.job_intention || {}\n      }\n\n      const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n      if (workExperienceModule) {\n        workExperienceModule.data = data.work_experiences || []\n      }\n    }\n  } catch (error) {\n    console.error('获取数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchProfileData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    loading.value = true\n    \n    if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.updateWorkExperience(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.addWorkExperience(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.updateJobIntention(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchProfileData()\n      }\n    } else if (currentModule.value?.type === 'basic_info') {\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchProfileData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\nonMounted(() => {\n  fetchProfileData()\n})\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CA4DM,OA5DNC,UA4DM,GA3DJC,mBAAA,CA0DM,OA1DNC,UA0DM,GAzDJC,YAAA,CAOEC,MAAA;IANCC,UAAU,EAAED,MAAA,CAAAE,SAAS;IACrBC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBC,WAAW,EAAEJ,MAAA,CAAAI,WAAW;IACxBC,mBAAmB,EAAEL,MAAA,CAAAK,mBAAmB;IACxCC,MAAI,EAAEN,MAAA,CAAAO,UAAU;IAChBC,iBAAe,EAAEC,IAAA,CAAAC;iHAGpBX,YAAA,CAIEC,MAAA;IAHC,iBAAe,EAAEA,MAAA,CAAAW,cAAc;IAC/B,cAAY,EAAEX,MAAA,CAAAY,WAAW;IACzBT,OAAO,EAAEH,MAAA,CAAAG;2EAGZJ,YAAA,CAQEC,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAAa,aAAa;IAC7BV,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBG,MAAI,EAAEN,MAAA,CAAAc,gBAAgB;IACtBC,KAAG,EAAEf,MAAA,CAAAgB,OAAO;IACZC,QAAM,EAAEjB,MAAA,CAAAkB,YAAY;IACpBC,UAAS,EAAEnB,MAAA,CAAAoB,QAAQ;IACnBC,YAAW,EAAErB,MAAA,CAAAsB;+EAGhBvB,YAAA,CAIEC,MAAA;IAHC,kBAAgB,EAAEA,MAAA,CAAAuB,eAAe;IACjCpB,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBqB,UAAQ,EAAExB,MAAA,CAAAyB;0EAGbC,mBAAA,cAAiB,EAET1B,MAAA,CAAA2B,aAAa,EAAEC,IAAI,0B,cAD3BC,YAAA,CAME7B,MAAA;IA1CR8B,GAAA;IAAAC,UAAA,EAsCiB/B,MAAA,CAAAgC,aAAa;IAtC9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAsCiBlC,MAAA,CAAAgC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAAmC,YAAY;IAC1BhC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBiC,QAAM,EAAEpC,MAAA,CAAAqC;wEAzCjBX,mBAAA,gBA4CMA,mBAAA,cAAiB,EAET1B,MAAA,CAAA2B,aAAa,EAAEC,IAAI,wB,cAD3BC,YAAA,CAME7B,MAAA;IAnDR8B,GAAA;IAAAC,UAAA,EA+CiB/B,MAAA,CAAAgC,aAAa;IA/C9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA+CiBlC,MAAA,CAAAgC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAAmC,YAAY;IAC1BhC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBiC,QAAM,EAAEpC,MAAA,CAAAqC;wEAlDjBX,mBAAA,gBAqDMA,mBAAA,cAAiB,EAET1B,MAAA,CAAA2B,aAAa,EAAEC,IAAI,qB,cAD3BC,YAAA,CAME7B,MAAA;IA5DR8B,GAAA;IAAAC,UAAA,EAwDiB/B,MAAA,CAAAgC,aAAa;IAxD9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAwDiBlC,MAAA,CAAAgC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAElC,MAAA,CAAAmC,YAAY;IAC1BhC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBiC,QAAM,EAAEpC,MAAA,CAAAqC;wEA3DjBX,mBAAA,e","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}