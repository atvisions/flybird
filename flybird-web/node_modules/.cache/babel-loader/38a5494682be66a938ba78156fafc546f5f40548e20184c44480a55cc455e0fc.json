{"ast":null,"code":"import { watch } from 'vue';\nimport { PencilSquareIcon, TrashIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'WorkExperienceContent',\n  props: {\n    data: {\n      type: Array,\n      default: () => []\n    }\n  },\n  emits: ['edit', 'remove'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 格式化日期范围\n    const formatDateRange = (startDate, endDate, isCurrent) => {\n      if (!startDate) return '';\n      const start = new Date(startDate).toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'numeric'\n      });\n      if (isCurrent) {\n        return `${start} - 至今`;\n      }\n      if (endDate) {\n        const end = new Date(endDate).toLocaleDateString('zh-CN', {\n          year: 'numeric',\n          month: 'numeric'\n        });\n        return `${start} - ${end}`;\n      }\n      return start;\n    };\n\n    // 监听数据变化\n    watch(() => props.data, newVal => {\n      // 移除所有 console.log\n    }, {\n      immediate: true\n    });\n    const __returned__ = {\n      props,\n      formatDateRange,\n      watch,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["watch","PencilSquareIcon","TrashIcon","props","__props","formatDateRange","startDate","endDate","isCurrent","start","Date","toLocaleDateString","year","month","end","data","newVal","immediate"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/WorkExperienceContent.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"item in data\" :key=\"item.id\" class=\"bg-gray-50 rounded-lg p-4\">\n      <!-- 标题栏 -->\n      <div class=\"flex items-center justify-between mb-3\">\n        <div class=\"flex-1\">\n          <h4 class=\"text-base font-medium text-gray-900\">{{ item.company }}</h4>\n        </div>\n        <div class=\"flex items-center space-x-2\">\n          <!-- 编辑按钮 -->\n          <button\n            @click=\"$emit('edit', item)\"\n            class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200\"\n            title=\"编辑\"\n          >\n            <PencilSquareIcon class=\"w-5 h-5 text-gray-900 hover:text-gray-700\" />\n          </button>\n          <!-- 删除按钮 -->\n          <button\n            @click=\"$emit('remove', item.id)\"\n            class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200\"\n            title=\"删除\"\n          >\n            <TrashIcon class=\"w-5 h-5 text-gray-900 hover:text-red-600\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- 其他内容保持不变 -->\n      <div class=\"flex items-center space-x-2\">\n        <span class=\"text-gray-600\">{{ item.position }}</span>\n        <span class=\"text-gray-500\">·</span>\n        <span class=\"text-sm text-gray-500 mt-1\">\n          {{ formatDateRange(item.start_date, item.end_date, item.is_current) }}\n          <span v-if=\"item.duration\" class=\"ml-1\">({{ item.duration }})</span>\n        </span>\n      </div>\n    </div>\n\n    <!-- 空状态 -->\n    <div v-if=\"!data || data.length === 0\" class=\"text-gray-400 text-center py-4\">\n      暂无工作经历，点击上方添加按钮新增\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { watch } from 'vue'\nimport { \n  PencilSquareIcon, \n  TrashIcon \n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    default: () => []\n  }\n})\n\ndefineEmits(['edit', 'remove'])\n\n// 格式化日期范围\nconst formatDateRange = (startDate, endDate, isCurrent) => {\n  if (!startDate) return ''\n  \n  const start = new Date(startDate).toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'numeric'\n  })\n  \n  if (isCurrent) {\n    return `${start} - 至今`\n  }\n  \n  if (endDate) {\n    const end = new Date(endDate).toLocaleDateString('zh-CN', {\n      year: 'numeric',\n      month: 'numeric'\n    })\n    return `${start} - ${end}`\n  }\n  \n  return start\n}\n\n// 监听数据变化\nwatch(() => props.data, (newVal) => {\n  // 移除所有 console.log\n}, { immediate: true })\n</script>\n\n<style scoped>\n.work-experience-content {\n  @apply space-y-4;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .work-experience-content {\n    @apply space-y-3;\n  }\n}\n</style> "],"mappings":"AA+CA,SAASA,KAAK,QAAQ,KAAI;AAC1B,SACEC,gBAAgB,EAChBC,SAAS,QACJ,2BAA0B;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;;IASd;IACA,MAAMC,eAAe,GAAGA,CAACC,SAAS,EAAEC,OAAO,EAAEC,SAAS,KAAK;MACzD,IAAI,CAACF,SAAS,EAAE,OAAO,EAAC;MAExB,MAAMG,KAAK,GAAG,IAAIC,IAAI,CAACJ,SAAS,CAAC,CAACK,kBAAkB,CAAC,OAAO,EAAE;QAC5DC,IAAI,EAAE,SAAS;QACfC,KAAK,EAAE;MACT,CAAC;MAED,IAAIL,SAAS,EAAE;QACb,OAAO,GAAGC,KAAK,OAAM;MACvB;MAEA,IAAIF,OAAO,EAAE;QACX,MAAMO,GAAG,GAAG,IAAIJ,IAAI,CAACH,OAAO,CAAC,CAACI,kBAAkB,CAAC,OAAO,EAAE;UACxDC,IAAI,EAAE,SAAS;UACfC,KAAK,EAAE;QACT,CAAC;QACD,OAAO,GAAGJ,KAAK,MAAMK,GAAG,EAAC;MAC3B;MAEA,OAAOL,KAAI;IACb;;IAEA;IACAT,KAAK,CAAC,MAAMG,KAAK,CAACY,IAAI,EAAGC,MAAM,IAAK;MAClC;IAAA,CACD,EAAE;MAAEC,SAAS,EAAE;IAAK,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}