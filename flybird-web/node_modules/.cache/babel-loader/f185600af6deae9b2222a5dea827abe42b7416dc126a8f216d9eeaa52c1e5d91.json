{"ast":null,"code":"import { ref, watch } from 'vue';\nimport { ElMessage } from 'element-plus';\nimport { genderOptions } from '../constants/options';\nimport { useFormValidation } from '../composables/useFormValidation';\nexport default {\n  __name: 'EditBasicDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const dialogVisible = ref(false);\n    const formRef = ref(null);\n\n    // 初始化表单数据\n    const form = ref({\n      name: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: '',\n      personal_summary: ''\n    });\n\n    // 使用表单验证规则\n    const {\n      rules\n    } = useFormValidation();\n\n    // 监听弹窗显示状态\n    watch(() => props.modelValue, val => {\n      dialogVisible.value = val;\n      if (val) {\n        // 初始化表单数据\n        form.value = {\n          name: props.initialData.name || '',\n          gender: props.initialData.gender || '',\n          phone: props.initialData.phone || '',\n          email: props.initialData.email || '',\n          location: props.initialData.location || '',\n          birth_date: props.initialData.birth_date || '',\n          personal_summary: props.initialData.personal_summary || ''\n        };\n      }\n    });\n\n    // 监听内部弹窗状态\n    watch(dialogVisible, val => {\n      emit('update:modelValue', val);\n      if (!val) {\n        formRef.value?.resetFields();\n      }\n    });\n\n    // 取消\n    const handleCancel = () => {\n      dialogVisible.value = false;\n    };\n\n    // 提交\n    const handleSubmit = async () => {\n      if (!formRef.value) return;\n      try {\n        await formRef.value.validate();\n        emit('submit', form.value);\n      } catch (error) {\n        console.error('表单验证失败:', error);\n        ElMessage.error('请检查表单填写是否正确');\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      dialogVisible,\n      formRef,\n      form,\n      rules,\n      handleCancel,\n      handleSubmit,\n      ref,\n      watch,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get genderOptions() {\n        return genderOptions;\n      },\n      get useFormValidation() {\n        return useFormValidation;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","ElMessage","genderOptions","useFormValidation","props","__props","emit","__emit","dialogVisible","formRef","form","name","gender","phone","email","location","birth_date","personal_summary","rules","modelValue","val","value","initialData","resetFields","handleCancel","handleSubmit","validate","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    v-model=\"dialogVisible\"\n    title=\"编辑个人资料\"\n    width=\"500px\"\n    :close-on-click-modal=\"false\"\n  >\n    <el-form\n      ref=\"formRef\"\n      :model=\"form\"\n      label-width=\"80px\"\n      :rules=\"rules\"\n    >\n      <el-form-item label=\"姓名\" prop=\"name\">\n        <el-input v-model=\"form.name\" placeholder=\"请输入姓名\" />\n      </el-form-item>\n\n      <el-form-item label=\"性别\" prop=\"gender\">\n        <el-select v-model=\"form.gender\" placeholder=\"请选择性别\" class=\"w-full\">\n          <el-option \n            v-for=\"option in genderOptions\" \n            :key=\"option.value\" \n            :label=\"option.label\" \n            :value=\"option.value\" \n          />\n        </el-select>\n      </el-form-item>\n\n      <el-form-item label=\"手机号\" prop=\"phone\">\n        <el-input v-model=\"form.phone\" placeholder=\"请输入手机号\" />\n      </el-form-item>\n\n      <el-form-item label=\"邮箱\" prop=\"email\">\n        <el-input v-model=\"form.email\" placeholder=\"请输入邮箱\" />\n      </el-form-item>\n\n      <el-form-item label=\"所在地\" prop=\"location\">\n        <el-input v-model=\"form.location\" placeholder=\"请输入所在地\" />\n      </el-form-item>\n\n      <el-form-item label=\"生日\" prop=\"birth_date\">\n        <el-date-picker\n          v-model=\"form.birth_date\"\n          type=\"date\"\n          placeholder=\"请选择生日\"\n          format=\"YYYY-MM-DD\"\n          value-format=\"YYYY-MM-DD\"\n          class=\"w-full\"\n        />\n      </el-form-item>\n\n      <el-form-item label=\"个人简介\" prop=\"personal_summary\">\n        <el-input\n          v-model=\"form.personal_summary\"\n          type=\"textarea\"\n          :rows=\"4\"\n          placeholder=\"请输入个人简介\"\n        />\n      </el-form-item>\n    </el-form>\n\n    <template #footer>\n      <div class=\"flex justify-end space-x-3\">\n        <el-button @click=\"handleCancel\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"loading\">\n          保存\n        </el-button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, watch } from 'vue'\nimport { ElMessage } from 'element-plus'\nimport { genderOptions } from '../constants/options'\nimport { useFormValidation } from '../composables/useFormValidation'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst dialogVisible = ref(false)\nconst formRef = ref(null)\n\n// 初始化表单数据\nconst form = ref({\n  name: '',\n  gender: '',\n  phone: '',\n  email: '',\n  location: '',\n  birth_date: '',\n  personal_summary: ''\n})\n\n// 使用表单验证规则\nconst { rules } = useFormValidation()\n\n// 监听弹窗显示状态\nwatch(() => props.modelValue, (val) => {\n  dialogVisible.value = val\n  if (val) {\n    // 初始化表单数据\n    form.value = {\n      name: props.initialData.name || '',\n      gender: props.initialData.gender || '',\n      phone: props.initialData.phone || '',\n      email: props.initialData.email || '',\n      location: props.initialData.location || '',\n      birth_date: props.initialData.birth_date || '',\n      personal_summary: props.initialData.personal_summary || ''\n    }\n  }\n})\n\n// 监听内部弹窗状态\nwatch(dialogVisible, (val) => {\n  emit('update:modelValue', val)\n  if (!val) {\n    formRef.value?.resetFields()\n  }\n})\n\n// 取消\nconst handleCancel = () => {\n  dialogVisible.value = false\n}\n\n// 提交\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    await formRef.value.validate()\n    emit('submit', form.value)\n  } catch (error) {\n    console.error('表单验证失败:', error)\n    ElMessage.error('请检查表单填写是否正确')\n  }\n}\n</script>"],"mappings":"AA0EA,SAASA,GAAG,EAAEC,KAAK,QAAQ,KAAI;AAC/B,SAASC,SAAS,QAAQ,cAAa;AACvC,SAASC,aAAa,QAAQ,sBAAqB;AACnD,SAASC,iBAAiB,QAAQ,kCAAiC;;;;;;;;;;;;;;;;;IAEnE,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,aAAa,GAAGT,GAAG,CAAC,KAAK;IAC/B,MAAMU,OAAO,GAAGV,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMW,IAAI,GAAGX,GAAG,CAAC;MACfY,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACA,MAAM;MAAEC;IAAM,CAAC,GAAGf,iBAAiB,CAAC;;IAEpC;IACAH,KAAK,CAAC,MAAMI,KAAK,CAACe,UAAU,EAAGC,GAAG,IAAK;MACrCZ,aAAa,CAACa,KAAK,GAAGD,GAAE;MACxB,IAAIA,GAAG,EAAE;QACP;QACAV,IAAI,CAACW,KAAK,GAAG;UACXV,IAAI,EAAEP,KAAK,CAACkB,WAAW,CAACX,IAAI,IAAI,EAAE;UAClCC,MAAM,EAAER,KAAK,CAACkB,WAAW,CAACV,MAAM,IAAI,EAAE;UACtCC,KAAK,EAAET,KAAK,CAACkB,WAAW,CAACT,KAAK,IAAI,EAAE;UACpCC,KAAK,EAAEV,KAAK,CAACkB,WAAW,CAACR,KAAK,IAAI,EAAE;UACpCC,QAAQ,EAAEX,KAAK,CAACkB,WAAW,CAACP,QAAQ,IAAI,EAAE;UAC1CC,UAAU,EAAEZ,KAAK,CAACkB,WAAW,CAACN,UAAU,IAAI,EAAE;UAC9CC,gBAAgB,EAAEb