removeItem","inactiveModules","onActivate","activateModule","_createCommentVNode","currentModule","type","_createBlock","key","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n  \n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :profile-data=\"profileData\"\n          :loading=\"loading\"\n          @ai-optimize=\"handleAIOptimize\"\n          @import=\"handleImport\"\n          @preview=\"handlePreview\"\n        />\n  \n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"handleEditModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n          @remove-item=\"removeItem\"\n        />\n  \n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n  \n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n  \n      <!-- 添加基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted } from 'vue'\n  import { useModules } from './composables/useModules'\n  import { profile } from '@/api/profile'\n  import { ElMessage, ElMessageBox } from 'element-plus'\n  \n  // 组件引入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  import EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\n  import EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\n  \n  // 状态管理\n  const { \n    activeModules, \n    currentModule, \n    inactiveModules, \n    addItem, \n    removeModule, \n    activateModule \n  } = useModules()\n  \n  const showEditModal = ref(false)\n  const editFormData = ref({})\n  const loading = ref(false)\n  \n  // 基本信息控制\n  const bioExpanded = ref(false)\n  const showBioExpandButton = ref(false)\n  \n  // 基本信息数据\n  const basicInfo = ref({})\n  \n  // 档案数据 - 添加完整的初始结构\n  const profileData = ref({\n    basic_info: {\n      name: '',\n      name_en: '',\n      personal_summary: '',\n      personal_summary_en: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: ''\n    },\n    job_intention: {\n      job_type: '',\n      job_status: '',\n      expected_salary: '',\n      expected_city: '',\n      industries: ''\n    },\n    work_experiences: [],\n    educations: [],\n    skills: []\n  })\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 获取档案数据\n  const fetchProfileData = async () => {\n    try {\n      loading.value = true\n      const response = await profile.getComplete()\n      if (response.data?.code === 200) {\n        const data = response.data.data\n        \n        // 更新档案数据\n        profileData.value = {\n          basic_info: data.basic_info || profileData.value.basic_info,\n          job_intention: data.job_intention || profileData.value.job_intention,\n          work_experiences: data.work_experiences || [],\n          educations: data.educations || [],\n          skills: data.skills || []\n        }\n\n        // 更新基本信息\n        basicInfo.value = data.basic_info || {}\n\n        // 更新完整度数据\n        completionData.value = {\n          total_score: data.completeness || 0,\n          dimensions: data.dimensions || {},\n          suggestions: data.suggestions || []\n        }\n      }\n    } catch (error) {\n      console.error('获取档案数据失败:', error)\n      ElMessage.error('获取数据失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 处理生物信息展开/收起\n  const toggleBioExpand = () => {\n    bioExpanded.value = !bioExpanded.value\n  }\n  \n  // 处理编辑\n  const handleEdit = (type, data) => {\n    // ... 编辑处理逻辑 ...\n  }\n  \n  // 处理 AI 优化\n  const handleAIOptimize = () => {\n    // ... AI 优化处理逻辑 ...\n  }\n  \n  // 处理导入\n  const handleImport = () => {\n    // ... 导入处理逻辑 ...\n  }\n  \n  // 处理预览\n  const handlePreview = () => {\n    // ... 预览处理逻辑 ...\n  }\n  \n  // 编辑具体项目（用于工作经历）\n  const editItem = (moduleId, item) => {\n    console.log('编辑具体项目:', moduleId, item)\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n    console.log('当前模块:', currentModule.value)\n    console.log('编辑表单数据:', editFormData.value)\n  }\n  \n  // 删除工作经历\n  const removeItem = async (moduleId, itemId) => {\n    try {\n      await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n        type: 'warning'\n      })\n      \n      if (moduleId === 'work_experience') {\n        await profile.deleteWorkExperience(itemId)\n        ElMessage.success('删除成功')\n        await fetchData()\n      }\n    } catch (error) {\n      if (error !== 'cancel') {\n        console.error('删除失败:', error)\n        ElMessage.error('删除失败')\n      }\n    }\n  }\n  \n  // 提交表单\n  const handleSubmit = async (data) => {\n    try {\n      if (currentModule.value?.type === 'work_experience') {\n        const response = await profile.updateWorkExperience(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      } else if (currentModule.value?.type === 'job_intention') {\n        const response = await profile.updateJobIntention(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      } else if (currentModule.value?.type === 'basic_info') {\n        const response = await profile.updateBasicInfo(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      }\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error(error.message || '保存失败')\n    }\n  }\n  \n  // 处理编辑模块\n  const handleEditModule = (moduleId) => {\n    console.log('编辑模块:', moduleId)\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    \n    // 如果是工作经历，清空表单数据\n    if (currentModule.value?.type === 'work_experience') {\n      editFormData.value = {}\n    } \n    // 如果是求职意向，使用现有数据\n    else if (currentModule.value?.type === 'job_intention') {\n      editFormData.value = { ...currentModule.value.data } || {}\n    }\n    \n    showEditModal.value = true\n    console.log('当前模块:', currentModule.value)\n    console.log('编辑表单数据:', editFormData.value)\n  }\n  \n  onMounted(() => {\n    fetchProfileData()\n  })\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CA+DM,OA/DNC,UA+DM,GA9DJC,mBAAA,CAkCM,OAlCNC,UAkCM,GAjCJC,YAAA,CAOAC,MAAA;IANCC,UAAU,EAAED,MAAA,CAAAE,SAAS;IACrBC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBC,WAAW,EAAEJ,MAAA,CAAAI,WAAW;IACxBC,mBAAmB,EAAEL,MAAA,CAAAK,mBAAmB;IACxCC,MAAI,EAAEN,MAAA,CAAAO,UAAU;IAChBC,iBAAe,EAAER,MAAA,CAAAS;4FAGlBV,YAAA,CAOEC,MAAA;IANC,iBAAe,EAAEA,MAAA,CAAAU,cAAc;IAC/B,cAAY,EAAEV,MAAA,CAAAW,WAAW;IACzBR,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBS,YAAW,EAAEZ,MAAA,CAAAa,gBAAgB;IAC7BC,QAAM,EAAEd,MAAA,CAAAe,YAAY;IACpBC,SAAO,EAAEhB,MAAA,CAAAiB;2EAGZlB,YAAA,CAQEC,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAAkB,aAAa;IAC7Bf,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBG,MAAI,EAAEN,MAAA,CAAAmB,gBAAgB;IACtBC,KAAG,EAAEpB,MAAA,CAAAqB,OAAO;IACZC,QAAM,EAAEtB,MAAA,CAAAuB,YAAY;IACpBC,UAAS,EAAExB,MAAA,CAAAyB,QAAQ;IACnBC,YAAW,EAAE1B,MAAA,CAAA2B;+EAGhB5B,YAAA,CAIEC,MAAA;IAHC,kBAAgB,EAAEA,MAAA,CAAA4B,eAAe;IACjCzB,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChB0B,UAAQ,EAAE7B,MAAA,CAAA8B;4EAIfC,mBAAA,cAAiB,EAET/B,MAAA,CAAAgC,aAAa,EAAEC,IAAI,0B,cAD3BC,YAAA,CAMElC,MAAA;IA9CRmC,GAAA;IAAAC,UAAA,EA0CiBpC,MAAA,CAAAqC,aAAa;IA1C9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA0CiBvC,MAAA,CAAAqC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEvC,MAAA,CAAAwC,YAAY;IAC1BrC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBsC,QAAM,EAAEzC,MAAA,CAAA0C;wEA7CjBX,mBAAA,gBAgDMA,mBAAA,cAAiB,EAET/B,MAAA,CAAAgC,aAAa,EAAEC,IAAI,wB,cAD3BC,YAAA,CAMElC,MAAA;IAvDRmC,GAAA;IAAAC,UAAA,EAmDiBpC,MAAA,CAAAqC,aAAa;IAnD9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAmDiBvC,MAAA,CAAAqC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEvC,MAAA,CAAAwC,YAAY;IAC1BrC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBsC,QAAM,EAAEzC,MAAA,CAAA0C;wEAtDjBX,mBAAA,gBAyDMA,mBAAA,gBAAmB,EAEX/B,MAAA,CAAAgC,aAAa,EAAEC,IAAI,qB,cAD3BC,YAAA,CAMElC,MAAA;IAhERmC,GAAA;IAAAC,UAAA,EA4DiBpC,MAAA,CAAAqC,aAAa;IA5D9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA4DiBvC,MAAA,CAAAqC,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEvC,MAAA,CAAAwC,YAAY;IAC1BrC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBsC,QAAM,EAAEzC,MAA