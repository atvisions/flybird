{"ast":null,"code":"import { Edit, Delete, Plus } from '@element-plus/icons-vue';\nimport JobIntentionContent from './JobIntentionContent.vue';\nimport WorkExperienceContent from './WorkExperienceContent.vue';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['edit', 'remove'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 添加错误处理\n    const handleError = error => {\n      console.error('WorkExperienceContent error:', error);\n    };\n    const __returned__ = {\n      handleError,\n      get Edit() {\n        return Edit;\n      },\n      get Delete() {\n        return Delete;\n      },\n      get Plus() {\n        return Plus;\n      },\n      JobIntentionContent,\n      WorkExperienceContent\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["Edit","Delete","Plus","JobIntentionContent","WorkExperienceContent","handleError","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"module in activeModules\" :key=\"module.id\" class=\"bg-white rounded-lg shadow\">\n      <!-- 模块头部 -->\n      <div class=\"flex items-center justify-between px-4 py-3 border-b\">\n        <div class=\"flex items-center space-x-2\">\n          <component :is=\"module.icon\" class=\"w-5 h-5 text-gray-500\" />\n          <h3 class=\"text-base font-medium\">{{ module.name }}</h3>\n        </div>\n        <div class=\"flex items-center space-x-2\">\n          <!-- 编辑按钮改为添加按钮 -->\n          <el-button\n            v-if=\"module.type === 'work_experience'\"\n            type=\"primary\"\n            link\n            :icon=\"Plus\"\n            @click=\"$emit('edit', module.id)\"\n          >\n            添加\n          </el-button>\n          <!-- 其他模块保持编辑按钮 -->\n          <el-button\n            v-else\n            type=\"primary\"\n            link\n            :icon=\"Edit\"\n            @click=\"$emit('edit', module.id, module.data)\"\n          >\n            编辑\n          </el-button>\n          <!-- 移除按钮 -->\n          <el-button\n            type=\"danger\"\n            link\n            :icon=\"Delete\"\n            @click=\"$emit('remove', module.id)\"\n          >\n            移除\n          </el-button>\n        </div>\n      </div>\n\n      <!-- 模块内容 -->\n      <div class=\"p-4\">\n        <!-- 求职意向内容 -->\n        <JobIntentionContent\n          v-if=\"module.type === 'job_intention'\"\n          :data=\"module.data\"\n        />\n        <!-- 工作经历内容 -->\n        <WorkExperienceContent \n          v-else-if=\"module.type === 'work_experience'\"\n          :data=\"module.data\"\n          @edit=\"item => $emit('edit-item', module.id, item)\"\n          @remove=\"id => $emit('remove-item', module.id, id)\"\n        />\n        <!-- 其他模块的默认内容 -->\n        <slot v-else :name=\"module.id\" :data=\"module.data\">\n          <div v-if=\"module.data\" class=\"text-gray-600\">\n            {{ JSON.stringify(module.data) }}\n          </div>\n          <div v-else class=\"text-gray-400 text-center py-4\">\n            暂无内容，点击编辑添加\n          </div>\n        </slot>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { Edit, Delete, Plus } from '@element-plus/icons-vue'\nimport JobIntentionContent from './JobIntentionContent.vue'\nimport WorkExperienceContent from './WorkExperienceContent.vue'\n\ndefineProps({\n  activeModules: {\n    type: Array,\n    required: true\n  },\n  loading: Boolean\n})\n\ndefineEmits(['edit', 'remove'])\n\n// 添加错误处理\nconst handleError = (error) => {\n  console.error('WorkExperienceContent error:', error)\n}\n</script>\n\n<style scoped>\n.module-header {\n  @apply flex items-center justify-between px-4 py-3 border-b;\n}\n\n.module-title {\n  @apply flex items-center space-x-2;\n}\n\n.module-actions {\n  @apply flex items-center space-x-2;\n}\n\n.module-content {\n  @apply p-4;\n}\n\n.empty-content {\n  @apply text-gray-400 text-center py-4;\n}\n</style>"],"mappings":"AAwEA,SAASA,IAAI,EAAEC,MAAM,EAAEC,IAAI,QAAQ,yBAAwB;AAC3D,OAAOC,mBAAmB,MAAM,2BAA0B;AAC1D,OAAOC,qBAAqB,MAAM,6BAA4B;;;;;;;;;;;;;;;;IAY9D;IACA,MAAMC,WAAW,GAAIC,KAAK,IAAK;MAC7BC,OAAO,CAACD,KAAK,CAAC,8BAA8B,EAAEA,KAAK;IACrD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}