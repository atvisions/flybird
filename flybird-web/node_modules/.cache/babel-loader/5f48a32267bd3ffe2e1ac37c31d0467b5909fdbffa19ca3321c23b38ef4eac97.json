{"ast":null,"code":"export default {\n  __name: 'EducationContent',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // ... script 部分保持不变\n\n    const __returned__ = {};\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":[],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/EducationContent.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/EducationContent.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <!-- 教育经历列表 -->\n    <div v-for=\"item in data\" :key=\"item.id\" class=\"relative\">\n      <!-- 时间线装饰 -->\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n      <div v-if=\"!isLast(item)\" class=\"absolute left-[0.5625rem] -translate-x-1/2 top-5 bottom-0 w-0.5 bg-gray-200\"></div>\n\n      <!-- 内容区域 -->\n      <div class=\"relative pl-12\">\n        <!-- 内容卡片 -->\n        <div class=\"p-4 bg-white border border-gray-200 rounded-lg group hover:border-gray-300 hover:shadow-sm transition-all\">\n          <div class=\"flex items-center justify-between\">\n            <div>\n              <h4 class=\"text-base font-medium text-gray-900\">{{ item.school }}</h4>\n              <p class=\"text-sm text-gray-500\">{{ item.major }} · {{ getDegreeLabel(item.degree) }}</p>\n            </div>\n            <div class=\"flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity\">\n              <button\n                @click=\"$emit('edit', item)\"\n                class=\"p-1 hover:bg-gray-100 rounded-full\"\n              >\n                <PencilSquareIcon class=\"w-5 h-5 text-gray-400\" />\n              </button>\n              <button\n                @click=\"$emit('delete', item.id)\"\n                class=\"p-1 hover:bg-gray-100 rounded-full\"\n              >\n                <TrashIcon class=\"w-5 h-5 text-gray-400\" />\n              </button>\n            </div>\n          </div>\n\n          <!-- 时间段 -->\n          <div class=\"mt-2 flex items-center text-sm text-gray-500\">\n            <CalendarIcon class=\"w-4 h-4 mr-1.5\" />\n            {{ formatDate(item.start_date) }} - {{ item.is_current ? '至今' : formatDate(item.end_date) }}\n          </div>\n\n          <!-- 在校经历 -->\n          <div v-if=\"item.description\" class=\"mt-3 text-sm text-gray-600\">\n            <p class=\"whitespace-pre-line\">{{ item.description }}</p>\n          </div>\n\n          <!-- 在校成就 -->\n          <div v-if=\"item.achievements\" class=\"mt-3 text-sm text-gray-600\">\n            <div class=\"text-sm font-medium text-gray-700 mb-1\">在校成就</div>\n            <p class=\"whitespace-pre-line\">{{ item.achievements }}</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 添加按钮 -->\n    <div class=\"relative pl-12\">\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n      <button\n        @click=\"$emit('add')\"\n        class=\"w-full flex items-center justify-center px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors\"\n      >\n        <PlusIcon class=\"w-4 h-4 mr-2\" />\n        添加教育经历\n      </button>\n    </div>\n  </div>\n</template>\n\n<script setup>\n// ... script 部分保持不变\n</script>\n\n<style scoped>\n/* 卡片悬停效果 */\n.group:hover {\n  @apply bg-white;\n}\n\n/* 时间线样式 */\n.border-blue-500 {\n  @apply border-blue-600;\n}\n\n/* 按钮过渡效果 */\n.transition-all {\n  @apply duration-200;\n}\n\n/* 卡片阴影效果 */\n.shadow-sm {\n  @apply shadow-[0_1px_2px_0_rgba(0,0,0,0.05)];\n}\n</style>"],"mappings":";;;;;;;IAqEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}