{"ast":null,"code":"import { createCommentVNode as _createCommentVNode, createVNode as _createVNode, createElementVNode as _createElementVNode, openBlock as _openBlock, createBlock as _createBlock, Fragment as _Fragment, createElementBlock as _createElementBlock } from \"vue\";\nconst _hoisted_1 = {\n  class: \"container mx-auto\"\n};\nconst _hoisted_2 = {\n  class: \"max-w-4xl mx-auto space-y-4\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createElementVNode(\"div\", _hoisted_2, [_createCommentVNode(\" 基本信息卡片 \"), _createVNode($setup[\"BasicInfo\"], {\n    resumeData: $setup.profileData.resumeData.value || {},\n    loading: $setup.loading,\n    bioExpanded: $setup.profileData.bioExpanded.value,\n    showBioExpandButton: $setup.profileData.showBioExpandButton.value,\n    getBioText: $setup.getBioText,\n    onSave: $setup.handleSave,\n    onToggleBioExpand: $setup.toggleBioExpand,\n    onEdit: $setup.handleEdit\n  }, null, 8 /* PROPS */, [\"resumeData\", \"loading\", \"bioExpanded\", \"showBioExpandButton\", \"getBioText\"]), _createCommentVNode(\" 简历状态卡片 \"), _createVNode($setup[\"ResumeStatus\"], {\n    \"completion-data\": $setup.completionData,\n    loading: $setup.loading,\n    onAiOptimize: $setup.handleAIOptimize,\n    onImport: $setup.importResume,\n    onPreview: $setup.previewResume\n  }, null, 8 /* PROPS */, [\"completion-data\", \"loading\"]), _createCommentVNode(\" 常规模块列表 \"), _createVNode($setup[\"ModuleList\"], {\n    \"active-modules\": $setup.activeModules,\n    loading: $setup.loading,\n    onEdit: $setup.handleEditModule,\n    onAdd: $setup.addItem,\n    onRemove: $setup.removeModule,\n    onEditItem: $setup.editItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onAdd\", \"onRemove\"]), _createCommentVNode(\" 添加更多模块 \"), _createVNode($setup[\"AddModule\"], {\n    \"inactive-modules\": $setup.inactiveModules,\n    loading: $setup.loading,\n    onActivate: $setup.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"])]), _createCommentVNode(\" 弹窗组件 \"), _createVNode($setup[\"EditBasicDialog\"], {\n    modelValue: $setup.showEditBasicDialog,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditBasicDialog = $event),\n    \"initial-data\": $setup.basicFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleBasicSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"]), _createCommentVNode(\" 编辑求职意向对话框 \"), $setup.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock($setup[\"EditJobIntentionDialog\"], {\n    key: 0,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : $setup.currentModule?.type === 'work_experience' ? (_openBlock(), _createElementBlock(_Fragment, {\n    key: 1\n  }, [_createCommentVNode(\" 工作经历编辑弹窗 \"), _createVNode($setup[\"EditWorkExperienceDialog\"], {\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])], 2112 /* STABLE_FRAGMENT, DEV_ROOT_FRAGMENT */)) : (_openBlock(), _createElementBlock(_Fragment, {\n    key: 2\n  }, [_createCommentVNode(\" 其他模块的编辑对话框 \"), _createVNode($setup[\"EditDialog\"], {\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showEditModal = $event),\n    module: $setup.currentModule,\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit,\n    onCancel: $setup.handleCancel\n  }, null, 8 /* PROPS */, [\"modelValue\", \"module\", \"initial-data\", \"loading\"])], 2112 /* STABLE_FRAGMENT, DEV_ROOT_FRAGMENT */)), _createVNode($setup[\"CreationDialog\"], {\n    modelValue: $setup.showCreationModal,\n    \"onUpdate:modelValue\": _cache[4] || (_cache[4] = $event => $setup.showCreationModal = $event),\n    \"selected-ids\": $setup.selectedCreationIds,\n    loading: $setup.loading,\n    onSubmit: $setup.handleCreationsSelected,\n    onCancel: $setup.closeCreationModal\n  }, null, 8 /* PROPS */, [\"modelValue\", \"selected-ids\", \"loading\", \"onCancel\"]), _createCommentVNode(\" AI 优化弹窗 \"), _createVNode($setup[\"AIDialog\"], {\n    modelValue: $setup.showAIDialog,\n    \"onUpdate:modelValue\": _cache[5] || (_cache[5] = $event => $setup.showAIDialog = $event),\n    \"total-score\": $setup.completionData.total_score,\n    suggestions: $setup.completionData.suggestions,\n    \"remaining-optimizations\": $setup.remainingOptimizations,\n    \"total-optimizations\": $setup.totalOptimizations,\n    loading: $setup.optimizationLoading,\n    \"optimization-result\": $setup.optimizationResult,\n    onStartOptimize: $setup.startAIOptimize,\n    onConfirm: $setup.confirmOptimization,\n    onCancel: $setup.cancelOptimization\n  }, null, 8 /* PROPS */, [\"modelValue\", \"total-score\", \"suggestions\", \"remaining-optimizations\", \"total-optimizations\", \"loading\", \"optimization-result\"])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createCommentVNode","_createVNode","$setup","resumeData","profileData","value","loading","bioExpanded","showBioExpandButton","getBioText","onSave","handleSave","onToggleBioExpand","toggleBioExpand","onEdit","handleEdit","completionData","onAiOptimize","handleAIOptimize","onImport","importResume","onPreview","previewResume","activeModules","handleEditModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","inactiveModules","onActivate","activateModule","modelValue","showEditBasicDialog","_cache","$event","basicFormData","onSubmit","handleBasicSubmit","currentModule","type","_createBlock","key","showEditModal","editFormData","handleSubmit","_Fragment","module","onCancel","handleCancel","showCreationModal","selectedCreationIds","handleCreationsSelected","closeCreationModal","showAIDialog","total_score","suggestions","remainingOptimizations","totalOptimizations","optimizationLoading","optimizationResult","onStartOptimize","startAIOptimize","onConfirm","confirmOptimization","cancelOptimization"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <!-- 基本信息卡片 -->\n        <BasicInfo\n        :resumeData=\"profileData.resumeData.value || {}\"\n        :loading=\"loading\"\n        :bioExpanded=\"profileData.bioExpanded.value\"\n        :showBioExpandButton=\"profileData.showBioExpandButton.value\"\n        :getBioText=\"getBioText\"\n        @save=\"handleSave\"\n        @toggleBioExpand=\"toggleBioExpand\"\n        @edit=\"handleEdit\"\n      />\n  \n        <!-- 简历状态卡片 -->\n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :loading=\"loading\"\n          @ai-optimize=\"handleAIOptimize\"\n          @import=\"importResume\"\n          @preview=\"previewResume\"\n        />\n  \n        <!-- 常规模块列表 -->\n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"handleEditModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n        />\n  \n        <!-- 添加更多模块 -->\n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 弹窗组件 -->\n      <EditBasicDialog\n        v-model=\"showEditBasicDialog\"\n        :initial-data=\"basicFormData\"\n        :loading=\"loading\"\n        @submit=\"handleBasicSubmit\"\n      />\n  \n      <!-- 编辑求职意向对话框 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n      \n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-else-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n  \n      <!-- 其他模块的编辑对话框 -->\n      <EditDialog\n        v-else\n        v-model=\"showEditModal\"\n        :module=\"currentModule\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n        @cancel=\"handleCancel\"\n      />\n  \n      <CreationDialog\n        v-model=\"showCreationModal\"\n        :selected-ids=\"selectedCreationIds\"\n        :loading=\"loading\"\n        @submit=\"handleCreationsSelected\"\n        @cancel=\"closeCreationModal\"\n      />\n  \n      <!-- AI 优化弹窗 -->\n      <AIDialog\n        v-model=\"showAIDialog\"\n        :total-score=\"completionData.total_score\"\n        :suggestions=\"completionData.suggestions\"\n        :remaining-optimizations=\"remainingOptimizations\"\n        :total-optimizations=\"totalOptimizations\"\n        :loading=\"optimizationLoading\"\n        :optimization-result=\"optimizationResult\"\n        @start-optimize=\"startAIOptimize\"\n        @confirm=\"confirmOptimization\"\n        @cancel=\"cancelOptimization\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted, computed, watch, onBeforeUnmount } from 'vue'\n  import { ElMessage } from 'element-plus'\n  import store from '@/store'\n  import { profile } from '@/api/profile'\n  \n  // 组件导入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditDialog from './dialogs/EditDialog.vue'\n  import AIDialog from './dialogs/AIDialog.vue'\n  import CreationDialog from './dialogs/CreationDialog.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  import EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\n  import EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\n \n  // Composables\n  import { useProfileData } from './composables/useProfileData'\n  import { useModules } from './composables/useModules'\n  import { useDialog } from './composables/useDialog'\n  import { useLoading } from './composables/useLoading'\n \n  // 初始化 profileData\n  const profileData = useProfileData()\n  const loading = ref(false)\n  const editFormData = ref({})\n  \n  // 添加调试日志\n  console.log('MyProfile profileData:', profileData)\n  \n  // 计算属性：获取处理后的个人简介文本\n  const getBioText = computed(() => {\n    if (!profileData.resumeData.value) return ''\n    return profileData.getBioText()\n  })\n  \n  // 处理保存\n  const handleSave = async (formData) => {\n    console.log('Handling save:', formData)\n    const success = await profileData.updateResumeData(formData)\n    if (success) {\n      await profileData.fetchInitialData()\n    }\n    return success\n  }\n  \n  // 处理展开/收起\n  const toggleBioExpand = () => {\n    console.log('Toggling bio expand')\n    profileData.toggleBioExpand()\n  }\n  \n  const {\n    activeModules,\n    inactiveModules,\n    currentModule,\n    editModule,\n    addItem,\n    removeModule,\n    activateModule,\n    fetchLayout,\n    isInitialized\n  } = useModules()\n  \n  const {\n    showEditModal,\n    showAIModal,\n    showCreationModal,\n    aiSuggestions,\n    selectedCreationIds,\n    showAIOptimize,\n    closeCreationModal\n  } = useDialog()\n  \n  const { loading: actionLoading, withLoading } = useLoading()  // 重命名避免冲突\n  \n  // 基本信息编辑状态\n  const showEditBasicDialog = ref(false)\n  const basicFormData = ref({})\n  \n  // 处理编辑按钮点击\n  const handleEdit = () => {\n    if (!profileData.resumeData.value) return\n    basicFormData.value = {\n      name: profileData.resumeData.value.name || '',\n      gender: profileData.resumeData.value.gender || '',\n      phone: profileData.resumeData.value.phone || '',\n      email: profileData.resumeData.value.email || '',\n      location: profileData.resumeData.value.location || '',\n      birth_date: profileData.resumeData.value.birth_date || '',\n      personal_summary: profileData.resumeData.value.personal_summary || ''\n    }\n    console.log('编辑表单数据:', basicFormData.value)\n    showEditBasicDialog.value = true\n  }\n  \n  // 处理基本信息提交\n  const handleBasicSubmit = async (formData) => {\n    if (!formData) return\n\n    loading.value = true\n    try {\n      await profileData.updateResumeData(formData)\n      showEditBasicDialog.value = false\n      ElMessage.success('保存成功')\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 获取完整度数据\n  const fetchCompleteness = async () => {\n    try {\n      console.log('开始获取完整度数据')\n      const response = await profile.getCompleteness()\n      console.log('完整度接口响应:', response)\n      \n      if (response.data?.data) {\n        console.log('更新前的完整度数据:', completionData.value)\n        completionData.value = response.data.data\n        console.log('更新后的完整度数据:', completionData.value)\n      } else {\n        console.warn('完整度数据格式不正确:', response)\n      }\n    } catch (error) {\n      console.error('获取简历完整度失败:', error)\n    }\n  }\n  \n  // 监听完整度数据变化\n  watch(() => completionData.value, (newVal) => {\n    console.log('完整度数据变化:', newVal)\n  }, { deep: true })\n  \n  // AI优化次数\n  const remainingOptimizations = ref(3) // 默认每月3次\n  const totalOptimizations = ref(3)\n  \n  // 获取优化次数\n  const fetchOptimizationCount = async () => {\n    try {\n      const response = await profile.getOptimizationCount()\n      if (response.data?.data) {\n        remainingOptimizations.value = response.data.data.remaining\n        totalOptimizations.value = response.data.data.total\n      }\n    } catch (error) {\n      console.error('获取优化次数失败:', error)\n    }\n  }\n  \n  // 生命周期钩子\n  onMounted(async () => {\n    console.log('MyProfile mounted')\n    loading.value = true\n    try {\n      // 确保布局先初始化\n      await fetchLayout()\n      \n      // 并行请求其他数据\n      await Promise.all([\n        profileData.fetchInitialData(),\n        fetchCompleteness(),\n        fetchOptimizationCount(),\n        fetchJobIntention()\n      ])\n    } catch (error) {\n      console.error('初始化数据失败:', error)\n      ElMessage.error('加载数据失败，请刷新页面重试')\n    } finally {\n      loading.value = false\n    }\n  })\n  \n  // 监听数据变化，当基本信息更新时重新获取完整度\n  watch(() => profileData.resumeData.value, async () => {\n    try {\n      await fetchCompleteness()\n    } catch (error) {\n      console.error('更新完整度失败:', error)\n    }\n  }, { deep: true })\n  \n  // 处理编辑模块\n  const handleEditModule = (moduleId, data = null) => {\n    console.log('编辑模块:', moduleId, '数据:', data)\n    const module = editModule(moduleId)\n    if (!module) return\n\n    currentModule.value = module\n    showEditModal.value = true\n\n    // 如果是工作经历模块，确保使用正确的字段名\n    if (module.type === 'work_experience') {\n      editFormData.value = {\n        ...data,\n        description: data?.description || '',  // 确保使用 description 字段\n      }\n      console.log('工作经历编辑数据:', editFormData.value)\n    } else {\n      editFormData.value = { ...data } || {}\n    }\n  }\n  \n  // 处理表单提交\n  const handleSubmit = async (formData) => {\n    try {\n      await withLoading(async () => {\n        if (currentModule.value?.type === 'work_experience') {\n          console.log('当前模块:', currentModule.value)\n          console.log('编辑表单数据:', editFormData.value)\n          console.log('提交的表单数据:', formData)\n          const response = await profile.updateWorkExperience(formData)\n          console.log('工作经历保存响应:', response)\n          \n          if (response.data?.code === 200) {\n            const moduleIndex = activeModules.value.findIndex(m => m.id === currentModule.value.id)\n            if (moduleIndex > -1) {\n              activeModules.value[moduleIndex].data = response.data.data\n            }\n            await fetchCompleteness()\n            ElMessage.success('保存成功')\n            showEditModal.value = false\n          } else {\n            throw new Error(response.data?.message || '保存失败')\n          }\n        } else if (currentModule.value?.type === 'job_intention') {\n          // 求职意向的处理\n          const response = await profile.updateJobIntention(formData)\n          if (response.data?.code === 200) {\n            const moduleIndex = activeModules.value.findIndex(m => m.id === currentModule.value.id)\n            if (moduleIndex > -1) {\n              activeModules.value[moduleIndex].data = response.data.data\n            }\n            await fetchCompleteness()\n            ElMessage.success('保存成功')\n            showEditModal.value = false\n          }\n        } else {\n          // 其他模块的处理\n          await profileData.updateResumeData(formData)\n          showEditModal.value = false\n        }\n      })\n    } catch (error) {\n      console.error('保存失败:', error)\n      // 显示更详细的错误信息\n      if (error.response?.data?.message) {\n        ElMessage.error(`保存失败: ${error.response.data.message}`)\n      } else if (error.response?.data?.errors) {\n        const errors = Object.entries(error.response.data.errors)\n          .map(([field, msgs]) => `${field}: ${msgs.join(', ')}`)\n          .join('\\n')\n        ElMessage.error(`数据验证失败:\\n${errors}`)\n      } else {\n        ElMessage.error(error.message || '保存失败，请稍后重试')\n      }\n    }\n  }\n  \n  const handleCancel = () => {\n    showEditModal.value = false\n  }\n  \n  \n  const importResume = async () => {\n    try {\n      await withLoading(async () => {\n        // TODO: 实现导入功能\n        ElMessage.info('功能开发中')\n      })\n    } catch (error) {\n      console.error('导入失败:', error)\n      ElMessage.error('导入失败，请稍后重试')\n    }\n  }\n  \n  const previewResume = () => {\n    // TODO: 实现预览功能\n    ElMessage.info('功能开发中')\n  }\n  // 处理头像更新\n\n  const handleCreationsSelected = async (selectedIds) => {\n    try {\n      await withLoading(async () => {\n        selectedCreationIds.value = selectedIds\n        closeCreationModal()\n        ElMessage.success('作品选择成功')\n      })\n    } catch (error) {\n      console.error('作品选择失败:', error)\n      ElMessage.error('作品选择失败，请稍后重试')\n    }\n  }\n  \n  const editItem = (moduleId, item) => {\n    handleEditModule(moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n  }\n  \n  // 添加调试日志\n  watch(() => profileData.resumeData.value, (newVal) => {\n    console.log('Profile data changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 添加调试日志\n  watch(() => store.getters.getUserInfo, (newVal) => {\n    console.log('Store user info changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 处理组件卸载\n  onBeforeUnmount(() => {\n    // 清理状态\n    showEditBasicDialog.value = false\n    loading.value = false\n  })\n  \n  // AI 优化相关状态\n  const showAIDialog = ref(false)\n  const optimizationResult = ref(null)\n  const optimizationLoading = ref(false)\n  \n  // 处理 AI 优化按钮点击\n  const handleAIOptimize = () => {\n    showAIDialog.value = true\n  }\n  \n  // 开始 AI 优化\n  const startAIOptimize = async () => {\n    try {\n      optimizationLoading.value = true\n      const response = await profile.getOptimizationPreview()\n      if (response.data?.code === 200) {\n        optimizationResult.value = response.data.data\n      } else {\n        throw new Error(response.data?.message || '获取优化预览失败')\n      }\n    } catch (error) {\n      console.error('AI 优化失败:', error)\n      ElMessage.error('AI 优化失败，请稍后重试')\n    } finally {\n      optimizationLoading.value = false\n    }\n  }\n  \n  // 确认应用优化\n  const confirmOptimization = async (optimizationId) => {\n    try {\n      optimizationLoading.value = true\n      const response = await profile.confirmOptimization(optimizationId)\n      if (response.data?.code === 200) {\n        ElMessage.success('优化内容已应用')\n        await Promise.all([\n          profileData.fetchInitialData(),\n          fetchCompleteness()\n        ])\n        showAIDialog.value = false\n      } else {\n        throw new Error(response.data?.message || '确认优化失败')\n      }\n    } catch (error) {\n      console.error('确认优化失败:', error)\n      ElMessage.error('确认优化失败，请重试')\n    } finally {\n      optimizationLoading.value = false\n    }\n  }\n  \n  // 取消优化\n  const cancelOptimization = () => {\n    showAIDialog.value = false\n    ElMessage.info('已取消本次优化')\n  }\n  \n  // 添加状态\n  const showJobIntentionDialog = ref(false)\n  const currentJobIntention = ref(null)\n  \n  // 处理编辑求职意向\n  const handleEditJobIntention = (moduleId) => {\n    const module = activeModules.value.find(m => m.id === moduleId)\n    currentJobIntention.value = module?.data || {}\n    showJobIntentionDialog.value = true\n  }\n  \n  // 处理求职意向提交\n  const handleJobIntentionSubmit = async (formData) => {\n    try {\n      loading.value = true\n      await profileData.updateResumeData(formData)\n      showJobIntentionDialog.value = false\n      ElMessage.success('保存成功')\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 在初始化时获取求职意向数据\n  const fetchJobIntention = async () => {\n    try {\n      const response = await profile.getJobIntention()\n      if (response.data?.code === 200) {\n        const moduleIndex = activeModules.value.findIndex(m => m.id === 'job_intention')\n        if (moduleIndex > -1) {\n          if (response.data.data) {\n            // 有数据时更新\n            const backendData = response.data.data\n            activeModules.value[moduleIndex].data = {\n              job_type: backendData.job_type,\n              expected_salary: backendData.expected_salary,\n              expected_city: backendData.expected_city,\n              job_status: backendData.job_status,\n              industries: backendData.industries,\n              // 保存显示值\n              status_display: backendData.status_display,\n              salary_expectation_display: backendData.salary_expectation_display\n            }\n          } else {\n            // 没有数据时设置为空对象\n            activeModules.value[moduleIndex].data = null\n          }\n        }\n      }\n    } catch (error) {\n      console.error('获取求职意向失败:', error)\n    }\n  }\n  \n  // 辅助函数：解析薪资字符串\n  const parseSalary = (salaryStr) => {\n    if (!salaryStr) return { min: null, max: null }\n    const matches = salaryStr.match(/(\\d+)K-(\\d+)K/) || []\n    if (matches.length === 3) {\n      return { min: parseInt(matches[1]), max: parseInt(matches[2]) }\n    }\n    const aboveMatch = salaryStr.match(/(\\d+)K以上/)\n    if (aboveMatch) {\n      return { min: parseInt(aboveMatch[1]), max: null }\n    }\n    const belowMatch = salaryStr.match(/(\\d+)K以下/)\n    if (belowMatch) {\n      return { min: null, max: parseInt(belowMatch[1]) }\n    }\n    return { min: null, max: null }\n  }\n  \n  // 辅助函数：解析城市字符串\n  const parseCity = (cityStr) => {\n    if (!cityStr) return []\n    return cityStr.split('-').map(city => ({ label: city, value: city }))\n  }\n  \n  // 监听布局变化\n  watch(() => activeModules.value, (newModules) => {\n    console.log('活动模块变化:', newModules)\n  }, { deep: true })