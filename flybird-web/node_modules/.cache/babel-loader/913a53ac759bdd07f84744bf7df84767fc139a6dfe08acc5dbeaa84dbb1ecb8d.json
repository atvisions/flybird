{"ast":null,"code":"import { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage } from 'element-plus';\nimport { LockClosedIcon } from '@heroicons/vue/solid';\nimport { auth } from '@/api/auth';\nimport { SMS_SCENE } from '@/constants';\nexport default {\n  __name: 'RegisterView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(false);\n    const countdown = ref(0);\n\n    // 移除 username，只保留必要的字段\n    const formData = ref({\n      phone: '',\n      code: '',\n      password: '',\n      confirm_password: ''\n    });\n\n    // 获取验证码\n    const handleGetCode = async () => {\n      try {\n        if (!formData.value.phone) {\n          ElMessage.warning('请输入手机号');\n          return;\n        }\n        await auth.sendSmsCode({\n          phone: formData.value.phone,\n          scene: SMS_SCENE.REGISTER\n        });\n        ElMessage.success('验证码已发送');\n        countdown.value = 60;\n        const timer = setInterval(() => {\n          countdown.value--;\n          if (countdown.value <= 0) {\n            clearInterval(timer);\n          }\n        }, 1000);\n      } catch (error) {\n        console.error('获取验证码失败:', error);\n        ElMessage.error(error.message || '获取验证码失败');\n      }\n    };\n\n    // 提交注册\n    const handleSubmit = async () => {\n      try {\n        loading.value = true;\n\n        // 表单验证\n        if (formData.value.password !== formData.value.confirm_password) {\n          ElMessage.error('两次输入的密码不一致');\n          return;\n        }\n        await auth.register({\n          phone: formData.value.phone,\n          code: formData.value.code,\n          password: formData.value.password,\n          confirm_password: formData.value.confirm_password\n        });\n        ElMessage.success('注册成功');\n        router.push('/login');\n      } catch (error) {\n        console.error('注册失败:', error);\n        ElMessage.error(error.message || '注册失败');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      router,\n      loading,\n      countdown,\n      formData,\n      handleGetCode,\n      handleSubmit,\n      ref,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get LockClosedIcon() {\n        return LockClosedIcon;\n      },\n      get auth() {\n        return auth;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","useRouter","ElMessage","LockClosedIcon","auth","SMS_SCENE","router","loading","countdown","formData","phone","code","password","confirm_password","handleGetCode","value","warning","sendSmsCode","scene","REGISTER","success","timer","setInterval","clearInterval","error","console","message","handleSubmit","register","push"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/RegisterView.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8\">\n    <div class=\"max-w-md w-full space-y-8\">\n      <!-- 标题部分保持不变 -->\n      <div class=\"text-center\">\n        <h2 class=\"mt-6 text-3xl font-extrabold text-gray-900\">\n          注册账号\n        </h2>\n      </div>\n\n      <!-- 表单部分 -->\n      <form class=\"mt-8 space-y-6\" @submit.prevent=\"handleSubmit\">\n        <div class=\"rounded-md shadow-sm -space-y-px\">\n          <!-- 移除用户名输入框 -->\n          \n          <!-- 手机号输入 -->\n          <div>\n            <label for=\"phone\" class=\"sr-only\">手机号</label>\n            <input\n              id=\"phone\"\n              v-model=\"formData.phone\"\n              type=\"tel\"\n              required\n              class=\"appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-t-md focus:outline-none focus:ring-primary-500 focus:border-primary-500 focus:z-10 sm:text-sm\"\n              placeholder=\"手机号\"\n            />\n          </div>\n\n          <!-- 验证码输入和获取按钮 -->\n          <div class=\"flex\">\n            <input\n              v-model=\"formData.code\"\n              type=\"text\"\n              required\n              class=\"appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-primary-500 focus:border-primary-500 focus:z-10 sm:text-sm\"\n              placeholder=\"验证码\"\n            />\n            <button\n              type=\"button\"\n              :disabled=\"countdown > 0\"\n              @click=\"handleGetCode\"\n              class=\"ml-2 px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              {{ countdown > 0 ? `${countdown}s` : '获取验证码' }}\n            </button>\n          </div>\n\n          <!-- 密码输入 -->\n          <div>\n            <label for=\"password\" class=\"sr-only\">密码</label>\n            <input\n              id=\"password\"\n              v-model=\"formData.password\"\n              type=\"password\"\n              required\n              class=\"appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-primary-500 focus:border-primary-500 focus:z-10 sm:text-sm\"\n              placeholder=\"密码\"\n            />\n          </div>\n\n          <!-- 确认密码输入 -->\n          <div>\n            <label for=\"confirm_password\" class=\"sr-only\">确认密码</label>\n            <input\n              id=\"confirm_password\"\n              v-model=\"formData.confirm_password\"\n              type=\"password\"\n              required\n              class=\"appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-b-md focus:outline-none focus:ring-primary-500 focus:border-primary-500 focus:z-10 sm:text-sm\"\n              placeholder=\"确认密码\"\n            />\n          </div>\n        </div>\n\n        <!-- 注册按钮 -->\n        <div>\n          <button\n            type=\"submit\"\n            :disabled=\"loading\"\n            class=\"group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n          >\n            <span class=\"absolute left-0 inset-y-0 flex items-center pl-3\">\n              <LockClosedIcon class=\"h-5 w-5 text-primary-500 group-hover:text-primary-400\" aria-hidden=\"true\" />\n            </span>\n            {{ loading ? '注册中...' : '注册' }}\n          </button>\n        </div>\n\n        <!-- 登录链接 -->\n        <div class=\"text-sm text-center\">\n          <router-link to=\"/login\" class=\"font-medium text-primary-600 hover:text-primary-500\">\n            已有账号？立即登录\n          </router-link>\n        </div>\n      </form>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { ElMessage } from 'element-plus'\nimport { LockClosedIcon } from '@heroicons/vue/solid'\nimport { auth } from '@/api/auth'\nimport { SMS_SCENE } from '@/constants'\n\nconst router = useRouter()\nconst loading = ref(false)\nconst countdown = ref(0)\n\n// 移除 username，只保留必要的字段\nconst formData = ref({\n  phone: '',\n  code: '',\n  password: '',\n  confirm_password: ''\n})\n\n// 获取验证码\nconst handleGetCode = async () => {\n  try {\n    if (!formData.value.phone) {\n      ElMessage.warning('请输入手机号')\n      return\n    }\n    \n    await auth.sendSmsCode({\n      phone: formData.value.phone,\n      scene: SMS_SCENE.REGISTER\n    })\n    \n    ElMessage.success('验证码已发送')\n    countdown.value = 60\n    const timer = setInterval(() => {\n      countdown.value--\n      if (countdown.value <= 0) {\n        clearInterval(timer)\n      }\n    }, 1000)\n  } catch (error) {\n    console.error('获取验证码失败:', error)\n    ElMessage.error(error.message || '获取验证码失败')\n  }\n}\n\n// 提交注册\nconst handleSubmit = async () => {\n  try {\n    loading.value = true\n    \n    // 表单验证\n    if (formData.value.password !== formData.value.confirm_password) {\n      ElMessage.error('两次输入的密码不一致')\n      return\n    }\n    \n    await auth.register({\n      phone: formData.value.phone,\n      code: formData.value.code,\n      password: formData.value.password,\n      confirm_password: formData.value.confirm_password\n    })\n    \n    ElMessage.success('注册成功')\n    router.push('/login')\n  } catch (error) {\n    console.error('注册失败:', error)\n    ElMessage.error(error.message || '注册失败')\n  } finally {\n    loading.value = false\n  }\n}\n</script>"],"mappings":"AAoGA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,cAAa;AACvC,SAASC,cAAc,QAAQ,sBAAqB;AACpD,SAASC,IAAI,QAAQ,YAAW;AAChC,SAASC,SAAS,QAAQ,aAAY;;;;;;;IAEtC,MAAMC,MAAM,GAAGL,SAAS,CAAC;IACzB,MAAMM,OAAO,GAAGP,GAAG,CAAC,KAAK;IACzB,MAAMQ,SAAS,GAAGR,GAAG,CAAC,CAAC;;IAEvB;IACA,MAAMS,QAAQ,GAAGT,GAAG,CAAC;MACnBU,KAAK,EAAE,EAAE;MACTC,IAAI,EAAE,EAAE;MACRC,QAAQ,EAAE,EAAE;MACZC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACA,MAAMC,aAAa,GAAG,MAAAA,CAAA,KAAY;MAChC,IAAI;QACF,IAAI,CAACL,QAAQ,CAACM,KAAK,CAACL,KAAK,EAAE;UACzBR,SAAS,CAACc,OAAO,CAAC,QAAQ;UAC1B;QACF;QAEA,MAAMZ,IAAI,CAACa,WAAW,CAAC;UACrBP,KAAK,EAAED,QAAQ,CAACM,KAAK,CAACL,KAAK;UAC3BQ,KAAK,EAAEb,SAAS,CAACc;QACnB,CAAC;QAEDjB,SAAS,CAACkB,OAAO,CAAC,QAAQ;QAC1BZ,SAAS,CAACO,KAAK,GAAG,EAAC;QACnB,MAAMM,KAAK,GAAGC,WAAW,CAAC,MAAM;UAC9Bd,SAAS,CAACO,KAAK,EAAC;UAChB,IAAIP,S