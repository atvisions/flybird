prop=\"position\">\n        <el-input v-model=\"form.position\" placeholder=\"请输入职位名称\" />\n      </el-form-item>\n\n      <!-- 部门 -->\n      <el-form-item label=\"所在部门\" prop=\"department\">\n        <el-input v-model=\"form.department\" placeholder=\"请输入所在部门\" />\n      </el-form-item>\n\n      <!-- 在职时间 -->\n      <el-form-item label=\"在职时间\">\n        <div class=\"flex items-center space-x-4\">\n          <el-form-item prop=\"start_date\" class=\"mb-0 flex-1\">\n            <el-date-picker\n              v-model=\"form.start_date\"\n              type=\"date\"\n              placeholder=\"入职时间\"\n              style=\"width: 100%\"\n            />\n          </el-form-item>\n          \n          <span v-if=\"!form.is_current\">至</span>\n          \n          <el-form-item v-if=\"!form.is_current\" prop=\"end_date\" class=\"mb-0 flex-1\">\n            <el-date-picker\n              v-model=\"form.end_date\"\n              type=\"date\"\n              placeholder=\"离职时间\"\n              style=\"width: 100%\"\n            />\n          </el-form-item>\n        </div>\n        \n        <el-checkbox v-model=\"form.is_current\" class=\"mt-2\">\n          至今\n        </el-checkbox>\n      </el-form-item>\n\n      <!-- 工作描述 -->\n      <el-form-item label=\"工作描述\" prop=\"description\">\n        <el-input\n          v-model=\"form.description\"\n          type=\"textarea\"\n          :rows=\"4\"\n          placeholder=\"请详细描述您的工作职责和内容（至少50字）\"\n        />\n      </el-form-item>\n\n      <!-- 工作成就 -->\n      <el-form-item label=\"工作成就\">\n        <el-input\n          v-model=\"form.achievements\"\n          type=\"textarea\"\n          :rows=\"3\"\n          placeholder=\"请描述您在这份工作中取得的成就\"\n        />\n      </el-form-item>\n\n      <!-- 技术栈 -->\n      <el-form-item label=\"技术栈\">\n        <el-input\n          v-model=\"form.technologies\"\n          type=\"textarea\"\n          :rows=\"2\"\n          placeholder=\"请列出您使用的主要技术栈\"\n        />\n      </el-form-item>\n    </el-form>\n\n    <template #footer>\n      <div class=\"flex justify-end space-x-4\">\n        <el-button @click=\"handleClose\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { XMarkIcon } from '@heroicons/vue/24/outline'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    required: true\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单引用\nconst formRef = ref(null)\n\n// 表单数据\nconst form = ref({\n  id: null,\n  company: '',\n  position: '',\n  department: '',\n  start_date: null,\n  end_date: null,\n  is_current: false,\n  description: '',\n  achievements: '',\n  technologies: ''\n})\n\n// 禁用未来日期\nconst disabledDate = (time) => {\n  return time.getTime() > Date.now()\n}\n\n// 提交表单\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    // 表单验证\n    await formRef.value.validate()\n    \n    // 如果验证通过，构造提交数据\n    const submitData = {\n      ...form.value,\n      start_date: form.value.start_date ? new Date(form.value.start_date).toISOString().split('T')[0] : null,\n      end_date: form.value.is_current ? null : \n        (form.value.end_date ? new Date(form.value.end_date).toISOString().split('T')[0] : null)\n    }\n\n    console.log('提交的表单数据:', submitData)\n    \n    await emit('submit', submitData)\n    handleClose()\n  } catch (error) {\n    console.error('表单验证或提交失败:', error)\n    \n    // 处理表单验证错误\n    if (error.fields) {\n      // Element Plus 表单验证错误\n      const firstField = Object.keys(error.fields)[0]\n      const firstError = error.fields[firstField][0].message\n      ElMessage.error(firstError)\n    } \n    // 处理后端返回的错误\n    else if (error.response?.data?.errors) {\n      const errors = error.response.data.errors\n      const firstError = Object.values(errors)[0]\n      ElMessage.error(Array.isArray(firstError) ? firstError[0] : firstError)\n    } \n    // 其他错误\n    else {\n      ElMessage.error(error.message || '保存失败')\n    }\n  }\n}\n\n// 表单验证规则\nconst rules = {\n  company: [\n    { required: true, message: '请输入公司名称', trigger: 'blur' },\n    { min: 2, message: '公司名称至少2个字符', trigger: 'blur' }\n  ],\n  position: [\n    { required: true, message: '请输入职位名称', trigger: 'blur' },\n    { min: 2, message: '职位名称至少2个字符', trigger: 'blur' }\n  ],\n  start_date: [\n    { required: true, message: '请选择入职时间', trigger: 'change' },\n    { \n      validator: (rule, value, callback) => {\n        if (value && form.value.end_date && value > form.value.end_date) {\n          callback(new Error('入职时间不能晚于离职时间'))\n        } else {\n          callback()\n        }\n      },\n      trigger: 'change'\n    }\n  ],\n  end_date: [\n    { \n      validator: (rule, value, callback) => {\n        if (!form.value.is_current && !value) {\n          callback(new Error('请选择离职时间'))\n        } else if (value && form.value.start_date && value < form.value.start_date) {\n          callback(new Error('离职时间不能早于入职时间'))\n        } else {\n          callback()\n        }\n      },\n      trigger: 'change'\n    }\n  ],\n  description: [\n    { required: true, message: '请输入工作描述', trigger: 'blur' },\n    { min: 50, message: '工作描述至少需要50个字符', trigger: 'blur' }\n  ]\n}\n\n// 初始化表单数据\nconst initForm = () => {\n  form.value = {\n    id: props.initialData.id || null,\n    company: props.initialData.company || '',\n    position: props.initialData.position || '',\n    department: props.initialData.department || '',\n    start_date: props.initialData.start_date ? new Date(props.initialData.start_date) : null,\n    end_date: props.initialData.end_date ? new Date(props.initialData.end_date) : null,\n    is_current: props.initialData.is_current || false,\n 