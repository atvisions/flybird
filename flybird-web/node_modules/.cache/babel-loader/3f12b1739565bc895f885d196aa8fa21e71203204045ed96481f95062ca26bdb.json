{"ast":null,"code":"import { ref, watch } from 'vue';\nimport { PencilSquareIcon, TrashIcon, PlusIcon, ExclamationTriangleIcon } from '@heroicons/vue/24/outline';\nimport { ALL_MODULES } from '@/constants';\nimport JobIntentionContent from './JobIntentionContent.vue';\nimport WorkExperienceContent from './WorkExperienceContent.vue';\nexport default {\n  __name: 'ModuleList',\n  props: {\n    activeModules: {\n      type: Array,\n      required: true\n    },\n    inactiveModules: {\n      type: Array,\n      required: true\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['remove', 'edit', 'edit-item', 'remove-item'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 获取模块显示名称\n    const getModuleName = type => {\n      return ALL_MODULES[type] || type;\n    };\n\n    // 删除确认相关\n    const showDeleteConfirm = ref(false);\n    const moduleToDelete = ref(null);\n\n    // 处理移除按钮点击\n    const handleRemove = moduleType => {\n      console.log('准备移除模块:', moduleType);\n      moduleToDelete.value = moduleType;\n      showDeleteConfirm.value = true;\n    };\n\n    // 确认移除\n    const confirmRemove = () => {\n      if (moduleToDelete.value) {\n        console.log('确认移除模块:', moduleToDelete.value);\n        emit('remove', moduleToDelete.value);\n        showDeleteConfirm.value = false;\n        moduleToDelete.value = null;\n      }\n    };\n\n    // 监听模块变化\n    watch(() => props.activeModules, newModules => {\n      console.log('ModuleList - 活动模块更新:', {\n        active: newModules,\n        inactive: props.inactiveModules,\n        activeCount: newModules.length,\n        inactiveCount: props.inactiveModules?.length\n      });\n    }, {\n      deep: true\n    });\n\n    // 格式化薪资显示\n    const formatSalary = salary => {\n      if (!salary) return '未设置';\n      const [min, max] = salary.split('-');\n      if (min && max) {\n        return `${min}-${max}K/月`;\n      }\n      return `${salary}K/月`;\n    };\n\n    // 获取到岗时间显示\n    const getArrivalTime = time => {\n      const timeMap = {\n        'immediately': '随时到岗',\n        'within_1_week': '1周内',\n        'within_1_month': '1个月内',\n        'within_3_months': '3个月内',\n        'negotiable': '待商议'\n      };\n      return timeMap[time] || '未设置';\n    };\n\n    // 获取工作性质显示\n    const getJobNature = nature => {\n      const natureMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return natureMap[nature] || '未设置';\n    };\n\n    // 获取工作类型显示\n    const getWorkType = type => {\n      const typeMap = {\n        'office': '办公室工作',\n        'remote': '远程工作',\n        'hybrid': '混合办公',\n        'flexible': '灵活办公'\n      };\n      return typeMap[type] || '未设置';\n    };\n\n    // 获取求职状态显示\n    const getJobStatus = status => {\n      const statusMap = {\n        'actively_looking': '积极找工作',\n        'open_to_offers': '考虑机会',\n        'not_looking': '暂不找工作'\n      };\n      return statusMap[status] || '未设置';\n    };\n\n    // 获取求职状态颜色\n    const getJobStatusColor = status => {\n      const colorMap = {\n        'actively_looking': 'bg-green-500',\n        'open_to_offers': 'bg-yellow-500',\n        'not_looking': 'bg-gray-500'\n      };\n      return colorMap[status] || 'bg-gray-300';\n    };\n    const __returned__ = {\n      props,\n      emit,\n      getModuleName,\n      showDeleteConfirm,\n      moduleToDelete,\n      handleRemove,\n      confirmRemove,\n      formatSalary,\n      getArrivalTime,\n      getJobNature,\n      getWorkType,\n      getJobStatus,\n      getJobStatusColor,\n      ref,\n      watch,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      },\n      get ALL_MODULES() {\n        return ALL_MODULES;\n      },\n      JobIntentionContent,\n      WorkExperienceContent\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","PencilSquareIcon","TrashIcon","PlusIcon","ExclamationTriangleIcon","ALL_MODULES","JobIntentionContent","WorkExperienceContent","props","__props","emit","__emit","getModuleName","type","showDeleteConfirm","moduleToDelete","handleRemove","moduleType","console","log","value","confirmRemove","activeModules","newModules","active","inactive","inactiveModules","activeCount","length","inactiveCount","deep","formatSalary","salary","min","max","split","getArrivalTime","time","timeMap","getJobNature","nature","natureMap","getWorkType","typeMap","getJobStatus","status","statusMap","getJobStatusColor","colorMap"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ModuleList.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ModuleList.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"module in activeModules\" :key=\"module.type\" class=\"bg-white rounded-lg shadow\">\n      <div class=\"flex items-center justify-between px-4 py-3\">\n        <h3 class=\"text-base font-medium text-gray-900\">{{ module.name }}</h3>\n        <div class=\"flex items-center space-x-2\">\n          <button\n            @click=\"$emit('edit', module.type)\"\n            class=\"p-1 hover:bg-gray-100 rounded-full\"\n          >\n            <PencilSquareIcon class=\"w-5 h-5 text-gray-400\" />\n          </button>\n          <button\n            @click=\"handleRemove(module.type)\"\n            class=\"p-1 hover:bg-gray-100 rounded-full\"\n          >\n            <TrashIcon class=\"w-5 h-5 text-gray-400\" />\n          </button>\n        </div>\n      </div>\n      \n      <div class=\"px-4 pb-4\">\n        <!-- 求职意向模块 -->\n        <template v-if=\"module.type === 'job_intention' && module.data\">\n          <div class=\"text-gray-600 space-y-3\">\n            <!-- 期望职位和薪资 -->\n            <div class=\"flex items-center justify-between\">\n              <div class=\"flex-1\">\n                <div class=\"text-sm text-gray-500\">期望职位</div>\n                <div class=\"font-medium\">{{ module.data.job_type || '未设置' }}</div>\n              </div>\n              <div class=\"flex-1\">\n                <div class=\"text-sm text-gray-500\">期望薪资</div>\n                <div class=\"font-medium\">\n                  {{ formatSalary(module.data.expected_salary) }}\n                </div>\n              </div>\n            </div>\n\n            <!-- 期望城市和到岗时间 -->\n            <div class=\"flex items-center justify-between\">\n              <div class=\"flex-1\">\n                <div class=\"text-sm text-gray-500\">期望城市</div>\n                <div class=\"font-medium\">{{ module.data.expected_city || '未设置' }}</div>\n              </div>\n              <div class=\"flex-1\">\n                <div class=\"text-sm text-gray-500\">到岗时间</div>\n                <div class=\"font-medium\">\n                  {{ getArrivalTime(module.data.arrival_time) }}\n                </div>\n              </div>\n            </div>\n\n            <!-- 工作性质和工作类型 -->\n            <div class=\"flex items-center justify-between\">\n              <div class=\"flex-1\">\n                <div class=\"text-sm text-gray-500\">工作性质</div>\n                <div class=\"font-medium\">\n                  {{ getJobNature(module.data.job_nature) }}\n                </div>\n              </div>\n              <div class=\"flex-1\">\n                <div class=\"text-sm text-gray-500\">工作类型</div>\n                <div class=\"font-medium\">\n                  {{ getWorkType(module.data.work_type) }}\n                </div>\n              </div>\n            </div>\n\n            <!-- 行业偏好 -->\n            <div v-if=\"module.data.industry_preference\">\n              <div class=\"text-sm text-gray-500\">行业偏好</div>\n              <div class=\"flex flex-wrap gap-2 mt-1\">\n                <span \n                  v-for=\"industry in module.data.industry_preference\" \n                  :key=\"industry\"\n                  class=\"px-2 py-1 text-sm bg-blue-50 text-blue-600 rounded\"\n                >\n                  {{ industry }}\n                </span>\n              </div>\n            </div>\n\n            <!-- 求职状态 -->\n            <div class=\"flex items-center space-x-2\">\n              <div \n                class=\"w-2 h-2 rounded-full\"\n                :class=\"getJobStatusColor(module.data.job_status)\"\n              ></div>\n              <span class=\"text-sm\">\n                {{ getJobStatus(module.data.job_status) }}\n              </span>\n            </div>\n          </div>\n        </template>\n\n        <!-- 工作经历模块 -->\n        <template v-else-if=\"module.type === 'work_experience' && module.data\">\n          <div v-for=\"(exp, index) in module.data\" :key=\"index\" class=\"mb-4 last:mb-0\">\n            <div class=\"font-medium text-gray-900\">{{ exp.company }}</div>\n            <div class=\"text-sm text-gray-500\">\n              {{ exp.start_date }} - {{ exp.end_date || '至今' }}\n            </div>\n            <div class=\"mt-1 text-gray-600\">{{ exp.position }}</div>\n            <div class=\"mt-1 text-gray-600 whitespace-pre-line\">{{ exp.description }}</div>\n          </div>\n        </template>\n\n        <!-- 默认显示 -->\n        <div v-else-if=\"!module.data\" class=\"text-center text-gray-400 py-4\">\n          暂无内容，点击编辑添加\n        </div>\n        <div v-else class=\"text-gray-600\">\n          {{ module.data }}\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 删除确认弹窗 -->\n  <el-dialog\n    v-model=\"showDeleteConfirm\"\n    width=\"400px\"\n    :show-close=\"false\"\n    class=\"delete-confirm-dialog\"\n    destroy-on-close\n  >\n    <div class=\"p-6\">\n      <div class=\"flex items-start space-x-3\">\n        <div class=\"p-2 bg-red-50 rounded-full\">\n          <ExclamationTriangleIcon class=\"w-6 h-6 text-red-600\" />\n        </div>\n        <div class=\"flex-1\">\n          <h3 class=\"text-lg font-medium text-gray-900\">确认移除板块？</h3>\n          <p class=\"mt-2 text-sm text-gray-500\">\n            移除板块后，该板块将移至\"更多模块\"中，您可以随时重新添加。\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"mt-6 flex justify-end space-x-3\">\n        <button\n          @click=\"showDeleteConfirm = false\"\n          class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n        >\n          取消\n        </button>\n        <button\n          @click=\"confirmRemove\"\n          class=\"px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500\"\n        >\n          确认移除\n        </button>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, watch } from 'vue'\nimport { \n  PencilSquareIcon, \n  TrashIcon,\n  PlusIcon,\n  ExclamationTriangleIcon \n} from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\nimport JobIntentionContent from './JobIntentionContent.vue'\nimport WorkExperienceContent from './WorkExperienceContent.vue'\n\nconst props = defineProps({\n  activeModules: {\n    type: Array,\n    required: true\n  },\n  inactiveModules: {\n    type: Array,\n    required: true\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['remove', 'edit', 'edit-item', 'remove-item'])\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n\n// 删除确认相关\nconst showDeleteConfirm = ref(false)\nconst moduleToDelete = ref(null)\n\n// 处理移除按钮点击\nconst handleRemove = (moduleType) => {\n  console.log('准备移除模块:', moduleType)\n  moduleToDelete.value = moduleType\n  showDeleteConfirm.value = true\n}\n\n// 确认移除\nconst confirmRemove = () => {\n  if (moduleToDelete.value) {\n    console.log('确认移除模块:', moduleToDelete.value)\n    emit('remove', moduleToDelete.value)\n    showDeleteConfirm.value = false\n    moduleToDelete.value = null\n  }\n}\n\n// 监听模块变化\nwatch(() => props.activeModules, (newModules) => {\n  console.log('ModuleList - 活动模块更新:', {\n    active: newModules,\n    inactive: props.inactiveModules,\n    activeCount: newModules.length,\n    inactiveCount: props.inactiveModules?.length\n  })\n}, { deep: true })\n\n// 格式化薪资显示\nconst formatSalary = (salary) => {\n  if (!salary) return '未设置'\n  const [min, max] = salary.split('-')\n  if (min && max) {\n    return `${min}-${max}K/月`\n  }\n  return `${salary}K/月`\n}\n\n// 获取到岗时间显示\nconst getArrivalTime = (time) => {\n  const timeMap = {\n    'immediately': '随时到岗',\n    'within_1_week': '1周内',\n    'within_1_month': '1个月内',\n    'within_3_months': '3个月内',\n    'negotiable': '待商议'\n  }\n  return timeMap[time] || '未设置'\n}\n\n// 获取工作性质显示\nconst getJobNature = (nature) => {\n  const natureMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return natureMap[nature] || '未设置'\n}\n\n// 获取工作类型显示\nconst getWorkType = (type) => {\n  const typeMap = {\n    'office': '办公室工作',\n    'remote': '远程工作',\n    'hybrid': '混合办公',\n    'flexible': '灵活办公'\n  }\n  return typeMap[type] || '未设置'\n}\n\n// 获取求职状态显示\nconst getJobStatus = (status) => {\n  const statusMap = {\n    'actively_looking': '积极找工作',\n    'open_to_offers': '考虑机会',\n    'not_looking': '暂不找工作'\n  }\n  return statusMap[status] || '未设置'\n}\n\n// 获取求职状态颜色\nconst getJobStatusColor = (status) => {\n  const colorMap = {\n    'actively_looking': 'bg-green-500',\n    'open_to_offers': 'bg-yellow-500',\n    'not_looking': 'bg-gray-500'\n  }\n  return colorMap[status] || 'bg-gray-300'\n}\n</script>\n\n<style scoped>\n.delete-confirm-dialog :deep(.el-dialog__body) {\n  @apply p-0;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .delete-confirm-dialog {\n    margin: 0 !important;\n  }\n  \n  .p-6 {\n    @apply p-4;\n  }\n}\n</style>"],"mappings":"AAgKA,SAASA,GAAG,EAAEC,KAAK,QAAQ,KAAI;AAC/B,SACEC,gBAAgB,EAChBC,SAAS,EACTC,QAAQ,EACRC,uBAAuB,QAClB,2BAA0B;AACjC,SAASC,WAAW,QAAQ,aAAY;AACxC,OAAOC,mBAAmB,MAAM,2BAA0B;AAC1D,OAAOC,qBAAqB,MAAM,6BAA4B;;;;;;;;;;;;;;;;;;;;;;;IAE9D,MAAMC,KAAK,GAAGC,OAAA;IAed,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,aAAa,GAAIC,IAAI,IAAK;MAC9B,OAAOR,WAAW,CAACQ,IAAI,CAAC,IAAIA,IAAG;IACjC;;IAEA;IACA,MAAMC,iBAAiB,GAAGf,GAAG,CAAC,KAAK;IACnC,MAAMgB,cAAc,GAAGhB,GAAG,CAAC,IAAI;;IAE/B;IACA,MAAMiB,YAAY,GAAIC,UAAU,IAAK;MACnCC,OAAO,CAACC,GAAG,CAAC,SAAS,EAAEF,UAAU;MACjCF,cAAc,CAACK,KAAK,GAAGH,UAAS;MAChCH,iBAAiB,CAACM,KAAK,GAAG,IAAG;IAC/B;;IAEA;IACA,MAAMC,aAAa,GAAGA,CAAA,KAAM;MAC1B,IAAIN,cAAc,CAACK,KAAK,EAAE;QACxBF,OAAO,CAACC,GAAG,CAAC,SAAS,EAAEJ,cAAc,CAACK,KAAK;QAC3CV,IAAI,CAAC,QAAQ,EAAEK,cAAc,CAACK,KAAK;QACnCN,iBAAiB,CAACM,KAAK,GAAG,KAAI;QAC9BL,cAAc,CAACK,KAAK,GAAG,IAAG;MAC5B;IACF;;IAEA;IACApB,KAAK,CAAC,MAAMQ,KAAK,CAACc,aAAa,EAAGC,UAAU,IAAK;MAC/CL,OAAO,CAACC,GAAG,CAAC,sBAAsB,EAAE;QAClCK,MAAM,EAAED,UAAU;QAClBE,QAAQ,EAAEjB,KAAK,CAACkB,eAAe;QAC/BC,WAAW,EAAEJ,UAAU,CAACK,MAAM;QAC9BC,aAAa,EAAErB,KAAK,CAACkB,eAAe,EAAEE;MACxC,CAAC;IACH,CAAC,EAAE;MAAEE,IAAI,EAAE;IAAK,CAAC;;IAEjB;IACA,MAAMC,YAAY,GAAIC,MAAM,IAAK;MAC/B,IAAI,CAACA,MAAM,EAAE,OAAO,KAAI;MACxB,MAAM,CAACC,GAAG,EAAEC,GAAG,CAAC,GAAGF,MAAM,CAACG,KAAK,CAAC,GAAG;MACnC,IAAIF,GAAG,IAAIC,GAAG,EAAE;QACd,OAAO,GAAGD,GAAG,IAAIC,GAAG,KAAI;MAC1B;MACA,OAAO,GAAGF,MAAM,KAAI;IACtB;;IAEA;IACA,MAAMI,cAAc,GAAIC,IAAI,IAAK;MAC/B,MAAMC,OAAO,GAAG;QACd,aAAa,EAAE,MAAM;QACrB,eAAe,EAAE,KAAK;QACtB,gBAAgB,EAAE,MAAM;QACxB,iBAAiB,EAAE,MAAM;QACzB,YAAY,EAAE;MAChB;MACA,OAAOA,OAAO,CAACD,IAAI,CAAC,IAAI,KAAI;IAC9B;;IAEA;IACA,MAAME,YAAY,GAAIC,MAAM,IAAK;MAC/B,MAAMC,SAAS,GAAG;QAChB,WAAW,EAAE,IAAI;QACjB,WAAW,EAAE,IAAI;QACjB,YAAY,EAAE,IAAI;QAClB,WAAW,EAAE;MACf;MACA,OAAOA,SAAS,CAACD,MAAM,CAAC,IAAI,KAAI;IAClC;;IAEA;IACA,MAAME,WAAW,GAAI7B,IAAI,IAAK;MAC5B,MAAM8B,OAAO,GAAG;QACd,QAAQ,EAAE,OAAO;QACjB,QAAQ,EAAE,MAAM;QAChB,QAAQ,EAAE,MAAM;QAChB,UAAU,EAAE;MACd;MACA,OAAOA,OAAO,CAAC9B,IAAI,CAAC,IAAI,KAAI;IAC9B;;IAEA;IACA,MAAM+B,YAAY,GAAIC,MAAM,IAAK;MAC/B,MAAMC,SAAS,GAAG;QAChB,kBAAkB,EAAE,OAAO;QAC3B,gBAAgB,EAAE,MAAM;QACxB,aAAa,EAAE;MACjB;MACA,OAAOA,SAAS,CAACD,MAAM,CAAC,IAAI,KAAI;IAClC;;IAEA;IACA,MAAME,iBAAiB,GAAIF,MAAM,IAAK;MACpC,MAAMG,QAAQ,GAAG;QACf,kBAAkB,EAAE,cAAc;QAClC,gBAAgB,EAAE,eAAe;QACjC,aAAa,EAAE;MACjB;MACA,OAAOA,QAAQ,CAACH,MAAM,CAAC,IAAI,aAAY;IACzC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}