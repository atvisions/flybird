 :value=\"platform.value\"\n                      >\n                        {{ platform.label }}\n                      </option>\n                    </select>\n                  </div>\n\n                  <!-- 链接地址 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      链接地址 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <input\n                      v-model=\"formData.url\"\n                      type=\"url\"\n                      required\n                      class=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                      :placeholder=\"getUrlPlaceholder\"\n                    />\n                  </div>\n\n                  <!-- 描述 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      描述\n                    </label>\n                    <textarea\n                      v-model=\"formData.description\"\n                      rows=\"3\"\n                      class=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                      placeholder=\"简单描述一下这个社交主页\"\n                    />\n                  </div>\n                </div>\n\n                <div class=\"mt-6 flex justify-end space-x-3\">\n                  <button\n                    type=\"button\"\n                    @click=\"$emit('update:modelValue', false)\"\n                    class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50\"\n                  >\n                    取消\n                  </button>\n                  <button\n                    type=\"submit\"\n                    :disabled=\"loading\"\n                    class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                  >\n                    {{ loading ? '保存中...' : '保存' }}\n                  </button>\n                </div>\n              </form>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { ref, watch, computed } from 'vue'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  TransitionRoot,\n  TransitionChild\n} from '@headlessui/vue'\n\n// 与后端对应的平台选项\nconst PLATFORM_CHOICES = [\n  { value: 'weibo', label: '新浪微博' },\n  { value: 'zhihu', label: '知乎' },\n  { value: 'zcool', label: '站酷' },\n  { value: 'douyin', label: '抖音' },\n  { value: 'bilibili', label: 'Bilibili' },\n  { value: 'github', label: 'GitHub' },\n  { value: 'twitter', label: 'Twitter' },\n  { value: 'website', label: '个人网站' },\n  { value: 'other', label: '其他' }\n]\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    required: true\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst formData = ref({\n  platform: '',\n  url: '',\n  description: ''\n})\n\n// 根据平台生成链接地址占位符\nconst getUrlPlaceholder = computed(() => {\n  switch (formData.value.platform) {\n    case 'weibo': return '如：https://weibo.com/username'\n    case 'zhihu': return '如：https://www.zhihu.com/people/username'\n    case 'zcool': return '如：https://www.zcool.com.cn/u/1234567'\n    case 'douyin': return '如：https://www.douyin.com/user/username'\n    case 'bilibili': return '如：https://space.bilibili.com/1234567'\n    case 'github': return '如：https://github.com/username'\n    case 'twitter': return '如：https://twitter.com/username'\n    case 'website': return '如：https://your-website.com'\n    case 'other': return '请输入完整的链接地址'\n    default: return '请先选择平台'\n  }\n})\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newData) => {\n  if (newData) {\n    formData.value = {\n      ...formData.value,\n      ...newData\n    }\n  }\n}, { immediate: true })\n\nconst handleSubmit = () => {\n  emit('submit', {\n    ...formData.value,\n    id: props.initialData?.id\n  })\n}\n</script> "],"mappings":";AA2GA,SAASA,GAAG,EAAEC,KAAK,EAAEC,QAAQ,QAAQ,KAAI;AACzC,SACEC,MAAM,EACNC,WAAW,EACXC,WAAW,EACXC,cAAc,EACdC,eAAc,QACT,iBAAgB;;AAEvB;;;;;;;;;;;;;;;;;;;;;;;;IACA,MAAMC,gBAAgB,GAAG,CACvB;MAAEC,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAO,CAAC,EACjC;MAAED,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAK,CAAC,EAC/B;MAAED,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAK,CAAC,EAC/B;MAAED,KAAK,EAAE,QAAQ;MAAEC,KAAK,EAAE;IAAK,CAAC,EAChC;MAAED,KAAK,EAAE,UAAU;MAAEC,KAAK,EAAE;IAAW,CAAC,EACxC;MAAED,KAAK,EAAE,QAAQ;MAAEC,KAAK,EAAE;IAAS,CAAC,EACpC;MAAED,KAAK,EAAE,SAAS;MAAEC,KAAK,EAAE;IAAU,CAAC,EACtC;MAAED,KAAK,EAAE,SAAS;MAAEC,KAAK,EAAE;IAAO,CAAC,EACnC;MAAED,KAAK,EAAE,OAAO;MAAEC,KAAK,EAAE;IAAK,EAChC;IAEA,MAAMC,KAAK,GAAGC,OAAA;IAed,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,QAAQ,GAAGf,GAAG,CAAC;MACnBgB,QAAQ,EAAE,EAAE;MACZC,GAAG,EAAE,EAAE;MACPC,WAAW,EAAE;IACf,CAAC;;IAED;IACA,MAAMC,iBAAiB,GAAGjB,QAAQ,CAAC,MAAM;MACvC,QAAQa,QAAQ,CAACN,KAAK,CAACO,QAAQ;QAC7B,KAAK,OAAO;UAAE,OAAO,8BAA6B;QAClD,KAAK,OAAO;UAAE,OAAO,yCAAwC;QAC7D,KAAK,OAAO;UAAE,OAAO,sCAAqC;QAC1D,KAAK,QAAQ;UAAE,OAAO,wCAAuC;QAC7D,KAAK,UAAU;UAAE,OAAO,sCAAqC;QAC7D,KAAK,QAAQ;UAAE,OAAO,+BAA8B;QACpD,KAAK,SAAS;UAAE,OAAO,gCAA+B;QACtD,KAAK,SAAS;UAAE,OAAO,4BAA2B;QAClD,KAAK,OAAO;UAAE,OAAO,YAAW;QAChC;UAAS,OAAO,QAAO;MACzB;IACF,CAAC;;IAED;IACAf,KAAK,CAAC,MAAMU,KAAK,CAACS,WAAW,EAAGC,OAAO,IAAK;MAC1C,IAAIA,OAAO,EAAE;QACXN,QAAQ,CAACN,KAAK,GAAAa,aAAA,CAAAA,aAAA,KACTP,QAAQ,CAACN,KAAK,GACdY,OAAM,CACX;MACF;IACF,CAAC,EAAE;MAAEE,SAAS,EAAE;IAAK,CAAC;IAEtB,MAAMC,YAAY,GAAGA,CAAA,KAAM;MACzBX,IAAI,CAAC,QAAQ,EAAAS,aAAA,CAAAA,aAAA,KACRP,QAAQ,CAACN,KAAK;QACjBgB,EAAE,EAAEd,KAAK,CAACS,WAAW,EAAEK;MAAC,EACzB;IACH