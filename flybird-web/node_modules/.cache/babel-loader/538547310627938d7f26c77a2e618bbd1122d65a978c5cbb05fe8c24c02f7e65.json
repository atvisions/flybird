{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { EyeIcon, EyeSlashIcon } from '@heroicons/vue/24/outline';\nimport { auth } from '@/api/auth';\nimport { showToast } from '@/components/ToastMessage';\nexport default {\n  __name: 'ChangePasswordDialog',\n  props: {\n    modelValue: Boolean\n  },\n  emits: ['update:modelValue', 'success'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const currentPassword = ref('');\n    const newPassword = ref('');\n    const confirmPassword = ref('');\n    const loading = ref(false);\n    const showCurrentPassword = ref(false);\n    const showNewPassword = ref(false);\n    const showConfirmPassword = ref(false);\n    const isValid = computed(() => {\n      return currentPassword.value && newPassword.value && confirmPassword.value && newPassword.value === confirmPassword.value && newPassword.value.length >= 6;\n    });\n    const handleUpdate = async () => {\n      if (!isValid.value) return;\n      try {\n        loading.value = true;\n        await auth.changePassword({\n          old_password: currentPassword.value,\n          new_password: newPassword.value,\n          confirm_password: confirmPassword.value\n        });\n        showToast('密码修改成功', 'success');\n        emit('success');\n        handleClose();\n      } catch (error) {\n        showToast(error.response?.data?.message || '密码修改失败', 'error');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const handleClose = () => {\n      currentPassword.value = '';\n      newPassword.value = '';\n      confirmPassword.value = '';\n      showCurrentPassword.value = false;\n      showNewPassword.value = false;\n      showConfirmPassword.value = false;\n      emit('update:modelValue', false);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      currentPassword,\n      newPassword,\n      confirmPassword,\n      loading,\n      showCurrentPassword,\n      showNewPassword,\n      showConfirmPassword,\n      isValid,\n      handleUpdate,\n      handleClose,\n      ref,\n      computed,\n      get EyeIcon() {\n        return EyeIcon;\n      },\n      get EyeSlashIcon() {\n        return EyeSlashIcon;\n      },\n      get auth() {\n        return auth;\n      },\n      get showToast() {\n        return showToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","EyeIcon","EyeSlashIcon","auth","showToast","props","__props","emit","__emit","currentPassword","newPassword","confirmPassword","loading","showCurrentPassword","showNewPassword","showConfirmPassword","isValid","value","length","handleUpdate","changePassword","old_password","new_password","confirm_password","handleClose","error","response","data","message"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/components/dialogs/ChangePasswordDialog.vue"],"sourcesContent":["<template>\n  <div v-if=\"modelValue\" class=\"fixed inset-0 z-50 overflow-y-auto\">\n    <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n      <!-- 背景遮罩 -->\n      <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\"></div>\n      <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\">&#8203;</span>\n      \n      <!-- 弹窗内容 -->\n      <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n        <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n          <div class=\"sm:flex sm:items-start\">\n            <div class=\"mt-3 text-center sm:mt-0 sm:text-left w-full\">\n              <h3 class=\"text-lg leading-6 font-medium text-gray-900\">修改密码</h3>\n              <div class=\"mt-4 space-y-4\">\n                <!-- 当前密码 -->\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700\">当前密码</label>\n                  <div class=\"mt-1 relative\">\n                    <input\n                      :type=\"showCurrentPassword ? 'text' : 'password'\"\n                      v-model=\"currentPassword\"\n                      class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                      placeholder=\"请输入当前密码\"\n                    />\n                    <button\n                      type=\"button\"\n                      @click=\"showCurrentPassword = !showCurrentPassword\"\n                      class=\"absolute inset-y-0 right-0 px-3 flex items-center\"\n                    >\n                      <EyeIcon v-if=\"!showCurrentPassword\" class=\"h-5 w-5 text-gray-400\" />\n                      <EyeSlashIcon v-else class=\"h-5 w-5 text-gray-400\" />\n                    </button>\n                  </div>\n                </div>\n\n                <!-- 新密码 -->\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700\">新密码</label>\n                  <div class=\"mt-1 relative\">\n                    <input\n                      :type=\"showNewPassword ? 'text' : 'password'\"\n                      v-model=\"newPassword\"\n                      class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                      placeholder=\"请输入新密码\"\n                    />\n                    <button\n                      type=\"button\"\n                      @click=\"showNewPassword = !showNewPassword\"\n                      class=\"absolute inset-y-0 right-0 px-3 flex items-center\"\n                    >\n                      <EyeIcon v-if=\"!showNewPassword\" class=\"h-5 w-5 text-gray-400\" />\n                      <EyeSlashIcon v-else class=\"h-5 w-5 text-gray-400\" />\n                    </button>\n                  </div>\n                </div>\n\n                <!-- 确认新密码 -->\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700\">确认新密码</label>\n                  <div class=\"mt-1 relative\">\n                    <input\n                      :type=\"showConfirmPassword ? 'text' : 'password'\"\n                      v-model=\"confirmPassword\"\n                      class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                      placeholder=\"请再次输入新密码\"\n                    />\n                    <button\n                      type=\"button\"\n                      @click=\"showConfirmPassword = !showConfirmPassword\"\n                      class=\"absolute inset-y-0 right-0 px-3 flex items-center\"\n                    >\n                      <EyeIcon v-if=\"!showConfirmPassword\" class=\"h-5 w-5 text-gray-400\" />\n                      <EyeSlashIcon v-else class=\"h-5 w-5 text-gray-400\" />\n                    </button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n          <button\n            type=\"button\"\n            @click=\"handleUpdate\"\n            :disabled=\"!isValid || loading\"\n            class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\"\n          >\n            <span v-if=\"loading\">更新中...</span>\n            <span v-else>确认</span>\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\"\n          >\n            取消\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { EyeIcon, EyeSlashIcon } from '@heroicons/vue/24/outline'\nimport { auth } from '@/api/auth'\nimport { showToast } from '@/components/ToastMessage'\n\nconst props = defineProps({\n  modelValue: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'success'])\n\nconst currentPassword = ref('')\nconst newPassword = ref('')\nconst confirmPassword = ref('')\nconst loading = ref(false)\n\nconst showCurrentPassword = ref(false)\nconst showNewPassword = ref(false)\nconst showConfirmPassword = ref(false)\n\nconst isValid = computed(() => {\n  return currentPassword.value &&\n         newPassword.value &&\n         confirmPassword.value &&\n         newPassword.value === confirmPassword.value &&\n         newPassword.value.length >= 6\n})\n\nconst handleUpdate = async () => {\n  if (!isValid.value) return\n\n  try {\n    loading.value = true\n    await auth.changePassword({\n      old_password: currentPassword.value,\n      new_password: newPassword.value,\n      confirm_password: confirmPassword.value\n    })\n    \n    showToast('密码修改成功', 'success')\n    emit('success')\n    handleClose()\n  } catch (error) {\n    showToast(error.response?.data?.message || '密码修改失败', 'error')\n  } finally {\n    loading.value = false\n  }\n}\n\nconst handleClose = () => {\n  currentPassword.value = ''\n  newPassword.value = ''\n  confirmPassword.value = ''\n  showCurrentPassword.value = false\n  showNewPassword.value = false\n  showConfirmPassword.value = false\n  emit('update:modelValue', false)\n}\n</scrip