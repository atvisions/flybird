{"ast":null,"code":"import { computed, ref, onMounted, onUnmounted, watch } from 'vue';\nimport { SparklesIcon, InformationCircleIcon, ChartBarIcon, CheckCircleIcon, ClockIcon, ArrowTrendingUpIcon, StarIcon, ExclamationTriangleIcon, CheckIcon } from '@heroicons/vue/24/outline';\nimport { useWindowSize } from '@vueuse/core';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'AIDialog',\n  props: {\n    modelValue: Boolean,\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    totalScore: {\n      type: Number,\n      default: 0\n    },\n    remainingOptimizations: {\n      type: Number,\n      required: true\n    },\n    totalOptimizations: {\n      type: Number,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'start-optimize', 'confirm', 'cancel'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const store = useStore();\n    const {\n      width\n    } = useWindowSize();\n\n    // 弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 总分颜色\n    const scoreColorClass = computed(() => {\n      if (props.totalScore >= 80) return 'text-green-600';\n      if (props.totalScore >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n\n    // 建议类型样式\n    const getTypeClass = type => {\n      const classMap = {\n        basic_info: 'bg-blue-50 text-blue-700',\n        work_experience: 'bg-purple-50 text-purple-700',\n        skill: 'bg-green-50 text-green-700',\n        education: 'bg-yellow-50 text-yellow-700',\n        project: 'bg-indigo-50 text-indigo-700',\n        achievement: 'bg-pink-50 text-pink-700'\n      };\n      return classMap[type] || 'bg-gray-50 text-gray-700';\n    };\n\n    // 建议类型名称\n    const getTypeName = type => {\n      const typeMap = {\n        basic_info: '基本信息',\n        work_experience: '工作经历',\n        skill: '技能特长',\n        education: '教育背景',\n        project: '项目经验',\n        achievement: '个人成就'\n      };\n      return typeMap[type] || type;\n    };\n\n    // 按重要性和提升分数排序的建议\n    const sortedSuggestions = computed(() => {\n      const importanceOrder = {\n        high: 3,\n        medium: 2,\n        low: 1\n      };\n      return [...props.suggestions].sort((a, b) => {\n        const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance];\n        if (importanceDiff !== 0) return importanceDiff;\n        return b.score_impact - a.score_impact;\n      });\n    });\n\n    // 是否是VIP会员\n    const isVip = computed(() => store.getters.isVip);\n    const optimizing = ref(false);\n    const optimizingProgress = ref(0);\n    const optimizationResult = ref(null);\n\n    // 开始优化\n    const startOptimize = () => {\n      optimizing.value = true;\n      emit('start-optimize');\n    };\n\n    // 处理确认\n    const handleConfirm = () => {\n      emit('confirm', optimizationResult.value.optimization_id);\n    };\n\n    // 处理取消\n    const handleCancel = () => {\n      optimizationResult.value = null;\n      optimizing.value = false;\n      emit('cancel');\n    };\n\n    // 更新优化进度\n    let progressInterval;\n    onMounted(() => {\n      progressInterval = setInterval(() => {\n        if (optimizing.value && optimizingProgress.value < 95) {\n          optimizingProgress.value += 1;\n        }\n      }, 1000);\n    });\n    onUnmounted(() => {\n      clearInterval(progressInterval);\n    });\n\n    // 监听优化结果\n    watch(() => props.optimizationResult, newVal => {\n      if (newVal) {\n        optimizing.value = false;\n        optimizationResult.value = newVal;\n      }\n    });\n    const __returned__ = {\n      props,\n      emit,\n      store,\n      width,\n      dialogWidth,\n      scoreColorClass,\n      getTypeClass,\n      getTypeName,\n      sortedSuggestions,\n      isVip,\n      optimizing,\n      optimizingProgress,\n      optimizationResult,\n      startOptimize,\n      handleConfirm,\n      handleCancel,\n      get progressInterval() {\n        return progressInterval;\n      },\n      set progressInterval(v) {\n        progressInterval = v;\n      },\n      computed,\n      ref,\n      onMounted,\n      onUnmounted,\n      watch,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get InformationCircleIcon() {\n        return InformationCircleIcon;\n      },\n      get ChartBarIcon() {\n        return ChartBarIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get ArrowTrendingUpIcon() {\n        return ArrowTrendingUpIcon;\n      },\n      get StarIcon() {\n        return StarIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","ref","onMounted","onUnmounted","watch","SparklesIcon","InformationCircleIcon","ChartBarIcon","CheckCircleIcon","ClockIcon","ArrowTrendingUpIcon","StarIcon","ExclamationTriangleIcon","CheckIcon","useWindowSize","useStore","ElMessage","props","__props","emit","__emit","store","width","dialogWidth","value","scoreColorClass","totalScore","getTypeClass","type","classMap","basic_info","work_experience","skill","education","project","achievement","getTypeName","typeMap","sortedSuggestions","importanceOrder","high","medium","low","suggestions","sort","a","b","importanceDiff","importance","score_impact","isVip","getters","optimizing","optimizingProgress","optimizationResult","startOptimize","handleConfirm","optimization_id","handleCancel","progressInterval","setInterval","clearInterval","newVal"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/AIDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"AI 优化建议\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n  >\n    <div class=\"space-y-6\">\n      <!-- 头部信息 -->\n      <div class=\"flex items-center justify-between p-4 bg-gray-50 rounded-lg\">\n        <div class=\"flex items-center space-x-6\">\n          <!-- 评分 -->\n          <div>\n            <div class=\"flex items-baseline\">\n              <span class=\"text-3xl font-bold\" :class=\"scoreColorClass\">{{ totalScore }}</span>\n              <span class=\"ml-1 text-sm text-gray-500\">分</span>\n            </div>\n            <div class=\"text-xs text-gray-500 mt-1\">当前评分</div>\n          </div>\n          <!-- 剩余次数 -->\n          <div>\n            <div class=\"flex items-center space-x-1\">\n              <SparklesIcon class=\"w-4 h-4 text-primary-500\" />\n              <span class=\"font-medium\" :class=\"{'text-red-600': remainingOptimizations === 0}\">\n                {{ remainingOptimizations }}/{{ totalOptimizations }}\n              </span>\n            </div>\n            <div class=\"text-xs text-gray-500 mt-1\">剩余优化次数</div>\n          </div>\n        </div>\n        <!-- VIP提示 -->\n        <div v-if=\"!isVip\" class=\"text-xs text-gray-500\">\n          <router-link to=\"/vip\" class=\"text-primary-600 hover:text-primary-700\">\n            升级会员\n          </router-link>\n          <span class=\"ml-1\">享无限次优化</span>\n        </div>\n      </div>\n\n      <!-- 优化中状态 -->\n      <div v-if=\"optimizing\" class=\"relative\">\n        <div class=\"absolute inset-0 bg-white/80 backdrop-blur-sm flex items-center justify-center z-10\">\n          <div class=\"text-center\">\n            <div class=\"relative w-16 h-16 mx-auto mb-4\">\n              <div class=\"absolute inset-0 bg-gradient-to-r from-primary-500 to-purple-500 rounded-full opacity-20 animate-pulse\"></div>\n              <div class=\"absolute inset-0 border-4 border-primary-500/30 rounded-full animate-spin-slow\"></div>\n              <SparklesIcon class=\"w-16 h-16 text-primary-600 animate-float\" />\n            </div>\n            <p class=\"text-base font-medium text-gray-900\">AI 正在优化您的简历</p>\n            <p class=\"text-sm text-gray-500 mt-2\">预计需要 1-2 分钟</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- 待改进项列表 -->\n      <div class=\"space-y-4\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-base font-medium text-gray-900\">待改进项</h3>\n          <span class=\"text-sm text-gray-500\">按优先级排序</span>\n        </div>\n        <div class=\"space-y-3\">\n          <div \n            v-for=\"(suggestion, index) in sortedSuggestions\" \n            :key=\"index\"\n            class=\"group bg-white rounded-lg p-4 border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all duration-200\"\n          >\n            <div class=\"flex items-start space-x-3\">\n              <!-- 优先级标记 -->\n              <div \n                class=\"flex-shrink-0 w-2 h-2 mt-2 rounded-full transition-colors\"\n                :class=\"{\n                  'bg-red-500 group-hover:animate-pulse': suggestion.importance === 'high',\n                  'bg-yellow-500': suggestion.importance === 'medium',\n                  'bg-blue-500': suggestion.importance === 'low'\n                }\"\n              ></div>\n              <!-- 建议内容 -->\n              <div class=\"flex-1\">\n                <div class=\"flex items-center space-x-2\">\n                  <span class=\"text-xs font-medium px-2 py-0.5 rounded\" \n                    :class=\"getTypeClass(suggestion.type)\">\n                    {{ getTypeName(suggestion.type) }}\n                  </span>\n                  <span class=\"text-sm text-gray-700\">{{ suggestion.message }}</span>\n                </div>\n                <div class=\"flex items-center mt-2 text-xs text-gray-500\">\n                  <ChartBarIcon class=\"w-4 h-4 mr-1\" />\n                  <span>预计提升：</span>\n                  <span class=\"text-primary-600 font-medium ml-1\">+{{ suggestion.score_impact }}分</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 底部按钮 -->\n      <div class=\"flex justify-center pt-4\">\n        <button\n          @click=\"startOptimize\"\n          :disabled=\"loading || remainingOptimizations === 0\"\n          class=\"group relative inline-flex items-center px-8 py-3 text-base font-medium text-white bg-gradient-to-r from-primary-600 to-purple-600 rounded-lg transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed hover:from-primary-700 hover:to-purple-700\"\n        >\n          <SparklesIcon class=\"w-5 h-5 mr-2 animate-pulse\" />\n          <span>{{ loading ? '优化中...' : '开始AI优化' }}</span>\n          <!-- 光效果 -->\n          <div class=\"absolute inset-0 rounded-lg overflow-hidden\">\n            <div class=\"absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000\"></div>\n          </div>\n        </button>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { computed, ref, onMounted, onUnmounted, watch } from 'vue'\nimport { SparklesIcon, InformationCircleIcon, ChartBarIcon, CheckCircleIcon, ClockIcon, ArrowTrendingUpIcon, StarIcon, ExclamationTriangleIcon, CheckIcon } from '@heroicons/vue/24/outline'\nimport { useWindowSize } from '@vueuse/core'\nimport { useStore } from 'vuex'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  suggestions: {\n    type: Array,\n    default: () => []\n  },\n  totalScore: {\n    type: Number,\n    default: 0\n  },\n  remainingOptimizations: {\n    type: Number,\n    required: true\n  },\n  totalOptimizations: {\n    type: Number,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'start-optimize', 'confirm', 'cancel'])\n\nconst store = useStore()\nconst { width } = useWindowSize()\n\n// 弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 总分颜色\nconst scoreColorClass = computed(() => {\n  if (props.totalScore >= 80) return 'text-green-600'\n  if (props.totalScore >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n})\n\n// 建议类型样式\nconst getTypeClass = (type) => {\n  const classMap = {\n    basic_info: 'bg-blue-50 text-blue-700',\n    work_experience: 'bg-purple-50 text-purple-700',\n    skill: 'bg-green-50 text-green-700',\n    education: 'bg-yellow-50 text-yellow-700',\n    project: 'bg-indigo-50 text-indigo-700',\n    achievement: 'bg-pink-50 text-pink-700'\n  }\n  return classMap[type] || 'bg-gray-50 text-gray-700'\n}\n\n// 建议类型名称\nconst getTypeName = (type) => {\n  const typeMap = {\n    basic_info: '基本信息',\n    work_experience: '工作经历',\n    skill: '技能特长',\n    education: '教育背景',\n    project: '项目经验',\n    achievement: '个人成就'\n  }\n  return typeMap[type] || type\n}\n\n// 按重要性和提升分数排序的建议\nconst sortedSuggestions = computed(() => {\n  const importanceOrder = { high: 3, medium: 2, low: 1 }\n  return [...props.suggestions].sort((a, b) => {\n    const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance]\n    if (importanceDiff !== 0) return importanceDiff\n    return b.score_impact - a.score_impact\n  })\n})\n\n// 是否是VIP会员\nconst isVip = computed(() => store.getters.isVip)\n\nconst optimizing = ref(false)\nconst optimizingProgress = ref(0)\nconst optimizationResult = ref(null)\n\n// 开始优化\nconst startOptimize = () => {\n  optimizing.value = true\n  emit('start-optimize')\n}\n\n// 处理确认\nconst handleConfirm = () => {\n  emit('confirm', optimizationResult.value.optimization_id)\n}\n\n// 处理取消\nconst handleCancel = () => {\n  optimizationResult.value = null\n  optimizing.value = false\n  emit('cancel')\n}\n\n// 更新优化进度\nlet progressInterval\nonMounted(() => {\n  progressInterval = setInterval(() => {\n    if (optimizing.value && optimizingProgress.value < 95) {\n      optimizingProgress.value += 1\n    }\n  }, 1000)\n})\n\nonUnmounted(() => {\n  clearInterval(progressInterval)\n})\n\n// 监听优化结果\nwatch(() => props.optimizationResult, (newVal) => {\n  if (newVal) {\n    optimizing.value = false\n    optimizationResult.value = newVal\n  }\n})\n</script>\n\n<style scoped>\n.animate-spin-slow {\n  animation: spin 8s linear infinite;\n}\n\n.animate-float {\n  animation: float 3s ease-in-out infinite;\n}\n\n@keyframes spin {\n  from {\n    transform: rotate(0deg);\n  }\n  to {\n    transform: rotate(360deg);\n  }\n}\n\n@keyframes float {\n  0%, 100% {\n    transform: translateY(0);\n  }\n  50% {\n    transform: translateY(-10px);\n  }\n}\n</style>"],"mappings":"AAsHA,SAASA,QAAQ,EAAEC,GAAG,EAAEC,SAAS,EAAEC,WAAW,EAAEC,KAAK,QAAQ,KAAI;AACjE,SAASC,YAAY,EAAEC,qBAAqB,EAAEC,YAAY,EAAEC,eAAe,EAAEC,SAAS,EAAEC,mBAAmB,EAAEC,QAAQ,EAAEC,uBAAuB,EAAEC,SAAS,QAAQ,2BAA0B;AAC3L,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGC,OAAA;IAqBd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,KAAK,GAAGN,QAAQ,CAAC;IACvB,MAAM;MAAEO;IAAM,CAAC,GAAGR,aAAa,CAAC;;IAEhC;IACA,MAAMS,WAAW,GAAGvB,QAAQ,CAAC,MAAM;MACjC,IAAIsB,KAAK,CAACE,KAAK,GAAG,GAAG,EAAE,OAAO,KAAI;MAClC,IAAIF,KAAK,CAACE,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;;IAED;IACA,MAAMC,eAAe,GAAGzB,QAAQ,C