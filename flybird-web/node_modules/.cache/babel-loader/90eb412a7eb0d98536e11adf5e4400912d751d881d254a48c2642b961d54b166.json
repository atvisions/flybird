  <DialogTitle as=\"h3\" class=\"text-lg font-medium text-gray-900 p-6 pb-0\">\n                {{ initialData?.id ? '编辑社交主页' : '添加社交主页' }}\n              </DialogTitle>\n\n              <form @submit.prevent=\"handleSubmit\" class=\"p-6\">\n                <div class=\"space-y-4\">\n                  <!-- 平台选择 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      平台名称 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <select\n                      v-model=\"formData.platform\"\n                      required\n                      class=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                      @change=\"handlePlatformChange\"\n                    >\n                      <option value=\"\">请选择平台</option>\n                      <option v-for=\"platform in PLATFORM_CHOICES\" \n                        :key=\"platform.value\" \n                        :value=\"platform.value\"\n                      >\n                        {{ platform.label }}\n                      </option>\n                    </select>\n                  </div>\n\n                  <!-- 链接地址 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      链接地址 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <div class=\"flex items-stretch space-x-1\">\n                      <div class=\"bg-gray-100 px-3 py-2 text-gray-500 border border-gray-300 rounded-l-lg overflow-hidden text-ellipsis whitespace-nowrap min-w-0 max-w-[180px]\" title={urlPrefix}>\n                        {{ urlPrefix }}\n                      </div>\n                      <input\n                        v-model=\"urlSuffix\"\n                        type=\"text\"\n                        required\n                        class=\"flex-1 min-w-0 px-3 py-2 border border-gray-300 rounded-r-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                        :placeholder=\"getUrlPlaceholder\"\n                      />\n                    </div>\n                    <!-- 完整链接预览 -->\n                    <div class=\"mt-1 text-xs text-gray-500 truncate\" :title=\"formData.url\">\n                      完整链接：{{ formData.url }}\n                    </div>\n                  </div>\n\n                  <!-- 描述 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      描述\n                    </label>\n                    <textarea\n                      v-model=\"formData.description\"\n                      rows=\"3\"\n                      class=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                      placeholder=\"简单描述一下这个社交主页\"\n                    />\n                  </div>\n                </div>\n\n                <div class=\"mt-6 flex justify-end space-x-3\">\n                  <button\n                    type=\"button\"\n                    @click=\"$emit('update:modelValue', false)\"\n                    class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50\"\n                  >\n                    取消\n                  </button>\n                  <button\n                    type=\"submit\"\n                    :disabled=\"loading\"\n                    class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                  >\n                    {{ loading ? '保存中...' : '保存' }}\n                  </button>\n                </div>\n              </form>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { ref, watch, computed } from 'vue'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  TransitionRoot,\n  TransitionChild\n} from '@headlessui/vue'\nimport { ElMessage } from 'element-plus'\n\n// 平台配置，包含链接前缀\nconst PLATFORM_CHOICES = [\n  { value: 'weibo', label: '新浪微博', prefix: 'https://weibo.com/' },\n  { value: 'zhihu', label: '知乎', prefix: 'https://www.zhihu.com/people/' },\n  { value: 'zcool', label: '站酷', prefix: 'https://www.zcool.com.cn/u/' },\n  { value: 'douyin', label: '抖音', prefix: 'https://www.douyin.com/user/' },\n  { value: 'bilibili', label: 'Bilibili', prefix: 'https://space.bilibili.com/' },\n  { value: 'github', label: 'GitHub', prefix: 'https://github.com/' },\n  { value: 'twitter', label: 'Twitter', prefix: 'https://twitter.com/' },\n  { value: 'website', label: '个人网站', prefix: 'https://' },\n  { value: 'other', label: '其他', prefix: '' }\n]\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    required: true\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\n// 添加调试信息\nconsole.log('EditSocialLinkDialog props:', props)\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst formData = ref({\n  platform: '',\n  url: '',\n  description: ''\n})\n\nconst urlSuffix = ref('')\n\n// 获取当前平台的链接前缀\nconst urlPrefix = computed(() => {\n  const platform = PLATFORM_CHOICES.find(p => p.value === formData.value.platform)\n  return platform?.prefix || 'https://'\n})\n\n// 根据平台生成占位符提示\nconst getUrlPlaceholder = computed(() => {\n  switch (formData.value.platform) {\n    case 'weibo': return 'your-weibo-id'\n    case 'zhihu': return 'your-zhihu-id'\n    case 'zcool': return '1234567'\n    case 'douyin': return 'your-douyin-id'\n    case 'bilibili': return '1234567'\n    case 'github': return 'username'\n    case 'twitter': return 'username'\n    case 'website': return 'your-website.com'\n    case 'other': return '完整的链接地址'\n    default: return 'example.com/your-page'\n  }\n})\n\n// 处理平台选择变化\nconst handlePlatformChange = () => {\n  if (formData.value.platform === 'other') {\n    urlSuffix.value = ''\n  } else if (!formData.value.platform) {\n    // 当取消选择平台时，清空输入\n    urlSuffix.value = ''\n  }\n}\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newData) => {\n  console.log('初始数据变化:', newData)\n  if (newData) {\n    formData.value = { ...newData }\n    // 如果有 URL，需要根据平台拆分出 suffix\n    if (formData.value.url) {\n      const platform = PLATFORM_CHOICES.find(p => p.value === formData.value.platform)\n      if (platform && platform.prefix) {\n        urlSuffix.value = formData.value.url.replace(platform.prefix, '')\n      } else {\n        urlSuffix.value = formData.value.url\n      }\n    }\n  } else {\n    formData.value = {\n      platform: '',\n      url: '',\n      description: ''\n    }\n    urlSuffix.value = ''\n  }\n}, { immediate: true })\n\n// 监听 urlSuffix 变化，自动更新完整 URL\nwatch(urlSuffix, (newValue) => {\n  console.log('URL Suffix 变化:', newValue)\n  if (!newValue) {\n    formData.value.url = ''\n    return\n  }\n\n  if (formData.value.platform === 'other') {\n    formData.value.url = newValue.startsWith('http') ? newValue : `https://${newValue}`\n  } else {\n    if (urlPrefix.value && newValue) {\n      formData.value.url = urlPrefix.value + newValue\n    }\n  }\n\n  console.log('URL更新:', {\n    platform: formData.value.platform,\n    prefix: urlPrefix.value,\n    suffix: newValue,\n    fullUrl: formData.value.url\n  })\n})\n\nconst handleSubmit = () => {\n  console.log('提交前的表单数据:', formData.value)\n\n  // 验证 URL 格式\n  if (!formData.value.url.startsWith('http://') && !formData.value.url.startsWith('https://')) {\n    ElMessage.error('请输入有效的链接地址，必须以 http:// 或 https:// 开头')\n    return\n  }\n\n  // 确保所有必填字段都有值\n  if (!formData.value.platform || !formData.value.url) {\n    ElM