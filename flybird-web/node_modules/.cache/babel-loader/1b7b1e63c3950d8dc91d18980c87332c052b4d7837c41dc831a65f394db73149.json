ate>\n  <div v-if=\"data\" class=\"space-y-3\">\n    <div class=\"grid grid-cols-2 gap-4\">\n      <!-- 工作类型 -->\n      <div class=\"flex items-start\">\n        <div class=\"w-24 flex-shrink-0\">\n          <span class=\"text-sm text-gray-500\">工作类型</span>\n        </div>\n        <div class=\"flex-1\">\n          <span class=\"text-sm text-gray-900\">{{ getJobTypeText(data.job_type) }}</span>\n        </div>\n      </div>\n\n      <!-- 求职状态 -->\n      <div class=\"flex items-start\">\n        <div class=\"w-24 flex-shrink-0\">\n          <span class=\"text-sm text-gray-500\">求职状态</span>\n        </div>\n        <div class=\"flex-1\">\n          <span class=\"text-sm text-gray-900\">{{ getJobStatusText(data.job_status) }}</span>\n        </div>\n      </div>\n\n      <!-- 期望薪资 -->\n      <div class=\"flex items-start\">\n        <div class=\"w-24 flex-shrink-0\">\n          <span class=\"text-sm text-gray-500\">期望薪资</span>\n        </div>\n        <div class=\"flex-1\">\n          <span class=\"text-sm text-gray-900\">{{ data.expected_salary || '未填写' }}</span>\n        </div>\n      </div>\n\n      <!-- 期望城市 -->\n      <div class=\"flex items-start\">\n        <div class=\"w-24 flex-shrink-0\">\n          <span class=\"text-sm text-gray-500\">期望城市</span>\n        </div>\n        <div class=\"flex-1\">\n          <span class=\"text-sm text-gray-900\">{{ formatCity(data.expected_city) }}</span>\n        </div>\n      </div>\n\n      <!-- 期望行业 -->\n      <div class=\"flex items-start col-span-2\">\n        <div class=\"w-24 flex-shrink-0\">\n          <span class=\"text-sm text-gray-500\">期望行业</span>\n        </div>\n        <div class=\"flex-1\">\n          <span class=\"text-sm text-gray-900\">{{ formatIndustries(data.industries) }}</span>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div v-else class=\"text-gray-400 text-center py-4\">\n    暂无内容，点击编辑添加\n  </div>\n</template>\n\n<script setup>\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS } from '../const