{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.find.js\";\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions';\nimport { BriefcaseIcon, UserCircleIcon, CurrencyYenIcon, MapPinIcon, BuildingOfficeIcon, DocumentPlusIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'JobIntentionContent',\n  props: {\n    data: {\n      type: Object,\n      default: null\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 添加调试日志\n    console.log('JobIntentionContent 接收到的数据:', props.data);\n\n    // 获取工作类型标签\n    const getJobTypeLabel = value => {\n      const option = JOB_TYPE_OPTIONS.find(opt => opt.value === value);\n      return option ? option.label : '未设置';\n    };\n\n    // 获取求职状态标签\n    const getJobStatusLabel = value => {\n      const statusMap = {\n        'unemployed_looking': '离职-找工作',\n        'employed_not_looking': '在职-暂不考虑',\n        'employed_looking': '在职-看机会',\n        'student_internship': '在校-找实习',\n        'fresh_graduate': '应届生'\n      };\n      return statusMap[value] || '未设置';\n    };\n\n    // 获取薪资标签\n    const getSalaryLabel = value => {\n      const option = SALARY_OPTIONS.find(opt => opt.value === value);\n      return option ? option.label : '未设置';\n    };\n\n    // 格式化城市\n    const formatCity = city => {\n      if (!city) return '未设置';\n      return city.split('-').join('、');\n    };\n\n    // 格式化行业\n    const formatIndustries = industries => {\n      if (!industries) return '未设置';\n      return industries.split(',').join('、');\n    };\n    const __returned__ = {\n      props,\n      getJobTypeLabel,\n      getJobStatusLabel,\n      getSalaryLabel,\n      formatCity,\n      formatIndustries,\n      get JOB_TYPE_OPTIONS() {\n        return JOB_TYPE_OPTIONS;\n      },\n      get JOB_STATUS_OPTIONS() {\n        return JOB_STATUS_OPTIONS;\n      },\n      get SALARY_OPTIONS() {\n        return SALARY_OPTIONS;\n      },\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get UserCircleIcon() {\n        return UserCircleIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BuildingOfficeIcon() {\n        return BuildingOfficeIcon;\n      },\n      get DocumentPlusIcon() {\n        return DocumentPlusIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["JOB_TYPE_OPTIONS","JOB_STATUS_OPTIONS","SALARY_OPTIONS","BriefcaseIcon","UserCircleIcon","CurrencyYenIcon","MapPinIcon","BuildingOfficeIcon","DocumentPlusIcon","props","__props","console","log","data","getJobTypeLabel","value","option","find","opt","label","getJobStatusLabel","statusMap","getSalaryLabel","formatCity","city","split","join","formatIndustries","industries"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<template>\n  <div class=\"p-4\">\n    <!-- 主要信息 -->\n    <div class=\"grid grid-cols-2 gap-4\">\n      <!-- 工作类型 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-blue-50 rounded-lg\">\n            <BriefcaseIcon class=\"w-5 h-5 text-blue-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">工作类型</span>\n            <div class=\"mt-1 text-gray-900\">{{ getJobTypeLabel(data?.job_type) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 求职状态 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-green-50 rounded-lg\">\n            <UserCircleIcon class=\"w-5 h-5 text-green-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">求职状态</span>\n            <div class=\"mt-1 text-gray-900\">{{ getJobStatusLabel(data?.job_status) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 期望薪资 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-purple-50 rounded-lg\">\n            <CurrencyYenIcon class=\"w-5 h-5 text-purple-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">期望薪资</span>\n            <div class=\"mt-1 text-gray-900\">{{ getSalaryLabel(data?.expected_salary) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 期望城市 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-orange-50 rounded-lg\">\n            <MapPinIcon class=\"w-5 h-5 text-orange-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">期望城市</span>\n            <div class=\"mt-1 text-gray-900\">{{ formatCity(data?.expected_city) }}</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 期望行业 -->\n    <div class=\"mt-4 bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n      <div class=\"flex items-start space-x-3\">\n        <div class=\"p-2 bg-indigo-50 rounded-lg\">\n          <BuildingOfficeIcon class=\"w-5 h-5 text-indigo-600\" />\n        </div>\n        <div>\n          <span class=\"text-sm font-medium text-gray-500\">期望行业</span>\n          <div class=\"mt-1 text-gray-900\">{{ formatIndustries(data?.industries) }}</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 空状态 -->\n    <div v-if=\"!data\" class=\"flex flex-col items-center justify-center py-8\">\n      <DocumentPlusIcon class=\"w-12 h-12 text-gray-300\" />\n      <p class=\"mt-2 text-gray-400\">暂无求职意向，点击编辑按钮添加</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions'\nimport { \n  BriefcaseIcon,\n  UserCircleIcon,\n  CurrencyYenIcon,\n  MapPinIcon,\n  BuildingOfficeIcon,\n  DocumentPlusIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: null\n  }\n})\n\n// 添加调试日志\nconsole.log('JobIntentionContent 接收到的数据:', props.data)\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const option = JOB_TYPE_OPTIONS.find(opt => opt.value === value)\n  return option ? option.label : '未设置'\n}\n\n// 获取求职状态标签\nconst getJobStatusLabel = (value) => {\n  const statusMap = {\n    'unemployed_looking': '离职-找工作',\n    'employed_not_looking': '在职-暂不考虑',\n    'employed_looking': '在职-看机会',\n    'student_internship': '在校-找实习',\n    'fresh_graduate': '应届生'\n  }\n  return statusMap[value] || '未设置'\n}\n\n// 获取薪资标签\nconst getSalaryLabel = (value) => {\n  const option = SALARY_OPTIONS.find(opt => opt.value === value)\n  return option ? option.label : '未设置'\n}\n\n// 格式化城市\nconst formatCity = (city) => {\n  if (!city) return '未设置'\n  return city.split('-').join('、')\n}\n\n// 格式化行业\nconst formatIndustries = (industries) => {\n  if (!industries) return '未设置'\n  return industries.split(',').join('、')\n}\n</script>\n\n<style scoped>\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .grid {\n    @apply grid-cols-1 gap-3;\n  }\n  \n  .p-4 {\n    @apply p-3;\n  }\n}\n\n/* 悬浮效果 */\n.bg-gray-50 {\n  transition: all 0.2s ease;\n}\n\n/* 图标容器 */\n.p-2 {\n  transition: all 0.2s ease;\n}\n\n.bg-gray-50:hover .p-2 {\n  transform: scale(1.1);\n}\n\n/* 图标容器悬浮效果 */\n.bg-gray-50:hover .p-2 {\n  transform: scale(1.1);\n  transition: transform 0.2s ease;\n}\n</style> "],"mappings":";;AA+EA,SAASA,gBAAgB,EAAEC,kBAAkB,EAAEC,