{"ast":null,"code":"export default {\n  __name: 'PhoneModal',\n  props: {\n    phone: String,\n    code: String,\n    loading: Boolean,\n    countdown: Number,\n    onSendCode: Function,\n    onUpdate: Function,\n    onClose: Function\n  },\n  emits: ['update:phone', 'update:code'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const __returned__ = {};\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":[],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/components/modals/PhoneModal.vue"],"sourcesContent":["<template>\n  <div class=\"fixed inset-0 z-50 overflow-y-auto\">\n    <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n      <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\"></div>\n      <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\">&#8203;</span>\n      \n      <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n        <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n          <div class=\"sm:flex sm:items-start\">\n            <div class=\"mt-3 text-center sm:mt-0 sm:text-left w-full\">\n              <h3 class=\"text-lg leading-6 font-medium text-gray-900\">更换手机号</h3>\n              <div class=\"mt-4 space-y-4\">\n                <!-- 新手机号输入 -->\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700\">新手机号</label>\n                  <div class=\"mt-1\">\n                    <input\n                      type=\"text\"\n                      :value=\"phone\"\n                      @input=\"$emit('update:phone', $event.target.value)\"\n                      class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                      placeholder=\"请输入新手机号\"\n                    />\n                  </div>\n                </div>\n                \n                <!-- 验证码输入 -->\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700\">验证码</label>\n                  <div class=\"mt-1 flex space-x-2\">\n                    <input\n                      type=\"text\"\n                      :value=\"code\"\n                      @input=\"$emit('update:code', $event.target.value)\"\n                      class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                      placeholder=\"请输入验证码\"\n                    />\n                    <button\n                      @click=\"onSendCode\"\n                      :disabled=\"countdown > 0\"\n                      class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap\"\n                    >\n                      {{ countdown > 0 ? `${countdown}s` : '获取验证码' }}\n                    </button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n          <button\n            type=\"button\"\n            @click=\"onUpdate\"\n            :disabled=\"!phone || !code || loading\"\n            class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\"\n          >\n            <span v-if=\"loading\">更新中...</span>\n            <span v-else>确认</span>\n          </button>\n          <button\n            type=\"button\"\n            @click=\"onClose\"\n            class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\"\n          >\n            取消\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\ndefineProps({\n  phone: String,\n  code: String,\n  loading: Boolean,\n  countdown: Number,\n  onSendCode: Function,\n  onUpdate: Function,\n  onClose: Function\n})\n\ndefineEmits(['update:phone', 'update:code'])\n</script> "],"mappings":"","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}