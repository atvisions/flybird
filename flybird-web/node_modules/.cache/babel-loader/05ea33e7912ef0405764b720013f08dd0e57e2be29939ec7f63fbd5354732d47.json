{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { useStore } from 'vuex';\nimport HeadView from '@/components/HeadView.vue';\nimport { showToast } from '@/components/ToastMessage';\nimport { auth } from '@/api/auth';\nexport default {\n  __name: 'LoginView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const store = useStore();\n\n    // 表单数据\n    const phone = ref('');\n    const password = ref('');\n    const loading = ref(false);\n    const rememberMe = ref(false);\n    const showPassword = ref(false);\n    const phoneError = ref('');\n    const passwordError = ref('');\n\n    // 表单验证状态\n    const isFormValid = computed(() => {\n      return phone.value && password.value && !loading.value && !phoneError.value && !passwordError.value;\n    });\n\n    // 手机号验证\n    const validatePhone = () => {\n      phoneError.value = '';\n      const phoneRegex = /^1[3-9]\\d{9}$/;\n      if (!phone.value) {\n        phoneError.value = '请输入手机号';\n        return false;\n      }\n      if (!phoneRegex.test(phone.value)) {\n        phoneError.value = '请输入正确的手机号';\n        return false;\n      }\n      return true;\n    };\n\n    // 密码验证\n    const validatePassword = () => {\n      passwordError.value = '';\n      if (!password.value) {\n        passwordError.value = '请输入密码';\n        return false;\n      }\n      if (password.value.length < 6) {\n        passwordError.value = '密码长度不能少于6位';\n        return false;\n      }\n      return true;\n    };\n\n    // 表单验证\n    const validatePasswordForm = () => {\n      const isPhoneValid = validatePhone();\n      const isPasswordValid = validatePassword();\n      return isPhoneValid && isPasswordValid;\n    };\n\n    // 处理登录\n    const handleLogin = async e => {\n      e.preventDefault();\n      if (!validatePasswordForm()) return;\n      try {\n        loading.value = true;\n        console.log('Starting login process with remember me:', rememberMe.value);\n        const response = await auth.login({\n          phone: phone.value,\n          password: password.value\n        });\n        console.log('Login response:', response);\n        if (response.data) {\n          const {\n            token,\n            refresh_token\n          } = response.data;\n\n          // 保存认证信息\n          localStorage.setItem('access_token', token);\n          localStorage.setItem('refresh_token', refresh_token);\n\n          // 更新 store，传入 rememberMe 状态\n          await store.dispatch('loginWithPassword', {\n            tokens: {\n              access: token,\n              refresh: refresh_token\n            },\n            remember: rememberMe.value,\n            // 确保传入记住我状态\n            phone: phone.value\n          });\n          showToast('登录成功', 'success');\n          const redirect = router.currentRoute.value.query.redirect || '/';\n          router.push(redirect);\n        } else {\n          throw new Error(response.data?.message || '登录失败');\n        }\n      } catch (error) {\n        console.error('Login process error:', error);\n        handleLoginError(error);\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 修改错误处理函数\n    const handleLoginError = error => {\n      let errorMessage = '登录失败，请重试';\n      if (error.code === 'ERR_NETWORK') {\n        errorMessage = '无法连接到服务器，请检查网络连接';\n      } else if (error.response) {\n        const {\n          status,\n          data\n        } = error.response;\n        switch (status) {\n          case 404:\n            errorMessage = '账号不存在';\n            break;\n          case 400:\n            errorMessage = data?.message || '登录信息有误，请检查后重试';\n            break;\n          case 401:\n            errorMessage = '手机号或密码错误';\n            break;\n          case 429:\n            errorMessage = '登录请求过于频繁，请稍后再试';\n            break;\n          case 500:\n            errorMessage = '服务器出现问题，请稍后再试';\n            break;\n          default:\n            errorMessage = data?.message || '登录失败，请稍后重试';\n        }\n      } else if (error.request) {\n        errorMessage = '网络连接失败，请检查网络后重试';\n      }\n      console.error('Login error details:', {\n        code: error.code,\n        message: error.message,\n        response: error.response,\n        request: error.request\n      });\n      showToast(errorMessage, 'error');\n    };\n\n    // 切换密码显示\n    const togglePassword = () => {\n      showPassword.value = !showPassword.value;\n    };\n\n    // 输入事件处理\n    const handlePhoneInput = () => {\n      if (phoneError.value) {\n        validatePhone();\n      }\n    };\n    const handlePasswordInput = () => {\n      if (passwordError.value) {\n        validatePassword();\n      }\n    };\n\n    // 检查登录状态\n    onMounted(async () => {\n      const isAuthenticated = await store.dispatch('checkAuth');\n      if (isAuthenticated) {\n        const redirect = router.currentRoute.value.query.redirect || '/';\n        router.push(redirect);\n      }\n    });\n    const __returned__ = {\n      router,\n      store,\n      phone,\n      password,\n      loading,\n      rememberMe,\n      showPassword,\n      phoneError,\n      passwordError,\n      isFormValid,\n      validatePhone,\n      validatePassword,\n      validatePasswordForm,\n      handleLogin,\n      handleLoginError,\n      togglePassword,\n      handlePhoneInput,\n      handlePasswordInput,\n      ref,\n      computed,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get useStore() {\n        return useStore;\n      },\n      HeadView,\n      get showToast() {\n        return showToast;\n      },\n      get auth() {\n        return auth;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","useRouter","useStore","HeadView","showToast","auth","router","store","phone","password","loading","rememberMe","showPassword","phoneError","passwordError","isFormValid","value","validatePhone","phoneRegex","test","validatePassword","length","validatePasswordForm","isPhoneValid","isPasswordValid","handleLogin","e","preventDefault","console","log","response","login","data","token","refresh_token","localStorage","setItem","dispatch","tokens","access","refresh","remember","redirect","currentRoute","query","push","Error","message","error","handleLoginError","errorMessage","code","status","request","togglePassword","handlePhoneInput","handlePasswordInput","isAuthenticated"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/LoginView.vue"],"sourcesContent":["<template>\n  <div class=\"flex flex-col min-h-screen\">\n    <HeadView />\n    <main class=\"flex-1 pt-14 relative z-[1] bg-gray-50\">\n      <!-- Logo 部分 -->\n      <div class=\"sm:mx-auto sm:w-full sm:max-w-md pt-8\">\n        <h2 class=\"mt-6 text-center text-2xl font-bold leading-9 tracking-tight text-gray-900\">登录账号</h2>\n      </div>\n\n      <div class=\"mt-10 sm:mx-auto sm:w-full sm:max-w-[480px]\">\n        <div class=\"bg-white px-6 py-12 shadow sm:rounded-lg sm:px-12\">\n          <form class=\"space-y-6\" @submit.prevent=\"handleLogin\">\n            <!-- 手机号输入 -->\n            <div>\n              <label for=\"phone\" class=\"block text-sm font-medium leading-6 text-gray-900\">手机号</label>\n              <div class=\"mt-2\">\n                <input \n                  type=\"tel\" \n                  id=\"phone\" \n                  v-model=\"phone\"\n                  @input=\"handlePhoneInput\"\n                  required\n                  class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-primary-600 sm:text-sm sm:leading-6 px-3\"\n                  :class=\"{'ring-red-300': phoneError}\"\n                >\n                <div v-if=\"phoneError\" class=\"mt-1 text-sm text-red-600\">{{ phoneError }}</div>\n              </div>\n            </div>\n\n            <!-- 密码输入 -->\n            <div>\n              <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">密码</label>\n              <div class=\"mt-2 relative\">\n                <input \n                  :type=\"showPassword ? 'text' : 'password'\"\n                  id=\"password\"\n                  v-model=\"password\"\n                  @input=\"handlePasswordInput\"\n                  required\n                  class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-primary-600 sm:text-sm sm:leading-6 px-3 pr-10\"\n                  :class=\"{'ring-red-300': passwordError}\"\n                >\n                <button \n                  type=\"button\"\n                  @click=\"togglePassword\"\n                  class=\"absolute inset-y-0 right-0 flex items-center pr-3\"\n                >\n                  <!-- 密码显示/隐藏图标 -->\n                  <svg v-if=\"showPassword\" class=\"h-5 w-5 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                  </svg>\n                  <svg v-else class=\"h-5 w-5 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                  </svg>\n                </button>\n              </div>\n              <div v-if=\"passwordError\" class=\"mt-1 text-sm text-red-600\">{{ passwordError }}</div>\n            </div>\n\n            <!-- 记住我和忘记密码 -->\n            <div class=\"flex items-center justify-between\">\n              <div class=\"flex items-center\">\n                <input \n                  id=\"remember-me\" \n                  type=\"checkbox\"\n                  v-model=\"rememberMe\"\n                  class=\"h-4 w-4 text-primary-600 focus:ring-primary-600 border-gray-300 rounded\"\n                >\n                <label for=\"remember-me\" class=\"ml-2 block text-sm text-gray-900\">记住我</label>\n              </div>\n\n              <div class=\"text-sm\">\n                <router-link to=\"/reset-password\" class=\"font-medium text-primary-600 hover:text-primary-500\">\n                  忘记密码？\n                </router-link>\n              </div>\n            </div>\n\n            <!-- 登录按钮 -->\n            <div>\n              <button \n                type=\"submit\"\n                :disabled=\"!isFormValid\"\n                class=\"flex w-full justify-center rounded-md bg-primary-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 disabled:opacity-50 disabled:cursor-not-allowed\"\n              >\n                <svg v-if=\"loading\" class=\"animate-spin -ml-1 mr-3 h-5 w-5 text-white\" fill=\"none\" viewBox=\"0 0 24 24\">\n                  <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n                  <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n                </svg>\n                {{ loading ? '登录中...' : '登录' }}\n              </button>\n            </div>\n          </form>\n\n          <!-- 其他登录方式 -->\n          <div class=\"mt-6\">\n            <div class=\"relative\">\n              <div class=\"absolute inset-0 flex items-center\">\n                <div class=\"w-full border-t border-gray-300\"></div>\n              </div>\n              <div class=\"relative flex justify-center text-sm\">\n                <span class=\"bg-white px-2 text-gray-500\">其他登录方式</span>\n              </div>\n            </div>\n\n            <div class=\"mt-6 grid grid-cols-3 gap-3\">\n              <div>\n                <button\n                  @click=\"handleWeChatClick\" \n                  class=\"w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-500 hover:bg-gray-50\"\n                >\n                  <span class=\"sr-only\">微信登录</span>\n                  <svg class=\"w-5 h-5 text-green-600\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M8.667 15.273c-.328 0-.593-.265-.593-.593v-1.778a.592.592 0 0 1 1.186 0v1.778c0 .328-.265.593-.593.593zm6.666 0c-.328 0-.593-.265-.593-.593v-1.778a.592.592 0 0 1 1.186 0v1.778c0 .328-.265.593-.593.593z\"/>\n                    <path d=\"M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm5.918 12.08c-.533 2.923-3.982 5.012-7.918 4.37-2.718-.444-4.963-2.165-5.735-4.37-.844-2.413.437-4.693 2.735-5.912.842-.446 1.777-.724 2.735-.832.437-.049.877-.073 1.318-.073 1.683 0 3.23.446 4.503 1.208 1.41.841 2.333 2.083 2.432 3.49.05.706-.095 1.406-.432 2.032-.535.99-1.563 1.756-2.9 2.165-1.096.336-2.245.361-3.368.073-.89-.227-1.683-.631-2.333-1.208-.437-.384-.706-.841-.816-1.333-.073-.336.024-.681.267-.927.242-.242.583-.339.915-.266.339.073.63.291.78.582.145.29.436.532.824.678.63.242 1.37.266 2.023.073.824-.242 1.37-.752 1.37-1.284 0-.532-.533-1.018-1.37-1.26-.63-.193-1.37-.169-2.023.073-.388.146-.679.388-.824.679-.145.29-.436.508-.78.581-.332.073-.673-.024-.915-.266-.243-.242-.34-.587-.267-.923.11-.492.379-.95.816-1.333.65-.577 1.443-.981 2.333-1.208 1.123-.288 2.272-.263 3.368.073 1.337.409 2.365 1.175 2.9 2.165.337.626.482 1.326.432 2.032-.099 1.407-1.022 2.649-2.432 3.49-1.273.762-2.82 1.208-4.503 1.208-.441 0-.881-.024-1.318-.073-.958-.108-1.893-.386-2.735-.832-2.298-1.219-3.579-3.499-2.735-5.912.772-2.205 3.017-3.926 5.735-4.37 3.936-.642 7.385 1.447 7.918 4.37z\"/>\n                  </svg>\n                </button>\n              </div>\n\n              <div>\n                <a href=\"#\" class=\"w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-500 hover:bg-gray-50\">\n                  <span class=\"sr-only\">QQ登录</span>\n                  <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path d=\"M12.003 2c-2.265 0-6.29 1.364-6.29 7.325v1.195S3.55 14.96 3.55 17.474c0 .665.17 1.025.281 1.025.114 0 .902-.484 1.748-2.072 0 0-.18 2.197 1.904 3.967 0 0-1.77.495-1.77 1.182 0 .686 4.078.43 6.29.43 2.213 0 6.29.256 6.29-.43 0-.687-1.77-1.182-1.77-1.182s2.085-1.77 1.905-3.967c.846 1.588 1.634 2.072 1.746 2.072.111 0 .283-.36.283-1.025 0-2.514-2.166-6.954-2.166-6.954V9.325C18.29 3.364 14.268 2 12.003 2z\"/>\n                  </svg>\n                </a>\n              </div>\n\n              <div>\n                <a href=\"#\" class=\"w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-500 hover:bg-gray-50\">\n                  <span class=\"sr-only\">微博登录</span>\n                  <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path d=\"M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.672 4.018.259 2.6-2.759 5.049-6.74 5.443z\"/>\n                  </svg>\n                </a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { useStore } from 'vuex'\nimport HeadView from '@/components/HeadView.vue'\nimport { showToast } from '@/components/ToastMessage'\nimport { auth } from '@/api/auth'\n\nconst router = useRouter()\nconst store = useStore()\n\n// 表单数据\nconst phone = ref('')\nconst password = ref('')\nconst loading = ref(false)\nconst rememberMe = ref(false)\nconst showPassword = ref(false)\nconst phoneError = ref('')\nconst passwordError = ref('')\n\n// 表单验证状态\nconst isFormValid = computed(() => {\n  return phone.value && password.value && !loading.value && !phoneError.value && !passwordError.value\n})\n\n// 手机号验证\nconst validatePhone = () => {\n  phoneError.value = ''\n  const phoneRegex = /^1[3-9]\\d{9}$/\n  if (!phone.value) {\n    phoneError.value = '请输入手机号'\n    return false\n  }\n  if (!phoneRegex.test(phone.value)) {\n    phoneError.value = '请输入正确的手机号'\n    return false\n  }\n  return true\n}\n\n// 密码验证\nconst validatePassword = () => {\n  passwordError.value = ''\n  if (!password.value) {\n    passwordError.value = '请输入密码'\n    return false\n  }\n  if (password.value.length < 6) {\n    passwordError.value = '密码长度不能少于6位'\n    return false\n  }\n  return true\n}\n\n// 表单验证\nconst validatePasswordForm = () => {\n  const isPhoneValid = validatePhone()\n  const isPasswordValid = validatePassword()\n  return isPhoneValid && isPasswordValid\n}\n\n// 处理登录\nconst handleLogin = async (e) => {\n  e.preventDefault()\n  if (!validatePasswordForm()) return\n\n  try {\n    loading.value = true\n    console.log('Starting login process with remember me:', rememberMe.value)\n\n    const response = await auth.login({\n      phone: phone.value,\n      password: password.value\n    })\n\n    console.log('Login response:', response)\n\n    if (response.data) {\n      const { token, refresh_token } = response.data\n      \n      // 保存认证信息\n      localStorage.setItem('access_token', token)\n      localStorage.setItem('refresh_token', refresh_token)\n      \n      // 更新 store，传入 rememberMe 状态\n      await store.dispatch('loginWithPassword', {\n        tokens: {\n          access: token,\n          refresh: refresh_token\n        },\n        remember: rememberMe.value,  // 确保传入记住我状态\n        phone: phone.value\n      })\n\n      showToast('登录成功', 'success')\n      const redirect = router.currentRoute.value.query.redirect || '/'\n      router.push(redirect)\n    } else {\n      throw new Error(response.data?.message || '登录失败')\n    }\n  } catch (error) {\n    console.error('Login process error:', error)\n    handleLoginError(error)\n  } finally {\n    loading.value = false\n  }\n}\n\n// 修改错误处理函数\nconst handleLoginError = (error) => {\n  let errorMessage = '登录失败，请重试'\n  \n  if (error.code === 'ERR_NETWORK') {\n    errorMessage = '无法连接到服务器，请检查网络连接'\n  } else if (error.response) {\n    const { status, data } = error.response\n    switch (status) {\n      case 404:\n        errorMessage = '账号不存在'\n        break\n      case 400:\n        errorMessage = data?.message || '登录信息有误，请检查后重试'\n        break\n      case 401:\n        errorMessage = '手机号或密码错误'\n        break\n      case 429:\n        errorMessage = '登录请求过于频繁，请稍后再试'\n        break\n      case 500:\n        errorMessage = '服务器出现问题，请稍后再试'\n        break\n      default:\n        errorMessage = data?.message || '登录失败，请稍后重试'\n    }\n  } else if (error.request) {\n    errorMessage = '网络连接失败，请检查网络后重试'\n  }\n\n  console.error('Login error details:', {\n    code: error.code,\n    message: error.message,\n    response: error.response,\n    request: error.request\n  })\n\n  showToast(errorMessage, 'error')\n}\n\n// 切换密码显示\nconst togglePassword = () => {\n  showPassword.value = !showPassword.value\n}\n\n// 输入事件处理\nconst handlePhoneInput = () => {\n  if (phoneError.value) {\n    validatePhone()\n  }\n}\n\nconst handlePasswordInput = () => {\n  if (passwordError.value) {\n    validatePassword()\n  }\n}\n\n// 检查登录状态\nonMounted(async () => {\n  const isAuthenticated = await store.dispatch('checkAuth')\n  if (isAuthenticated) {\n    const redirect = router.currentRoute.value.query.redirect || '/'\n    router.push(redirect)\n  }\n})\n</script>"],"mappings":"AAkJA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAI;AAC7C,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,QAAQ,QAAQ,MAAK;AAC9B,OAAOC,QAAQ,MAAM,2BAA0B;AAC/C,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,IAAI,QAAQ,YAAW;;;;;;;IAEhC,MAAMC,MAAM,GAAGL,SAAS,CAAC;IACzB,MAAMM,KAAK,GAAGL,QAAQ,CAAC;;IAEvB;IACA,MAAMM,KAAK,GAAGV,GAAG,CAAC,EAAE;IACpB,MAAMW,QAAQ,GAAGX,GAAG,CAAC,EAAE;IACvB,MAAMY,OAAO,GAAGZ,GAAG,CAAC,KAAK;IACzB,MAAMa,UAAU,GAAGb,GAAG,CAAC,KAAK;IAC5B,MAAMc,YAAY,GAAGd,GAAG,CAAC,KAAK;IAC9B,MAAMe,UAAU,GAAGf,GAAG,CAAC,EAAE;IACzB,MAAMgB,aAAa,GAAGhB,GAAG,CAAC,EAAE;;IAE5B;IACA,MAAMiB,WAAW,GAAGhB,QAAQ,CAAC,MAAM;MACjC,OAAOS,KAAK,CAACQ,KAAK,IAAIP,QAAQ,CAACO,KAAK,IAAI,CAACN,OAAO,CAACM,KAAK,IAAI,CAACH,UAAU,CAACG,KAAK,IAAI,CAACF,aAAa,CAACE,KAAI;IACpG,CAAC;;IAED;IACA,MAAMC,aAAa,GAAGA,CAAA,KAAM;MAC1BJ,UAAU,CAACG,KAAK,GAAG,EAAC;MACpB,MAAME,UAAU,GAAG,eAAc;MACjC,IAAI,CAACV,KAAK,CAACQ,KAAK,EAAE;QAChBH,UAAU,CAACG,KAAK,GAAG,QAAO;QAC1B,OAAO,KAAI;MACb;MACA,IAAI,CAACE,UAAU,CAACC,IAAI,CAACX,KAAK,CAACQ,KAAK,CAAC,EAAE;QACjCH,UAAU,CAACG,KAAK,GAAG,WAAU;QAC7B,OAAO,KAAI;MACb;MACA,OAAO,IAAG;IACZ;;IAEA;IACA,MAAMI,gBAAgB,GAAGA,CAAA,KAAM;MAC7BN,aAAa,CAACE,KAAK,GAAG,EAAC;MACvB,IAAI,CAACP,QAAQ,CAACO,KAAK,EAAE;QACnBF,aAAa,CAACE,KAAK,GAAG,OAAM;QAC5B,OAAO,KAAI;MACb;MACA,IAAIP,QAAQ,CAACO,KAAK,CAACK,MAAM,GAAG,CAAC,EAAE;QAC7BP,aAAa,CAACE,KAAK,GAAG,YAAW;QACjC,OAAO,KAAI;MACb;MACA,OAAO,IAAG;IACZ;;IAEA;IACA,MAAMM,oBAAoB,GAAGA,CAAA,KAAM;MACjC,MAAMC,YAAY,GAAGN,aAAa,CAAC;MACnC,MAAMO,eAAe,GAAGJ,gBAAgB,CAAC;MACzC,OAAOG,YAAY,IAAI