tring' && (salary.includes('K') || salary.includes('k'))) {\n        return salary;\n      }\n      // 否则添加 'K'\n      return `${salary}K`;\n    };\n\n    // 热门行业列表\n    const hotIndustries = ['互联网', '人工智能', '大数据', '云计算', '金融科技', '电子商务', '教育科技', '医疗健康'];\n\n    // 处理行业标签点击\n    const handleIndustryClick = industry => {\n      // 触发编辑事件，让父组件处理\n      emit('edit', 'job_intention', _objectSpread(_objectSpread({}, props.data), {}, {\n        industries: props.data.industries ? `${props.data.industries},${industry}` : industry\n      }));\n    };\n\n    // 添加 emit 定义\n    const emit = __emit;\n\n    // 调试日志\n    onMounted(() => {\n      console.log('JobIntentionContent mounted, data:', props.data);\n    });\n    watch(() => props.data, newData => {\n      console.log('JobIntentionContent data changed:', newData);\n    }, {\n      deep: true\n    });\n    const __returned__ = {\n      props,\n      getJobTypeLabel,\n      getJobStatusLabel,\n      formatCity,\n      formatIndustries,\n      getStatusColor,\n      formatSalary,\n      hotIndustries,\n      handleIndustryClick,\n      emit,\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get UserCircleIcon() {\n        return UserCircleIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BuildingOfficeIcon() {\n        return BuildingOfficeIcon;\n      },\n      get DocumentPlusIcon() {\n        return DocumentPlusIcon;\n      },\n      onMounted,\n      watch\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["BriefcaseIcon","UserCircleIcon","CurrencyYenIcon","MapPinIcon","BuildingOfficeIcon","DocumentPlusIcon","onMounted","watch","props","__props","getJobTypeLabel","value","typeMap","getJobStatusLabel","statusMap","formatCity","city","split","join","formatIndustries","industries","Array","isArray","getStatusColor","status","colorMap","formatSalary","salary","includes","hotIndustries","handleIndustryClick","industry","emit","_objectSpread","data","__emit","console","log","newData","deep"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<template>\n  <div>\n    <template v-if=\"data\">\n      <div class=\"grid grid-cols-2 gap-6\">\n        <!-- 求职状态 -->\n        <div class=\"flex items-center space-x-3\">\n          <div class=\"w-10 h-10 rounded-lg flex items-center justify-center bg-blue-50\">\n            <div class=\"relative\">\n              <UserCircleIcon class=\"w-6 h-6 text-blue-500\" />\n              <div :class=\"[\n                'absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full border-2 border-white',\n                getStatusColor(data.job_status)\n              ]\"></div>\n            </div>\n          </div>\n          <div>\n            <div class=\"text-xs text-gray-400\">求职状态</div>\n            <div class=\"mt-0.5 text-sm text-gray-700\">{{ getJobStatusLabel(data.job_status) }}</div>\n          </div>\n        </div>\n\n        <!-- 工作类型 -->\n        <div class=\"flex items-center space-x-3\">\n          <div class=\"w-10 h-10 rounded-lg flex items-center justify-center bg-indigo-50\">\n            <BriefcaseIcon class=\"w-6 h-6 text-indigo-500\" />\n          </div>\n          <div>\n            <div class=\"text-xs text-gray-400\">工作类型</div>\n            <div class=\"mt-0.5 text-sm text-gray-700\">{{ getJobTypeLabel(data.job_type) }}</div>\n          </div>\n        </div>\n\n        <!-- 期望薪资 -->\n        <div class=\"flex items-center space-x-3\">\n          <div class=\"w-10 h-10 rounded-lg flex items-center justify-center bg-emerald-50\">\n            <CurrencyYenIcon class=\"w-6 h-6 text-emerald-500\" />\n          </div>\n          <div>\n            <div class=\"text-xs text-gray-400\">期望薪资</div>\n            <div class=\"mt-0.5 text-sm text-gray-700\">{{ formatSalary(data.expected_salary) }}</div>\n          </div>\n        </div>\n\n        <!-- 期望城市 -->\n        <div class=\"flex items-center space-x-3\">\n          <div class=\"w-10 h-10 rounded-lg flex items-center justify-center bg-rose-50\">\n            <MapPinIcon class=\"w-6 h-6 text-rose-500\" />\n          </div>\n          <div>\n            <div class=\"text-xs text-gray-400\">期望城市</div>\n            <div class=\"mt-0.5 text-sm text-gray-700\">{{ formatCity(data.expected_city) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 期望行业 -->\n      <div class=\"mt-6 border-t border-gray-100 pt-4\">\n        <div class=\"flex items-center space-x-3\">\n          <div class=\"w-10 h-10 rounded-lg flex items-center justify-center bg-purple-50\">\n            <BuildingOfficeIcon class=\"w-6 h-6 text-purple-500\" />\n          </div>\n          <div class=\"flex-1\">\n            <div class=\"text-xs text-gray-400\">期望行业</div>\n            <div class=\"mt-0.5 text-sm text-gray-700\">{{ formatIndustries(data.industries) }}</div>\n            <!-- 热门行业标签 -->\n            <div class=\"mt-2 flex flex-wrap gap-2\">\n              <button\n                v-for=\"industry in hotIndustries\"\n                :key=\"industry\"\n                class=\"px-2 py-1 text-xs rounded-full bg-gray-50 text-gray-600 hover:bg-gray-100 transition-colors\"\n                @click=\"handleIndustryClick(industry)\"\n              >\n                {{ industry }}\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </template>\n\n    <!-- 空状态 -->\n    <div v-else class=\"flex flex-col items-center justify-center py-12 bg-gray-50 rounded-lg\">\n      <DocumentPlusIcon class=\"w-12 h-12 text-gray-300\" />\n      <p class=\"mt-2 text-sm text-gray-400\">暂无求职意向，点击编辑按钮添加</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { \n  BriefcaseIcon,\n  UserCircleIcon,\n  CurrencyYenIcon,\n  MapPinIcon,\n  BuildingOfficeIcon,\n  DocumentPlusIcon\n} from '@heroicons/vue/24/outline'\nimport { onMounted, watch } from 'vue'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: () => ({})\n  }\n})\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const typeMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return typeMap[value] || '未设置'\n}\n\n// 获取求职状态标签\nconst getJobStatusLabel = (value) => {\n  const statusMap = {\n    'actively_looking': '正在积极找工作',\n    'open_to_offers': '对机会持开放态度',\n    'not_looking': '暂时不找工作'\n  }\n  return statusMap[value] || '未设置'\n}\n\n// 格式化城市\nconst formatCity = (city) => {\n  if (!city) return '未设置'\n  return city.split('-').join('、')\n}\n\n// 格式化行业\nconst formatIndustries = (industries) => {\n  if (!industries) return '未设置'\n  if (Array.isArray(industries)) {\n    return industries.join('、')\n  }\n  return industries.split(',').join('、')\n}\n\n// 获取状态对应的颜色\nconst getStatusColor = (status) => {\n  const colorMap = {\n    'actively_looking': 'bg-green-500',  // 正在积极找工作 - 绿色\n    'open_to_offers': 'bg-blue-500',     // 对机会持开放态度 - 蓝色\n    'not_looking': 'bg-gray-400'         // 暂时不找工作 - 灰色\n  }\n  return colorMap[status] || 'bg-gray-400'\n}\n\n// 格式化薪资\nconst formatSalary = (salary) => {\n  if (!salary) return '未设置'\n  // 如果已经包含 'K' 或其他单位，直接返回\n  if (typeof salary === 'string' && (salary.includes('K') || salary.includes('k'))) {\n    return salary\n  }\n  // 否则添加 'K'\n  return `${salary}K`\n}\n\n// 热门行业列表\nconst hotIndustries = [\n  '互联网',\n  '人工智能',\n  '大数据',\n  '云计算',\n  '金融科技',\n  '电子商务',\n  '教育科技',\n  '医疗健康'\n]\n\n// 处理行业标签点击\nconst handleIndustryClick = (industry) => {\n  // 触发编辑事件，让父组件处理\n  emit('edit', 'job_intention', {\n    ...props.data,\n    industries: props.data.industries \n      ? `${props.data.industries},${industry}`\n      : industry\n  })\n}\n\n// 添加 emit 定义\nconst emit = defineEmits(['edit'])\n\n// 调试日志\nonMounted(() => {\n  console.log('JobIntentionContent mounted, data:', props.data)\n})\n\nwatch(() => props.data, (newData) => {\n  console.log('JobIntentionContent data changed:', newData)\n}, { deep: true })\n</script>\n\n<style scoped>\n.w-10 {\n  transition: transform 0.2s ease;\n}\n\n.flex:hover .w-10 {\n  transform: scale(1.1);\n}\n\n@media (max-width: 640px) {\n  .grid-cols-2 {\n    @apply grid-cols-1 gap-4;\n  }\n}\n</style>"],"mappings":";AAyFA,SACEA,aAAa,EACbC,cAAc,EACdC,eAAe,EACfC,UAAU,EACVC,kBAAkB,EAClBC,gBAAe,QACV,2BAA0B;AACjC,SAASC,SAAS,EAAEC,KAAK,QAAQ,KAAI;;;;;;;;;;;;;;;IAErC,MAAMC,KAAK,GAAGC,OAAA;;IAOd;IACA,MAAMC,eAAe,GAAIC,KAAK,IAAK;MACjC,MAAMC,OAAO,GAAG;QACd,WAAW,EAAE,IAAI;QACjB,WAAW,EAAE,IAAI;QACjB,YAAY,EAAE,IAAI;QAClB,WAAW,EAAE;MACf;MACA,OAAOA,OAAO,CAACD,KAAK,CAAC,IAAI,KAAI;IAC/B;;IAEA;IACA,MAAME,iBAAiB,GAAIF,KAAK,IAAK;MACnC,MAAMG,SAAS,GAAG;QAChB,kBAAkB,EAAE,SAAS;QAC7B,gBAAgB,EAAE,UAAU;QAC5B,aAAa,EAAE;MACjB;MACA,OAAOA,SAAS,CAACH,KAAK,CAAC,IAAI,KAAI;IACjC;;IAEA;IACA,MAAMI,UAAU,GAAIC,IAAI,IAAK;MAC3B,IAAI,CAACA,IAAI,EAAE,OAAO,KAAI;MACtB,OAAOA,IAAI,CAACC,KAAK,CAAC,GAAG,CAAC,CAACC,IAAI,CAAC,GAAG;IACjC;;IAEA;IACA,MAAMC,gBAAgB,GAAIC,UAAU,IAAK;MACvC,IAAI,CAACA,UAAU,EAAE,OAAO,KAAI;MAC5B,IAAIC,KAAK,CAACC,OAAO,CAACF,UAAU,CAAC,EAAE;QAC7B,OAAOA,UAAU,CAACF,IAAI,CAAC,GAAG;MAC5B;MACA,OAAOE,UAAU,CAACH,KAAK,CAAC,GAAG,CAAC,CAACC,IAAI,CAAC,GAAG;IACvC;;IAEA;IACA,MAAMK,cAAc,GAAIC,MAAM,IAAK;MACjC,MAAMC,QAAQ,GAAG;QACf,kBAAkB,EAAE,cAAc;QAAG;QACrC,gBAAgB,EAAE,aAAa;QAAM;QACrC,aAAa,EAAE,aAAa,CAAS;MACvC;MACA,OAAOA,QAAQ,CAACD,MAAM,CAAC,IAAI,aAAY;IACzC;;IAEA;IACA,MAAME,YAAY,GAAIC,MAAM,IAAK;MAC/B,IAAI,CAACA,MAAM,EAAE,OAAO,KAAI;MACxB;MACA,IAAI,OAAOA,MAAM,KAAK,QAAQ,KAAKA,MAAM,CAACC,QAAQ,CAAC,GAAG,CAAC,IAAID,MAAM,CAACC,QAAQ,CAAC,GAAG,CAAC,CAAC,EAAE;QAChF,OAAOD,MAAK;MACd;MACA;MACA,OAAO,GAAGA,MAAM,GAAE;IACpB;;IAEA;IACA,MAAME,aAAa,GAAG,CACpB,KAAK,EACL,MAAM,EACN,KAAK,EACL,KAAK,EACL,MAAM,EACN,MAAM,EACN,MAAM,EACN,MAAK,CACP;;IAEA;IACA,MAAMC,mBAAmB,GAAIC,QAAQ,