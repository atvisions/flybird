{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { useDeleteAccount } from '@/composables/useDeleteAccount';\nimport { useNickname } from '@/composables/useNickname';\nimport { usePhone } from '@/composables/usePhone';\nimport { useChangePassword } from '@/composables/useChangePassword';\nexport default {\n  __name: 'AccountSettings',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n    const router = useRouter();\n\n    // 基础信息\n    const username = computed(() => store.state.userInfo?.username || '未设置');\n    const uid = computed(() => store.state.userInfo?.uid || '暂无');\n    const phone = computed(() => store.state.basicInfo?.phone || store.state.userInfo?.phone || '');\n\n    // 使用 composables\n    const nickname = useNickname();\n    const phoneManager = usePhone();\n    const password = useChangePassword();\n    const deleteAccount = useDeleteAccount();\n\n    // 工具方法\n    const maskPhone = phone => {\n      if (!phone) return '未绑定';\n      return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2');\n    };\n\n    // 打开弹窗的方法\n    const showNicknameModal = ref(false);\n    const showPhoneModal = ref(false);\n    const showPasswordModal = ref(false);\n    const showDeleteConfirm = ref(false);\n\n    // 打开昵称弹窗\n    const openNicknameModal = () => {\n      nickname.value = store.state.userInfo?.username?.toString() || '';\n      showNicknameModal.value = true;\n    };\n\n    // 打开手机号弹窗\n    const openPhoneModal = () => {\n      phoneManager.value = '';\n      phoneManager.code = '';\n      showPhoneModal.value = true;\n    };\n\n    // 打开密码修改弹窗\n    const openPasswordModal = () => {\n      showPasswordModal.value = true;\n    };\n\n    // 打开注销确认弹窗\n    const openDeleteConfirm = () => {\n      deleteAccount.password = '';\n      showDeleteConfirm.value = true;\n    };\n\n    // 关闭弹窗的方法\n    const closeNicknameModal = () => {\n      showNicknameModal.value = false;\n      nickname.value = '';\n    };\n    const closePhoneModal = () => {\n      showPhoneModal.value = false;\n      phoneManager.value = '';\n      phoneManager.code = '';\n    };\n    const closePasswordModal = () => {\n      showPasswordModal.value = false;\n    };\n    const closeDeleteConfirm = () => {\n      showDeleteConfirm.value = false;\n      deleteAccount.password = '';\n    };\n\n    // 处理成功回调\n    const handleNicknameSuccess = () => {\n      closeNicknameModal();\n      showToast('昵称修改成功', 'success');\n    };\n    const handlePhoneSuccess = () => {\n      closePhoneModal();\n      showToast('手机号修改成功', 'success');\n    };\n    const handlePasswordSuccess = () => {\n      closePasswordModal();\n      showToast('密码修改成功', 'success');\n    };\n    const handleDeleteSuccess = () => {\n      showToast('账户已注销', 'success');\n      router.push('/login');\n    };\n    const __returned__ = {\n      store,\n      router,\n      username,\n      uid,\n      phone,\n      nickname,\n      phoneManager,\n      password,\n      deleteAccount,\n      maskPhone,\n      showNicknameModal,\n      showPhoneModal,\n      showPasswordModal,\n      showDeleteConfirm,\n      openNicknameModal,\n      openPhoneModal,\n      openPasswordModal,\n      openDeleteConfirm,\n      closeNicknameModal,\n      closePhoneModal,\n      closePasswordModal,\n      closeDeleteConfirm,\n      handleNicknameSuccess,\n      handlePhoneSuccess,\n      handlePasswordSuccess,\n      handleDeleteSuccess,\n      ref,\n      computed,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get useDeleteAccount() {\n        return useDeleteAccount;\n      },\n      get useNickname() {\n        return useNickname;\n      },\n      get usePhone() {\n        return usePhone;\n      },\n      get useChangePassword() {\n        return useChangePassword;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","useRouter","showToast","useDeleteAccount","useNickname","usePhone","useChangePassword","store","router","username","state","userInfo","uid","phone","basicInfo","nickname","phoneManager","password","deleteAccount","maskPhone","replace","showNicknameModal","showPhoneModal","showPasswordModal","showDeleteConfirm","openNicknameModal","value","toString","openPhoneModal","code","openPasswordModal","openDeleteConfirm","closeNicknameModal","closePhoneModal","closePasswordModal","closeDeleteConfirm","handleNicknameSuccess","handlePhoneSuccess","handlePasswordSuccess","handleDeleteSuccess","push"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/AccountSettings.vue"],"sourcesContent":["<template>\n  <div class=\"max-w-4xl mx-auto\">\n    <div class=\"space-y-6\">\n      <!-- 账户信息 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户信息</h2>\n        </div>\n        \n        <div class=\"p-6 space-y-6\">\n          <!-- UID -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex items-center space-x-2\">\n              <span class=\"text-sm font-medium text-gray-500\">用户 ID</span>\n              <span class=\"text-sm text-gray-900\">{{ uid }}</span>\n            </div>\n            <div class=\"text-xs text-gray-500\">用户唯一标识</div>\n          </div>\n\n          <!-- 昵称 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex items-center space-x-2\">\n              <span class=\"text-sm font-medium text-gray-500\">昵称</span>\n              <span class=\"text-sm text-gray-900\">{{ username }}</span>\n              <span class=\"text-xs text-gray-400\" v-if=\"!username\">\n                (默认为 Flybird + 手机号后4位)\n              </span>\n            </div>\n            <button \n              @click=\"openNicknameModal\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              <svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z\" />\n              </svg>\n              设置\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 账户安全 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户安全</h2>\n        </div>\n        \n        <div class=\"p-6 space-y-6\">\n          <!-- 手机号 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">手机号</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">{{ maskPhone(phone) }}</p>\n            </div>\n            <button @click=\"openPhoneModal\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              更换手机号\n            </button>\n          </div>\n\n          <!-- 密码 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">登录密码</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">用于保护账号安全</p>\n            </div>\n            <button @click=\"openPasswordModal\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              修改密码\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 账户注销 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户注销</h2>\n        </div>\n        \n        <div class=\"p-6\">\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-red-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">账户注销</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">注销后，账户将被永久删除且无法恢复</p>\n            </div>\n            <button @click=\"openDeleteConfirm\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-red-600 hover:text-red-700 \n              transition-colors rounded-md hover:bg-red-50\">\n              注销账户\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 各种弹窗 -->\n      <Teleport to=\"body\">\n        <!-- 昵称设置弹窗 -->\n        <div v-if=\"showNicknameModal\" class=\"fixed inset-0 z-50 overflow-y-auto\">\n          <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n            <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\"></div>\n            <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\">&#8203;</span>\n            \n            <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n              <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n                <div class=\"sm:flex sm:items-start\">\n                  <div class=\"mt-3 text-center sm:mt-0 sm:text-left w-full\">\n                    <h3 class=\"text-lg leading-6 font-medium text-gray-900\">设置昵称</h3>\n                    <div class=\"mt-4\">\n                      <input\n                        type=\"text\"\n                        v-model=\"nickname.value\"\n                        maxlength=\"8\"\n                        class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                        placeholder=\"请输入4-8位昵称，支持中文、字母、数字\"\n                        @keyup.enter=\"nickname.handleUpdate\"\n                      />\n                      <div class=\"mt-1 text-xs text-gray-500\">\n                        昵称长度需要在4-8位之间，只能包含中文、字母、数字\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n                <button\n                  type=\"button\"\n                  @click=\"nickname.handleUpdate\"\n                  :disabled=\"!nickname.value.trim() || nickname.loading\"\n                  class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\"\n                >\n                  <span v-if=\"nickname.loading\">更新中...</span>\n                  <span v-else>确认</span>\n                </button>\n                <button\n                  type=\"button\"\n                  @click=\"closeNicknameModal\"\n                  class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\"\n                >\n                  取消\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 手机号修改弹窗 -->\n        <div v-if=\"showPhoneModal\" class=\"fixed inset-0 z-50 overflow-y-auto\">\n          <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n            <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\"></div>\n            <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\">&#8203;</span>\n            \n            <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n              <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n                <div class=\"sm:flex sm:items-start\">\n                  <div class=\"mt-3 text-center sm:mt-0 sm:text-left w-full\">\n                    <h3 class=\"text-lg leading-6 font-medium text-gray-900\">更换手机号</h3>\n                    <div class=\"mt-4 space-y-4\">\n                      <!-- 新手机号输入 -->\n                      <div>\n                        <label class=\"block text-sm font-medium text-gray-700\">新手机号</label>\n                        <div class=\"mt-1\">\n                          <input\n                            type=\"text\"\n                            v-model=\"phoneManager.value\"\n                            class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                            placeholder=\"请输入新手机号\"\n                          />\n                        </div>\n                      </div>\n                      \n                      <!-- 验证码输入 -->\n                      <div>\n                        <label class=\"block text-sm font-medium text-gray-700\">验证码</label>\n                        <div class=\"mt-1 flex space-x-2\">\n                          <input\n                            type=\"text\"\n                            v-model=\"phoneManager.code\"\n                            class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                            placeholder=\"请输入验证码\"\n                          />\n                          <button\n                            @click=\"phoneManager.handleSendCode\"\n                            :disabled=\"phoneManager.countdown > 0\"\n                            class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap\"\n                          >\n                            {{ phoneManager.countdown > 0 ? `${phoneManager.countdown}s` : '获取验证码' }}\n                          </button>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n                <button\n                  type=\"button\"\n                  @click=\"phoneManager.handleUpdate\"\n                  :disabled=\"!phoneManager.value || !phoneManager.code || phoneManager.loading\"\n                  class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\"\n                >\n                  <span v-if=\"phoneManager.loading\">更新中...</span>\n                  <span v-else>确认</span>\n                </button>\n                <button\n                  type=\"button\"\n                  @click=\"closePhoneModal\"\n                  class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\"\n                >\n                  取消\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 密码修改弹窗 -->\n        <ChangePasswordDialog\n          v-model=\"showPasswordModal\"\n          @success=\"handlePasswordSuccess\"\n        />\n\n        <!-- 账户注销确认弹窗 -->\n        <div v-if=\"showDeleteConfirm\" class=\"fixed inset-0 z-50 overflow-y-auto\">\n          <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n            <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\"></div>\n            <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\">&#8203;</span>\n            \n            <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n              <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n                <div class=\"sm:flex sm:items-start\">\n                  <div class=\"mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10\">\n                    <svg class=\"h-6 w-6 text-red-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n                    </svg>\n                  </div>\n                  <div class=\"mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left\">\n                    <h3 class=\"text-lg leading-6 font-medium text-gray-900\">确认注销账户？</h3>\n                    <div class=\"mt-2\">\n                      <div class=\"bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4\">\n                        <div class=\"flex\">\n                          <div class=\"flex-shrink-0\">\n                            <svg class=\"h-5 w-5 text-yellow-400\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                              <path fill-rule=\"evenodd\" d=\"M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z\" clip-rule=\"evenodd\" />\n                            </svg>\n                          </div>\n                          <div class=\"ml-3\">\n                            <p class=\"text-sm text-yellow-700\">\n                              <strong>警告：</strong> 此操作将永久删除您的账户，包括：\n                            </p>\n                            <ul class=\"mt-2 text-sm text-yellow-700 list-disc list-inside\">\n                              <li>所有个人信息和设置</li>\n                              <li>账户关联的所有数据</li>\n                              <li>无法恢复已删除的数据</li>\n                            </ul>\n                          </div>\n                        </div>\n                      </div>\n                      <p class=\"text-sm text-gray-500\">\n                        请输入登录密码确认此操作。\n                      </p>\n                      <!-- 密码输入框 -->\n                      <div class=\"mt-4\">\n                        <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">\n                          登录密码\n                        </label>\n                        <div class=\"mt-1\">\n                          <input\n                            type=\"password\"\n                            id=\"password\"\n                            v-model=\"deleteAccount.password\"\n                            class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                            placeholder=\"请输入密码\"\n                            @keyup.enter=\"deleteAccount.handleDelete\"\n                          />\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n                <button type=\"button\" \n                  @click=\"deleteAccount.handleDelete\"\n                  :disabled=\"!deleteAccount.password || deleteAccount.loading\"\n                  class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\">\n                  确认注销\n                </button>\n                <button type=\"button\" \n                  @click=\"closeDeleteConfirm\"\n                  class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\">\n                  取消\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </Teleport>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { useDeleteAccount } from '@/composables/useDeleteAccount'\nimport { useNickname } from '@/composables/useNickname'\nimport { usePhone } from '@/composables/usePhone'\nimport { useChangePassword } from '@/composables/useChangePassword'\n\nconst store = useStore()\nconst router = useRouter()\n\n// 基础信息\nconst username = computed(() => store.state.userInfo?.username || '未设置')\nconst uid = computed(() => store.state.userInfo?.uid || '暂无')\nconst phone = computed(() => store.state.basicInfo?.phone || store.state.userInfo?.phone || '')\n\n// 使用 composables\nconst nickname = useNickname()\nconst phoneManager = usePhone()\nconst password = useChangePassword()\nconst deleteAccount = useDeleteAccount()\n\n// 工具方法\nconst maskPhone = (phone) => {\n  if (!phone) return '未绑定'\n  return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n// 打开弹窗的方法\nconst showNicknameModal = ref(false)\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\nconst showDeleteConfirm = ref(false)\n\n// 打开昵称弹窗\nconst openNicknameModal = () => {\n  nickname.value = store.state.userInfo?.username?.toString() || ''\n  showNicknameModal.value = true\n}\n\n// 打开手机号弹窗\nconst openPhoneModal = () => {\n  phoneManager.value = ''\n  phoneManager.code = ''\n  showPhoneModal.value = true\n}\n\n// 打开密码修改弹窗\nconst openPasswordModal = () => {\n  showPasswordModal.value = true\n}\n\n// 打开注销确认弹窗\nconst openDeleteConfirm = () => {\n  deleteAccount.password = ''\n  showDeleteConfirm.value = true\n}\n\n// 关闭弹窗的方法\nconst closeNicknameModal = () => {\n  showNicknameModal.value = false\n  nickname.value = ''\n}\n\nconst closePhoneModal = () => {\n  showPhoneModal.value = false\n  phoneManager.value = ''\n  phoneManager.code = ''\n}\n\nconst closePasswordModal = () => {\n  showPasswordModal.value = false\n}\n\nconst closeDeleteConfirm = () => {\n  showDeleteConfirm.value = false\n  deleteAccount.password = ''\n}\n\n// 处理成功回调\nconst handleNicknameSuccess = () => {\n  closeNicknameModal()\n  showToast('昵称修改成功', 'success')\n}\n\nconst handlePhoneSuccess = () => {\n  closePhoneModal()\n  showToast('手机号修改成功', 'success')\n}\n\nconst handlePasswordSuccess = () => {\n  closePasswordModal()\n  showToast('密码修改成功', 'success')\n}\n\nconst handleDeleteSuccess = () => {\n  showToast('账户已注销', 'success')\n  router.push('/login')\n}\n</script>\n\n<style scoped>\n/* 如果有任何样式，放在这里 */\n</style>"],"mappings":"AAoUA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,