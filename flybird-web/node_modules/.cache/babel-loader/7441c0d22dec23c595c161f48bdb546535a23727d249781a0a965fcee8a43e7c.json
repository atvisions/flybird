   onCancel: $setup.closeCreationModal\n  }, null, 8 /* PROPS */, [\"modelValue\", \"selected-ids\", \"loading\", \"onCancel\"])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createCommentVNode","_createVNode","$setup","resumeData","profileData","value","loading","bioExpanded","showBioExpandButton","getBioText","onSave","handleSave","onToggleBioExpand","toggleBioExpand","onEdit","handleEdit","completionData","onAiOptimize","handleAIOptimize","onImport","importResume","onPreview","previewResume","showAIOptimize","_createBlock","key","total_score","suggestions","remainingOptimizations","totalOptimizations","optimizationLoading","onStartOptimize","startAIOptimize","onConfirm","confirmOptimization","onCancel","cancelOptimization","activeModules","editModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","inactiveModules","onActivate","activateModule","modelValue","showEditBasicDialog","_cache","$event","basicFormData","onSubmit","handleBasicSubmit","showEditModal","module","currentModule","editFormData","handleSubmit","handleCancel","showCreationModal","selectedCreationIds","handleCreationsSelected","closeCreationModal"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <!-- 基本信息卡片 -->\n        <BasicInfo\n        :resumeData=\"profileData.resumeData.value || {}\"\n        :loading=\"loading\"\n        :bioExpanded=\"profileData.bioExpanded.value\"\n        :showBioExpandButton=\"profileData.showBioExpandButton.value\"\n        :getBioText=\"getBioText\"\n        @save=\"handleSave\"\n        @toggleBioExpand=\"toggleBioExpand\"\n        @edit=\"handleEdit\"\n      />\n  \n        <!-- 简历状态卡片 -->\n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :loading=\"loading\"\n          @ai-optimize=\"handleAIOptimize\"\n          @import=\"importResume\"\n          @preview=\"previewResume\"\n        />\n  \n        <!-- AI优化内容 -->\n        <AIDialog\n          v-if=\"showAIOptimize\"\n          :total-score=\"completionData.total_score\"\n          :suggestions=\"completionData.suggestions\"\n          :remaining-optimizations=\"remainingOptimizations\"\n          :total-optimizations=\"totalOptimizations\"\n          :loading=\"optimizationLoading\"\n          @start-optimize=\"startAIOptimize\"\n          @confirm=\"confirmOptimization\"\n          @cancel=\"cancelOptimization\"\n        />\n  \n        <!-- 常规模块列表 -->\n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"editModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n        />\n  \n        <!-- 添加更多模块 -->\n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 弹窗组件 -->\n      <EditBasicDialog\n        v-model=\"showEditBasicDialog\"\n        :initial-data=\"basicFormData\"\n        :loading=\"loading\"\n        @submit=\"handleBasicSubmit\"\n      />\n  \n      <EditDialog\n        v-model=\"showEditModal\"\n        :module=\"currentModule\"\n        :initial-form-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n        @cancel=\"handleCancel\"\n      />\n  \n      <CreationDialog\n        v-model=\"showCreationModal\"\n        :selected-ids=\"selectedCreationIds\"\n        :loading=\"loading\"\n        @submit=\"handleCreationsSelected\"\n        @cancel=\"closeCreationModal\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted, computed, watch, onBeforeUnmount } from 'vue'\n  import { ElMessage } from 'element-plus'\n  import store from '@/store'\n  import { profile } from '@/api/profile'\n  \n  // 组件导入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditDialog from './dialogs/EditDialog.vue'\n  import AIDialog from './dialogs/AIDialog.vue'\n  import CreationDialog from './dialogs/CreationDialog.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n \n  // Composables\n  import { useProfileData } from './composables/useProfileData'\n  import { useModules } from './composables/useModules'\n  import { useDialog } from './composables/useDialog'\n  import { useLoading } from './composables/useLoading'\n \n  // 初始化 profileData\n  const profileData = useProfileData()\n  const loading = ref(false)\n  const editFormData = ref({})\n  \n  // 添加调试日志\n  console.log('MyProfile profileData:', profileData)\n  \n  // 计算属性：获取处理后的个人简介文本\n  const getBioText = computed(() => {\n    if (!profileData.resumeData.value) return ''\n    return profileData.getBioText()\n  })\n  \n  // 处理保存\n  const handleSave = async (formData) => {\n    console.log('Handling save:', formData)\n    const success = await profileData.updateResumeData(formData)\n    if (success) {\n      await profileData.fetchInitialData()\n    }\n    return success\n  }\n  \n  // 处理展开/收起\n  const toggleBioExpand = () => {\n    console.log('Toggling bio expand')\n    profileData.toggleBioExpand()\n  }\n  \n  const {\n    activeModules,\n    inactiveModules,\n    currentModule,\n    editModule,\n    addItem,\n    removeModule,\n    activateModule\n  } = useModules()\n  \n  const {\n    showEditModal,\n    showAIModal,\n    showCreationModal,\n    aiSuggestions,\n    selectedCreationIds,\n    showAIOptimize,\n    closeCreationModal\n  } = useDialog()\n  \n  const { loading: actionLoading, withLoading } = useLoading()  // 重命名避免冲突\n  \n  // 基本信息编辑状态\n  const showEditBasicDialog = ref(false)\n  const basicFormData = ref({})\n  \n  // 处理编辑按钮点击\n  const handleEdit = () => {\n    if (!profileData.resumeData.value) return\n    basicFormData.value = {\n      name: profileData.resumeData.value.name || '',\n      gender: profileData.resumeData.value.gender || '',\n      phone: profileData.resumeData.value.phone || '',\n      email: profileData.resumeData.value.email || '',\n      location: profileData.resumeData.value.location || '',\n      birth_date: profileData.resumeData.value.birth_date || '',\n      personal_summary: profileData.resumeData.value.personal_summary || ''\n    }\n    console.log('编辑表单数据:', basicFormData.value)\n    showEditBasicDialog.value = true\n  }\n  \n  // 处理基本信息提交\n  const handleBasicSubmit = async (formData) => {\n    if (!formData) return\n\n    loading.value = true\n    try {\n      await profileData.updateResumeData(formData)\n      showEditBasicDialog.value = false\n      ElMessage.success('保存成功')\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 获取完整度数据\n  const fetchCompleteness = async () => {\n    try {\n      console.log('开始获取完整度数据')\n      const response = await profile.getCompleteness()\n      console.log('完整度接口响应:', response)\n      \n      if (response.data?.data) {\n        console.log('更新前的完整度数据:', completionData.value)\n        completionData.value = response.data.data\n        console.log('更新后的完整度数据:', completionData.value)\n      } else {\n        console.warn('完整度数据格式不正确:', response)\n      }\n    } catch (error) {\n      console.error('获取简历完整度失败:', error)\n    }\n  }\n  \n  // 监听完整度数据变化\n  watch(() => completionData.value, (newVal) => {\n    console.log('完整度数据变化:', newVal)\n  }, { deep: true })\n  \n  // AI优化次数\n  const remainingOptimizations = ref(3) // 默认每月3次\n  const totalOptimizations = ref(3)\n  \n  // 获取优化次数\n  const fetchOptimizationCount = async () => {\n    try {\n      const response = await profile.getOptimizationCount()\n      if (response.data?.data) {\n        remainingOptimizations.value = response.data.data.remaining\n        totalOptimizations.value = response.data.data.total\n      }\n    } catch (error) {\n      console.error('获取优化次数失败:', error)\n    }\n  }\n  \n  // 生命周期钩子\n  onMounted(async () => {\n    console.log('MyProfile mounted')\n    loading.value = true\n    try {\n      // 并行请求所有数据\n      await Promise.all([\n        profileData.fetchInitialData(),\n        fetchCompleteness(),\n        fetchOptimizationCount()\n      ])\n    } catch (error) {\n      console.error('初始化数据失败:', error)\n      ElMessage.error('加载数据失败，请刷新页面重试')\n    } finally {\n      loading.value = false\n    }\n  })\n  \n  // 监听数据变化，当基本信息更新时重新获取完整度\n  watch(() => profileData.resumeData.value, async () => {\n    try {\n      await fetchCompleteness()\n    } catch (error) {\n      console.error('更新完整度失败:', error)\n    }\n  }, { deep: true })\n  \n  // 处理函数\n  const handleSubmit = async (formData) => {\n    try {\n      await withLoading(async () => {\n        await profileData.updateResumeData(formData)\n        showEditModal.value = false\n        ElMessage.success('保存成功')\n      })\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请检查表单')\n    }\n  }\n  \n  const handleCancel = () => {\n    showEditModal.value = false\n  }\n  \n  \n  const importResume = async () => {\n    try {\n      await withLoading(async () => {\n        // TODO: 实现导入功能\n        ElMessage.info('功能开发中')\n      })\n    } catch (error) {\n      console.error('导入失败:', error)\n      ElMessage.error('导入失败，请稍后重试')\n    }\n  }\n  \n  const previewResume = () => {\n    // TODO: 实现预览功能\n    ElMessage.info('功能开发中')\n  }\n  // 处理头像更新\n\n  const handleCreationsSelected = async (selectedIds) => {\n    try {\n      await withLoading(async () => {\n        selectedCreationIds.value = selectedIds\n        closeCreationModal()\n        ElMessage.success('作品选择成功')\n      })\n    } catch (error) {\n      console.error('作品选择失败:', error)\n      ElMessage.error('作品选择失败，请稍后重试')\n    }\n  }\n  \n  const editItem = (moduleId, item) => {\n    editModule(moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n  }\n  \n  // 添加调试日志\n  watch(() => profileData.resumeData.value, (newVal) => {\n    console.log('Profile data changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 添加调试日志\n  watch(() => store.getters.getUserInfo, (newVal) => {\n    console.log('Store user info changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 处理组件卸载\n  onBeforeUnmount(() => {\n    // 清理状态\n    showEditBasicDialog.value = false\n    loading.value = false\n  })\n  \n  // 添加优化相关的状态\n  const optimizationResult = ref(null)\n  const showOptimizingDialog = ref(false)\n  \n  // 处理 AI 优化\n  const handleAIAction = async (action) => {\n    if (action === 'optimize') {\n      try {\n        loading.value = true\n        const response = await profile.getOptimizationPreview()\n        if (response.data?.code === 200) {\n          // 显示优化预览弹窗\n          optimizationResult.value = response.data.data\n          showOptimizingDialog.value = true\n        }\n      } catch (error) {\n        console.error('获取优化预览失败:', error)\n        ElMessage.error('获取优化预览失败，请重试')\n      } finally {\n        loading.value = false\n      }\n    }\n  }\n  \n  // 处理优化确认\n  const handleOptimizationConfirm = async (optimizationId) => {\n    try {\n      loading.value = true\n      const response = await profile.confirmOptimization(optimizationId)\n      if (response.data?.code === 200) {\n        ElMessage.success('简历优化成功！')\n        await fetchCompleteness() // 刷新完整度数据\n        showOptimizingDialog.value = false\n      }\n    } catch (error) {\n      console.error('确认优化失败:', error)\n      ElMessage.error('确认优化失败，请重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 处理优化取消\n  const handleOptimizationCancel = () => {\n    showOptimizingDialog.value = false\n  }\n  \n  // AI 优化相关状态\n  const showAIDialog = ref(false)\n  const showAIProcess = ref(false)\n  const showAIResult = ref(false)\n  const optimizationLoading = ref(false)\n  \n  // 处理 AI 优化流程\n  const handleAIOptimize = async () => {\n    try {\n      showAIDialog.value = true\n    } catch (error) {\n      console.error('获取 AI 建议失败:', error)\n      ElMessage.error('获取优化建议失败，请稍后重试')\n    }\n  }\n  \n  // 开始 AI 优化\n  const startAIOptimize = async () => {\n    try {\n      showAIDialog.value = false\n      showAIProcess.value = true\n      optimizationLoading.value = true\n      \n      // 获取优化预览\n      const response = await profile.getOptimizationPreview()\n      if (response.data?.code === 200) {\n        optimizationResult.value = response.data.data\n        showAIProcess.value = false\n        showAIResult.value = true\n      } else {\n        throw new Error(response.data?.message || '获取优化预览失败')\n      }\n    } catch (error) {\n      console.error('AI 优化失败:', error)\n      if (error.code === 'ECONNABORTED') {\n        ElMessage.error('AI 优化需要一些时间，请稍后重试')\n      } else {\n        ElMessage.error('AI 优化失败，请稍后重试')\n      }\n      showAIProcess.value = false\n      showAIDialog.value = true  // 失败时返回到建议页面\n    } finally {\n      optimizationLoading.value = false\n    }\n  }\n  \n  // 确认应用优化\n  const confirmOptimization = async (optimizationId) => {\n    try {\n      optimizationLoading.value = true\n      const response = await profile.confirmOptimization(optimizationId)\n      if (response.data?.code === 200) {\n        ElMessage.success('优化内容已应用')\n        showAIResult.value = false\n        // 刷新数据\n        await Promise.all([\n          profileData.fetchInitialData(),\n          fetchCompleteness()\n        ])\n      } else {\n        throw new Error(response.data?.message || '确认优化失败')\n      }\n    } catch (error) {\n      console.error('确认优化失败:', error)\n      ElMessage.error('确认优化失败，请重试')\n    } finally {\n      optimizationLoading.value = false\n    }\n  }\n  \n  // 取消优化\n  const cancelOptimization = () => {\n    showAIResult.value = false\n    ElMessage.info('已取消本次优化')\n  }\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CA8EM,OA9ENC,UA8EM,GA7EJC,mBAAA,CAmDM,OAnDNC,UAmDM,GAlDJC,mBAAA,YAAe,EACfC,YAAA,CASAC,MAAA;IARCC,UAAU,EAAED,MAAA,CAAAE,WAAW,CAACD,UAAU,CAACE,KAAK;IACxCC,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBC,WAAW,EAAEL,MAAA,CAAAE,WAAW,CAACG,WAAW,CAACF,KAAK;IAC1CG,mBAAmB,EAAEN,MAAA,CAAAE,WAAW,CAACI,mBAAmB,CAACH,KAAK;IAC1DI,UAAU,EAAEP,MAAA,CAAAO,UAAU;IACtBC,MAAI,EAAER,MAAA,CAAAS,UAAU;IAChBC,iBAAe,EAAEV,MAAA,CAAAW,eAAe;IAChCC,MAAI,EAAEZ,MAAA,CAAAa;0GAGPf,mBAAA,YAAe,EACfC,YAAA,CAMEC,MAAA;IALC,iBAAe,EAAEA,MAAA,CAAAc,cAAc;IAC/BV,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBW,YAAW,EAAEf,MAAA,CAAAgB,gBAAgB;IAC7BC,QAAM,EAAEjB,MAAA,CAAAkB,YAAY;IACpBC,SAAO,EAAEnB,MAAA,CAAAoB;2DAGZtB,mBAAA,YAAe,EAEPE,MAAA,CAAAqB,cAAc,I,cADtBC,YAAA,CAUEtB,MAAA;IApCVuB,GAAA;IA4BW,aAAW,EAAEvB,MAAA,CAAAc,cAAc,CAACU,WAAW;IACvCC,WAAW,EAAEzB,MAAA,CAAAc,cAAc,CAACW,WAAW;IACvC,yBAAuB,EAAEzB,MAAA,CAAA0B,sBAAsB;IAC/C,qBAAmB,EAAE1B,MAAA,CAAA2B,kBAAkB;IACvCvB,OAAO,EAAEJ,MAAA,CAAA4B,mBAAmB;IAC5BC,eAAc,EAAE7B,MAAA,CAAA8B,eAAe;IAC/BC,SAAO,EAAE/B,MAAA,CAAAgC,mBAAmB;IAC5BC,QAAM,EAAEjC,MAAA,CAAAkC;0HAnCnBpC,mBAAA,gBAsCQA,mBAAA,YAAe,EACfC,YAAA,CAOEC,MAAA;IANC,gBAAc,EAAEA,MAAA,CAAAmC,aAAa;IAC7B/B,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBQ,MAAI,EAAEZ,MAAA,CAAAoC,UAAU;IAChBC,KAAG,EAAErC,MAAA,CAAAsC,OAAO;IACZC,QAAM,EAAEvC,MAAA,CAAAwC,YAAY;IACpBC,UAAS,EAAEzC,MAAA,CAAA0C;yFAGd5C,mBAAA,YAAe,EACfC,YAAA,CAIEC,MAAA;IAHC,kBAAgB,EAAEA,MAAA,CAAA2C,eAAe;IACjCvC,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBwC,UAAQ,EAAE5C,MAAA,CAAA6C;4EAIf/C,mBAAA,UAAa,EACbC,YAAA,CAKEC,MAAA;IA9DR8C,UAAA,EA0DiB9C,MAAA,CAAA+C,mBAAmB;IA1DpC,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA0DiBjD,MAAA,CAAA+C,mBAAmB,GAAAE,MAAA;IAC3B,cAAY,EAAEjD