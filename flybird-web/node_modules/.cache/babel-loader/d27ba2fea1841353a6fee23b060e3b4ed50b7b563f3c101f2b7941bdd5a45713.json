 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"])]), _createCommentVNode(\" 工作经历编辑弹窗 \"), _ctx.currentModule?.type === 'work_experience' ? (_openBlock(), _createBlock(_component_EditWorkExperienceDialog, {\n    key: 0,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), _ctx.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock(_component_EditJobIntentionDialog, {\n    key: 1,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true)]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","_component_BasicInfo","resumeData","_ctx","profileData","value","loading","onEdit","handleEdit","_component_ResumeStatus","completionData","_component_ModuleList","activeModules","handleEditModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","onRemoveItem","removeItem","_component_AddModule","inactiveModules","onActivate","activateModule","_createCommentVNode","currentModule","type","_createBlock","_component_EditWorkExperienceDialog","key","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit","_component_EditJobIntentionDialog"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <BasicInfo\n        :resumeData=\"profileData.resumeData.value || {}\"\n        :loading=\"loading\"\n        @edit=\"handleEdit\"\n      />\n  \n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :loading=\"loading\"\n        />\n  \n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"handleEditModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n          @remove-item=\"removeItem\"\n        />\n  \n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n  \n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted } from 'vue'\n  import { useModules } from './composables/useModules'\n  import { profile } from '@/api/profile'\n  import { ElMessage, ElMessageBox } from 'element-plus'\n  \n  // 组件引入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  import EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\n  import EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\n  \n  // 状态管理\n  const { activeModules, currentModule, inactiveModules, handleEditModule, addItem, removeModule, activateModule } = useModules()\n  const showEditModal = ref(false)\n  const editFormData = ref({})\n  const loading = ref(false)\n  \n  // 基本信息数据\n  const profileData = ref({\n    resumeData: ref({}),\n    bioExpanded: ref(false),\n    showBioExpandButton: ref(false)\n  })\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {}\n  })\n  \n  // 获取数据\n  const fetchData = async () => {\n    try {\n      loading.value = true\n\n      // 获取基本信息\n      const basicResponse = await profile.getBasicInfo()\n      if (basicResponse.data?.code === 200) {\n        profileData.value.resumeData.value = basicResponse.data.data\n      }\n\n      // 获取完整度评分\n      const completenessResponse = await profile.getCompleteness()\n      if (completenessResponse.data?.code === 200) {\n        completionData.value = completenessResponse.data.data\n      }\n\n      // 获取求职意向数据\n      const intentionResponse = await profile.getJobIntention()\n      if (intentionResponse.data?.code === 200) {\n        const moduleIndex = activeModules.value.findIndex(m => m.type === 'job_intention')\n        if (moduleIndex > -1) {\n          activeModules.value[moduleIndex] = {\n            ...activeModules.value[moduleIndex],\n            data: intentionResponse.data.data\n          }\n        }\n      }\n\n      // 获取工作经历数据\n      const workResponse = await profile.getWorkExperiences()\n      if (workResponse.data?.code === 200) {\n        const moduleIndex = activeModules.value.findIndex(m => m.type === 'work_experience')\n        if (moduleIndex > -1) {\n          const workData = workResponse.data.data || []\n          activeModules.value[moduleIndex] = {\n            ...activeModules.value[moduleIndex],\n            data: workData\n          }\n        }\n      }\n\n    } catch (error) {\n      console.error('获取数据失败:', error)\n      ElMessage.error('获取数据失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 编辑基本信息\n  const handleEdit = () => {\n    // 基本信息编辑处理\n  }\n  \n  // 处理编辑模块\n  const handleEditModule = (moduleId) => {\n    console.log('编辑模块:', moduleId)\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    \n    // 如果是工作经历，清空表单数据\n    if (currentModule.value?.type === 'work_experience') {\n      editFormData.value = {}\n    } \n    // 如果是求职意向，使用现有数据\n    else if (currentModule.value?.type === 'job_intention') {\n      editFormData.value = { ...currentModule.value.data } || {}\n    }\n    \n    showEditModal.value = true\n    console.log('当前模块:', currentModule.value)\n    console.log('编辑表单数据:', editFormData.value)\n  }\n  \n  // 编辑具体项目（用于工作经历）\n  const editItem = (moduleId, item) => {\n    console.log('编辑具体项目:', moduleId, item)\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n    console.log('当前模块:', currentModule.value)\n    console.log('编辑表单数据:', editFormData.value)\n  }\n  \n  // 删除工作经历\n  const removeItem = async (moduleId, itemId) => {\n    try {\n      await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n        type: 'warning'\n      })\n      \n      if (moduleId === 'work_experience') {\n        await profile.deleteWorkExperience(itemId)\n        ElMessage.success('删除成功')\n        await fetchData()\n      }\n    } catch (error) {\n      if (error !== 'cancel') {\n        console.error('删除失败:', error)\n        ElMessage.error('删除失败')\n      }\n    }\n  }\n  \n  // 提交表单\n  const handleSubmit = async (data) => {\n    try {\n      if (currentModule.value?.type === 'work_experience') {\n        const response = await profile.updateWorkExperience(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      } else if (currentModule.value?.type === 'job_intention') {\n        const response = await profile.updateJobIntention(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      }\n    } catch (error) {\n      console.error('保存失败:', error)\n      if (error.response?.data?.errors) {\n        const errors = error.response.data.errors\n        const firstError = Object.values(errors)[0]\n        ElMessage.error(Array.isArray(firstError) ? firstError[0] : firstError)\n      } else {\n        ElMessage.error(error.message || '保存失败')\n      }\n    }\n  }\n  \n  onMounted(async () => {\n    await fetchData()\n  })\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;;;;;;;uBAD1CC,mBAAA,CA+CM,OA/CNC,UA+CM,GA9CJC,mBAAA,CA2BM,OA3BNC,UA2BM,GA1BJC,YAAA,CAIAC,oBAAA;IAHCC,UAAU,EAAEC,IAAA,CAAAC,WAAW,CAACF,UAAU,CAACG,KAAK;IACxCC,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBC,MAAI,EAAEJ,IAAA,CAAAK;gEAGPR,YAAA,CAGES,uBAAA;IAFC,iBAAe,EAAEN,IAAA,CAAAO,cAAc;IAC/BJ,OAAO,EAAEH,IAAA,CAAAG;2DAGZN,YAAA,CAQEW,qBAAA;IAPC,gBAAc,EAAER,IAAA,CAAAS,aAAa;IAC7BN,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBC,MAAI,EAAEJ,IAAA,CAAAU,gBAAgB;IACtBC,KAAG,EAAEX,IAAA,CAAAY,OAAO;IACZC,QAAM,EAAEb,IAAA,CAAAc,YAAY;IACpBC,UAAS,EAAEf,IAAA,CAAAgB,QAAQ;IACnBC,YAAW,EAAEjB,IAAA,CAAAkB;uHAGhBrB,YAAA,CAIEsB,oBAAA;IAHC,kBAAgB,EAAEnB,IAAA,CAAAoB,eAAe;IACjCjB,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChBkB,UAAQ,EAAErB,IAAA,CAAAsB;4EAIfC,mBAAA,cAAiB,EAETvB,IAAA,CAAAwB,aAAa,EAAEC,IAAI,0B,cAD3BC,YAAA,CAMEC,mCAAA;IAvCRC,GAAA;IAAAC,UAAA,EAmCiB7B,IAAA,CAAA8B,aAAa;IAnC9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAmCiBhC,IAAA,CAAA8B,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEhC,IAAA,CAAAiC,YAAY;IAC1B9B,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChB+B,QAAM,EAAElC,IAAA,CAAAmC;oFAtCjBZ,mBAAA,gBAyCMA,mBAAA,cAAiB,EAETvB,IAAA,CAAAwB,aAAa,EAAEC,IAAI,wB,cAD3BC,YAAA,CAMEU,iCAAA;IAhDRR,GAAA;IAAAC,UAAA,EA4CiB7B,IAAA,CAAA8B,aAAa;IA5C9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA4CiBhC,IAAA,CAAA8B,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEhC,IAAA,CAAAiC,YAAY;IAC1B9B,OAAO,EAAEH,IAAA,CAAAG,OAAO;IAChB+B,QAAM,EAAElC,IAAA,CAAAmC;oFA/CjBZ,mBAAA,e","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}