{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport { ref, computed, watch, onMounted } from 'vue';\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS, SALARY_OPTIONS } from '../constants/jobOptions';\nimport { cityOptions } from '../constants/cityOptions';\nimport { INDUSTRY_CATEGORIES } from '../constants/industryOptions';\n\n// 添加调试日志\n\nexport default {\n  __name: 'EditJobIntentionDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    console.log('求职状态选项:', JOB_STATUS_OPTIONS);\n    const props = __props;\n    const emit = __emit;\n\n    // 表单引用\n    const formRef = ref(null);\n\n    // 常用城市列表\n    const commonCities = ['北京', '上海', '广州', '深圳', '杭州', '南京', '成都', '武汉', '西安', '苏州', '天津', '重庆'];\n\n    // 城市选择\n    const selectedCities = ref([]);\n\n    // 表单数据\n    const form = ref({\n      job_type: '',\n      job_status: '',\n      expected_salary: '',\n      expected_city: '',\n      industries: []\n    });\n\n    // 处理城市变化\n    const handleCityChange = value => {\n      form.value.expected_city = value.join('-');\n    };\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      console.log('初始数据变化:', newVal);\n      if (newVal) {\n        // 转换旧的状态值到新的状态值\n        const convertOldStatus = oldStatus => {\n          const statusMap = {\n            'open': 'unemployed_looking',\n            'closed': 'employed_not_looking'\n          };\n          return statusMap[oldStatus] || oldStatus;\n        };\n        const formData = _objectSpread(_objectSpread(_objectSpread({}, form.value), newVal), {}, {\n          job_status: convertOldStatus(newVal.job_status) // 转换状态值\n        });\n        form.value = formData;\n        console.log('更新后的表单数据:', form.value);\n\n        // 解析城市数据\n        if (newVal.expected_city) {\n          selectedCities.value = newVal.expected_city.split('-');\n          console.log('解析后的城市数据:', selectedCities.value);\n        } else {\n          selectedCities.value = [];\n        }\n\n        // 解析行业数据\n        if (newVal.industries) {\n          form.value.industries = typeof newVal.industries === 'string' ? newVal.industries.split(',').filter(Boolean) : newVal.industries;\n          console.log('解析后的行业数据:', form.value.industries);\n        }\n      }\n    }, {\n      immediate: true\n    });\n\n    // 表单验证规则\n    const rules = {\n      job_type: [{\n        required: true,\n        message: '请选择工作类型',\n        trigger: 'change'\n      }],\n      job_status: [{\n        required: true,\n        message: '请选择求职状态',\n        trigger: 'change'\n      }]\n    };\n\n    // 对话框可见性\n    const dialogVisible = computed({\n      get: () => props.modelValue,\n      set: val => emit('update:modelValue', val)\n    });\n\n    // 提交表单\n    const handleSubmit = async () => {\n      if (!formRef.value) return;\n      try {\n        await formRef.value.validate();\n        console.log('表单验证通过');\n\n        // 处理行业数据\n        const formData = _objectSpread({}, form.value);\n\n        // 确保使用新的状态值\n        const statusMap = {\n          'open': 'unemployed_looking',\n          'closed': 'employed_not_looking'\n        };\n        formData.job_status = statusMap[formData.job_status] || formData.job_status;\n        if (Array.isArray(formData.industries)) {\n          formData.industries = formData.industries.join(',');\n        }\n        console.log('提交的数据:', formData);\n        emit('submit', formData);\n      } catch (error) {\n        console.error('表单验证失败:', error);\n      }\n    };\n    onMounted(() => {\n      console.log('组件挂载时的求职状态选项:', JOB_STATUS_OPTIONS);\n    });\n\n    // 临时定义选项用于测试\n    const LOCAL_JOB_STATUS_OPTIONS = [{\n      value: 'unemployed_looking',\n      label: '离职-找工作'\n    }, {\n      value: 'employed_not_looking',\n      label: '在职-暂不考虑'\n    }, {\n      value: 'employed_looking',\n      label: '在职-看机会'\n    }, {\n      value: 'student_internship',\n      label: '在校-找实习'\n    }, {\n      value: 'fresh_graduate',\n      label: '应届生'\n    }];\n    const __returned__ = {\n      props,\n      emit,\n      formRef,\n      commonCities,\n      selectedCities,\n      form,\n      handleCityChange,\n      rules,\n      dialogVisible,\n      handleSubmit,\n      LOCAL_JOB_STATUS_OPTIONS,\n      ref,\n      computed,\n      watch,\n      onMounted,\n      get JOB_TYPE_OPTIONS() {\n        return JOB_TYPE_OPTIONS;\n      },\n      get JOB_STATUS_OPTIONS() {\n        return JOB_STATUS_OPTIONS;\n      },\n      get SALARY_OPTIONS() {\n        return SALARY_OPTIONS;\n      },\n      get cityOptions() {\n        return cityOptions;\n      },\n      get INDUSTRY_CATEGORIES() {\n        return INDUSTRY_CATEGORIES;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","onMounted","JOB_TYPE_OPTIONS","JOB_STATUS_OPTIONS","SALARY_OPTIONS","cityOptions","INDUSTRY_CATEGORIES","console","log","props","__props","emit","__emit","formRef","commonCities","selectedCities","form","job_type","job_status","expected_salary","expected_city","industries","handleCityChange","value","join","initialData","newVal","convertOldStatus","oldStatus","statusMap","formData","_objectSpread","split","filter","Boolean","immediate","rules","required","message","trigger","dialogVisible","get","modelValue","set","val","handleSubmit","validate","Array","isArray","error","LOCAL_JOB_STATUS_OPTIONS","label"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditJobIntentionDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    title=\"编辑求职意向\"\n    v-model=\"dialogVisible\"\n    width=\"640px\"\n    :close-on-click-modal=\"false\"\n    class=\"edit-dialog\"\n    destroy-on-close\n  >\n    <el-form\n      ref=\"formRef\"\n      :model=\"form\"\n      :rules=\"rules\"\n      label-position=\"top\"\n      class=\"p-6\"\n    >\n      <div class=\"grid grid-cols-2 gap-6\">\n        <!-- 工作类型 -->\n        <el-form-item label=\"工作类型\" prop=\"job_type\" class=\"mb-0\">\n          <el-select\n            v-model=\"form.job_type\"\n            placeholder=\"请选择工作类型\"\n            clearable\n            class=\"w-full\"\n          >\n            <el-option\n              v-for=\"option in JOB_TYPE_OPTIONS\"\n              :key=\"option.value\"\n              :label=\"option.label\"\n              :value=\"option.value\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <!-- 求职状态 -->\n        <el-form-item label=\"求职状态\" prop=\"job_status\" class=\"mb-0\">\n          <el-select\n            v-model=\"form.job_status\"\n            placeholder=\"请选择求职状态\"\n            clearable\n            class=\"w-full\"\n          >\n            <el-option\n              v-for=\"option in LOCAL_JOB_STATUS_OPTIONS\"\n              :key=\"option.value\"\n              :label=\"option.label\"\n              :value=\"option.value\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <!-- 期望薪资 -->\n        <el-form-item label=\"期望薪资\" prop=\"expected_salary\" class=\"mb-0\">\n          <el-select\n            v-model=\"form.expected_salary\"\n            placeholder=\"请选择期望薪资\"\n            clearable\n            class=\"w-full\"\n          >\n            <el-option\n              v-for=\"option in SALARY_OPTIONS\"\n              :key=\"option.value\"\n              :label=\"option.label\"\n              :value=\"option.value\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <!-- 期望城市 -->\n        <el-form-item label=\"期望城市\" prop=\"expected_city\" class=\"mb-0\">\n          <el-select\n            v-model=\"selectedCities\"\n            multiple\n            filterable\n            allow-create\n            default-first-option\n            placeholder=\"请输入期望城市，可多选\"\n            clearable\n            collapse-tags\n            class=\"w-full\"\n            @change=\"handleCityChange\"\n          >\n            <el-option\n              v-for=\"city in commonCities\"\n              :key=\"city\"\n              :label=\"city\"\n              :value=\"city\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <!-- 期望行业 -->\n        <el-form-item label=\"期望行业\" prop=\"industries\" class=\"mb-0 col-span-2\">\n          <el-select\n            v-model=\"form.industries\"\n            multiple\n            filterable\n            allow-create\n            default-first-option\n            placeholder=\"请选择或输入期望行业\"\n            clearable\n            collapse-tags\n            class=\"w-full\"\n          >\n            <el-option-group\n              v-for=\"(category, key) in INDUSTRY_CATEGORIES\"\n              :key=\"key\"\n              :label=\"category.label\"\n            >\n              <el-option\n                v-for=\"industry in category.industries\"\n                :key=\"industry\"\n                :label=\"industry\"\n                :value=\"industry\"\n              />\n            </el-option-group>\n          </el-select>\n        </el-form-item>\n      </div>\n    </el-form>\n\n    <template #footer>\n      <div class=\"flex justify-end gap-2 px-6 py-4 bg-gray-50\">\n        <el-button \n          class=\"!text-gray-600 border-gray-300 hover:!text-primary hover:border-primary\"\n          @click=\"dialogVisible = false\"\n        >\n          取消\n        </el-button>\n        <el-button \n          type=\"primary\"\n          class=\"!bg-primary border-primary