{"ast":null,"code":"import { ref, reactive } from 'vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'EditJobIntentionDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const formRef = ref(null);\n\n    // 表单数据\n    const form = reactive({\n      position: props.initialData.position || '',\n      city: props.initialData.city || [],\n      salary_min: props.initialData.salary_min || null,\n      salary_max: props.initialData.salary_max || null,\n      availability: props.initialData.availability || '',\n      job_type: props.initialData.job_type || ''\n    });\n\n    // 表单验证规则\n    const rules = {\n      position: [{\n        required: true,\n        message: '请输入期望职位',\n        trigger: 'blur'\n      }],\n      city: [{\n        required: true,\n        message: '请选择期望城市',\n        trigger: 'change'\n      }],\n      availability: [{\n        required: true,\n        message: '请选择到岗时间',\n        trigger: 'change'\n      }],\n      job_type: [{\n        required: true,\n        message: '请选择工作类型',\n        trigger: 'change'\n      }]\n    };\n\n    // 到岗时间选项\n    const availabilityOptions = [{\n      label: '随时到岗',\n      value: 'immediately'\n    }, {\n      label: '一周内',\n      value: 'one_week'\n    }, {\n      label: '一个月内',\n      value: 'one_month'\n    }, {\n      label: '三个月内',\n      value: 'three_months'\n    }, {\n      label: '待商议',\n      value: 'negotiable'\n    }];\n\n    // 工作类型选项\n    const jobTypeOptions = [{\n      label: '全职',\n      value: 'full_time'\n    }, {\n      label: '兼职',\n      value: 'part_time'\n    }, {\n      label: '实习',\n      value: 'internship'\n    }, {\n      label: '自由职业',\n      value: 'freelance'\n    }];\n\n    // 城市选项（示例数据，实际应该从API获取）\n    const cityOptions = [{\n      value: 'beijing',\n      label: '北京',\n      children: [{\n        value: 'chaoyang',\n        label: '朝阳区'\n      }, {\n        value: 'haidian',\n        label: '海淀区'\n      }]\n    }\n    // ... 其他城市\n    ];\n\n    // 提交表单\n    const handleSubmit = async () => {\n      if (!formRef.value) return;\n      try {\n        await formRef.value.validate();\n        emit('submit', {\n          type: 'job_intention',\n          data: {\n            position: form.position,\n            city: form.city,\n            salary_min: form.salary_min,\n            salary_max: form.salary_max,\n            availability: form.availability,\n            job_type: form.job_type\n          }\n        });\n      } catch (error) {\n        console.error('表单验证失败:', error);\n        ElMessage.error('请完善必填信息');\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      formRef,\n      form,\n      rules,\n      availabilityOptions,\n      jobTypeOptions,\n      cityOptions,\n      handleSubmit,\n      ref,\n      reactive,\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","reactive","ElMessage","props","__props","emit","__emit","formRef","form","position","initialData","city","salary_min","salary_max","availability","job_type","rules","required","message","trigger","availabilityOptions","label","value","jobTypeOptions","cityOptions","children","handleSubmit","validate","type","data","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/EditJobIntentionDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"编辑求职意向\"\n    width=\"640px\"\n  >\n    <el-form\n      ref=\"formRef\"\n      :model=\"form\"\n      :rules=\"rules\"\n      label-width=\"100px\"\n      class=\"space-y-4\"\n    >\n      <!-- 期望职位 -->\n      <el-form-item label=\"期望职位\" prop=\"position\">\n        <el-input v-model=\"form.position\" placeholder=\"请输入期望职位\" />\n      </el-form-item>\n\n      <!-- 期望城市 -->\n      <el-form-item label=\"期望城市\" prop=\"city\">\n        <el-cascader\n          v-model=\"form.city\"\n          :options=\"cityOptions\"\n          placeholder=\"请选择期望城市\"\n        />\n      </el-form-item>\n\n      <!-- 期望薪资 -->\n      <el-form-item label=\"期望薪资\">\n        <div class=\"flex items-center space-x-2\">\n          <el-input-number\n            v-model=\"form.salary_min\"\n            :min=\"0\"\n            :max=\"form.salary_max || 999\"\n            placeholder=\"最低\"\n          />\n          <span class=\"text-gray-500\">K -</span>\n          <el-input-number\n            v-model=\"form.salary_max\"\n            :min=\"form.salary_min || 0\"\n            placeholder=\"最高\"\n          />\n          <span class=\"text-gray-500\">K</span>\n        </div>\n      </el-form-item>\n\n      <!-- 到岗时间 -->\n      <el-form-item label=\"到岗时间\" prop=\"availability\">\n        <el-select v-model=\"form.availability\" placeholder=\"请选择到岗时间\">\n          <el-option\n            v-for=\"item in availabilityOptions\"\n            :key=\"item.value\"\n            :label=\"item.label\"\n            :value=\"item.value\"\n          />\n        </el-select>\n      </el-form-item>\n\n      <!-- 工作类型 -->\n      <el-form-item label=\"工作类型\" prop=\"job_type\">\n        <el-select v-model=\"form.job_type\" placeholder=\"请选择工作类型\">\n          <el-option\n            v-for=\"item in jobTypeOptions\"\n            :key=\"item.value\"\n            :label=\"item.label\"\n            :value=\"item.value\"\n          />\n        </el-select>\n      </el-form-item>\n    </el-form>\n\n    <template #footer>\n      <div class=\"flex justify-end space-x-3\">\n        <el-button @click=\"$emit('update:modelValue', false)\">取消</el-button>\n        <el-button type=\"primary\" :loading=\"loading\" @click=\"handleSubmit\">\n          保存\n        </el-button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, reactive } from 'vue'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst formRef = ref(null)\n\n// 表单数据\nconst form = reactive({\n  position: props.initialData.position || '',\n  city: props.initialData.city || [],\n  salary_min: props.initialData.salary_min || null,\n  salary_max: props.initialData.salary_max || null,\n  availability: props.initialData.availability || '',\n  job_type: props.initialData.job_type || ''\n})\n\n// 表单验证规则\nconst rules = {\n  position: [\n    { required: true, message: '请输入期望职位', trigger: 'blur' }\n  ],\n  city: [\n    { required: true, message: '请选择期望城市', trigger: 'change' }\n  ],\n  availability: [\n    { required: true, message: '请选择到岗时间', trigger: 'change' }\n  ],\n  job_type: [\n    { required: true, message: '请选择工作类型', trigger: 'change' }\n  ]\n}\n\n// 到岗时间选项\nconst availabilityOptions = [\n  { label: '随时到岗', value: 'immediately' },\n  { label: '一周内', value: 'one_week' },\n  { label: '一个月内', value: 'one_month' },\n  { label: '三个月内', value: 'three_months' },\n  { label: '待商议', value: 'negotiable' }\n]\n\n// 工作类型选项\nconst jobTypeOptions = [\n  { label: '全职', value: 'full_time' },\n  { label: '兼职', value: 'part_time' },\n  { label: '实习', value: 'internship' },\n  { label: '自由职业', value: 'freelance' }\n]\n\n// 城市选项（示例数据，实际应该从API获取）\nconst cityOptions = [\n  {\n    value: 'beijing',\n    label: '北京',\n    children: [\n      { value: 'chaoyang', label: '朝阳区' },\n      { value: 'haidian', label: '海淀区' }\n    ]\n  },\n  // ... 其他城市\n]\n\n// 提交表单\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    await formRef.value.validate()\n    emit('submit', {\n      type: 'job_intention',\n      data: {\n        position: form.position,\n        city: form.city,\n        salary_min: form.salary_min,\n        salary_max: form.salary_max,\n        availability: form.availability,\n        job_type: form.job_type\n      }\n    })\n  } catch (error) {\n    console.error('表单验证失败:', error)\n    ElMessage.error('请完善必填信息')\n  }\n}\n</script> "],"mappings":"AAoFA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,OAAO,GAAGP,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMQ,IAAI,GAAGP,QAAQ,CAAC;MACpBQ,QAAQ,EAAEN,KAAK,CAACO,WAAW,CAACD,QAAQ,IAAI,EAAE;MAC1CE,IAAI,EAAER,KAAK,CAACO,WAAW,CAACC,IAAI,IAAI,EAAE;MAClCC,UAAU,EAAET,KAAK,CAACO,WAAW,CAACE,UAAU,IAAI,IAAI;MAChDC,UAAU,EAAEV,KAAK,CAACO,WAAW,CAACG,UAAU,IAAI,IAAI;MAChDC,YAAY,EAAEX,KAAK,CAACO,WAAW,CAACI,YAAY,IAAI,EAAE;MAClDC,QAAQ,EAAEZ,KAAK,CAACO,WAAW,CAACK,QAAQ,IAAI;IAC1C,CAAC;;IAED;IACA,MAAMC,KAAK,GAAG;MACZP,QAAQ,EAAE,CACR;QAAEQ,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAO,EACvD;MACDR,IAAI,EAAE,CACJ;QAAEM,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAS,EACzD;MACDL,YAAY,EAAE,CACZ;QAAEG,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAS,EACzD;MACDJ,QAAQ,EAAE,CACR;QAAEE,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,SAAS;QAAEC,OAAO,EAAE;MAAS;IAE5D;;IAEA;IACA,MAAMC,mBAAmB,GAAG,CAC1B;MAAEC,KAAK,EAAE,MAAM;MAAEC,KAAK,EAAE;IAAc,CAAC,EACvC;MAAED,KAAK,EAAE,KAAK;MAAEC,KAAK,EAAE;IAAW,CAAC,EACnC;MAAED,KAAK,EAAE,MAAM;MAAEC,KAAK,EAAE;IAAY,CAAC,EACrC;MAAED,KAAK,EAAE,MAAM;MAAEC,KAAK,EAAE;IAAe,CAAC,EACxC;MAAED,KAAK,EAAE,KAAK;MAAEC,KAAK,EAAE;IAAa,EACtC;;IAEA;IACA,MAAMC,cAAc,GAAG,CACrB;MAAEF,KAAK,EAAE,IAAI;MAAEC,KAAK,EAAE;IAAY,CAAC,EACnC;MAAED,KAAK,EAAE,IAAI;MAAEC,KAAK,EAAE;IAAY,CAAC,EACnC;MAAED,KAAK,EAAE,IAAI;MAAEC,KAAK,EAAE;IAAa,CAAC,EACpC;MAAED,KAAK,EAAE,MAAM;MAAEC,KAAK,EAAE;IAAY