ogs/EditWorkExperienceDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    v-model=\"modelValue\"\n    :title=\"initialData.id ? '编辑工作经历' : '添加工作经历'\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    destroy-on-close\n  >\n    <el-form\n      ref=\"formRef\"\n      :model=\"form\"\n      :rules=\"rules\"\n      label-position=\"top\"\n    >\n      <!-- 公司名称 -->\n      <el-form-item label=\"公司名称\" prop=\"company\">\n        <el-input v-model=\"form.company\" placeholder=\"请输入公司名称\" />\n      </el-form-item>\n\n      <!-- 职位名称 -->\n      <el-form-item label=\"职位名称\" prop=\"position\">\n        <el-input v-model=\"form.position\" placeholder=\"请输入职位名称\" />\n      </el-form-item>\n\n      <!-- 部门 -->\n      <el-form-item label=\"所在部门\" prop=\"department\">\n        <el-input v-model=\"form.department\" placeholder=\"请输入所在部门\" />\n      </el-form-item>\n\n      <!-- 在职时间 -->\n      <el-form-item label=\"在职时间\">\n        <div class=\"flex items-center space-x-4\">\n          <el-form-item prop=\"start_date\" class=\"mb-0 flex-1\">\n            <el-date-picker\n              v-model=\"form.start_date\"\n              type=\"date\"\n              placeholder=\"入职时间\"\n              style=\"width: 100%\"\n            />\n          </el-form-item>\n          \n          <span v-if=\"!form.is_current\">至</span>\n          \n          <el-form-item v-if=\"!form.is_current\" prop=\"end_date\" class=\"mb-0 flex-1\">\n            <el-date-picker\n              v-model=\"form.end_date\"\n              type=\"date\"\n              placeholder=\"离职时间\"\n              style=\"width: 100%\"\n            />\n          </el-form-item>\n        </div>\n        \n        <el-checkbox v-model=\"form.is_current\" class=\"mt-2\">\n          至今\n        </el-checkbox>\n      </el-form-item>\n\n      <!-- 工作描述 -->\n      <el-form-item label=\"工作描述\" prop=\"description\">\n        <el-input\n          v-model=\"form.description\"\n          type=\"textarea\"\n          :rows=\"4\"\n          placeholder=\"请详细描述您的工作职责和内容（至少50字）\"\n        />\n      </el-form-item>\n\n      <!-- 工作成就 -->\n      <el-form-item label=\"工作成就\">\n        <el-input\n          v-model=\"form.achievements\"\n          type=\"textarea\"\n          :rows=\"3\"\n          placeholder=\"请描述您在这份工作中取得的成就\"\n        />\n      </el-form-item>\n\n      <!-- 技术栈 -->\n      <el-form-item label=\"技术栈\">\n        <el-input\n          v-model=\"form.technologies\"\n          type=\"textarea\"\n          :rows=\"2\"\n          placeholder=\"请列出您使用的主要技术栈\"\n        />\n      </el-form-item>\n    </el-form>\n\n    <template #footer>\n      <div class=\"flex justify-end space-x-4\">\n        <el-button @click=\"handleClose\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { XMarkIcon } from '@heroicons/vue/24/outline'\nimport { ElMessage } from 'element-plus'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单引用\nconst formRef = ref(null)\n\n// 表单数据\nconst form = ref({\n  id: null,\n  company: '',\n  position: '',\n  department: '',\n  start_date: null,\n  end_date: null,\n  is_current: false,\n  description: '',\n  achievements: '',\n  technologies: ''\n})\n\n// 禁用未来日期\nconst disabledDate = (time) => {\n  return time.getTime() > Date.now()\n}\n\n// 提交表单\nconst handleSubmit = async () => {\n  if (!formRef.value) return\n  \n  try {\n    await formRef.value.validate()\n    \n    // 构造提交数据\n    const submitData = {\n      ...form.value,\n      start_date: form.value.start_date?.toISOString().split('T')[0],\n      end_date: form.value.is_current ? null : form.value.end_date?.toISOString().split('T')[0]\n    }\n\n    console.log('提交的表单数据:', submitData)\n    \n    await emit('submit', submitData)\n    handleClose()\n  } catch (error) {\n    if (error.response?.data?.errors) {\n      const errors = error.response.data.errors\n      const firstError = Object.values(errors)[0]\n      ElMessage.error(Array.isArray(firstError) ? firstError[0] : firstError)\n    } else if (error.message) {\n      ElMessage.error(error.message)\n    } else {\n      ElMessage.error('表单验证失败')\n    }\n    console.error('提交工作经历失败:', error)\n  }\n}\n\n// 表单验证规则\nconst rules = {\n  company: [\n    { required: true, message: '请输入公司名称', trigger: 'blur' }\n  ],\n  position: [\n    { required: true, message: '请输入职位名称', trigger: 'blur' }\n  ],\n  start_date: [\n    { required: true, message: '请选择入职时间', trigger: 'change' }\n  ],\n  description: [\n    { required: true, message: '请输入工作描述', trigger: 'blur' },\n    { min: 50, message: '工作描述至少需要50个字符', trigger: 'blur' }\n  ]\n}\n\n// 初始化表单数据\nconst initForm = () => {\n  form.value = {\n    id: props.initialData.id || null,\n    company: props.initialData.company || '',\n    position: props.initialData.position || '',\n    department: props.initialData.department || '',\n    start_date: props.initialData.start_date ? new Date(props.initialData.start_date) : null,\n    end_date: props.initialData.end_date ? new Date(props.initialData.end_date) : null,\n    is_current: props.initialData.is_current || false,\n    description: props.initialData.description || '',\n    achievements: props.initialData.achievements || '',\n    technologies: props.initialData.technologies || ''\n  }\n}\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    if (newVal) {\n      initForm()\n    }\n  },\n  { immediate: true }\n)\n\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\n\n// 根据屏幕宽度设置弹窗宽度\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 处理关闭对话框\nconst handleClose = () => {\n  formRef.value?.resetFields()\n  emit('update:modelValue', false)\n}\n\n// 日期快捷选项\nconst dateShortcuts = [\n  {\n    text: '最近一年',\n    value: () => {\n      const end = new Date()\n      const start = new Date()\n      start.setFullYear(start.getFullYear() - 1)\n      return [start, end]\n    }\n  },\n  {\n    text: '最近两年',\n    value: () => {\n      const end = new Date()\n      const start = new Date()\n      start.setFullYear(start.getFullYear() - 2)\n      return [start, end]\n    }\n  }\n]\n</script>\n\n<style>\n.edit-dialog {\n  @apply max-h-screen flex flex-col;\n}\n\n.edit-dialog :deep(.el-dialog__body) {\n  @apply flex-1 overflow-y-auto;\n}\n\n.edit-dialog :deep(.el-dialog__footer) {\n  @apply sticky bottom-0 bg-gray-50 z-10;\n}\n\n/* 移动端样式 */\n@media (max-width: 640px) {\n  .edit-dialog {\n    margin: 0 !important;\n  }\n\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    height: calc(100vh - 120px);\n    overflow-y: auto;\n  }\n\n  .el-form-item {\n    @apply mb-3;\n  }\n\n  /* 调整输入框在移动端的大小 */\n  input, select, textarea {\n    @apply text-base py-2.5;\n  }\n}\n\n/* 桌面端样式 */\n@media (min-width: 641px) {\n  .edit-dialog :deep(.el-dialog__body) {\n    @apply p-0;\n    max-height: calc(80vh - 120px);\n    overflow-y: auto;\n  }\n}\n</style> "],"mappings":";AAmGA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,SAAS,QAAQ,cAAa;;;;;;;;;;;;;;;;;IAEvC,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,OAAO,GAAGV,GAAG,CAAC,IAAI;;IAExB;IACA,MAAMW,IAAI,GAAGX,GAAG,CAAC;MACfY,EAAE,EAAE,IAAI;MACRC,OAAO,EAAE,EAAE;MACXC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,UAAU,EAAE,IAAI;MAChBC,QAAQ,EAAE,IAAI;MACdC,UAAU,EAAE,KAAK;MACjBC,WAAW,EAAE,EAAE;MACfC,YAAY,EAAE,EAAE;MAChBC,YAAY,EAAE;IAChB,CAAC;;IAED;IACA,MAAMC,YAAY,GAAIC,IAAI,IAAK;MAC7B,OAAOA,IAAI,CAACC,OAAO,CAAC,CAAC,GAAGC,IAAI,CAACC,GAAG,CAAC;IACnC;;IAEA;IACA,MAAMC,YAAY,GAAG,MAAAA,CAAA,KAA