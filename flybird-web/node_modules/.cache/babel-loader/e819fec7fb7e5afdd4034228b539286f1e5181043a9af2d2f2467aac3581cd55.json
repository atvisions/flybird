{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.find.js\";\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS } from '../constants/jobOptions';\nexport default {\n  __name: 'JobIntentionContent',\n  props: {\n    data: {\n      type: Object,\n      default: () => null\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 获取工作类型文本\n    const getJobTypeText = jobType => {\n      const option = JOB_TYPE_OPTIONS.find(opt => opt.value === jobType);\n      return option ? option.label : '未填写';\n    };\n\n    // 获取求职状态文本\n    const getJobStatusText = status => {\n      const option = JOB_STATUS_OPTIONS.find(opt => opt.value === status);\n      return option ? option.label : '未填写';\n    };\n\n    // 获取状态标签类型\n    const getStatusTagType = status => {\n      const typeMap = {\n        'unemployed_looking': 'danger',\n        'employed_not_looking': 'info',\n        'employed_looking': 'warning',\n        'student_internship': 'success',\n        'fresh_graduate': 'primary'\n      };\n      return typeMap[status] || 'info';\n    };\n\n    // 格式化行业为数组\n    const formatIndustriesArray = industries => {\n      if (!industries) return [];\n      return typeof industries === 'string' ? industries.split(',') : industries;\n    };\n    const __returned__ = {\n      props,\n      getJobTypeText,\n      getJobStatusText,\n      getStatusTagType,\n      formatIndustriesArray,\n      get JOB_TYPE_OPTIONS() {\n        return JOB_TYPE_OPTIONS;\n      },\n      get JOB_STATUS_OPTIONS() {\n        return JOB_STATUS_OPTIONS;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["JOB_TYPE_OPTIONS","JOB_STATUS_OPTIONS","props","__props","getJobTypeText","jobType","option","find","opt","value","label","getJobStatusText","status","getStatusTagType","typeMap","formatIndustriesArray","industries","split"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<template>\n  <div v-if=\"data\" class=\"job-intention-content\">\n    <!-- 工作类型和求职状态 -->\n    <div class=\"info-row\">\n      <div class=\"info-item\">\n        <div class=\"info-label\">工作类型</div>\n        <div class=\"info-value\">\n          <el-tag size=\"small\" type=\"info\">\n            {{ getJobTypeText(data.job_type) }}\n          </el-tag>\n        </div>\n      </div>\n      <div class=\"info-item\">\n        <div class=\"info-label\">求职状态</div>\n        <div class=\"info-value\">\n          <el-tag \n            size=\"small\" \n            :type=\"getStatusTagType(data.job_status)\"\n          >\n            {{ getJobStatusText(data.job_status) }}\n          </el-tag>\n        </div>\n      </div>\n    </div>\n\n    <!-- 期望薪资和期望城市 -->\n    <div class=\"info-row\">\n      <div class=\"info-item\">\n        <div class=\"info-label\">期望薪资</div>\n        <div class=\"info-value\">\n          <el-tag size=\"small\" type=\"success\" v-if=\"data.expected_salary\">\n            {{ data.expected_salary }}\n          </el-tag>\n          <span v-else class=\"text-gray-400\">未填写</span>\n        </div>\n      </div>\n      <div class=\"info-item\">\n        <div class=\"info-label\">期望城市</div>\n        <div class=\"info-value\">\n          <template v-if=\"data.expected_city\">\n            <el-tag\n              v-for=\"city in data.expected_city.split('-')\"\n              :key=\"city\"\n              class=\"city-tag\"\n              size=\"small\"\n              type=\"warning\"\n            >\n              {{ city }}\n            </el-tag>\n          </template>\n          <span v-else class=\"text-gray-400\">未填写</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- 期望行业 -->\n    <div class=\"info-row\">\n      <div class=\"info-item full-width\">\n        <div class=\"info-label\">期望行业</div>\n        <div class=\"info-value\">\n          <template v-if=\"data.industries\">\n            <el-tag\n              v-for=\"industry in formatIndustriesArray(data.industries)\"\n              :key=\"industry\"\n              class=\"industry-tag\"\n              size=\"small\"\n              type=\"primary\"\n            >\n              {{ industry }}\n            </el-tag>\n          </template>\n          <span v-else class=\"text-gray-400\">未填写</span>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div v-else class=\"empty-content\">\n    暂无内容，点击编辑添加\n  </div>\n</template>\n\n<script setup>\nimport { JOB_TYPE_OPTIONS, JOB_STATUS_OPTIONS } from '../constants/jobOptions'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: () => null\n  }\n})\n\n// 获取工作类型文本\nconst getJobTypeText = (jobType) => {\n  const option = JOB_TYPE_OPTIONS.find(opt => opt.value === jobType)\n  return option ? option.label : '未填写'\n}\n\n// 获取求职状态文本\nconst getJobStatusText = (status) => {\n  const option = JOB_STATUS_OPTIONS.find(opt => opt.value === status)\n  return option ? option.label : '未填写'\n}\n\n// 获取状态标签类型\nconst getStatusTagType = (status) => {\n  const typeMap = {\n    'unemployed_looking': 'danger',\n    'employed_not_looking': 'info',\n    'employed_looking': 'warning',\n    'student_internship': 'success',\n    'fresh_graduate': 'primary'\n  }\n  return typeMap[status] || 'info'\n}\n\n// 格式化行业为数组\nconst formatIndustriesArray = (industries) => {\n  if (!industries) return []\n  return typeof industries === 'string' ? industries.split(',') : industries\n}\n</script>\n\n<style scoped>\n.job-intention-content {\n  @apply space-y-4;\n}\n\n.info-row {\n  @apply flex flex-wrap gap-4;\n}\n\n.info-item {\n  @apply flex-1 min-w-[200px];\n}\n\n.info-item.full-width {\n  @apply w-full;\n}\n\n.info-label {\n  @apply text-sm text-gray-500 mb-1;\n}\n\n.info-value {\n  @apply flex flex-wrap gap-2;\n}\n\n.city-tag {\n  @apply mr-1;\n}\n\n.industry-tag {\n  @apply mr-1;\n}\n\n.empty-content {\n  @apply text-gray-400 text-center py-4;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .info-item {\n    @apply min-w-full;\n  }\n  \n  .info-row {\n    @apply gap-2;\n  }\n  \n  .info-value {\n    @apply gap-1;\n  }\n}\n\n:deep(.el-tag) {\n  margin-right: 4px;\n  margin-bottom: 4px;\n}\n\n:deep(.el-tag--small) {\n  height: 22px;\n  padding: 0 8px;\n  font-size: 12px;\n}\n</style> "],"mappings":";;AAkFA,SAASA,gBAAgB,EAAEC,kBAAkB,QAAQ,yBAAwB;;;;;;;;;;;;;IAE7E,MAAMC,KAAK,GAAGC,OAAA;;IAOd;IACA,MAAMC,cAAc,GAAIC,OAAO,IAAK;MAClC,MAAMC,MAAM,GAAGN,gBAAgB,CAACO,IAAI,CAACC,GAAG,IAAIA,GAAG,CAACC,KAAK,KAAKJ,OAAO;MACjE,OAAOC,MAAM,GAAGA,MAAM,CAACI,KAAK,GAAG,KAAI;IACrC;;IAEA;IACA,MAAMC,gBAAgB,GAAIC,MAAM,IAAK;MACnC,MAAMN,MAAM,GAAGL,kBAAkB,CAACM,IAAI,CAACC,GAAG,IAAIA,GAAG,CAACC,KAAK,KAAKG,MAAM;MAClE,OAAON,MAAM,GAAGA,MAAM,CAACI,KAAK,GAAG,KAAI;IACrC;;IAEA;IACA,MAAMG,gBAAgB,GAAID,MAAM,IAAK;MACnC,MAAME,OAAO,GAAG;QACd,oBAAoB,EAAE,QAAQ;QAC9B,sBAAsB,EAAE,MAAM;QAC9B,kBAAkB,EAAE,SAAS;QAC7B,oBAAoB,EAAE,SAAS;QAC/B,gBAAgB,EAAE;MACpB;MACA,OAAOA,OAAO,CAACF,MAAM,CAAC,IAAI,MAAK;IACjC;;IAEA;IACA,MAAMG,qBAAqB,GAAIC,UAAU,IAAK;MAC5C,IAAI,CAACA,UAAU,EAAE,OAAO,EAAC;MACzB,OAAO,OAAOA,UAAU,KAAK,QAAQ,GAAGA,UAAU,CAACC,KAAK,CAAC,GAAG,CAAC,GAAGD,UAAS;IAC3E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}