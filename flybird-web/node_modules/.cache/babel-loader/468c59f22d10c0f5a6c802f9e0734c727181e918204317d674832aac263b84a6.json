CameraIcon class=\"w-8 h-8 text-white\" />\n                </div>\n                <input\n                ref=\"fileInput\"\n                type=\"file\"\n                accept=\"image/*\"\n                class=\"hidden\"\n                @change=\"handleFileChange\"\n                />\n          </div>\n  \n          <!-- 用户信息 -->\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center justify-between mb-3\">\n              <h2 class=\"text-lg font-medium text-gray-900\">\n                <template v-if=\"resumeData.name\">\n                  {{ resumeData.name }}\n                </template>\n                <span v-else class=\"text-sm text-gray-400\">未设置姓名</span>\n              </h2>\n              <button\n                @click=\"$emit('edit')\"\n                class=\"inline-flex items-center px-2.5 py-1 text-xs font-medium text-primary-600 hover:text-primary-700 border border-primary-600 hover:border-primary-700 rounded\"\n              >\n                <PencilIcon class=\"w-3.5 h-3.5 mr-1\" />\n                编辑资料\n              </button>\n            </div>\n  \n            <!-- 基本信息列表 -->\n            <div class=\"grid grid-cols-2 gap-3\">\n              <!-- 手机号 -->\n              <div class=\"flex items-center text-gray-600\">\n                <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.phone\">\n                  <span class=\"text-sm truncate\">{{ resumeData.phone }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置手机号</span>\n              </div>\n  \n              <!-- 邮箱 -->\n              <div class=\"flex items-center text-gray-600\">\n                <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.email\">\n                  <span class=\"text-sm truncate\">{{ resumeData.email }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置邮箱</span>\n              </div>\n  \n              <!-- 所在地 -->\n              <div class=\"flex items-center text-gray-600\">\n                <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.location\">\n                  <span class=\"text-sm truncate\">{{ resumeData.location }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置所在地</span>\n              </div>\n  \n              <!-- 求职状态 -->\n              <div class=\"flex items-center text-gray-600\">\n                <BriefcaseIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.jobStatus\">\n                  <span class=\"text-sm truncate\">{{ resumeData.jobStatus }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置求职状态</span>\n              </div>\n  \n              <!-- 工作年限 -->\n              <div class=\"flex items-center text-gray-600\">\n                <ClockIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.workYears\">\n                  <span class=\"text-sm truncate\">{{ resumeData.workYears }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置工作年限</span>\n              </div>\n  \n              <!-- 期望薪资 -->\n              <div class=\"flex items-center text-gray-600\">\n                <CurrencyYenIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.expectedSalary\">\n                  <span class=\"text-sm truncate\">{{ resumeData.expectedSalary }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置期望薪资</span>\n              </div>\n            </div>\n  \n            <!-- 个人简介 -->\n            <div class=\"mt-3\">\n              <div class=\"flex items-center text-gray-600 mb-1\">\n                <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm font-medium\">个人简介</span>\n              </div>\n              <template v-if=\"resumeData.bio\">\n                <p class=\"text-sm text-gray-600 leading-relaxed line-clamp-2\">\n                  {{ resumeData.bio }}\n                </p>\n              </template>\n              <p v-else class=\"text-sm text-gray-400 leading-relaxed\">\n                未设置个人简介\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed, nextTick } from 'vue'\nimport { ElMessage , ElLoading } from 'element-plus'\nimport request, { API_PATHS } from '@/utils/request'  \nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nconst store = useStore()\nconst loadingInstance = ref(null)\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon\n} from '@heroicons/vue/24/outline'\n// 从 store 获取头像\nconst avatarUrl = computed(() => store.getters.getUserAvatar)\n// 处理图片加载错误\nconst handleImageError = (e) => {\n  e.target.src = defaultAvatarImage\n}\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:resumeData'])\nconst fileInput = ref(null)\n\n// 处理文件上传\nconst handleFileChange = async (event) => {\n  if (!event.target.files.length) return\n\n  try {\n    // 文件验证\n    const file = event.target.files[0]\n    \n    // 文件类型验证\n    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif']\n    if (!allowedTypes.includes(file.type)) {\n      ElMessage.error('请上传 JPG、PNG 或 GIF 格式的图片')\n      return\n    }\n\n    // 文件大小验证 (5MB)\n    const maxSize = 5 * 1024 * 1024\n    if (file.size > maxSize) {\n      ElMessage.error('图片大小不能超过 5MB')\n      return\n    }\n\n    loadingInstance.value = ElLoading.service({\n      target: '.avatar-upload',\n      text: '上传中...'\n    })\n\n    // 准备表单数据\n    const formData = new FormData()\n    formData.append('file', file)  // 修改这里，key 改为 'file'\n\n    // 添加调试日志\n    console.log('Uploading file:', {\n      name: file.name,\n      type: file.type,\n      size: file.size,\n      formData: Array.from(formData.entries())\n    })\n\n    // 获取 token\n    const token = localStorage.getItem('access_token')\n    if (!token) {\n      throw new Error('未找到认证信息')\n    }\n\n    const response = await request({\n      url: '/api/v1/users/profile/avatar/upload/',\n      method: 'post',\n      data: formData,\n      headers: {\n        'Authorization': `Bearer ${token}`,\n        'Content-Type': 'multipart/form-data',\n        'Accept': 'application/json'\n      },\n      onUploadProgress: (progressEvent) => {\n        const percentCompleted = Math.round((progressEvent.loaded * 100) / progressEvent.total)\n        console.log('Upload progress:', percentCompleted + '%')\n      }\n    })\n\n    console.log('Upload response:', response)\n\n    if (response.data) {\n      const avatarPath = response.data.avatar_url || response.data.url\n      if (!avatarPath) {\n        throw new Error('上传成功但未获取到头像路径')\n      }\n\n      // 更新 store 中的用户信息\n      store.commit('SET_USER_INFO', {\n        avatar: avatarPath\n      })\n\n      // 更新本地数据\n      emit('update:resumeData', {\n        ...props.resumeData,\n        avatar: avatarPath\n      })\n\n      ElMessage.success('头像上传成功')\n    } else {\n      throw new Error(response.message || '上传失败')\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error)\n    if (error.response) {\n      console.error('Error details:', {\n        status: error.response.status,\n        data: error.response.data,\n        headers: error.response.headers,\n        config: error.config\n      })\n    }\n    \n    let errorMessage = '头像上传失败，请重试'\n    if (error.response?.status === 500) {\n      errorMessage = '服务器处理失败，请检查文件格式和大小'\n    } else if (error.response?.status === 413) {\n      errorMessage = '文件太大，请选择较小的图片'\n    } else if (error.response?.status === 401) {\n      errorMessage = '登录已过期，请重新登录'\n    } else if (error.response?.data?.message) {\n      errorMessage = error.response.data.message\n    }\n    \n    ElMessage.error(errorMessage)\n  } finally {\n    loadingInstance.value?.close()\n    loadingInstance.value = null\n    event.target.value = ''\n  }\n}\n\n\n// 触发文件选择\nconst triggerUpload = () => {\n  fileInput.value.click()\n}\n</script>"],"mappings":";AA6HA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,QAAQ,KAAI;AAC5C,SAASC,SAAS,EAAGC,SAAS,QAAQ,cAAa;AACnD,OAAOC,OAAO,IAAIC,SAAS,QAAQ,iBAAiB;AACpD,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAG9B,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAS,QACJ,2BAA0B;AACjC;;;;;;;;;;;;;;;;;IAbA,MAAMC,KAAK,GAAGV,QAAQ,CAAC;IACvB,MAAMW,eAAe,GAAGnB,GAAG,CAAC,IAAI;IAahC,MAAMoB,SAAS,GAAGnB,QAAQ,CAAC,MAAMiB,KAAK,CAACG,OAAO,CAACC,aAAa;IAC5D;IACA,MAAMC,gBAAgB,GAAIC,CAAC,IAAK;MAC9BA,CAAC,CAACC,MAAM,CAACC,GAAG,GAAGnB,kBAAiB;IAClC;IACA,MAAMoB,KAAK,GAAGC,OAAA;IAQd,MAAMC,IAAI,GAAGC,MAAA;IACb,MAAMC,SAAS,GAAG/B,GAAG,CAAC,IAAI;;IAE1B;IACA,MAAMgC,gBAAgB,GAAG,MAAOC,KAAK,IAAK;MACxC,IAAI,CAACA,KAAK,CAACR,MAAM,CAACS,KAAK,CAACC,MAAM,EAAE;MAEhC,IAAI;QACF;QACA,MAAMC,IAAI,GAAGH,KAAK,CAACR,MAAM,CAACS,KAAK,CAAC,CAAC;;QAEjC;QACA,MAAMG,YAAY,GAAG,CAAC,YAAY,EAAE,WAAW,EAAE,WAAW;QAC5D,IAAI,CAACA,YAAY,CAACC,QAAQ,CAACF,IAAI,CAACG,IAAI,CAAC,EAAE;UACrCpC,SAAS,CAACqC,KAAK,CAAC,yBAAyB;UACzC;QACF;;QAEA;QACA,MAAMC,OAAO,GAAG,CAAC,GAAG,IAAI,GAAG,IAAG;QAC9B,IAAIL,IAAI,CAACM,IAAI,GAAGD,OAAO,EAAE;UACvBtC,SAAS,CAACqC,KAAK,CAAC,cAAc;UAC9B;QACF;QAEArB,eAAe,CAACwB,KAAK,GAAGvC,SAAS,CAACwC,OAAO,CAAC;UACxCnB,MAAM,EAAE,gBAAgB;UACxBoB,IAAI,EAAE;QACR,CAAC;;QAED;QACA,MAAMC,QAAQ,GAAG,IAAIC,QAAQ,CAAC;QAC9BD,QAAQ,CAACE,MAAM,CAAC,MAAM,EAAEZ,IAAI,CAAC,EAA