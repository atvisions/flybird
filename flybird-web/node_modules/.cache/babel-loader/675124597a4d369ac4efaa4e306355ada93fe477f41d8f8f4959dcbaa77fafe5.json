d || null,\n      name: newVal.name || '',\n      link: newVal.link || '',\n      description: newVal.description || ''\n    }\n  }\n}, { immediate: true, deep: true })\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n\n// 验证表单\nconst validateForm = () => {\n  let isValid = true\n  errors.value = {\n    name: '',\n    link: '',\n    description: ''\n  }\n\n  if (!form.value.name?.trim()) {\n    errors.value.name = '请输入作品名称'\n    isValid = false\n  }\n\n  if (form.value.link && !isValidUrl(form.value.link)) {\n    errors.value.link = '请输入有效的链接地址'\n    isValid = false\n  }\n\n  return isValid\n}\n\n// 验证 URL\nconst isValidUrl = (url) => {\n  try {\n    new URL(url)\n    return true\n  } catch {\n    return false\n  }\n}\n\n// 提交处理\nconst handleSubmit = () => {\n  if (!validateForm()) {\n    return\n  }\n\n  const formData = {\n    ...form.value,\n    name: form.value.name.trim(),\n    link: form.value.link?.trim() || '',\n    description: form.value.description?.trim() || ''\n  }\n\n  // 如果是新建，不传 id\n  if (!formData.id) {\n    delete formData.id\n  }\n\n  emit('submit', formData)\n}\n</script> "],"mappings":";AA0HA,SAASA,GAAG,EAAEC,KAAK,QAAQ,KAAI;AAC/B,SACEC,MAAM,EACNC,WAAW,EACXC,WAAW,EACXC,cAAc,EACdC,eAAc,QACT,iBAAgB;AACvB,SAASC,SAAS,QAAQ,2BAA0B;;;;;;;;;;;;;;;;;IAEpD,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,IAAI,GAAGZ,GAAG,CAAC;MACfa,EAAE,EAAE,IAAI;MACRC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,WAAW,EAAE;IACf,CAAC;;IAED;IACA,MAAMC,MAAM,GAAGjB,GAAG,CAAC;MACjBc,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,WAAW,EAAE;IACf,CAAC;;IAED;IACAf,KAAK,CAAC,MAAMO,KAAK,CAACU,WAAW,EAAGC,MAAM,IAAK;MACzC,IAAIA,MAAM,EAAE;QACVP,IAAI,CAACQ,KAAK,GAAG;UACXP,EAAE,EAAEM,MAAM,CAACN,EAAE,IAAI,IAAI;UACrBC,IAAI,EAAEK,MAAM,CAACL,IAAI,IAAI,EAAE;UACvBC,IAAI,EAAEI,MAAM,CAACJ,IAAI,IAAI,EAAE;UACvBC,WAAW,EAAEG,MAAM,CAACH,WAAW,IAAI;QACrC;MACF;IACF,CAAC,EAAE;MAAEK,SAAS,EAAE,IAAI;MAAEC,IAAI,EAAE;IAAK,CAAC;IAElC,MAAMC,WAAW,GAAGA,CAAA,KAAM;MACxBb,IAAI,CAAC,mBAAm