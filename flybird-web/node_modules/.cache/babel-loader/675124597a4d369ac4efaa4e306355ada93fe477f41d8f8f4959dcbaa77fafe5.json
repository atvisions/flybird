     }\n    };\n\n    // 提交处理\n    const handleSubmit = () => {\n      if (!validateForm()) {\n        return;\n      }\n      const formData = _objectSpread(_objectSpread({}, form.value), {}, {\n        name: form.value.name.trim(),\n        link: form.value.link?.trim() || '',\n        description: form.value.description?.trim() || ''\n      });\n\n      // 如果是新建，不传 id\n      if (!formData.id) {\n        delete formData.id;\n      }\n      emit('submit', formData);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      form,\n      errors,\n      handleClose,\n      validateForm,\n      isValidUrl,\n      handleSubmit,\n      ref,\n      watch,\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get TransitionChild() {\n        return TransitionChild;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","Dialog","DialogPanel","DialogTitle","TransitionRoot","TransitionChild","XMarkIcon","props","__props","emit","__emit","form","id","name","link","description","errors","initialData","newVal","value","immediate","deep","handleClose","validateForm","isValid","trim","isValidUrl","url","URL","handleSubmit","formData","_objectSpread"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/EditPortfolioDialog.vue"],"sourcesContent":["<template>\n  <TransitionRoot appear :show=\"modelValue\" as=\"template\">\n    <Dialog as=\"div\" @close=\"handleClose\" class=\"relative z-50\">\n      <TransitionChild\n        as=\"template\"\n        enter=\"duration-300 ease-out\"\n        enter-from=\