        <!-- 进度条 -->\n        <div class=\"bg-gray-200 rounded-full h-2.5 mb-4\">\n          <div \n            class=\"h-2.5 rounded-full transition-all duration-500\"\n            :class=\"progressColorClass\"\n            :style=\"{ width: `${completionRate}%` }\"\n          ></div>\n        </div>\n  \n        <!-- 操作按钮 -->\n        <div class=\"grid grid-cols-3 gap-3\">\n          <button\n            @click=\"$emit('ai-optimize')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 transition-all duration-200 shadow-sm\"\n          >\n            <SparklesIcon class=\"w-4 h-4 mr-1.5\" />\n            AI优化\n          </button>\n  \n          <button\n            @click=\"$emit('import')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <ArrowDownTrayIcon class=\"w-4 h-4 mr-1.5\" />\n            导入简历\n          </button>\n  \n          <button\n            @click=\"$emit('preview')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <EyeIcon class=\"w-4 h-4 mr-1.5\" />\n            预览简历\n          </button>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\n  import { computed } from 'vue'\n  import { \n    SparklesIcon,\n    ArrowDownTrayIcon,\n    EyeIcon \n  } from '@heroicons/vue/24/outline'\n  \n  const props = defineProps({\n    completionData: {\n      type: Object,\n      required: true,\n      default: () => ({\n        total_score: 0,\n        dimensions: {},\n        suggestions: []\n      })\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  })\n  \n  defineEmits(['ai-optimize', 'import', 'preview'])\n  \n  // 总分 - 保留一位小数\n  const totalScore = computed(() => {\n    console.log('计算总分，原始数据:', props.completionData)\n    const score = props.completionData?.total_score || 0\n    const formattedScore = Number(score.toFixed(1))\n    console.log('格式化后的总分:', formattedScore)\n    return formattedScore\n  })\n  \n  // 维度数据 - 保留整数\n  const dimensions = computed(() => {\n    console.log('计算维度数据，原始数据:', props.completionData?.dimensions)\n    const dims = props.completionData?.dimensions || {}\n    const formattedDims = Object.entries(dims).reduce((acc, [key, value]) => {\n      acc[key] = {\n        ...value,\n        score: Math.round(value.score || 0)\n      }\n      return acc\n    }, {})\n    console.log('格式化后的维度数据:', formattedDims)\n    return formattedDims\n  })\n  \n  // 建议\n  const suggestions = computed(() => {\n    console.log('获取建议数据:', props.completionData?.suggestions)\n    return props.completionData?.suggestions || []\n  })\n  \n  // 维度名称映射\n  const getDimensionName = (key) => {\n    const nameMap = {\n      basic_info: '基本信息',\n      experience: '工作经历',\n      capability: '能力素质',\n      achievement: '个人成就'\n    }\n    return nameMap[key] || key\n  }\n  \n  // 进度条颜色\n  const progressColorClass = computed(() => {\n    const score = totalScore.value\n    if (score >= 80) return 'bg-green-500'\n    if (score >= 50) return 'bg-yellow-500'\n    return 'bg-red-500'\n  })\n  \n  // 文字颜色\n  const progressTextColorClass = computed(() => {\n    const score = totalScore.value\n    if (score >= 80) return 'text-green-600'\n    if (score >= 50) return 'text-yellow-600'\n    return 'text-red-600'\n  })\n  </script>\n\n<style scoped>\n/* 添加按钮悬停效果 */\nbutton {\n  position: relative;\n  overflow: hidden;\n}\n\nbutton::after {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 100%;\n  height: 100%;\n  background-color: rgba(255, 255, 255, 0.1);\n  transform: translate(-50%, -50%) scale(0);\n  border-radius: inherit;\n  transition: transform 0.3s ease;\n}\n\nbutton:hover::after {\n  transform: translate(-50%, -50%) scale(1.5);\n}\n\n/* 渐变进度条效果 */\n.bg-green-500 {\n  background: linear-gradient(90deg, #10B981 0%, #34D399 100%);\n}\n\n.bg-yellow-500 {\n  background: linear-gradient(90deg, #F59E0B 0%, #FBBF24 100%);\n}\n\n.bg-red-500 {\n  background: linear-gradient(90deg, #EF4444 0%, #F87171 100%);\n}\n</style>"],"mappings":";;EAESA,KAAK,EAAC;AAA4B;;EAChCA,KAAK,EAAC;AAAK;;EAETA,KAAK,EAAC;AAAwC;;EAQ9CA,KAAK,EAAC;AAAqC;;EAS3CA,KAAK,EAAC;AAAwB;;uBApBvCC,mBAAA,CA8CM,OA9CNC,UA8CM,GA7CJC,mBAAA,CA4CM,OA5CNC,UA4CM,GA3CJC,mBAAA,YAAe,EACfF,mBAAA,CAKM,OALNG,UAKM,G,0BAJJH,mBAAA,CAA0D;IAAtDH,KAAK,EAAC;EAAqC,GAAC,OAAK,sBACrDG,mBAAA,CAEO;IAFDH,KAAK,EAPrBO,eAAA,EAOsB,uBAAuB,EAASC,MAAA,CAAAC,sBAAsB;sBAC7DC,IAAA,CAAAC,cAAc,IAAG,IACtB,uB,GAGFN,mBAAA,SAAY,EACZF,mBAAA,CAMM,OANNS,UAMM,GALJT,mBAAA,CAIO;IAHLH,KAAK,EAfjBO,eAAA,EAekB,gDAAgD,EAC9CC,MAAA,CAAAK,kBAAkB;IACzBC,KAAK,EAjBlBC,eAAA;MAAAC,KAAA,KAiBgCN,IAAA,CAAAC,cAAc;IAAA;oCAItCN,mBAAA,UAAa,EACbF,mBAAA,CAwBM,OAxBNc,UAwBM,GAvBJd,mBAAA,CAMS;IALNe,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEV,IAAA,CAAAW,KAAK;IACbrB,KAAK,EAAC;MAENsB,YAAA,CAAuCd,MAAA;IAAzBR,KAAK,EAAC;EAAgB,I,0BA3BhDuB,gBAAA,CA2BmD,QAEzC,G,GAEApB,mBAAA,CAMS;IALNe,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEV,IAAA,CAAAW,KAAK;IACbrB,KAAK,EAAC;MAENsB,YAAA,CAA4Cd,MAAA;IAAzBR,KAAK,EAAC;EAAgB,I,0BAnCrDuB,gBAAA,CAmCwD,QAE9C,G,GAEApB,mBAAA,CAMS;IALNe,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEV,IAAA,CAAAW,KAAK;IACbrB,KAAK,EAAC;MAENsB,YAAA,CAAkCd,MAAA;IAAzBR,KAAK,EAAC;EAAgB,I,0BA3C3CuB,gBAAA,CA2C8C,QAEpC,G","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}