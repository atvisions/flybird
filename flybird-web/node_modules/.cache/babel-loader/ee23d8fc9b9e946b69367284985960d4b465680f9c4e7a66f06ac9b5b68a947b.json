{"ast":null,"code":"import { BriefcaseIcon, UserCircleIcon, CurrencyYenIcon, MapPinIcon, BuildingOfficeIcon, DocumentPlusIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'JobIntentionContent',\n  props: {\n    data: {\n      type: Object,\n      default: null\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 获取工作类型标签\n    const getJobTypeLabel = value => {\n      const typeMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return typeMap[value] || '未设置';\n    };\n\n    // 获取求职状态标签\n    const getJobStatusLabel = value => {\n      const statusMap = {\n        'unemployed_looking': '离职-找工作',\n        'employed_not_looking': '在职-暂不考虑',\n        'employed_looking': '在职-看机会',\n        'student_internship': '在校-找实习',\n        'fresh_graduate': '应届生'\n      };\n      return statusMap[value] || '未设置';\n    };\n\n    // 获取薪资标签\n    const getSalaryLabel = value => {\n      if (!value) return '未设置';\n      return `${value}K/月`;\n    };\n\n    // 格式化城市\n    const formatCity = city => {\n      if (!city) return '未设置';\n      return city.split('-').join('、');\n    };\n\n    // 格式化行业\n    const formatIndustries = industries => {\n      if (!industries) return '未设置';\n      return industries.split(',').join('、');\n    };\n    const __returned__ = {\n      props,\n      getJobTypeLabel,\n      getJobStatusLabel,\n      getSalaryLabel,\n      formatCity,\n      formatIndustries,\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get UserCircleIcon() {\n        return UserCircleIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BuildingOfficeIcon() {\n        return BuildingOfficeIcon;\n      },\n      get DocumentPlusIcon() {\n        return DocumentPlusIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["BriefcaseIcon","UserCircleIcon","CurrencyYenIcon","MapPinIcon","BuildingOfficeIcon","DocumentPlusIcon","props","__props","getJobTypeLabel","value","typeMap","getJobStatusLabel","statusMap","getSalaryLabel","formatCity","city","split","join","formatIndustries","industries"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/JobIntentionContent.vue -->\n<template>\n  <div class=\"p-4\">\n    <!-- 主要信息 -->\n    <div v-if=\"data\" class=\"grid grid-cols-2 gap-4\">\n      <!-- 工作类型 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-blue-50 rounded-lg\">\n            <BriefcaseIcon class=\"w-5 h-5 text-blue-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">工作类型</span>\n            <div class=\"mt-1 text-gray-900\">{{ getJobTypeLabel(data.job_type) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 求职状态 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-green-50 rounded-lg\">\n            <UserCircleIcon class=\"w-5 h-5 text-green-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">求职状态</span>\n            <div class=\"mt-1 text-gray-900\">{{ getJobStatusLabel(data.job_status) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 期望薪资 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-purple-50 rounded-lg\">\n            <CurrencyYenIcon class=\"w-5 h-5 text-purple-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">期望薪资</span>\n            <div class=\"mt-1 text-gray-900\">{{ getSalaryLabel(data.expected_salary) }}</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 期望城市 -->\n      <div class=\"bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n        <div class=\"flex items-start space-x-3\">\n          <div class=\"p-2 bg-orange-50 rounded-lg\">\n            <MapPinIcon class=\"w-5 h-5 text-orange-600\" />\n          </div>\n          <div>\n            <span class=\"text-sm font-medium text-gray-500\">期望城市</span>\n            <div class=\"mt-1 text-gray-900\">{{ formatCity(data.expected_city) }}</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 期望行业 -->\n    <div v-if=\"data?.industries\" class=\"mt-4 bg-gray-50 rounded-lg p-3 transition-all hover:bg-gray-100\">\n      <div class=\"flex items-start space-x-3\">\n        <div class=\"p-2 bg-indigo-50 rounded-lg\">\n          <BuildingOfficeIcon class=\"w-5 h-5 text-indigo-600\" />\n        </div>\n        <div>\n          <span class=\"text-sm font-medium text-gray-500\">期望行业</span>\n          <div class=\"mt-1 text-gray-900\">{{ formatIndustries(data.industries) }}</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 空状态 -->\n    <div v-if=\"!data\" class=\"flex flex-col items-center justify-center py-8\">\n      <DocumentPlusIcon class=\"w-12 h-12 text-gray-300\" />\n      <p class=\"mt-2 text-gray-400\">暂无求职意向，点击编辑按钮添加</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { \n  BriefcaseIcon,\n  UserCircleIcon,\n  CurrencyYenIcon,\n  MapPinIcon,\n  BuildingOfficeIcon,\n  DocumentPlusIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: null\n  }\n})\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const typeMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return typeMap[value] || '未设置'\n}\n\n// 获取求职状态标签\nconst getJobStatusLabel = (value) => {\n  const statusMap = {\n    'unemployed_looking': '离职-找工作',\n    'employed_not_looking': '在职-暂不考虑',\n    'employed_looking': '在职-看机会',\n    'student_internship': '在校-找实习',\n    'fresh_graduate': '应届生'\n  }\n  return statusMap[value] || '未设置'\n}\n\n// 获取薪资标签\nconst getSalaryLabel = (value) => {\n  if (!value) return '未设置'\n  return `${value}K/月`\n}\n\n// 格式化城市\nconst formatCity = (city) => {\n  if (!city) return '未设置'\n  return city.split('-').join('、')\n}\n\n// 格式化行业\nconst formatIndustries = (industries) => {\n  if (!industries) return '未设置'\n  return industries.split(',').join('、')\n}\n</script>\n\n<style scoped>\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .grid {\n    @apply grid-cols-1 gap-3;\n  }\n  \n  .p-4 {\n    @apply p-3;\n  }\n}\n\n/* 悬浮效果 */\n.bg-gray-50 {\n  transition: all 0.2s ease;\n}\n\n/* 图标容器 */\n.p-2 {\n  transition: all 0.2s ease;\n}\n\n.bg-gray-50:hover .p-2 {\n  transform: scale(1.1);\n}\n</style>"],"mappings":"AAgFA,SACEA,aAAa,EACbC,cAAc,EACdC,eAAe,EACfC,UAAU,EACVC,kBAAkB,EAClBC,gBAAe,QACV,2BAA0B;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;;IAOd;IACA,MAAMC,eAAe,GAAIC,KAAK,IAAK;MACjC,MAAMC,OAAO,GAAG;QACd,WAAW,EAAE,IAAI;QACjB,WAAW,EAAE,IAAI;QACjB,YAAY,EAAE,IAAI;QAClB,WAAW,EAAE;MACf;MACA,OAAOA,OAAO,CAACD,KAAK,CAAC,IAAI,KAAI;IAC/B;;IAEA;IACA,MAAME,iBAAiB,GAAIF,KAAK,IAAK;MACnC,MAAMG,SAAS,GAAG;QAChB,oBAAoB,EAAE,QAAQ;QAC9B,sBAAsB,EAAE,SAAS;QACjC,kBAAkB,EAAE,QAAQ;QAC5B,oBAAoB,EAAE,QAAQ;QAC9B,gBAAgB,EAAE;MACpB;MACA,OAAOA,SAAS,CAACH,KAAK,CAAC,IAAI,KAAI;IACjC;;IAEA;IACA,MAAMI,cAAc,GAAIJ,KAAK,IAAK;MAChC,IAAI,CAACA,KAAK,EAAE,OAAO,KAAI;MACvB,OAAO,GAAGA,KAAK,KAAI;IACrB;;IAEA;IACA,MAAMK,UAAU,GAAIC,IAAI,IAAK;MAC3B,IAAI,CAACA,IAAI,EAAE,OAAO,KAAI;MACtB,OAAOA,IAAI,CAACC,KAAK,CAAC,GAAG,CAAC,CAACC,IAAI,CAAC,GAAG;IACjC;;IAEA;IACA,MAAMC