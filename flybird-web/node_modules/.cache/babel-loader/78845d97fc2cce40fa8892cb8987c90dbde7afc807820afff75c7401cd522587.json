{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { useModules } from '@/composables/useModules';\nimport { useProfileData } from '@/composables/useProfileData';\nimport profile from '@/api/profile';\nimport { ElMessage } from 'element-plus';\n\n// 获取数据相关\n\nexport default {\n  __name: 'index',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const profileLoading = ref(false);\n    const profileData = ref(null);\n    const completionData = ref(null);\n    const bioExpanded = ref(false);\n    const showBioExpandButton = ref(false);\n\n    // 使用组合式函数\n    const {\n      loading: modulesLoading,\n      activeModules,\n      inactiveModules,\n      fetchModulesData\n    } = useModules();\n    const {\n      fetchCompletionData\n    } = useProfileData();\n\n    // 当前编辑的模块\n    const currentModule = ref(null);\n    const editFormData = ref({});\n    const showEditModal = ref(false);\n\n    // 初始化数据\n    const initData = async () => {\n      try {\n        profileLoading.value = true;\n\n        // 获取档案数据\n        const response = await profile.getData();\n        if (response.data?.code === 200) {\n          profileData.value = response.data.data;\n\n          // 检查个人简介是否需要展开按钮\n          const summary = profileData.value?.basic_info?.personal_summary;\n          if (summary) {\n            // 创建临时元素来测量文本高度\n            const tempEl = document.createElement('div');\n            tempEl.style.width = '100%';\n            tempEl.style.lineHeight = '1.5';\n            tempEl.style.fontSize = '14px';\n            tempEl.innerText = summary;\n            document.body.appendChild(tempEl);\n\n            // 如果文本高度超过3行，显示展开按钮\n            const lineHeight = parseInt(getComputedStyle(tempEl).lineHeight);\n            showBioExpandButton.value = tempEl.offsetHeight > lineHeight * 3;\n            document.body.removeChild(tempEl);\n          }\n        }\n\n        // 获取模块数据\n        await fetchModulesData();\n\n        // 获取完整度数据\n        await fetchCompletionData();\n      } catch (error) {\n        console.error('初始化数据失败:', error);\n        ElMessage.error('获取数据失败，请刷新重试');\n      } finally {\n        profileLoading.value = false;\n      }\n    };\n\n    // 更新数据\n    const handleUpdate = async () => {\n      await initData();\n    };\n\n    // 处理编辑\n    const handleEdit = (type, data) => {\n      console.log('处理编辑:', {\n        type,\n        data\n      });\n      currentModule.value = {\n        type\n      };\n      editFormData.value = data || {};\n      showEditModal.value = true;\n    };\n\n    // 处理个人简介展开/收起\n    const toggleBioExpand = () => {\n      bioExpanded.value = !bioExpanded.value;\n    };\n\n    // 处理工作经历相关\n    const showWorkExperienceDialog = ref(false);\n    const currentEditData = ref({});\n    const {\n      loading,\n      withLoading\n    } = useLoading();\n\n    // 处理工作经历提交\n    const handleWorkExperienceSubmit = async data => {\n      try {\n        await withLoading(async () => {\n          if (data.id) {\n            await profile.updateModule('work_experience', data);\n            ElMessage.success('更新成功');\n          } else {\n            await profile.addModuleItem('work_experience', data);\n            ElMessage.success('添加成功');\n          }\n          showWorkExperienceDialog.value = false;\n          await fetchModulesData();\n        });\n      } catch (error) {\n        console.error('保存失败:', error);\n        ElMessage.error('保存失败，请稍后重试');\n      }\n    };\n\n    // 初始化\n    onMounted(() => {\n      initData();\n    });\n    const __returned__ = {\n      profileLoading,\n      profileData,\n      completionData,\n      bioExpanded,\n      showBioExpandButton,\n      modulesLoading,\n      activeModules,\n      inactiveModules,\n      fetchModulesData,\n      fetchCompletionData,\n      currentModule,\n      editFormData,\n      showEditModal,\n      initData,\n      handleUpdate,\n      handleEdit,\n      toggleBioExpand,\n      showWorkExperienceDialog,\n      currentEditData,\n      loading,\n      withLoading,\n      handleWorkExperienceSubmit,\n      ref,\n      onMounted,\n      get useModules() {\n        return useModules;\n      },\n      get useProfileData() {\n        return useProfileData;\n      },\n      get profile() {\n        return profile;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useModules","useProfileData","profile","ElMessage","profileLoading","profileData","completionData","bioExpanded","showBioExpandButton","loading","modulesLoading","activeModules","inactiveModules","fetchModulesData","fetchCompletionData","currentModule","editFormData","showEditModal","initData","value","response","getData","data","code","summary","basic_info","personal_summary","tempEl","document","createElement","style","width","lineHeight","fontSize","innerText","body","appendChild","parseInt","getComputedStyle","offsetHeight","removeChild","error","console","handleUpdate","handleEdit","type","log","toggleBioExpand","showWorkExperienceDialog","currentEditData","withLoading","useLoading","handleWorkExperienceSubmit","id","updateModule","success","addModuleItem"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto pb-6\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <!-- 基本信息 -->\n      <BasicInfo\n        :resumeData=\"profileData?.basic_info\"\n        :loading=\"profileLoading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @update=\"handleUpdate\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <!-- 简历状态 -->\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"profileLoading\"\n      />\n\n      <!-- 激活的模块列表 -->\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"modulesLoading\"\n        :fetch-modules-data=\"fetchModulesData\"\n        @edit=\"handleEdit\"\n        @remove=\"handleModuleRemove\"\n      />\n\n      <!-- 未激活的模块按钮组 -->\n      <div v-if=\"inactiveModules.length > 0\" class=\"bg-white rounded-lg shadow\">\n        <div class=\"px-4 py-3\">\n          <h3 class=\"text-sm font-medium text-gray-900\">添加更多模块</h3>\n          <div class=\"mt-3 flex flex-wrap gap-2\">\n            <button\n              v-for=\"module in inactiveModules\"\n              :key=\"module.type\"\n              @click=\"handleAddModule(module.type)\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm text-gray-600 bg-gray-50 hover:bg-gray-100 rounded border border-gray-200\"\n            >\n              {{ getModuleName(module.type) }}\n              <PlusIcon class=\"w-4 h-4 ml-1 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-model=\"showWorkExperienceDialog\"\n        :initial-data=\"currentEditData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleWorkExperienceSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-model=\"showJobIntentionDialog\"\n        :initial-data=\"editJobIntentionData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleJobIntentionSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- AI 优化弹窗 -->\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n\n      <!-- 删除确认弹窗 -->\n      <TransitionRoot appear :show=\"showDeleteConfirm\" as=\"template\">\n        <Dialog as=\"div\" class=\"relative z-50\" @close=\"showDeleteConfirm = false\">\n          <!-- 背景遮罩 -->\n          <TransitionChild\n            as=\"template\"\n            enter=\"duration-300 ease-out\"\n            enter-from=\"opacity-0\"\n            enter-to=\"opacity-100\"\n            leave=\"duration-200 ease-in\"\n            leave-from=\"opacity-100\"\n            leave-to=\"opacity-0\"\n          >\n            <div class=\"fixed inset-0 bg-black/25\" />\n          </TransitionChild>\n\n          <!-- 对话框 -->\n          <div class=\"fixed inset-0 overflow-y-auto\">\n            <div class=\"flex min-h-full items-center justify-center p-4 text-center\">\n              <TransitionChild\n                as=\"template\"\n                enter=\"duration-300 ease-out\"\n                enter-from=\"opacity-0 scale-95\"\n                enter-to=\"opacity-100 scale-100\"\n                leave=\"duration-200 ease-in\"\n                leave-from=\"opacity-100 scale-100\"\n                leave-to=\"opacity-0 scale-95\"\n              >\n                <DialogPanel class=\"w-full max-w-md transform overflow-hidden rounded-xl bg-white text-left align-middle shadow-xl transition-all\">\n                  <div class=\"p-6\">\n                    <div class=\"flex items-start space-x-3\">\n                      <div class=\"p-2 bg-red-50 rounded-full flex-shrink-0\">\n                        <ExclamationTriangleIcon class=\"w-6 h-6 text-red-600\" />\n                      </div>\n                      <div class=\"flex-1\">\n                        <DialogTitle as=\"h3\" class=\"text-lg font-medium text-gray-900\">\n                          确认删除工作经历？\n                        </DialogTitle>\n                        <p class=\"mt-2 text-sm text-gray-500\">\n                          删除后将无法恢复，请确认是否继续。\n                        </p>\n                      </div>\n                    </div>\n                    \n                    <div class=\"mt-6 flex justify-end space-x-3\">\n                      <button\n                        type=\"button\"\n                        @click=\"showDeleteConfirm = false\"\n                        class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n                      >\n                        取消\n                      </button>\n                      <button\n                        type=\"button\"\n                        @click=\"confirmDelete\"\n                        class=\"px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500\"\n                      >\n                        确认删除\n                      </button>\n                    </div>\n                  </div>\n                </DialogPanel>\n              </TransitionChild>\n            </div>\n          </div>\n        </Dialog>\n      </TransitionRoot>\n\n      <!-- 教育经历编辑弹窗 -->\n      <EditEducationDialog\n        v-model=\"showEducationDialog\"\n        :initial-data=\"editEducationData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleEducationSubmit\"\n      />\n\n      <!-- 社交主页编辑弹窗 -->\n      <EditSocialLinkDialog\n        v-if=\"currentModule?.type === 'social_link'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n      \n      <!-- 作品展示编辑弹窗 -->\n      <EditPortfolioDialog\n        v-if=\"currentModule?.type === 'portfolio'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport { useModules } from '@/composables/useModules'\nimport { useProfileData } from '@/composables/useProfileData'\nimport profile from '@/api/profile'\nimport { ElMessage } from 'element-plus'\n\n// 获取数据相关\nconst profileLoading = ref(false)\nconst profileData = ref(null)\nconst completionData = ref(null)\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 使用组合式函数\nconst { \n  loading: modulesLoading,\n  activeModules,\n  inactiveModules,\n  fetchModulesData\n} = useModules()\n\nconst {\n  fetchCompletionData\n} = useProfileData()\n\n// 当前编辑的模块\nconst currentModule = ref(null)\nconst editFormData = ref({})\nconst showEditModal = ref(false)\n\n// 初始化数据\nconst initData = async () => {\n  try {\n    profileLoading.value = true\n    \n    // 获取档案数据\n    const response = await profile.getData()\n    if (response.data?.code === 200) {\n      profileData.value = response.data.data\n      \n      // 检查个人简介是否需要展开按钮\n      const summary = profileData.value?.basic_info?.personal_summary\n      if (summary) {\n        // 创建临时元素来测量文本高度\n        const tempEl = document.createElement('div')\n        tempEl.style.width = '100%'\n        tempEl.style.lineHeight = '1.5'\n        tempEl.style.fontSize = '14px'\n        tempEl.innerText = summary\n        document.body.appendChild(tempEl)\n        \n        // 如果文本高度超过3行，显示展开按钮\n        const lineHeight = parseInt(getComputedStyle(tempEl).lineHeight)\n        showBioExpandButton.value = tempEl.offsetHeight > lineHeight * 3\n        \n        document.body.removeChild(tempEl)\n      }\n    }\n    \n    // 获取模块数据\n    await fetchModulesData()\n    \n    // 获取完整度数据\n    await fetchCompletionData()\n    \n  } catch (error) {\n    console.error('初始化数据失败:', error)\n    ElMessage.error('获取数据失败，请刷新重试')\n  } finally {\n    profileLoading.value = false\n  }\n}\n\n// 更新数据\nconst handleUpdate = async () => {\n  await initData()\n}\n\n// 处理编辑\nconst handleEdit = (type, data) => {\n  console.log('处理编辑:', { type, data })\n  currentModule.value = { type }\n  editFormData.value = data || {}\n  showEditModal.value = true\n}\n\n// 处理个人简介展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 处理工作经历相关\nconst showWorkExperienceDialog = ref(false)\nconst currentEditData = ref({})\nconst { loading, withLoading } = useLoading()\n\n// 处理工作经历提交\nconst handleWorkExperienceSubmit = async (data) => {\n  try {\n    await withLoading(async () => {\n      if (data.id) {\n        await profile.updateModule('work_experience', data)\n        ElMessage.success('更新成功')\n      } else {\n        await profile.addModuleItem('work_experience', data)\n        ElMessage.success('添加成功')\n      }\n      showWorkExperienceDialog.value = false\n      await fetchModulesData()\n    })\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error('保存失败，请稍后重试')\n  }\n}\n\n// 初始化\nonMounted(() => {\n  initData()\n})\n</script>"],"mappings":"AAoLA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAI;AACnC,SAASC,UAAU,QAAQ,0BAAyB;AACpD,SAASC,cAAc,QAAQ,8BAA6B;AAC5D,OAAOC,OAAO,MAAM,eAAc;AAClC,SAASC,SAAS,QAAQ,cAAa;;AAEvC;;;;;;;;IACA,MAAMC,cAAc,GAAGN,GAAG,CAAC,KAAK;IAChC,MAAMO,WAAW,GAAGP,GAAG,CAAC,IAAI;IAC5B,MAAMQ,cAAc,GAAGR,GAAG,CAAC,IAAI;IAC/B,MAAMS,WAAW,GAAGT,GAAG,CAAC,KAAK;IAC7B,MAAMU,mBAAmB,GAAGV,GAAG,CAAC,KAAK;;IAErC;IACA,MAAM;MACJW,OAAO,EAAEC,cAAc;MACvBC,aAAa;MACbC,eAAe;MACfC;IACF,CAAC,GAAGb,UAAU,CAAC;IAEf,MAAM;MACJc;IACF,CAAC,GAAGb,cAAc,CAAC;;IAEnB;IACA,MAAMc,aAAa,GAAGjB,GAAG,CAAC,IAAI;IAC9B,MAAMkB,YAAY,GAAGlB,GAAG,CAAC,CAAC,CAAC;IAC3B,MAAMmB,aAAa,GAAGnB,GAAG,CAAC,KAAK;;IAE/B;IACA,MAAMoB,QAAQ,GAAG,MAAAA,CAAA,KAAY;MAC3B,IAAI;QACFd,cAAc,CAACe,KAAK,GAAG,IAAG;;QAE1B;QACA,MAAMC,QAAQ,GAAG,MAAMlB,OAAO,CAACmB,OAAO,CAAC;QACvC,IAAID,QAAQ,CAACE,IAAI,EAAEC,IAAI,KAAK,GAAG,EAAE;UAC/BlB,WAAW,CAACc,KAAK,GAAGC,QAAQ,CAACE,IAAI,CAACA,IAAG;;UAErC;UAC