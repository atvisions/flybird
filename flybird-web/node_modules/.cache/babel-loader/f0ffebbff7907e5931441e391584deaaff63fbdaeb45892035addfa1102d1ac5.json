{"ast":null,"code":"import { computed } from 'vue';\nimport { SparklesIcon } from '@heroicons/vue/24/outline';\nimport { useWindowSize } from '@vueuse/core';\nexport default {\n  __name: 'AIDialog',\n  props: {\n    modelValue: Boolean,\n    suggestions: {\n      type: Array,\n      default: () => []\n    },\n    dimensions: {\n      type: Object,\n      default: () => ({})\n    },\n    totalScore: {\n      type: Number,\n      default: 0\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'action'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const {\n      width\n    } = useWindowSize();\n\n    // 弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n\n    // 总分颜色\n    const scoreColorClass = computed(() => {\n      if (props.totalScore >= 80) return 'text-green-600';\n      if (props.totalScore >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n\n    // 维度名称\n    const getDimensionName = key => {\n      const nameMap = {\n        basic_info: '基本信息',\n        experience: '工作经历',\n        capability: '能力素质',\n        achievement: '个人成就'\n      };\n      return nameMap[key] || key;\n    };\n\n    // 维度分数颜色\n    const getDimensionScoreClass = score => {\n      if (score >= 80) return 'text-green-600';\n      if (score >= 60) return 'text-yellow-600';\n      return 'text-red-600';\n    };\n\n    // 维度进度条颜色\n    const getDimensionProgressClass = score => {\n      if (score >= 80) return 'bg-green-500';\n      if (score >= 60) return 'bg-yellow-500';\n      return 'bg-red-500';\n    };\n\n    // 处理优化\n    const handleOptimize = () => {\n      emit('action', 'optimize');\n    };\n\n    // 建议类型名称\n    const getTypeName = type => {\n      const typeMap = {\n        basic_info: '基本信息',\n        work_experience: '工作经历',\n        skill: '技能特长',\n        education: '教育背景',\n        project: '项目经验',\n        achievement: '个人成就'\n      };\n      return typeMap[type] || type;\n    };\n\n    // 建议类型样式\n    const getTypeClass = type => {\n      const classMap = {\n        basic_info: 'bg-blue-50 text-blue-700',\n        work_experience: 'bg-purple-50 text-purple-700',\n        skill: 'bg-green-50 text-green-700',\n        education: 'bg-yellow-50 text-yellow-700',\n        project: 'bg-indigo-50 text-indigo-700',\n        achievement: 'bg-pink-50 text-pink-700'\n      };\n      return classMap[type] || 'bg-gray-50 text-gray-700';\n    };\n\n    // 按重要性和提升分数排序的建议\n    const sortedSuggestions = computed(() => {\n      const importanceOrder = {\n        high: 3,\n        medium: 2,\n        low: 1\n      };\n      return [...props.suggestions].sort((a, b) => {\n        const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance];\n        if (importanceDiff !== 0) return importanceDiff;\n        return b.score_impact - a.score_impact;\n      });\n    });\n    const __returned__ = {\n      props,\n      emit,\n      width,\n      dialogWidth,\n      scoreColorClass,\n      getDimensionName,\n      getDimensionScoreClass,\n      getDimensionProgressClass,\n      handleOptimize,\n      getTypeName,\n      getTypeClass,\n      sortedSuggestions,\n      computed,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get useWindowSize() {\n        return useWindowSize;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","SparklesIcon","useWindowSize","props","__props","emit","__emit","width","dialogWidth","value","scoreColorClass","totalScore","getDimensionName","key","nameMap","basic_info","experience","capability","achievement","getDimensionScoreClass","score","getDimensionProgressClass","handleOptimize","getTypeName","type","typeMap","work_experience","skill","education","project","getTypeClass","classMap","sortedSuggestions","importanceOrder","high","medium","low","suggestions","sort","a","b","importanceDiff","importance","score_impact"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/AIDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"AI 优化建议\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n  >\n    <div class=\"space-y-6\">\n      <!-- 总体评分 -->\n      <div class=\"bg-gray-50 rounded-lg p-4\">\n        <div class=\"flex items-center justify-between mb-2\">\n          <h3 class=\"text-base font-medium text-gray-900\">总体评分</h3>\n          <span class=\"text-lg font-semibold\" :class=\"scoreColorClass\">{{ totalScore }}分</span>\n        </div>\n        <p class=\"text-sm text-gray-600\">基于各维度权重计算的综合评分</p>\n      </div>\n\n      <!-- 维度得分 -->\n      <div class=\"space-y-4\">\n        <h3 class=\"text-base font-medium text-gray-900\">各维度得分</h3>\n        <div class=\"space-y-3\">\n          <div v-for=\"(dimension, key) in dimensions\" :key=\"key\" class=\"bg-white rounded-lg p-4 border border-gray-200\">\n            <div class=\"flex items-center justify-between mb-2\">\n              <div>\n                <span class=\"text-sm font-medium text-gray-700\">{{ getDimensionName(key) }}</span>\n                <span class=\"text-xs text-gray-500 ml-2\">权重：{{ (dimension.weight * 100).toFixed(0) }}%</span>\n              </div>\n              <span class=\"text-sm font-medium\" :class=\"getDimensionScoreClass(dimension.score)\">\n                {{ dimension.score.toFixed(1) }}分\n              </span>\n            </div>\n            <div class=\"bg-gray-100 rounded-full h-1.5\">\n              <div \n                class=\"h-1.5 rounded-full transition-all duration-500\"\n                :class=\"getDimensionProgressClass(dimension.score)\"\n                :style=\"{ width: `${dimension.score}%` }\"\n              ></div>\n            </div>\n            <div class=\"mt-1 text-xs text-gray-500\">\n              贡献：{{ dimension.weighted_score.toFixed(1) }}分\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 改进建议 -->\n      <div class=\"space-y-4\">\n        <div class=\"flex items-center justify-between\">\n          <h3 class=\"text-base font-medium text-gray-900\">改进建议</h3>\n          <span class=\"text-sm text-gray-500\">按优先级排序</span>\n        </div>\n        <div class=\"space-y-3\">\n          <div \n            v-for=\"(suggestion, index) in sortedSuggestions\" \n            :key=\"index\"\n            class=\"bg-white rounded-lg p-4 border border-gray-200\"\n          >\n            <div class=\"flex items-start space-x-3\">\n              <div \n                class=\"flex-shrink-0 w-2 h-2 mt-2 rounded-full\"\n                :class=\"{\n                  'bg-red-500': suggestion.importance === 'high',\n                  'bg-yellow-500': suggestion.importance === 'medium',\n                  'bg-blue-500': suggestion.importance === 'low'\n                }\"\n              ></div>\n              <div class=\"flex-1\">\n                <div class=\"flex items-center space-x-2\">\n                  <span class=\"text-xs font-medium px-2 py-0.5 rounded\" \n                    :class=\"getTypeClass(suggestion.type)\">\n                    {{ getTypeName(suggestion.type) }}\n                  </span>\n                  <span class=\"text-sm text-gray-700\">{{ suggestion.message }}</span>\n                </div>\n                <p class=\"text-xs text-gray-500 mt-1\">\n                  预计提升：+{{ suggestion.score_impact }}分\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <template #footer>\n      <div class=\"flex justify-end space-x-3\">\n        <button\n          @click=\"$emit('update:modelValue', false)\"\n          class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\"\n        >\n          关闭\n        </button>\n        <button\n          @click=\"handleOptimize\"\n          :disabled=\"loading\"\n          class=\"inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-md transition-colors disabled:opacity-50\"\n        >\n          <SparklesIcon class=\"w-4 h-4 mr-1.5\" />\n          一键优化\n        </button>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\nimport { SparklesIcon } from '@heroicons/vue/24/outline'\nimport { useWindowSize } from '@vueuse/core'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  suggestions: {\n    type: Array,\n    default: () => []\n  },\n  dimensions: {\n    type: Object,\n    default: () => ({})\n  },\n  totalScore: {\n    type: Number,\n    default: 0\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'action'])\n\nconst { width } = useWindowSize()\n\n// 弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\n// 总分颜色\nconst scoreColorClass = computed(() => {\n  if (props.totalScore >= 80) return 'text-green-600'\n  if (props.totalScore >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n})\n\n// 维度名称\nconst getDimensionName = (key) => {\n  const nameMap = {\n    basic_info: '基本信息',\n    experience: '工作经历',\n    capability: '能力素质',\n    achievement: '个人成就'\n  }\n  return nameMap[key] || key\n}\n\n// 维度分数颜色\nconst getDimensionScoreClass = (score) => {\n  if (score >= 80) return 'text-green-600'\n  if (score >= 60) return 'text-yellow-600'\n  return 'text-red-600'\n}\n\n// 维度进度条颜色\nconst getDimensionProgressClass = (score) => {\n  if (score >= 80) return 'bg-green-500'\n  if (score >= 60) return 'bg-yellow-500'\n  return 'bg-red-500'\n}\n\n// 处理优化\nconst handleOptimize = () => {\n  emit('action', 'optimize')\n}\n\n// 建议类型名称\nconst getTypeName = (type) => {\n  const typeMap = {\n    basic_info: '基本信息',\n    work_experience: '工作经历',\n    skill: '技能特长',\n    education: '教育背景',\n    project: '项目经验',\n    achievement: '个人成就'\n  }\n  return typeMap[type] || type\n}\n\n// 建议类型样式\nconst getTypeClass = (type) => {\n  const classMap = {\n    basic_info: 'bg-blue-50 text-blue-700',\n    work_experience: 'bg-purple-50 text-purple-700',\n    skill: 'bg-green-50 text-green-700',\n    education: 'bg-yellow-50 text-yellow-700',\n    project: 'bg-indigo-50 text-indigo-700',\n    achievement: 'bg-pink-50 text-pink-700'\n  }\n  return classMap[type] || 'bg-gray-50 text-gray-700'\n}\n\n// 按重要性和提升分数排序的建议\nconst sortedSuggestions = computed(() => {\n  const importanceOrder = { high: 3, medium: 2, low: 1 }\n  return [...props.suggestions].sort((a, b) => {\n    const importanceDiff = importanceOrder[b.importance] - importanceOrder[a.importance]\n    if (importanceDiff !== 0) return importanceDiff\n    return b.score_impact - a.score_impact\n  })\n})\n</script>"],"mappings":"AA4GA,SAASA,QAAQ,QAAQ,KAAI;AAC7B,SAASC,YAAY,QAAQ,2BAA0B;AACvD,SAASC,aAAa,QAAQ,cAAa;;;;;;;;;;;;;;;;;;;;;;;;;IAE3C,MAAMC,KAAK,GAAGC,OAAA;IAiBd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAM;MAAEC;IAAM,CAAC,GAAGL,aAAa,CAAC;;IAEhC;IACA,MAAMM,WAAW,GAAGR,QAAQ,CAAC,MAAM;MACjC,IAAIO,KAAK,CAACE,KAAK,GAAG,GAAG,EAAE,OAAO,KAAI;MAClC,IAAIF,KAAK,CAACE,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;;IAED;IACA,MAAMC,eAAe,GAAGV,QAAQ,CAAC,MAAM;MACrC,IAAIG,KAAK,CAACQ,UAAU,IAAI,EAAE,EAAE,OAAO,gBAAe;MAClD,IAAIR,KAAK,CAACQ,UAAU,IAAI,EAAE,EAAE,OAAO,iBAAgB;MACnD,OAAO,cAAa;IACtB,CAAC;;IAED;IACA,MAAMC,gBAAgB,GAAIC,GAAG,IAAK;MAChC,MAAMC,OAAO,GAAG;QACdC,UAAU,EAAE,MAAM;QAClBC,UAAU,EAAE,MAAM;QAClBC,UAAU,EAAE,MAAM;QAClBC,WAAW,EAAE;MACf;MACA,OAAOJ,OAAO,CAACD,GAAG,CAAC,IAAIA,GAA