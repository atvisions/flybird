{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { profile } from '@/api/profile';\nimport { showToast } from '@/components/ToastMessage';\nimport { UserIcon, PhoneIcon, EnvelopeIcon, MapPinIcon, CalendarIcon, PencilIcon, CameraIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'BasicInfo',\n  props: {\n    resumeData: {\n      type: Object,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:resumeData', 'save'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const isEditing = ref(false);\n    const editData = ref({});\n\n    // 性别显示文本\n    const genderText = computed(() => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[props.resumeData.gender] || '未设置性别';\n    });\n\n    // 开始编辑\n    const startEdit = () => {\n      editData.value = _objectSpread({}, props.resumeData);\n      isEditing.value = true;\n    };\n\n    // 取消编辑\n    const cancelEdit = () => {\n      isEditing.value = false;\n      editData.value = {};\n    };\n\n    // 保存编辑\n    const saveEdit = async () => {\n      try {\n        const formData = {\n          name: editData.value.name,\n          gender: editData.value.gender,\n          phone: editData.value.phone,\n          email: editData.value.email,\n          location: editData.value.location,\n          birth_date: editData.value.birth_date,\n          personal_summary: editData.value.bio,\n          jobStatus: editData.value.jobStatus,\n          expectedSalary: editData.value.expectedSalary\n        };\n        emit('save', formData);\n        isEditing.value = false;\n      } catch (error) {\n        console.error('保存失败:', error);\n        showToast('保存失败，请重试', 'error');\n      }\n    };\n    const __returned__ = {\n      props,\n      emit,\n      isEditing,\n      editData,\n      genderText,\n      startEdit,\n      cancelEdit,\n      saveEdit,\n      ref,\n      computed,\n      get useStore() {\n        return useStore;\n      },\n      get profile() {\n        return profile;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get UserIcon() {\n        return UserIcon;\n      },\n      get PhoneIcon() {\n        return PhoneIcon;\n      },\n      get EnvelopeIcon() {\n        return EnvelopeIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get CameraIcon() {\n        return CameraIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","profile","showToast","UserIcon","PhoneIcon","EnvelopeIcon","MapPinIcon","CalendarIcon","PencilIcon","CameraIcon","props","__props","emit","__emit","isEditing","editData","genderText","genderMap","male","female","other","resumeData","gender","startEdit","value","_objectSpread","cancelEdit","saveEdit","formData","name","phone","email","location","birth_date","personal_summary","bio","jobStatus","expectedSalary","error","console"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n  <div class=\"bg-white shadow sm:rounded-lg\">\n    <!-- 显示模式 -->\n    <div v-if=\"!isEditing\" class=\"px-4 py-5 sm:p-6\">\n      <div class=\"flex justify-between items-start\">\n        <div class=\"flex items-center space-x-4\">\n          <!-- 头像 -->\n          <div class=\"relative\">\n            <img \n              :src=\"currentAvatarUrl\"\n              :alt=\"resumeData.name || '用户头像'\"\n              class=\"h-32 w-32 rounded-full object-cover\"\n              @error=\"handleImageError\"\n            />\n            <button\n              @click=\"triggerUpload\"\n              class=\"absolute bottom-0 right-0 p-1 rounded-full bg-white shadow-lg hover:bg-gray-50\"\n            >\n              <CameraIcon class=\"h-5 w-5 text-gray-500\" />\n            </button>\n            <input\n              ref=\"fileInput\"\n              type=\"file\"\n              accept=\"image/*\"\n              class=\"hidden\"\n              @change=\"handleFileChange\"\n            />\n          </div>\n          \n          <!-- 基本信息 -->\n          <div>\n            <h3 class=\"text-lg font-medium text-gray-900\">{{ resumeData.name || '未设置姓名' }}</h3>\n            <div class=\"mt-1 grid grid-cols-1 gap-y-2\">\n              <div class=\"flex items-center text-sm text-gray-500\">\n                <UserIcon class=\"mr-1.5 h-4 w-4\" />\n                {{ genderText }}\n              </div>\n              <div class=\"flex items-center text-sm text-gray-500\">\n                <PhoneIcon class=\"mr-1.5 h-4 w-4\" />\n                {{ resumeData.phone || '未设置手机号' }}\n              </div>\n              <div class=\"flex items-center text-sm text-gray-500\">\n                <EnvelopeIcon class=\"mr-1.5 h-4 w-4\" />\n                {{ resumeData.email || '未设置邮箱' }}\n              </div>\n              <div class=\"flex items-center text-sm text-gray-500\">\n                <MapPinIcon class=\"mr-1.5 h-4 w-4\" />\n                {{ resumeData.location || '未设置所在地' }}\n              </div>\n              <div class=\"flex items-center text-sm text-gray-500\">\n                <CalendarIcon class=\"mr-1.5 h-4 w-4\" />\n                {{ resumeData.birth_date || '未设置生日' }}\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- 编辑按钮 -->\n        <button\n          @click=\"startEdit\"\n          class=\"inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded-md text-indigo-600 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500\"\n        >\n          <PencilIcon class=\"h-4 w-4 mr-1\" />\n          编辑\n        </button>\n      </div>\n\n      <!-- 个人简介 -->\n      <div class=\"mt-6\">\n        <h4 class=\"text-sm font-medium text-gray-900\">个人简介</h4>\n        <p class=\"mt-2 text-sm text-gray-500\">\n          {{ resumeData.bio || '未设置个人简介' }}\n        </p>\n      </div>\n    </div>\n\n    <!-- 编辑模式 -->\n    <div v-else class=\"px-4 py-5 sm:p-6\">\n      <!-- 基本信息表单 -->\n      <div class=\"grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2\">\n        <!-- 姓名 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">姓名</label>\n          <input \n            type=\"text\"\n            v-model=\"editData.name\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入姓名\"\n          />\n        </div>\n\n        <!-- 性别 -->\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700\">性别</label>\n          <select\n            v-model=\"editData.gender\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n          >\n            <option value=\"\">请选择性别</option>\n            <option value=\"male\">男</option>\n            <option value=\"female\">女</option>\n            <option value=\"other\">其他</option>\n          </select>\n        </div>\n\n        <!-- 其他字段... -->\n\n        <!-- 个人简介 -->\n        <div class=\"col-span-2\">\n          <label class=\"block text-sm font-medium text-gray-700\">个人简介</label>\n          <textarea\n            v-model=\"editData.bio\"\n            rows=\"4\"\n            class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm\"\n            placeholder=\"请输入个人简介\"\n          ></textarea>\n        </div>\n      </div>\n\n      <!-- 按钮组 -->\n      <div class=\"mt-6 flex justify-end space-x-3\">\n        <button\n          type=\"button\"\n          @click=\"cancelEdit\"\n          class=\"inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500\"\n        >\n          取消\n        </button>\n        <button\n          type=\"button\"\n          @click=\"saveEdit\"\n          :disabled=\"loading\"\n          class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50\"\n        >\n          {{ loading ? '保存中...' : '保存' }}\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { profile } from '@/api/profile'\nimport { showToast } from '@/components/ToastMessage'\nimport {\n  UserIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  CalendarIcon,\n  PencilIcon,\n  CameraIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:resumeData', 'save'])\n\nconst isEditing = ref(false)\nconst editData = ref({})\n\n// 性别显示文本\nconst genderText = computed(() => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[props.resumeData.gender] || '未设置性别'\n})\n\n// 开始编辑\nconst startEdit = () => {\n  editData.value = { ...props.resumeData }\n  isEditing.value = true\n}\n\n// 取消编辑\nconst cancelEdit = () => {\n  isEditing.value = false\n  editData.value = {}\n}\n\n// 保存编辑\nconst saveEdit = async () => {\n  try {\n    const formData = {\n      name: editData.value.name,\n      gender: editData.value.gender,\n      phone: editData.value.phone,\n      email: editData.value.email,\n      location: editData.value.location,\n      birth_date: editData.value.birth_date,\n      personal_summary: editData.value.bio,\n      jobStatus: editData.value.jobStatus,\n      expectedSalary: editData.value.expectedSalary\n    }\n\n    emit('save', formData)\n    isEditing.value = false\n  } catch (error) {\n    console.error('保存失败:', error)\n    showToast('保存失败，请重试', 'error')\n  }\n}\n</script>"],"mappings":";AA+IA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,OAAO,QAAQ,eAAc;AACtC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SACEC,QAAQ,EACRC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,YAAY,EACZC,UAAU,EACVC,UAAS,QACJ,2BAA0B;;;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;IAQd,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,SAAS,GAAGhB,GAAG,CAAC,KAAK;IAC3B,MAAMiB,QAAQ,GAAGjB,GAAG,CAAC,CAAC,CAAC;;IAEvB;IACA,MAAMkB,UAAU,GAAGjB,QAAQ,CAAC,MAAM;MAChC,MAAMkB,SAAS,GAAG;QAChBC,IAAI,EAAE,GAAG;QACTC,MAAM,EAAE,GAAG;QACXC,KAAK,EAAE;MACT;MACA,OAAOH,SAAS,CAACP,KAAK,CAACW,UAAU,CAACC,MAAM,CAAC,IAAI,OAAM;IACrD,CAAC;;IAED;IACA,MAAMC,SAAS,GAAGA,CAAA,KAAM;MACtBR,QAAQ,CAACS,KAAK,GAAAC,aAAA,KAAQf,KAAK,CAACW,UAAU,CAAC;MACvCP,SAAS,CAACU,KAAK,GAAG,IAAG;IACvB;;IAEA;IACA,MAAME,UAAU,GAAGA,CAAA,KAAM;MACvBZ,SAAS,CAACU,KAAK,GAAG,KAAI;MACtBT,QAAQ,CAACS,KAAK,GAAG,CAAC;IACpB;;IAEA;IACA,MAAMG,QAAQ,GAAG,MAAAA,CAAA,KAAY;MAC3B,IAAI;QACF,MAAMC,QAAQ,GAAG;UACfC,IAAI,EAAEd,QAAQ,CAACS,KAAK,CAACK,IAAI;UACzBP,MAAM,EAAEP,QAAQ,CAACS,KAAK,CAACF,MAAM;UAC7BQ,KAAK,EAAEf,QAAQ,CAACS,KAAK,CAACM,KAAK;UAC3BC,KAAK,EAAEhB,QAAQ,CAACS,KAAK,CAACO,KAAK;UAC3BC,QAAQ,EAAEjB,QAAQ,CAACS,KAAK,CAACQ,QAAQ;UACjCC,UAAU,EAAElB,QAAQ,CAACS,KAAK,CAACS,UAAU;UACrCC,gBAAgB,EAAEnB,