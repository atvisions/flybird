elValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), $setup.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock($setup[\"EditJobIntentionDialog\"], {\n    key: 1,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 添加基本信息编辑弹窗 \"), $setup.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock($setup[\"EditBasicDialog\"], {\n    key: 2,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true)]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","$setup","resumeData","profileData","value","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onToggleBioExpand","toggleBioExpand","completionData","activeModules","handleEditModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","onRemoveItem","removeItem","inactiveModules","onActivate","activateModule","_createCommentVNode","currentModule","type","_createBlock","key","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <BasicInfo\n        :resumeData=\"profileData.resumeData.value || {}\"\n        :loading=\"loading\"\n        :bioExpanded=\"profileData.bioExpanded\"\n        :showBioExpandButton=\"profileData.showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @toggleBioExpand=\"profileData.toggleBioExpand\"\n      />\n  \n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :loading=\"loading\"\n        />\n  \n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"handleEditModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n          @remove-item=\"removeItem\"\n        />\n  \n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n  \n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n  \n      <!-- 添加基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted } from 'vue'\n  import { useModules } from './composables/useModules'\n  import { profile } from '@/api/profile'\n  import { ElMessage, ElMessageBox } from 'element-plus'\n  \n  // 组件引入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  import EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\n  import EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\n  \n  // 状态管理\n  const { \n    activeModules, \n    currentModule, \n    inactiveModules, \n    addItem, \n    removeModule, \n    activateModule \n  } = useModules()\n  \n  const showEditModal = ref(false)\n  const editFormData = ref({})\n  const loading = ref(false)\n  \n  // 基本信息数据\n  const profileData = ref({\n    resumeData: ref({}),\n    bioExpanded: ref(false),\n    showBioExpandButton: ref(false)\n  })\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {}\n  })\n  \n  // 获取数据\n  const fetchData = async () => {\n    try {\n      loading.value = true\n\n      // 获取基本信息\n      const basicResponse = await profile.getBasicInfo()\n      if (basicResponse.data?.code === 200) {\n        profileData.value.resumeData.value = basicResponse.data.data\n      }\n\n      // 获取完整度评分\n      const completenessResponse = await profile.getCompleteness()\n      if (completenessResponse.data?.code === 200) {\n        completionData.value = completenessResponse.data.data\n      }\n\n      // 获取求职意向数据\n      const intentionResponse = await profile.getJobIntention()\n      if (intentionResponse.data?.code === 200) {\n        const moduleIndex = activeModules.value.findIndex(m => m.type === 'job_intention')\n        if (moduleIndex > -1) {\n          activeModules.value[moduleIndex] = {\n            ...activeModules.value[moduleIndex],\n            data: intentionResponse.data.data\n          }\n        }\n      }\n\n      // 获取工作经历数据\n      const workResponse = await profile.getWorkExperiences()\n      if (workResponse.data?.code === 200) {\n        const moduleIndex = activeModules.value.findIndex(m => m.type === 'work_experience')\n        if (moduleIndex > -1) {\n          const workData = workResponse.data.data || []\n          activeModules.value[moduleIndex] = {\n            ...activeModules.value[moduleIndex],\n            data: workData\n          }\n        }\n      }\n\n    } catch (error) {\n      console.error('获取数据失败:', error)\n      ElMessage.error('获取数据失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 编辑基本信息\n  const handleEdit = () => {\n    console.log('处理基本信息编辑')\n    currentModule.value = {\n      type: 'basic_info',\n      data: profileData.value.resumeData.value\n    }\n    editFormData.value = { ...currentModule.value.data }\n    showEditModal.value = true\n  }\n  \n  // 处理编辑模块\n  const handleEditModule = (moduleId) => {\n    console.log('编辑模块:', moduleId)\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    \n    // 如果是工作经历，清空表单数据\n    if (currentModule.value?.type === 'work_experience') {\n      editFormData.value = {}\n    } \n    // 如果是求职意向，使用现有数据\n    else if (currentModule.value?.type === 'job_intention') {\n      editFormData.value = { ...currentModule.value.data } || {}\n    }\n    \n    showEditModal.value = true\n    console.log('当前模块:', currentModule.value)\n    console.log('编辑表单数据:', editFormData.value)\n  }\n  \n  // 编辑具体项目（用于工作经历）\n  const editItem = (moduleId, item) => {\n    console.log('编辑具体项目:', moduleId, item)\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n    console.log('当前模块:', currentModule.value)\n    console.log('编辑表单数据:', editFormData.value)\n  }\n  \n  // 删除工作经历\n  const removeItem = async (moduleId, itemId) => {\n    try {\n      await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n        type: 'warning'\n      })\n      \n      if (moduleId === 'work_experience') {\n        await profile.deleteWorkExperience(itemId)\n        ElMessage.success('删除成功')\n        await fetchData()\n      }\n    } catch (error) {\n      if (error !== 'cancel') {\n        console.error('删除失败:', error)\n        ElMessage.error('删除失败')\n      }\n    }\n  }\n  \n  // 提交表单\n  const handleSubmit = async (data) => {\n    try {\n      if (currentModule.value?.type === 'work_experience') {\n        const response = await profile.updateWorkExperience(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      } else if (currentModule.value?.type === 'job_intention') {\n        const response = await profile.updateJobIntention(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      } else if (currentModule.value?.type === 'basic_info') {\n        const response = await profile.updateBasicInfo(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchData()\n        }\n      }\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error(error.message || '保存失败')\n    }\n  }\n  \n  onMounted(async () => {\n    await fetchData()\n  })\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CA2DM,OA3DNC,UA2DM,GA1DJC,mBAAA,CA8BM,OA9BNC,UA8BM,GA7BJC,YAAA,CAOAC,MAAA;IANCC,UAAU,EAAED,MAAA,CAAAE,WAAW,CAACD,UAAU,CAACE,KAAK;IACxCC,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBC,WAAW,EAAEL,MAAA,CAAAE,WAAW,CAACG,WAAW;IACpCC,mBAAmB,EAAEN,MAAA,CAAAE,WAAW,CAACI,mBAAmB;IA