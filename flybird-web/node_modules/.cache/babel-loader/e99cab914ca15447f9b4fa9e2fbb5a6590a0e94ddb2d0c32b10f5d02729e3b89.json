{"ast":null,"code":"import { SparklesIcon, ClockIcon, CheckCircleIcon, ArrowTrendingUpIcon, StarIcon, CheckIcon, ExclamationTriangleIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'AIOptimizationResult',\n  props: {\n    modelValue: Boolean,\n    result: {\n      type: Object,\n      required: true\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'confirm', 'cancel'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 获取章节标题\n    const getSectionTitle = (section, key) => {\n      const titles = {\n        basic_info: {\n          personal_summary: '个人简介'\n        },\n        work_experiences: '工作经历',\n        educations: '教育背景',\n        skills: '专业技能',\n        certificates: '证书认证',\n        languages: '语言能力',\n        portfolios: '项目作品'\n      };\n      return titles[section]?.[key] || titles[section] || key;\n    };\n\n    // 获取项目标题\n    const getItemTitle = item => {\n      if (item.name) return item.name;\n      if (item.title) return item.title;\n      if (item.company) return `${item.company} - ${item.position}`;\n      if (item.school) return `${item.school} - ${item.major}`;\n      return '';\n    };\n\n    // 处理确认\n    const handleConfirm = () => {\n      emit('confirm', props.result.optimization_id);\n    };\n\n    // 处理取消\n    const handleCancel = () => {\n      emit('cancel');\n    };\n    const __returned__ = {\n      props,\n      emit,\n      getSectionTitle,\n      getItemTitle,\n      handleConfirm,\n      handleCancel,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      },\n      get ArrowTrendingUpIcon() {\n        return ArrowTrendingUpIcon;\n      },\n      get StarIcon() {\n        return StarIcon;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get ExclamationTriangleIcon() {\n        return ExclamationTriangleIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["SparklesIcon","ClockIcon","CheckCircleIcon","ArrowTrendingUpIcon","StarIcon","CheckIcon","ExclamationTriangleIcon","props","__props","emit","__emit","getSectionTitle","section","key","titles","basic_info","personal_summary","work_experiences","educations","skills","certificates","languages","portfolios","getItemTitle","item","name","title","company","position","school","major","handleConfirm","result","optimization_id","handleCancel"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/AIOptimizationResult.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    title=\"AI 优化结果预览\"\n    :width=\"900\"\n    :close-on-click-modal=\"false\"\n    class=\"ai-optimization-result\"\n  >\n    <div class=\"space-y-6\">\n      <!-- 主要改进点 -->\n      <div class=\"bg-primary-50 rounded-lg p-4\">\n        <h4 class=\"text-sm font-medium text-primary-900 mb-2\">主要改进</h4>\n        <ul class=\"space-y-1\">\n          <li v-for=\"(improvement, index) in result.summary.key_improvements\" \n            :key=\"index\"\n            class=\"text-sm text-primary-700 flex items-start space-x-2\"\n          >\n            <CheckCircleIcon class=\"w-4 h-4 mt-0.5 flex-shrink-0\" />\n            <span>{{ improvement }}</span>\n          </li>\n        </ul>\n      </div>\n\n      <!-- 各部分优化内容 -->\n      <div class=\"space-y-4\">\n        <template v-for=\"(section, sectionKey) in result.preview\" :key=\"sectionKey\">\n          <div v-for=\"(item, itemKey) in section\" :key=\"itemKey\">\n            <div class=\"border rounded-lg mb-4\">\n              <div class=\"bg-gray-50 px-4 py-2 rounded-t-lg flex items-center justify-between\">\n                <h4 class=\"font-medium text-gray-900\">{{ getSectionTitle(sectionKey, itemKey) }}</h4>\n                <span class=\"text-xs text-gray-500\">{{ getItemTitle(item) }}</span>\n              </div>\n              <div class=\"p-4 space-y-4\">\n                <!-- 前后对比 -->\n                <div class=\"grid grid-cols-2 gap-6\">\n                  <div class=\"space-y-2\">\n                    <div class=\"flex items-center text-sm text-gray-500\">\n                      <ClockIcon class=\"w-4 h-4 mr-1\" />\n                      <span>当前内容</span>\n                    </div>\n                    <div class=\"bg-gray-50 p-3 rounded text-sm text-gray-600\">\n                      {{ item.before }}\n                    </div>\n                  </div>\n                  <div class=\"space-y-2\">\n                    <div class=\"flex items-center text-sm text-green-600\">\n                      <SparklesIcon class=\"w-4 h-4 mr-1\" />\n                      <span>优化建议</span>\n                    </div>\n                    <div class=\"bg-green-50 p-3 rounded text-sm text-gray-800\">\n                      {{ item.after }}\n                    </div>\n                  </div>\n                </div>\n                <!-- 改进说明 -->\n                <div class=\"border-t pt-3\">\n                  <h5 class=\"text-sm font-medium text-gray-700 mb-2\">优化要点：</h5>\n                  <ul class=\"space-y-1\">\n                    <li v-for=\"(change, index) in item.changes\" \n                      :key=\"index\"\n                      class=\"text-sm text-gray-600 flex items-start space-x-2\"\n                    >\n                      <ArrowTrendingUpIcon class=\"w-4 h-4 text-green-500 mt-0.5 flex-shrink-0\" />\n                      <span>{{ change }}</span>\n                    </li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </div>\n        </template>\n      </div>\n\n      <!-- 预期效果 -->\n      <div class=\"bg-green-50 rounded-lg p-4\">\n        <h4 class=\"text-sm font-medium text-green-900 mb-2\">预期效果</h4>\n        <ul class=\"space-y-1\">\n          <li v-for=\"(benefit, index) in result.summary.expected_benefits\" \n            :key=\"index\"\n            class=\"text-sm text-green-700 flex items-start space-x-2\"\n          >\n            <StarIcon class=\"w-4 h-4 mt-0.5 flex-shrink-0\" />\n            <span>{{ benefit }}</span>\n          </li>\n        </ul>\n      </div>\n\n      <!-- 确认按钮 -->\n      <div class=\"flex justify-between items-center pt-4 border-t\">\n        <div class=\"text-sm text-gray-500\">\n          <ExclamationTriangleIcon class=\"w-4 h-4 inline mr-1 text-yellow-500\" />\n          确认后将覆盖原有内容\n        </div>\n        <div class=\"flex space-x-3\">\n          <button\n            @click=\"handleCancel\"\n            class=\"px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors\"\n          >\n            放弃优化\n          </button>\n          <button\n            @click=\"handleConfirm\"\n            :disabled=\"loading\"\n            class=\"inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-md transition-colors disabled:opacity-50\"\n          >\n            <CheckIcon class=\"w-4 h-4 mr-1.5\" />\n            {{ loading ? '确认中...' : '确认应用' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { \n  SparklesIcon, ClockIcon, CheckCircleIcon, \n  ArrowTrendingUpIcon, StarIcon, CheckIcon,\n  ExclamationTriangleIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  result: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'confirm', 'cancel'])\n\n// 获取章节标题\nconst getSectionTitle = (section, key) => {\n  const titles = {\n    basic_info: {\n      personal_summary: '个人简介'\n    },\n    work_experiences: '工作经历',\n    educations: '教育背景',\n    skills: '专业技能',\n    certificates: '证书认证',\n    languages: '语言能力',\n    portfolios: '项目作品'\n  }\n  return titles[section]?.[key] || titles[section] || key\n}\n\n// 获取项目标题\nconst getItemTitle = (item) => {\n  if (item.name) return item.name\n  if (item.title) return item.title\n  if (item.company) return `${item.company} - ${item.position}`\n  if (item.school) return `${item.school} - ${item.major}`\n  return ''\n}\n\n// 处理确认\nconst handleConfirm = () => {\n  emit('confirm', props.result.optimization_id)\n}\n\n// 处理取消\nconst handleCancel = () => {\n  emit('cancel')\n}\n</script> "],"mappings":"AAoHA,SACEA,YAAY,EAAEC,SAAS,EAAEC,eAAe,EACxCC,mBAAmB,EAAEC,QAAQ,EAAEC,SAAS,EACxCC,uBAAsB,QACjB,2BAA0B;;;;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;IASd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,eAAe,GAAGA,CAACC,OAAO,EAAEC,GAAG,KAAK;MACxC,MAAMC,MAAM,GAAG;QACbC,UAAU,EAAE;UACVC,gBAAgB,EAAE;QACpB,CAAC;QACDC,gBAAgB,EAAE,MAAM;QACxBC,UAAU,EAAE,MAAM;QAClBC,MAAM,EAAE,MAAM;QACdC,YAAY,EAAE,MAAM;QACpBC,SAAS,EAAE,MAAM;QACjBC,UAAU,EAAE;MACd;MACA,OAAOR,MAAM,CAACF,OAAO,CAAC,GAAGC,GAAG,CAAC,IAAIC,MAAM,CAACF,OAAO,CAAC,IAAIC,GAAE;IACxD;;IAEA;IACA,MAAMU,YAAY,GAAIC,IAAI,IAAK;MAC7B,IAAIA,IAAI,CAACC,IAAI,EAAE,OAAOD,IAAI,CAACC,IAAG;MAC9B,IAAID,IAAI,CAACE,KAAK,EAAE,OAAOF,IAAI,CAACE,KAAI;MAChC,IAAIF,IAAI,CAACG,OAAO,EAAE,OAAO,GAAGH,IAAI,CAACG,OAAO,MAAMH,IAAI,CAACI,QAAQ,EAAC;MAC5D,IAAIJ,IAAI,CAACK,MAAM,EAAE,OAAO,GAAGL,IAAI,CAACK,MAAM,MAAML,IAAI,CAACM,KAAK,EAAC;MACvD,OAAO,EAAC;IACV;;IAEA;IACA,MAAMC,aAAa,GAAGA,CAAA,KAAM;MAC1BtB,IAAI,CAAC,SAAS,EAAEF,KAAK,CAACyB,MAAM,CAACC,eAAe;IAC9C;;IAEA;IACA,MAAMC,YAAY,GAAGA,CAAA,KAAM;MACzBzB,IAAI,CAAC,QAAQ;IACf","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}