click"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <div class=\"p-4\">\n        <div class=\"flex items-start space-x-5\">\n          <!-- 头像部分 -->\n          <div class=\"relative group\">\n            <img \n                :src=\"avatarUrl\" \n                class=\"w-20 h-20 rounded-full object-cover border-2 border-white shadow\"\n                alt=\"用户头像\"\n                @error=\"handleImageError\"\n                />\n                <div \n                @click=\"triggerUpload\"\n                class=\"absolute inset-0 flex items-center justify-center rounded-full bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-200\"\n                >\n                <CameraIcon class=\"w-8 h-8 text-white\" />\n                </div>\n                <input\n                ref=\"fileInput\"\n                type=\"file\"\n                accept=\"image/*\"\n                class=\"hidden\"\n                @change=\"handleFileChange\"\n                />\n          </div>\n  \n          <!-- 用户信息 -->\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center justify-between mb-3\">\n              <h2 class=\"text-lg font-medium text-gray-900\">\n                <template v-if=\"resumeData.name\">\n                  {{ resumeData.name }}\n                </template>\n                <span v-else class=\"text-sm text-gray-400\">未设置姓名</span>\n              </h2>\n              <button\n                @click=\"$emit('edit')\"\n                class=\"inline-flex items-center px-2.5 py-1 text-xs font-medium text-primary-600 hover:text-primary-700 border border-primary-600 hover:border-primary-700 rounded\"\n              >\n                <PencilIcon class=\"w-3.5 h-3.5 mr-1\" />\n                编辑资料\n              </button>\n            </div>\n  \n            <!-- 基本信息列表 -->\n            <div class=\"grid grid-cols-2 gap-3\">\n              <!-- 手机号 -->\n              <div class=\"flex items-center text-gray-600\">\n                <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.phone\">\n                  <span class=\"text-sm truncate\">{{ resumeData.phone }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置手机号</span>\n              </div>\n  \n              <!-- 邮箱 -->\n              <div class=\"flex items-center text-gray-600\">\n                <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.email\">\n                  <span class=\"text-sm truncate\">{{ resumeData.email }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置邮箱</span>\n              </div>\n  \n              <!-- 所在地 -->\n              <div class=\"flex items-center text-gray-600\">\n                <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.location\">\n                  <span class=\"text-sm truncate\">{{ resumeData.location }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置所在地</span>\n              </div>\n  \n              <!-- 求职状态 -->\n              <div class=\"flex items-center text-gray-600\">\n                <BriefcaseIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.jobStatus\">\n                  <span class=\"text-sm truncate\">{{ resumeData.jobStatus }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置求职状态</span>\n              </div>\n  \n              <!-- 工作年限 -->\n              <div class=\"flex items-center text-gray-600\">\n                <ClockIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.workYears\">\n                  <span class=\"text-sm truncate\">{{ resumeData.workYears }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置工作年限</span>\n              </div>\n  \n              <!-- 期望薪资 -->\n              <div class=\"flex items-center text-gray-600\">\n                <CurrencyYenIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.expectedSalary\">\n                  <span class=\"text-sm truncate\">{{ resumeData.expectedSalary }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置期望薪资</span>\n              </div>\n            </div>\n  \n            <!-- 个人简介 -->\n            <div class=\"mt-3\">\n              <div class=\"flex items-center text-gray-600 mb-1\">\n                <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm font-medium\">个人简介</span>\n              </div>\n              <template v-if=\"resumeData.bio\">\n                <p class=\"text-sm text-gray-600 leading-relaxed line-clamp-2\">\n                  {{ resumeData.bio }}\n                </p>\n              </template>\n              <p v-else class=\"text-sm text-gray-400 leading-relaxed\">\n                未设置个人简介\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed, nextTick } from 'vue'\nimport { ElMessage , ElLoading } from 'element-plus'\nimport request, { API_PATHS } from '@/utils/request'  \nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nimport { profile } from '@/api/profile'\nconst store = useStore()\nconst loadingInstance = ref(null)\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon\n} from '@heroicons/vue/24/outline'\n// 从 store 获取头像\nconst avatarUrl = computed(() => store.getters.getUserAvatar)\n// 处理图片加载错误\nconst handleImageError = (e) => {\n  e.target.src = defaultAvatarImage\n}\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:resumeData'])\nconst fileInput = ref(null)\n\n// 处理文件上传\nconst handleFileChange = async (event) => {\n  if (!event.target.files.length) return\n\n  try {\n    const file = event.target.files[0]\n    \n    // 文件验证\n    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif']\n    if (!allowedTypes.includes(file.type)) {\n      ElMessage.error('请上传 JPG、PNG 或 GIF 格式的图片')\n      return\n    }\n\n    // 文件大小验证 (5MB)\n    const maxSize = 5 * 1024 * 1024\n    if (file.size > maxSize) {\n      ElMessage.error('图片大小不能超过 5MB')\n      return\n    }\n\n    loadingInstance.value = ElLoading.service({\n      target: '.avatar-upload',\n      text: '上传中...'\n    })\n\n    try {\n      const response = await profile.uploadAvatar(file)\n      console.log('Upload response:', response)\n\n      if (response.code === 200 && response.data?.avatar_url) {\n        const newAvatarUrl = response.data.avatar_url\n\n        // 更新 store 中的用户信息\n        store.commit('SET_USER_INFO', {\n          avatar: newAvatarUrl\n        })\n\n        // 更新本地数据\n        emit('update:resumeData', {\n          ...props.resumeData,\n          avatar: newAvatarUrl\n        })\n\n        // 强制刷新用户信息\n        await store.dispatch('fetchUserInfo')\n\n        // 添加调试日志\n        console.log('Avatar updated:', {\n          newAvatar: newAvatarUrl,\n          storeAvatar: store.getters.getUserAvatar,\n          resumeDataAvatar: props.resumeData.avatar\n        })\n\n        ElMessage.success(response.message || '头像上传成功')\n      } else {\n        throw new Error(response.message || '上传失败')\n      }\n    } catch (uploadError) {\n      console.error('Upload error:', uploadError)\n      throw uploadError\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error)\n    ElMessage.error(error.message || '头像上传失败，请重试')\n  } finally {\n    loadingInstance.value?.close()\n    loadingInstance.value = null\n    event.target.value = ''\n  }\n}\n\n// 添加一个计算属性来获取带时间戳的头像 URL\nconst currentAvatarUrl = computed(() => {\n  const baseUrl = store.getters.getUserAvatar\n  return baseUrl + '?t=' + Date.now()\n})\n\n// 触发文件选择\nconst triggerUpload = () => {\n  fileInput.value.click()\n}\n</script>"],"mappings":";AA6HA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,QAAQ,KAAI;AAC5C,SAASC,SAAS,EAAGC,SAAS,QAAQ,cAAa;AACnD,OAAOC,OAAO,IAAIC,SAAS,QAAQ,iBAAiB;AACpD,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,OAAO,QAAQ,eAAc;AAGtC,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAS,QACJ,2BAA0B;AACjC;;;;;;;;;;;;;;;;;IAbA,MAAMC,KAAK,GAAGX,QAAQ,CAAC;IACvB,MAAMY,eAAe,GAAGpB,GAAG,CAAC,IAAI;IAahC,MAAMqB,SAAS,GAAGpB,QAAQ,CAAC,MAAMkB,KAAK,CAACG,OAAO,CAACC,aAAa;IAC5D;IACA,MAAMC,gBAAgB,GAAIC,CAAC,IAAK;MAC9BA,CAAC,CAACC,MAAM,CAACC,GAAG,GAAGpB,kBAAiB;IAClC;IACA,MAAMqB,KAAK,GAAGC,OAAA;IAQd,MAAMC,IAAI,GAAGC,MAAA;IACb,MAAMC,SAAS,GAAGhC,GAAG,CAAC,IAAI;;IAE1B;IACA,MAAMiC,gBAAgB,GAAG,MAAOC,KAAK,IAAK;MACxC,IAAI,CAACA,KAAK,CAACR,MAAM,CAACS,KAAK,CAACC,MAAM,EAAE;MAEhC,IAAI;QACF,MAAMC,IAAI,GAAGH,KAAK,CAACR,MAAM,CAACS,KAAK,CAAC,CAAC;;QAEjC;QACA,MAAMG,YAAY,GAAG,CAAC,YAAY,EAAE,WAAW,EAAE,WAAW;QAC5D,IAAI,CAACA,YAAY,CAACC,QAAQ,CAACF,IAAI,CAACG,IAAI,CAAC,EAAE;UACrCrC,SAAS,CAACsC,KAAK,CAAC,yBAAyB;UACzC;QACF;;QAEA;QACA,MAAMC,OAAO,GAAG,CAAC,GAAG,IAAI,GAAG,IAAG;QAC9B,IAAIL,IAAI,CAACM,IAAI,GAAGD,OAAO,EAAE;UACvBvC,SAAS,CAACsC,KAAK,CAAC,cAAc;UAC9B;QACF;QAEArB,eAAe,CAACwB,KAAK,GAAGxC,SAAS,CAACyC,OAAO,CAAC;UACxCnB,MAAM,EAAE,gBAAgB;UACxBoB,IAAI,EAAE;QACR,CAAC;QAED,IAAI;UACF,MAAMC,QAAQ,GAAG,MAAMtC,OAAO,CAACuC,YAAY,CAACX,IAAI