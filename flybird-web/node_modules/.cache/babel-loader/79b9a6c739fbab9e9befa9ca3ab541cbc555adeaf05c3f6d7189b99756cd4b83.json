{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport { ref, computed, onMounted, onUnmounted } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { auth } from '@/api/auth';\nimport { SMS_SCENE } from '@/constants';\nimport HeadView from '@/components/HeadView.vue';\n\n/**\n * Vuex store 实例\n * @type {import('vuex').Store}\n */\n\nexport default {\n  __name: 'RegisterView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n\n    /**\n     * Vue Router 实例\n     * @type {import('vue-router').Router}\n     */\n    const router = useRouter();\n\n    /**\n     * 表单数据\n     * @type {import('vue').Ref<Object>}\n     */\n    const form = ref({\n      phone: '',\n      password: '',\n      code: '',\n      countdown: 0\n    });\n\n    /**\n     * UI 状态变量\n     */\n    const showPassword = ref(false);\n    const agreed = ref(false);\n    const loading = ref(false);\n    const sendingCode = ref(false);\n\n    /**\n     * 表单验证计算属性\n     * @type {import('vue').ComputedRef<boolean>}\n     */\n    const isFormValid = computed(() => {\n      return form.value.phone && form.value.code && form.value.password && form.value.password.length >= 6 && agreed.value;\n    });\n\n    /**\n     * 切换密码显示状态\n     */\n    const togglePassword = () => {\n      showPassword.value = !showPassword.value;\n    };\n\n    /**\n     * 统一错误处理函数\n     */\n    const handleError = (error, {\n      type,\n      onRegistered\n    }) => {\n      // 处理限速错误\n      if (error.isRateLimit) {\n        const minutes = Math.ceil(error.retryAfter / 60);\n        showToast(`操作过于频繁，请在 ${minutes} 分钟后重试`, 'warning');\n        return;\n      }\n      const errorData = error.response?.data;\n\n      // 处理已注册错误\n      if (errorData?.errors?.phone?.[0]?.includes('已注册')) {\n        showToast('手机号已注册', 'warning');\n        onRegistered();\n        return;\n      }\n\n      // 处理验证码错误\n      if (errorData?.errors?.code?.[0]?.includes('验证码')) {\n        showToast('验证码错误或已过期，请重新获取', 'error');\n        return;\n      }\n\n      // 处理其他业务错误\n      if (errorData?.message) {\n        showToast(errorData.message, 'error');\n        return;\n      }\n\n      // 处理默认错误\n      const defaultMessages = {\n        sendCode: '发送验证码失败，请稍后重试',\n        register: '注册失败，请稍后重试'\n      };\n      showToast(defaultMessages[type], 'error');\n    };\n\n    /**\n     * 获取验证码\n     */\n    const getVerifyCode = async () => {\n      if (!form.value.phone) {\n        showToast('请输入手机号', 'warning');\n        return;\n      }\n      const phoneRegex = /^1[3-9]\\d{9}$/;\n      if (!phoneRegex.test(form.value.phone)) {\n        showToast('请输入正确的手机号', 'warning');\n        return;\n      }\n      try {\n        sendingCode.value = true;\n        const response = await auth.sendVerifyCode({\n          phone: form.value.phone,\n          scene: SMS_SCENE.REGISTER\n        });\n        if (response.data?.code === 200 || response.data?.detail === '验证码已发送') {\n          form.value.countdown = 60;\n          const timer = setInterval(() => {\n            form.value.countdown--;\n            if (form.value.countdown <= 0) {\n              clearInterval(timer);\n            }\n          }, 1000);\n          showToast('验证码已发送', 'success');\n        } else {\n          throw new Error(response.data?.message || response.data?.detail || '发送验证码失败');\n        }\n      } catch (error) {\n        console.error('发送验证码失败:', error.response || error);\n        handleError(error, {\n          type: 'sendCode',\n          onRegistered: () => router.push('/login')\n        });\n      } finally {\n        sendingCode.value = false;\n      }\n    };\n\n    /**\n     * 注册处理\n     */\n    const handleRegister = async () => {\n      try {\n        loading.value = true;\n\n        // 表单验证\n        if (!form.value.phone || !form.value.code || !form.value.password || !form.value.confirmPassword) {\n          showToast('请填写完整信息', 'warning');\n          return;\n        }\n\n        // 验证两次密码是否一致\n        if (form.value.password !== form.value.confirmPassword) {\n          showToast('两次输入的密码不一致', 'warning');\n          return;\n        }\n\n        // 1. 注册\n        try {\n          const registerResponse = await auth.register({\n            phone: form.value.phone.trim(),\n            code: form.value.code,\n            password: form.value.password,\n            confirm_password: form.value.confirmPassword\n          });\n          if (!registerResponse.data || registerResponse.data.code !== 200) {\n            throw new Error(registerResponse.data?.message || '注册失败');\n          }\n          const {\n            access,\n            refresh,\n            user\n          } = registerResponse.data.data;\n\n          // 2. 更新 store 状态\n          await store.dispatch('login', {\n            tokens: {\n              access,\n              refresh\n            },\n            user: _objectSpread(_objectSpread({}, user), {}, {\n              phone: form.value.phone.trim()\n            })\n          });\n          showToast('注册成功', 'success');\n\n          // 3. 等待一下再跳转\n          await new Promise(resolve => setTimeout(resolve, 300));\n          router.push('/user');\n        } catch (error) {\n          // 处理限速错误\n          if (error.isRateLimit) {\n            const minutes = Math.ceil(error.retryAfter / 60);\n            showToast(`操作过于频繁，请在 ${minutes} 分钟后重试`, 'warning');\n            return;\n          }\n          throw error;\n        }\n      } catch (error) {\n        console.error('注册/登录失败:', error);\n        handleError(error, {\n          type: 'register',\n          onRegistered: () => router.push('/login')\n        });\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    /**\n     * 检查网络连接状态\n     * @returns {boolean} 网络是否可用\n     */\n    const checkNetwork = () => {\n      if (!navigator.onLine) {\n        showToast('网络连接不稳定，请检查网络设置', 'warning');\n        return false;\n      }\n      return true;\n    };\n\n    /**\n     * 网络恢复处理\n     */\n    const handleOnline = () => {\n      showToast('网络已连接', 'success');\n    };\n\n    /**\n     * 网络断开处理\n     */\n    const handleOffline = () => {\n      showToast('网络连接已断开', 'warning');\n    };\n\n    // 生命周期钩子\n    onMounted(() => {\n      window.addEventListener('online', handleOnline);\n      window.addEventListener('offline', handleOffline);\n    });\n    onUnmounted(() => {\n      window.removeEventListener('online', handleOnline);\n      window.removeEventListener('offline', handleOffline);\n    });\n\n    // 处理登录错误\n    const handleLoginError = error => {\n      console.error('Login error details:', error);\n\n      // 获取错误响应数据\n      const errorData = error.response?.data;\n\n      // 处理具体的错误情况\n      if (errorData?.code === 400) {\n        if (errorData.message.includes('密码错误')) {\n          showToast('密码错误，请重试', 'error');\n          return;\n        }\n        if (errorData.message.includes('用户不存在')) {\n          showToast('用户不存在', 'error');\n          return;\n        }\n      }\n\n      // 处理其他错误情况\n      if (error.response?.status === 401) {\n        showToast('用户名或密码错误', 'error');\n      } else if (error.response?.status === 429) {\n        showToast('登录请求过于频繁，请稍后再试', 'error');\n      } else if (error.response?.status === 500) {\n        showToast('服务器错误，请稍后重试', 'error');\n      } else if (!navigator.onLine) {\n        showToast('网络连接失败，请检查网络设置', 'error');\n      } else {\n        showToast(errorData?.message || '登录失败，请稍后重试', 'error');\n      }\n    };\n\n    // 在登录处理中使用\n    const handleLogin = async e => {\n      e.preventDefault();\n      if (!validatePasswordForm()) return;\n      try {\n        loading.value = true;\n        const response = await auth.login({\n          phone: phone.value,\n          password: password.value\n        });\n        console.log('Login response:', response);\n        if (response.data.code === 200) {\n          const {\n            token,\n            refresh_token,\n            user\n          } = response.data.data || {};\n          if (!token || !refresh_token || !user) {\n            throw new Error('登录响应数据不完整');\n          }\n\n          // 保存认证信息\n          localStorage.setItem('access_token', token);\n          localStorage.setItem('refresh_token', refresh_token);\n          try {\n            // 更新 store\n            await store.dispatch('loginWithPassword', {\n              tokens: {\n                access: token,\n                refresh: refresh_token\n              },\n              user: user,\n              remember: rememberMe.value,\n              phone: phone.value\n            });\n            showToast('登录成功', 'success');\n            const redirect = router.currentRoute.value.query.redirect || '/';\n            router.push(redirect);\n          } catch (storeError) {\n            console.error('Store update error:', storeError);\n            handleLoginError(storeError);\n          }\n        } else {\n          throw new Error(response.data.message || '登录失败');\n        }\n      } catch (error) {\n        console.error('Login error:', error);\n        handleLoginError(error);\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      store,\n      router,\n      form,\n      showPassword,\n      agreed,\n      loading,\n      sendingCode,\n      isFormValid,\n      togglePassword,\n      handleError,\n      getVerifyCode,\n      handleRegister,\n      checkNetwork,\n      handleOnline,\n      handleOffline,\n      handleLoginError,\n      handleLogin,\n      ref,\n      computed,\n      onMounted,\n      onUnmounted,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get auth() {\n        return auth;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      },\n      HeadView\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","onUnmounted","useStore","useRouter","showToast","auth","SMS_SCENE","HeadView","store","router","form","phone","password","code","countdown","showPassword","agreed","loading","sendingCode","isFormValid","value","length","togglePassword","handleError","error","type","onRegistered","isRateLimit","minutes","Math","ceil","retryAfter","errorData","response","data","errors","includes","message","defaultMessages","sendCode","register","getVerifyCode","phoneRegex","test","sendVerifyCode","scene","REGISTER","detail","timer","setInterval","clearInterval","Error","console","push","handleRegister","confirmPassword","registerResponse","trim","confirm_password","access","refresh","user","dispatch","tokens","_objectSpread","Promise","resolve","setTimeout","checkNetwork","navigator","onLine","handleOnline","handleOffline","window","addEventListener","removeEventListener","handleLoginError","status","handleLogin","e","preventDefault","validatePasswordForm","login","log","token","refresh_token","localStorage","setItem","remember","rememberMe","redirect","currentRoute","query","storeError"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/RegisterView.vue"],"sourcesContent":["<template>\n  <div class=\"flex flex-col min-h-screen\">\n  <HeadView />\n  <main class=\"flex-1 pt-14 relative z-[1] bg-gray-50\">\n    <div class=\"sm:mx-auto sm:w-full sm:max-w-md pt-8\">\n      <h2 class=\"mt-6 text-center text-2xl font-bold leading-9 tracking-tight text-gray-900\">注册账号</h2>\n    </div>\n    <div class=\"mt-10 sm:mx-auto sm:w-full sm:max-w-[480px]\">\n      <div class=\"bg-white px-6 py-12 shadow sm:rounded-lg sm:px-12\">\n        <form class=\"space-y-6\" @submit.prevent=\"handleRegister\">\n          <!-- 手机号输入 -->\n          <div>\n            <label for=\"phone\" class=\"block text-sm font-medium leading-6 text-gray-900\">手机号</label>\n            <div class=\"mt-2\">\n              <input \n                id=\"phone\" \n                v-model=\"form.phone\" \n                type=\"text\" \n                required\n                placeholder=\"请输入手机号\"\n                class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n              />\n            </div>\n          </div>\n\n          <!-- 验证码输入 -->\n          <div>\n            <label for=\"code\" class=\"block text-sm font-medium leading-6 text-gray-900\">验证码</label>\n            <div class=\"mt-2 flex\">\n              <div class=\"flex-grow\">\n                <input \n                  id=\"code\" \n                  v-model=\"form.code\" \n                  type=\"text\" \n                  required\n                  placeholder=\"请输入验证码\"\n                  class=\"block w-full rounded-l-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n                />\n              </div>\n              <button \n                type=\"button\"\n                @click=\"getVerifyCode\"\n                :disabled=\"form.countdown > 0 || sendingCode\"\n                class=\"relative -ml-px whitespace-nowrap inline-flex items-center rounded-r-md px-6 py-2 text-sm font-semibold ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-10 w-[140px]\"\n                :class=\"form.countdown > 0 || sendingCode ? 'text-gray-400 bg-gray-50' : 'text-indigo-600'\"\n              >\n                <svg v-if=\"sendingCode\" class=\"animate-spin -ml-1 mr-2 h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\">\n                  <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n                  <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n                </svg>\n                <span class=\"w-full text-center\">\n                  {{ sendingCode ? '发送中...' : form.countdown > 0 ? `${form.countdown}s` : '获取验证码' }}\n                </span>\n              </button>\n            </div>\n          </div>\n\n          <!-- 密码输入 -->\n          <div>\n            <label for=\"password\" class=\"block text-sm font-medium leading-6 text-gray-900\">密码</label>\n            <div class=\"mt-2 relative\">\n              <input \n                id=\"password\" \n                v-model=\"form.password\" \n                :type=\"showPassword ? 'text' : 'password'\" \n                required\n                placeholder=\"请输入密码\"\n                class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n              />\n              <button \n                type=\"button\" \n                @click=\"togglePassword\"\n                class=\"absolute inset-y-0 right-0 pr-3 flex items-center\"\n              >\n                <svg v-if=\"showPassword\" class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                </svg>\n                <svg v-else class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                </svg>\n              </button>\n            </div>\n          </div>\n\n          <!-- 确认密码输入 -->\n          <div>\n            <label for=\"confirmPassword\" class=\"block text-sm font-medium leading-6 text-gray-900\">确认密码</label>\n            <div class=\"mt-2 relative\">\n              <input \n                id=\"confirmPassword\" \n                v-model=\"form.confirmPassword\"\n                type=\"password\"\n                required\n                placeholder=\"请确认密码\"\n                class=\"block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6\" \n              />\n              <button \n                type=\"button\" \n                @click=\"togglePassword\"\n                class=\"absolute inset-y-0 right-0 pr-3 flex items-center\"\n              >\n                <svg v-if=\"showPassword\" class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                </svg>\n                <svg v-else class=\"h-5 w-5 text-gray-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                </svg>\n              </button>\n            </div>\n          </div>\n\n          <!-- 服务条款 -->\n          <div class=\"flex items-center\">\n            <input \n              id=\"agree-terms\" \n              v-model=\"agreed\" \n              type=\"checkbox\" \n              required\n              class=\"h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600\" \n            />\n            <label for=\"agree-terms\" class=\"ml-3 block text-sm leading-6 text-gray-900\">\n              我已阅读并同意\n              <a href=\"#\" class=\"font-semibold text-indigo-600 hover:text-indigo-500\">服务条款</a>\n              和\n              <a href=\"#\" class=\"font-semibold text-indigo-600 hover:text-indigo-500\">隐私政策</a>\n            </label>\n          </div>\n\n          <!-- 注册按钮 -->\n          <div>\n            <button \n              type=\"submit\" \n              :disabled=\"!isFormValid || loading\"\n              class=\"flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold leading-6 text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              <svg v-if=\"loading\" class=\"animate-spin -ml-1 mr-3 h-5 w-5 text-white\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n                <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n              </svg>\n              {{ loading ? '注册中...' : '注册' }}\n            </button>\n          </div>\n        </form>\n\n        <!-- 登录链接 -->\n        <div>\n          <div class=\"relative mt-10\">\n            <div class=\"absolute inset-0 flex items-center\" aria-hidden=\"true\">\n              <div class=\"w-full border-t border-gray-200\"></div>\n            </div>\n            <div class=\"relative flex justify-center text-sm font-medium leading-6\">\n              <span class=\"bg-white px-6 text-gray-900\">已有账号?</span>\n            </div>\n          </div>\n\n          <div class=\"mt-6\">\n            <router-link \n              to=\"/login\"\n              class=\"flex w-full justify-center rounded-md bg-white px-3 py-1.5 text-sm font-semibold leading-6 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600\"\n            >\n              登录\n            </router-link>\n          </div>\n        </div>\n      </div>\n    </div>\n\n</main>\n</div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, onUnmounted } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { auth } from '@/api/auth'\nimport { SMS_SCENE } from '@/constants'\nimport HeadView from '@/components/HeadView.vue'\n\n/**\n * Vuex store 实例\n * @type {import('vuex').Store}\n */\nconst store = useStore()\n\n/**\n * Vue Router 实例\n * @type {import('vue-router').Router}\n */\nconst router = useRouter()\n\n/**\n * 表单数据\n * @type {import('vue').Ref<Object>}\n */\nconst form = ref({\n  phone: '',\n  password: '',\n  code: '',\n  countdown: 0\n})\n\n/**\n * UI 状态变量\n */\nconst showPassword = ref(false)\nconst agreed = ref(false)\nconst loading = ref(false)\nconst sendingCode = ref(false)\n\n/**\n * 表单验证计算属性\n * @type {import('vue').ComputedRef<boolean>}\n */\nconst isFormValid = computed(() => {\n  return form.value.phone && \n         form.value.code && \n         form.value.password && \n         form.value.password.length >= 6 && \n         agreed.value\n})\n\n/**\n * 切换密码显示状态\n */\nconst togglePassword = () => {\n  showPassword.value = !showPassword.value\n}\n\n/**\n * 统一错误处理函数\n */\nconst handleError = (error, { type, onRegistered }) => {\n  // 处理限速错误\n  if (error.isRateLimit) {\n    const minutes = Math.ceil(error.retryAfter / 60)\n    showToast(`操作过于频繁，请在 ${minutes} 分钟后重试`, 'warning')\n    return\n  }\n\n  const errorData = error.response?.data\n  \n  // 处理已注册错误\n  if (errorData?.errors?.phone?.[0]?.includes('已注册')) {\n    showToast('手机号已注册', 'warning')\n    onRegistered()\n    return\n  }\n  \n  // 处理验证码错误\n  if (errorData?.errors?.code?.[0]?.includes('验证码')) {\n    showToast('验证码错误或已过期，请重新获取', 'error')\n    return\n  }\n  \n  // 处理其他业务错误\n  if (errorData?.message) {\n    showToast(errorData.message, 'error')\n    return\n  }\n  \n  // 处理默认错误\n  const defaultMessages = {\n    sendCode: '发送验证码失败，请稍后重试',\n    register: '注册失败，请稍后重试'\n  }\n  showToast(defaultMessages[type], 'error')\n}\n\n/**\n * 获取验证码\n */\nconst getVerifyCode = async () => {\n  if (!form.value.phone) {\n    showToast('请输入手机号', 'warning')\n    return\n  }\n  \n  const phoneRegex = /^1[3-9]\\d{9}$/\n  if (!phoneRegex.test(form.value.phone)) {\n    showToast('请输入正确的手机号', 'warning')\n    return\n  }\n\n  try {\n    sendingCode.value = true\n    const response = await auth.sendVerifyCode({\n      phone: form.value.phone,\n      scene: SMS_SCENE.REGISTER\n    })\n    \n    if (response.data?.code === 200 || response.data?.detail === '验证码已发送') {\n      form.value.countdown = 60\n      const timer = setInterval(() => {\n        form.value.countdown--\n        if (form.value.countdown <= 0) {\n          clearInterval(timer)\n        }\n      }, 1000)\n      \n      showToast('验证码已发送', 'success')\n    } else {\n      throw new Error(response.data?.message || response.data?.detail || '发送验证码失败')\n    }\n  } catch (error) {\n    console.error('发送验证码失败:', error.response || error)\n    handleError(error, {\n      type: 'sendCode',\n      onRegistered: () => router.push('/login')\n    })\n  } finally {\n    sendingCode.value = false\n  }\n}\n\n/**\n * 注册处理\n */\nconst handleRegister = async () => {\n  try {\n    loading.value = true\n    \n    // 表单验证\n    if (!form.value.phone || !form.value.code || !form.value.password || !form.value.confirmPassword) {\n      showToast('请填写完整信息', 'warning')\n      return\n    }\n\n    // 验证两次密码是否一致\n    if (form.value.password !== form.value.confirmPassword) {\n      showToast('两次输入的密码不一致', 'warning')\n      return\n    }\n\n    // 1. 注册\n    try {\n      const registerResponse = await auth.register({\n        phone: form.value.phone.trim(),\n        code: form.value.code,\n        password: form.value.password,\n        confirm_password: form.value.confirmPassword\n      })\n\n      if (!registerResponse.data || registerResponse.data.code !== 200) {\n        throw new Error(registerResponse.data?.message || '注册失败')\n      }\n\n      const { access, refresh, user } = registerResponse.data.data\n\n      // 2. 更新 store 状态\n      await store.dispatch('login', {\n        tokens: {\n          access,\n          refresh\n        },\n        user: {\n          ...user,\n          phone: form.value.phone.trim()\n        }\n      })\n\n      showToast('注册成功', 'success')\n\n      // 3. 等待一下再跳转\n      await new Promise(resolve => setTimeout(resolve, 300))\n      router.push('/user')\n    } catch (error) {\n      // 处理限速错误\n      if (error.isRateLimit) {\n        const minutes = Math.ceil(error.retryAfter / 60)\n        showToast(`操作过于频繁，请在 ${minutes} 分钟后重试`, 'warning')\n        return\n      }\n      throw error\n    }\n\n  } catch (error) {\n    console.error('注册/登录失败:', error)\n    handleError(error, {\n      type: 'register',\n      onRegistered: () => router.push('/login')\n    })\n  } finally {\n    loading.value = false\n  }\n}\n\n/**\n * 检查网络连接状态\n * @returns {boolean} 网络是否可用\n */\nconst checkNetwork = () => {\n  if (!navigator.onLine) {\n    showToast('网络连接不稳定，请检查网络设置', 'warning')\n    return false\n  }\n  return true\n}\n\n/**\n * 网络恢复处理\n */\nconst handleOnline = () => {\n  showToast('网络已连接', 'success')\n}\n\n/**\n * 网络断开处理\n */\nconst handleOffline = () => {\n  showToast('网络连接已断开', 'warning')\n}\n\n// 生命周期钩子\nonMounted(() => {\n  window.addEventListener('online', handleOnline)\n  window.addEventListener('offline', handleOffline)\n})\n\nonUnmounted(() => {\n  window.removeEventListener('online', handleOnline)\n  window.removeEventListener('offline', handleOffline)\n})\n\n// 处理登录错误\nconst handleLoginError = (error) => {\n  console.error('Login error details:', error)\n  \n  // 获取错误响应数据\n  const errorData = error.response?.data\n  \n  // 处理具体的错误情况\n  if (errorData?.code === 400) {\n    if (errorData.message.includes('密码错误')) {\n      showToast('密码错误，请重试', 'error')\n      return\n    }\n    if (errorData.message.includes('用户不存在')) {\n      showToast('用户不存在', 'error')\n      return\n    }\n  }\n\n  // 处理其他错误情况\n  if (error.response?.status === 401) {\n    showToast('用户名或密码错误', 'error')\n  } else if (error.response?.status === 429) {\n    showToast('登录请求过于频繁，请稍后再试', 'error')\n  } else if (error.response?.status === 500) {\n    showToast('服务器错误，请稍后重试', 'error')\n  } else if (!navigator.onLine) {\n    showToast('网络连接失败，请检查网络设置', 'error')\n  } else {\n    showToast(errorData?.message || '登录失败，请稍后重试', 'error')\n  }\n}\n\n// 在登录处理中使用\nconst handleLogin = async (e) => {\n  e.preventDefault()\n  if (!validatePasswordForm()) return\n\n  try {\n    loading.value = true\n    const response = await auth.login({\n      phone: phone.value,\n      password: password.value\n    })\n    \n    console.log('Login response:', response)\n    \n    if (response.data.code === 200) {\n      const { token, refresh_token, user } = response.data.data || {}\n      \n      if (!token || !refresh_token || !user) {\n        throw new Error('登录响应数据不完整')\n      }\n      \n      // 保存认证信息\n      localStorage.setItem('access_token', token)\n      localStorage.setItem('refresh_token', refresh_token)\n      \n      try {\n        // 更新 store\n        await store.dispatch('loginWithPassword', {\n          tokens: {\n            access: token,\n            refresh: refresh_token\n          },\n          user: user,\n          remember: rememberMe.value,\n          phone: phone.value\n        })\n        \n        showToast('登录成功', 'success')\n        const redirect = router.currentRoute.value.query.redirect || '/'\n        router.push(redirect)\n      } catch (storeError) {\n        console.error('Store update error:', storeError)\n        handleLoginError(storeError)\n      }\n    } else {\n      throw new Error(response.data.message || '登录失败')\n    }\n  } catch (error) {\n    console.error('Login error:', error)\n    handleLoginError(error)\n  } finally {\n    loading.value = false\n  }\n}\n</script>"],"mappings":";AA8KA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,WAAW,QAAQ,KAAI;AAC1D,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,IAAI,QAAQ,YAAW;AAChC,SAASC,SAAS,QAAQ,aAAY;AACtC,OAAOC,QAAQ,MAAM,2BAA0B;;AAE/C;AACA;AACA;AACA;;;;;;;;IACA,MAAMC,KAAK,GAAGN,QAAQ,CAAC;;IAEvB;AACA;AACA;AACA;IACA,MAAMO,MAAM,GAAGN,SAAS,CAAC;;IAEzB;AACA;AACA;AACA;IACA,MAAMO,IAAI,GAAGZ,GAAG,CAAC;MACfa,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,IAAI,EAAE,EAAE;MACRC,SAAS,EAAE;IACb,CAAC;;IAED;AACA;AACA;IACA,MAAMC,YAAY,GAAGjB,GAAG,CAAC,KAAK;IAC9B,MAAMkB,MAAM,GAAGlB,GAAG,CAAC,KAAK;IACxB,MAAMmB,OAAO,GAAGnB,GAAG,CAAC,KAAK;IACzB,MAAMoB,WAAW,GAAGpB,GAAG,CAAC,KAAK;;IAE7B;AACA;AACA;AACA;IACA,M