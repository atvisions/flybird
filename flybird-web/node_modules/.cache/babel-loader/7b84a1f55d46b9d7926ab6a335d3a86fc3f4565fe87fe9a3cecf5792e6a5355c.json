{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.for-each.js\";\nimport \"core-js/modules/esnext.iterator.map.js\";\nimport \"core-js/modules/esnext.iterator.some.js\";\nimport { ref, computed, onMounted } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { XMarkIcon, CheckCircleIcon, XCircleIcon, MinusCircleIcon } from '@heroicons/vue/24/solid';\nexport default {\n  __name: 'AIOptimizeDialog',\n  props: {\n    modelValue: Boolean,\n    profileData: {\n      type: Object,\n      required: true\n    }\n  },\n  emits: ['update:modelValue', 'apply'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 字段配置\n    const fieldConfig = [\n    // 基本信息\n    {\n      name: 'name',\n      label: '姓名（中文）',\n      group: '基本信息'\n    }, {\n      name: 'name_en',\n      label: '姓名（英文）',\n      group: '基本信息'\n    }, {\n      name: 'personal_summary',\n      label: '个人简介（中文）',\n      group: '基本信息'\n    }, {\n      name: 'personal_summary_en',\n      label: '个人简介（英文）',\n      group: '基本信息'\n    },\n    // 求职意向\n    {\n      name: 'job_type',\n      label: '工作类型',\n      group: '求职意向'\n    }, {\n      name: 'job_status',\n      label: '求职状态',\n      group: '求职意向'\n    }, {\n      name: 'expected_salary',\n      label: '期望薪资',\n      group: '求职意向'\n    }, {\n      name: 'expected_city',\n      label: '期望城市',\n      group: '求职意向'\n    }, {\n      name: 'industries',\n      label: '期望行业',\n      group: '求职意向'\n    },\n    // 工作经历（对每个工作经历的字段进行优化）\n    {\n      name: 'work_experiences',\n      label: '工作经历',\n      group: '工作经历',\n      isArray: true,\n      fields: [{\n        name: 'company',\n        label: '公司名称'\n      }, {\n        name: 'position',\n        label: '职位名称'\n      }, {\n        name: 'department',\n        label: '所在部门'\n      }, {\n        name: 'description',\n        label: '工作描述'\n      }, {\n        name: 'achievements',\n        label: '工作成就'\n      }, {\n        name: 'technologies',\n        label: '技术栈'\n      }]\n    },\n    // 教育经历\n    {\n      name: 'educations',\n      label: '教育经历',\n      group: '教育经历',\n      isArray: true,\n      fields: [{\n        name: 'school',\n        label: '学校名称'\n      }, {\n        name: 'major',\n        label: '专业'\n      }, {\n        name: 'degree',\n        label: '学位'\n      }]\n    },\n    // 技能特长\n    {\n      name: 'skills',\n      label: '技能特长',\n      group: '技能特长',\n      isArray: true\n    }];\n\n    // 模拟 AI 优化结果\n    const mockOptimize = async (field, value) => {\n      if (!value) return null;\n      const optimizations = {\n        // 基本信息优化\n        name_en: value => value.toLowerCase().replace(/\\b\\w/g, l => l.toUpperCase()),\n        personal_summary: value => `我是一名经验丰富的${value.includes('开发') ? '开发工程师' : '专业人士'}，${value}`,\n        personal_summary_en: value => `I am an experienced ${value.includes('developer') ? 'developer' : 'professional'} ${value}`,\n        // 求职意向优化\n        expected_salary: value => value.includes('面议') ? '根据经验和能力，期望薪资15k-25k' : value,\n        industries: value => value.split(',').map(i => i.trim()).join('、'),\n        // 工作经历优化\n        description: value => value.replace(/^我/, '').replace(/。$/, '，工作中注重团队协作和技术创新。'),\n        achievements: value => value ? `${value}，为团队和公司创造了显著价值。` : '通过技术创新和流程优化，提升了团队工作效率，获得领导和同事的一致好评。',\n        technologies: value => value ? value.split(',').sort().join(', ') : '',\n        // 技能特长优化\n        skills: value => Array.isArray(value) ? value.map(skill => skill.replace(/^熟悉/, '精通')).join(', ') : value.split(',').map(skill => skill.trim()).join(', ')\n      };\n\n      // 模拟 API 延迟\n      await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 2000));\n\n      // 根据字段名返回优化结果\n      return optimizations[field.name] ? optimizations[field.name](value) : `${value}（已优化）`;\n    };\n\n    // 处理字段数据\n    const processFields = () => {\n      const result = [];\n      fieldConfig.forEach(field => {\n        if (field.isArray) {\n          // 处理数组类型的字段（如工作经历、教育经历）\n          const items = props.profileData[field.name] || [];\n          items.forEach((item, index) => {\n            if (field.fields) {\n              // 如果有子字段（如工作经历的详细信息）\n              field.fields.forEach(subField => {\n                result.push(_objectSpread(_objectSpread({}, subField), {}, {\n                  label: `${field.label} ${index + 1} - ${subField.label}`,\n                  currentValue: item[subField.name] || '',\n                  group: field.group,\n                  optimizedValue: '',\n                  status: 'pending'\n                }));\n              });\n            } else {\n              // 如果是简单数组（如技能特长）\n              result.push(_objectSpread(_objectSpread({}, field), {}, {\n                currentValue: item,\n                optimizedValue: '',\n                status: 'pending'\n              }));\n            }\n          });\n        } else {\n          // 处理普通字段\n          result.push(_objectSpread(_objectSpread({}, field), {}, {\n            currentValue: props.profileData[field.name] || '',\n            optimizedValue: '',\n            status: 'pending'\n          }));\n        }\n      });\n      return result;\n    };\n    const fields = ref(processFields());\n\n    // 计算属性\n    const displayFields = computed(() => {\n      return fields.value.sort((a, b) => {\n        if (a.status === 'pending' && b.status !== 'pending') return 1;\n        if (a.status !== 'pending' && b.status === 'pending') return -1;\n        return 0;\n      });\n    });\n    const completedCount = computed(() => fields.value.filter(f => ['success', 'failed'].includes(f.status)).length);\n    const totalFields = computed(() => fields.value.length);\n    const hasOptimized = computed(() => fields.value.some(f => f.status === 'success'));\n\n    // 开始优化\n    const startOptimize = async () => {\n      for (const field of fields.value) {\n        if (!field.currentValue) continue;\n        field.status = 'processing';\n        try {\n          const optimized = await mockOptimize(field, field.currentValue);\n          if (optimized) {\n            field.optimizedValue = optimized;\n            field.status = 'success';\n          } else {\n            field.status = 'pending';\n          }\n        } catch (error) {\n          console.error('优化失败:', error);\n          field.status = 'failed';\n        }\n      }\n    };\n\n    // 对话框控制\n    const dialogVisible = computed({\n      get: () => props.modelValue,\n      set: value => emit('update:modelValue', value)\n    });\n\n    // 响应式布局\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      return '900px';\n    });\n\n    // 处理关闭\n    const handleClose = () => {\n      dialogVisible.value = false;\n    };\n\n    // 处理应用优化\n    const handleApply = () => {\n      const optimizedData = {};\n      fields.value.forEach(field => {\n        if (field.status === 'success') {\n          optimizedData[field.name] = field.optimizedValue;\n        }\n      });\n      emit('apply', optimizedData);\n      handleClose();\n    };\n\n    // 开始优化\n    onMounted(() => {\n      startOptimize();\n    });\n    const __returned__ = {\n      props,\n      emit,\n      fieldConfig,\n      mockOptimize,\n      processFields,\n      fields,\n      displayFields,\n      completedCount,\n      totalFields,\n      hasOptimized,\n      startOptimize,\n      dialogVisible,\n      width,\n      isMobile,\n      dialogWidth,\n      handleClose,\n      handleApply,\n      ref,\n      computed,\n      onMounted,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      },\n      get XCircleIcon() {\n        return XCircleIcon;\n      },\n      get MinusCircleIcon() {\n        return MinusCircleIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","useWindowSize","XMarkIcon","CheckCircleIcon","XCircleIcon","MinusCircleIcon","props","__props","emit","__emit","fieldConfig","name","label","group","isArray","fields","mockOptimize","field","value","optimizations","name_en","toLowerCase","replace","l","toUpperCase","personal_summary","includes","personal_summary_en","expected_salary","industries","split","map","i","trim","join","description","achievements","technologies","sort","skills","Array","skill","Promise","resolve","setTimeout","Math","random","processFields","result","forEach","items","profileData","item","index","subField","push","_objectSpread","currentValue","optimizedValue","status","displayFields","a","b","completedCount","filter","f","length","totalFields","hasOptimized","some","startOptimize","optimized","error","console","dialogVisible","get","modelValue","set","width","isMobile","dialogWidth","handleClose","handleApply","optimizedData"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/AIOptimizeDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    v-model=\"dialogVisible\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    class=\"optimize-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- 头部 -->\n      <div class=\"dialog-header\">\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-3\">\n            <h3 class=\"text-lg font-medium text-gray-900\">AI 优化</h3>\n            <div class=\"flex items-center space-x-1 text-sm text-gray-500\">\n              <span>已完成</span>\n              <span class=\"font-medium text-blue-600\">{{ completedCount }}</span>\n              <span>/</span>\n              <span>{{ totalFields }}</span>\n            </div>\n          </div>\n          <button\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- 内容区域 -->\n      <div class=\"dialog-body\">\n        <div class=\"relative overflow-x-auto\">\n          <table class=\"w-full text-sm text-left\">\n            <thead class=\"text-xs text-gray-700 uppercase bg-gray-50 sticky top-0 z-10\">\n              <tr>\n                <th class=\"px-4 py-3 w-40\">字段名称</th>\n                <th class=\"px-4 py-3\">当前内容</th>\n                <th class=\"px-4 py-3\">AI 优化建议</th>\n                <th class=\"px-4 py-3 w-20 text-center\">状态</th>\n              </tr>\n            </thead>\n            <tbody>\n              <TransitionGroup \n                name=\"list\"\n                tag=\"template\"\n              >\n                <tr \n                  v-for=\"field in displayFields\" \n                  :key=\"field.name\"\n                  class=\"bg-white border-b hover:bg-gray-50\"\n                  :class=\"{'opacity-50': field.status === 'processing'}\"\n                >\n                  <td class=\"px-4 py-3 font-medium text-gray-900\">\n                    {{ field.label }}\n                  </td>\n                  <td class=\"px-4 py-3 text-gray-600\">\n                    <div class=\"max-h-20 overflow-y-auto\">\n                      {{ field.currentValue || '未填写' }}\n                    </div>\n                  </td>\n                  <td class=\"px-4 py-3\">\n                    <div \n                      class=\"max-h-20 overflow-y-auto\"\n                      :class=\"{\n                        'text-gray-400': !field.optimizedValue,\n                        'text-gray-900': field.optimizedValue\n                      }\"\n                    >\n                      <template v-if=\"field.status === 'processing'\">\n                        <div class=\"flex items-center space-x-2\">\n                          <div class=\"animate-pulse\">\n                            <div class=\"h-2 bg-gray-200 rounded w-full\"></div>\n                            <div class=\"h-2 bg-gray-200 rounded w-3/4 mt-2\"></div>\n                          </div>\n                        </div>\n                      </template>\n                      <template v-else>\n                        {{ field.optimizedValue || '等待优化...' }}\n                      </template>\n                    </div>\n                  </td>\n                  <td class=\"px-4 py-3 text-center\">\n                    <template v-if=\"field.status === 'success'\">\n                      <CheckCircleIcon class=\"w-5 h-5 text-green-500 mx-auto\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'failed'\">\n                      <XCircleIcon class=\"w-5 h-5 text-red-500 mx-auto\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'processing'\">\n                      <div class=\"animate-spin rounded-full h-5 w-5 border-2 border-gray-300 border-t-blue-600 mx-auto\"></div>\n                    </template>\n                    <template v-else>\n                      <MinusCircleIcon class=\"w-5 h-5 text-gray-300 mx-auto\" />\n                    </template>\n                  </td>\n                </tr>\n              </TransitionGroup>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <!-- 底部 -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-between items-center\">\n          <div class=\"text-sm text-gray-500\">\n            优化完成后，您可以选择应用建议的内容\n          </div>\n          <div class=\"flex space-x-3\">\n            <button\n              @click=\"handleClose\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n            >\n              取消\n            </button>\n            <button\n              @click=\"handleApply\"\n              :disabled=\"!hasOptimized\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              应用优化\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { \n  XMarkIcon, \n  CheckCircleIcon, \n  XCircleIcon,\n  MinusCircleIcon\n} from '@heroicons/vue/24/solid'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  profileData: {\n    type: Object,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'apply'])\n\n// 字段配置\nconst fieldConfig = [\n  // 基本信息\n  { name: 'name', label: '姓名（中文）', group: '基本信息' },\n  { name: 'name_en', label: '姓名（英文）', group: '基本信息' },\n  { name: 'personal_summary', label: '个人简介（中文）', group: '基本信息' },\n  { name: 'personal_summary_en', label: '个人简介（英文）', group: '基本信息' },\n  \n  // 求职意向\n  { name: 'job_type', label: '工作类型', group: '求职意向' },\n  { name: 'job_status', label: '求职状态', group: '求职意向' },\n  { name: 'expected_salary', label: '期望薪资', group: '求职意向' },\n  { name: 'expected_city', label: '期望城市', group: '求职意向' },\n  { name: 'industries', label: '期望行业', group: '求职意向' },\n\n  // 工作经历（对每个工作经历的字段进行优化）\n  { name: 'work_experiences', label: '工作经历', group: '工作经历', isArray: true, fields: [\n    { name: 'company', label: '公司名称' },\n    { name: 'position', label: '职位名称' },\n    { name: 'department', label: '所在部门' },\n    { name: 'description', label: '工作描述' },\n    { name: 'achievements', label: '工作成就' },\n    { name: 'technologies', label: '技术栈' }\n  ]},\n\n  // 教育经历\n  { name: 'educations', label: '教育经历', group: '教育经历', isArray: true, fields: [\n    { name: 'school', label: '学校名称' },\n    { name: 'major', label: '专业' },\n    { name: 'degree', label: '学位' }\n  ]},\n\n  // 技能特长\n  { name: 'skills', label: '技能特长', group: '技能特长', isArray: true }\n]\n\n// 模拟 AI 优化结果\nconst mockOptimize = async (field, value) => {\n  if (!value) return null\n\n  const optimizations = {\n    // 基本信息优化\n    name_en: value => value.toLowerCase().replace(/\\b\\w/g, l => l.toUpperCase()),\n    personal_summary: value => `我是一名经验丰富的${value.includes('开发') ? '开发工程师' : '专业人士'}，${value}`,\n    personal_summary_en: value => `I am an experienced ${value.includes('developer') ? 'developer' : 'professional'} ${value}`,\n\n    // 求职意向优化\n    expected_salary: value => value.includes('面议') ? '根据经验和能力，期望薪资15k-25k' : value,\n    industries: value => value.split(',').map(i => i.trim()).join('、'),\n\n    // 工作经历优化\n    description: value => value.replace(/^我/, '').replace(/。$/, '，工作中注重团队协作和技术创新。'),\n    achievements: value => value ? `${value}，为团队和公司创造了显著价值。` : '通过技术创新和流程优化，提升了团队工作效率，获得领导和同事的一致好评。',\n    technologies: value => value ? value.split(',').sort().join(', ') : '',\n\n    // 技能特长优化\n    skills: value => Array.isArray(value) ? \n      value.map(skill => skill.replace(/^熟悉/, '精通')).join(', ') : \n      value.split(',').map(skill => skill.trim()).join(', ')\n  }\n\n  // 模拟 API 延迟\n  await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 2000))\n\n  // 根据字段名返回优化结果\n  return optimizations[field.name] ? \n    optimizations[field.name](value) : \n    `${value}（已优化）`\n}\n\n// 处理字段数据\nconst processFields = () => {\n  const result = []\n  \n  fieldConfig.forEach(field => {\n    if (field.isArray) {\n      // 处理数组类型的字段（如工作经历、教育经历）\n      const items = props.profileData[field.name] || []\n      items.forEach((item, index) => {\n        if (field.fields) {\n          // 如果有子字段（如工作经历的详细信息）\n          field.fields.forEach(subField => {\n            result.push({\n              ...subField,\n              label: `${field.label} ${index + 1} - ${subField.label}`,\n              currentValue: item[subField.name] || '',\n              group: field.group,\n              optimizedValue: '',\n              status: 'pending'\n            })\n          })\n        } else {\n          // 如果是简单数组（如技能特长）\n          result.push({\n            ...field,\n            currentValue: item,\n            optimizedValue: '',\n            status: 'pending'\n          })\n        }\n      })\n    } else {\n      // 处理普通字段\n      result.push({\n        ...field,\n        currentValue: props.profileData[field.name] || '',\n        optimizedValue: '',\n        status: 'pending'\n      })\n    }\n  })\n\n  return result\n}\n\nconst fields = ref(processFields())\n\n// 计算属性\nconst displayFields = computed(() => {\n  return fields.value.sort((a, b) => {\n    if (a.status === 'pending' && b.status !== 'pending') return 1\n    if (a.status !== 'pending' && b.status === 'pending') return -1\n    return 0\n  })\n})\n\nconst completedCount = computed(() => \n  fields.value.filter(f => ['success', 'failed'].includes(f.status)).length\n)\n\nconst totalFields = computed(() => fields.value.length)\n\nconst hasOptimized = computed(() => \n  fields.value.some(f => f.status === 'success')\n)\n\n// 开始优化\nconst startOptimize = async () => {\n  for (const field of fields.value) {\n    if (!field.currentValue) continue\n    \n    field.status = 'processing'\n    try {\n      const optimized = await mockOptimize(field, field.currentValue)\n      if (optimized) {\n        field.optimizedValue = optimized\n        field.status = 'success'\n      } else {\n        field.status = 'pending'\n      }\n    } catch (error) {\n      console.error('优化失败:', error)\n      field.status = 'failed'\n    }\n  }\n}\n\n// 对话框控制\nconst dialogVisible = computed({\n  get: () => props.modelValue,\n  set: (value) => emit('update:modelValue', value)\n})\n\n// 响应式布局\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  return '900px'\n})\n\n// 处理关闭\nconst handleClose = () => {\n  dialogVisible.value = false\n}\n\n// 处理应用优化\nconst handleApply = () => {\n  const optimizedData = {}\n  fields.value.forEach(field => {\n    if (field.status === 'success') {\n      optimizedData[field.name] = field.optimizedValue\n    }\n  })\n  emit('apply', optimizedData)\n  handleClose()\n}\n\n// 开始优化\nonMounted(() => {\n  startOptimize()\n})\n</script>\n\n<style scoped>\n/* 表格动画 */\n.list-move,\n.list-enter-active,\n.list-leave-active {\n  transition: all 0.5s ease;\n}\n\n.list-enter-from,\n.list-leave-to {\n  opacity: 0;\n  transform: translateY(30px);\n}\n\n.list-leave-active {\n  position: absolute;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .dialog-body {\n    @apply px-2;\n  }\n  \n  th, td {\n    @apply px-2 py-2;\n  }\n  \n  .dialog-footer {\n    @apply flex-col space-y-3;\n  }\n  \n  .dialog-footer button {\n    @apply w-full;\n  }\n}\n</style> "],"mappings":";;;;;;AAqIA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAI;AAC7C,SAASC,aAAa,QAAQ,cAAa;AAC3C,SACEC,SAAS,EACTC,eAAe,EACfC,WAAW,EACXC,eAAc,QACT,yBAAwB;;;;;;;;;;;;;;;;IAE/B,MAAMC,KAAK,GAAGC,OAAA;IAQd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,WAAW,GAAG;IAClB;IACA;MAAEC,IAAI,EAAE,MAAM;MAAEC,KAAK,EAAE,QAAQ;MAAEC,KAAK,EAAE;IAAO,CAAC,EAChD;MAAEF,IAAI,EAAE,SAAS;MAAEC,KAAK,EAAE,QAAQ;MAAEC,KAAK,EAAE;IAAO,CAAC,EACnD;MAAEF,IAAI,EAAE,kBAAkB;MAAEC,KAAK,EAAE,UAAU;MAAEC,KAAK,EAAE;IAAO,CAAC,EAC9D;MAAEF,IAAI,EAAE,qBAAqB;MAAEC,KAAK,EAAE,UAAU;MAAEC,KAAK,EAAE;IAAO,CAAC;IAEjE;IACA;MAAEF,IAAI,EAAE,UAAU;MAAEC,KAAK,EAAE,MAAM;MAAEC,KAAK,EAAE