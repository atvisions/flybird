{"ast":null,"code":"import { createVNode as _createVNode, createCommentVNode as _createCommentVNode, openBlock as _openBlock, createBlock as _createBlock, createElementVNode as _createElementVNode, createElementBlock as _createElementBlock } from \"vue\";\nconst _hoisted_1 = {\n  class: \"container mx-auto\"\n};\nconst _hoisted_2 = {\n  class: \"max-w-4xl mx-auto space-y-4\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createElementVNode(\"div\", _hoisted_2, [_createVNode($setup[\"BasicInfo\"], {\n    resumeData: $setup.basicInfo,\n    loading: $setup.loading,\n    bioExpanded: $setup.bioExpanded,\n    showBioExpandButton: $setup.showBioExpandButton,\n    onEdit: $setup.handleEdit,\n    onToggleBioExpand: $setup.toggleBioExpand\n  }, null, 8 /* PROPS */, [\"resumeData\", \"loading\", \"bioExpanded\", \"showBioExpandButton\"]), _createVNode($setup[\"ResumeStatus\"], {\n    \"completion-data\": $setup.completionData,\n    \"profile-data\": $setup.profileData,\n    loading: $setup.loading\n  }, null, 8 /* PROPS */, [\"completion-data\", \"profile-data\", \"loading\"]), _createVNode($setup[\"ModuleList\"], {\n    \"active-modules\": $setup.activeModules,\n    loading: $setup.loading,\n    onEdit: $setup.handleEditModule,\n    onAdd: $setup.addItem,\n    onRemove: $setup.removeModule,\n    onEditItem: $setup.editItem,\n    onRemoveItem: $setup.removeItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onAdd\", \"onRemove\"]), _createVNode($setup[\"AddModule\"], {\n    \"inactive-modules\": $setup.inactiveModules,\n    loading: $setup.loading,\n    onActivate: $setup.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"]), _createCommentVNode(\" 工作经历编辑弹窗 \"), $setup.currentModule?.type === 'work_experience' ? (_openBlock(), _createBlock($setup[\"EditWorkExperienceDialog\"], {\n    key: 0,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), $setup.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock($setup[\"EditJobIntentionDialog\"], {\n    key: 1,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), $setup.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock($setup[\"EditBasicDialog\"], {\n    key: 2,\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showEditModal = $event),\n    \"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createVNode($setup[\"AIOptimizeDialog\"], {\n    modelValue: $setup.showAIOptimizeDialog,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showAIOptimizeDialog = $event),\n    \"profile-data\": $setup.profileData,\n    onApply: $setup.handleAIOptimize\n  }, null, 8 /* PROPS */, [\"modelValue\", \"profile-data\"])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","$setup","resumeData","basicInfo","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onToggleBioExpand","toggleBioExpand","completionData","profileData","activeModules","handleEditModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","onRemoveItem","removeItem","inactiveModules","onActivate","activateModule","_createCommentVNode","currentModule","type","_createBlock","key","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit","showAIOptimizeDialog","onApply","handleAIOptimize"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"loading\"\n      />\n\n      <ModuleList\n        :active-modules=\"activeModules\"\n        :loading=\"loading\"\n        @edit=\"handleEditModule\"\n        @add=\"addItem\"\n        @remove=\"removeModule\"\n        @edit-item=\"editItem\"\n        @remove-item=\"removeItem\"\n      />\n\n      <AddModule\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"loading\"\n        @activate=\"activateModule\"\n      />\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch } from 'vue'\nimport { useModules } from './composables/useModules'\nimport { profile } from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\nimport AIOptimizeDialog from './dialogs/AIOptimizeDialog.vue'\n\n// 状态管理\nconst { \n  activeModules, \n  currentModule, \n  inactiveModules, \n  addItem, \n  removeModule, \n  activateModule \n} = useModules()\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\nconst loading = ref(false)\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 基本信息数据\nconst basicInfo = ref({})\n\n// 档案数据\nconst profileData = ref({\n  basic_info: {\n    name: '',\n    name_en: '',\n    personal_summary: '',\n    personal_summary_en: '',\n    gender: '',\n    phone: '',\n    email: '',\n    location: '',\n    birth_date: ''\n  },\n  job_intention: {\n    job_type: '',\n    job_status: '',\n    expected_salary: '',\n    expected_city: '',\n    industries: ''\n  },\n  work_experiences: [],\n  educations: [],\n  skills: []\n})\n\n// 完整度数据\nconst completionData = ref({\n  total_score: 0,\n  dimensions: {},\n  suggestions: []\n})\n\n// 添加缺失的响应式变量\nconst showAIOptimizeDialog = ref(false)\n\n// 处理 Bio 展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 定义组件的 emits\ndefineEmits([\n  'update:modelValue',\n  'edit',\n  'add',\n  'remove',\n  'edit-item',\n  'remove-item'\n])\n\n// 获取档案数据\nconst fetchProfileData = async () => {\n  try {\n    loading.value = true\n    \n    // 获取完整档案数据\n    const response = await profile.getComplete()\n    console.log('Profile Response:', response.data)  // 调试日志\n    \n    if (response.data?.code === 200) {\n      const data = response.data.data\n      \n      // 更新档案数据\n      profileData.value = {\n        basic_info: data.basic_info || {},\n        job_intention: data.job_intention || {},\n        work_experiences: data.work_experiences || [],\n        educations: data.educations || [],\n        skills: data.skills || [],\n        certificates: data.certificates || [],\n        projects: data.projects || []\n      }\n\n      // 更新基本信息\n      basicInfo.value = {\n        ...data.basic_info,\n        ...data.user  // 合并用户信息\n      }\n      console.log('Updated Basic Info:', basicInfo.value)  // 调试日志\n\n      // 更新活动模块数据\n      const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n      if (jobIntentionModule) {\n        jobIntentionModule.data = data.job_intention || {}\n      }\n\n      const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n      if (workExperienceModule) {\n        workExperienceModule.data = data.work_experiences || []\n      }\n    }\n\n    // 获取完整度数据\n    const completenessResponse = await profile.getCompleteness()\n    if (completenessResponse.data?.code === 200) {\n      completionData.value = {\n        total_score: completenessResponse.data.data.total_score || 0,\n        dimensions: completenessResponse.data.data.dimensions || {},\n        suggestions: completenessResponse.data.data.suggestions || []\n      }\n    }\n  } catch (error) {\n    console.error('获取数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 监听完整度数据变化\nwatch(() => completionData.value, (newVal) => {}, { deep: true })\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchProfileData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    loading.value = true\n    \n    if (currentModule.value?.type === 'basic_info') {\n      // 基本信息保存\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchProfileData()\n      } else {\n        throw new Error(response.data?.message || '保存失败')\n      }\n    } else if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.workExperience.update(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        } else {\n          throw new Error(response.data?.message || '更新失败')\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.workExperience.add(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.updateJobIntention(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchProfileData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\n// 处理 AI 优化结果\nconst handleAIOptimize = (optimizedData) => {\n  Object.entries(optimizedData).forEach(([key, value]) => {\n    const [category, field] = key.split('.')\n    if (category && field) {\n      if (!profileData.value[category]) {\n        profileData.value[category] = {}\n      }\n      profileData.value[category][field] = value\n    } else {\n      profileData.value[key] = value\n    }\n  })\n}\n\nonMounted(() => {\n  fetchProfileData()\n})\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CAkEM,OAlENC,UAkEM,GAjEJC,mBAAA,CAgEM,OAhENC,UAgEM,GA/DJC,YAAA,CAOEC,MAAA;IANCC,UAAU,EAAED,MAAA,CAAAE,SAAS;IACrBC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBC,WAAW,EAAEJ,MAAA,CAAAI,WAAW;IACxBC,mBAAmB,EAAEL,MAAA,CAAAK,mBAAmB;IACxCC,MAAI,EAAEN,MAAA,CAAAO,UAAU;IAChBC,iBAAe,EAAER,MAAA,CAAAS;4FAGpBV,YAAA,CAIEC,MAAA;IAHC,iBAAe,EAAEA,MAAA,CAAAU,cAAc;IAC/B,cAAY,EAAEV,MAAA,CAAAW,WAAW;IACzBR,OAAO,EAAEH,MAAA,CAAAG;2EAGZJ,YAAA,CAQEC,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAAY,aAAa;IAC7BT,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBG,MAAI,EAAEN,MAAA,CAAAa,gBAAgB;IACtBC,KAAG,EAAEd,MAAA,CAAAe,OAAO;IACZC,QAAM,EAAEhB,MAAA,CAAAiB,YAAY;IACpBC,UAAS,EAAElB,MAAA,CAAAmB,QAAQ;IACnBC,YAAW,EAAEpB,MAAA,CAAAqB;+EAGhBtB,YAAA,CAIEC,MAAA;IAHC,kBAAgB,EAAEA,MAAA,CAAAsB,eAAe;IACjCnB,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBoB,UAAQ,EAAEvB,MAAA,CAAAwB;0EAGbC,mBAAA,cAAiB,EAETzB,MAAA,CAAA0B,aAAa,EAAEC,IAAI,0B,cAD3BC,YAAA,CAME5B,MAAA;IA1CR6B,GAAA;IAAAC,UAAA,EAsCiB9B,MAAA,CAAA+B,aAAa;IAtC9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAsCiBjC,MAAA,CAAA+B,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEjC,MAAA,CAAAkC,YAAY;IAC1B/B,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBgC,QAAM,EAAEnC,MAAA,CAAAoC;wEAzCjBX,mBAAA,gBA4CMA,mBAAA,cAAiB,EAETzB,MAAA,CAAA0B,aAAa,EAAEC,IAAI,wB,cAD3BC,YAAA,CAME5B,MAAA;IAnDR6B,GAAA;IAAAC,UAAA,EA+CiB9B,MAAA,CAAA+B,aAAa;IA/C9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA+CiBjC,MAAA,CAAA+B,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEjC,MAAA,CAAAkC,YAAY;IAC1B/B,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBgC,QAAM,EAAEnC,MAAA,CAAAoC;wEAlDjBX,mBAAA,gBAqDMA,mBAAA,cAAiB,EAETzB,MAAA,CAAA0B,aAAa,EAAEC,IAAI,qB,cAD3BC,YAAA,CAME5B,MAAA;IA5DR6B,GAAA;IAAAC,UAAA,EAwDiB9B,MAAA,CAAA+B,aAAa;IAxD9B,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAwDiBjC,MAAA,CAAA+B,aAAa,GAAAE,MAAA;IACrB,cAAY,EAAEjC,MAAA,CAAAkC,YAAY;IAC1B/B,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBgC,QAAM,EAAEnC,MAAA,CAAAoC;wEA3DjBX,mBAAA,gBA8DM1B,YAAA,CAIEC,MAAA;IAlER8B,UAAA,EA+DiB9B,MAAA,CAAAqC,oBAAoB;IA/DrC,uBAAAL,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA+DiBjC,MAAA,CAAAqC,oBAAoB,GAAAJ,MAAA;IAC5B,cAAY,EAAEjC,MAAA,CAAAW,WAAW;IACzB2B,OAAK,EAAEtC,MAAA,CAAAuC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}