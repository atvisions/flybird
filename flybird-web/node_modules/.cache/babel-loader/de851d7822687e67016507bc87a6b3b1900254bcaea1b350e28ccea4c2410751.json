    alt=\"用户头像\"\n                @error=\"handleImageError\"\n                />\n                <div \n                @click=\"triggerUpload\"\n                class=\"absolute inset-0 flex items-center justify-center rounded-full bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-200\"\n                >\n                <CameraIcon class=\"w-8 h-8 text-white\" />\n                </div>\n                <input\n                ref=\"fileInput\"\n                type=\"file\"\n                accept=\"image/*\"\n                class=\"hidden\"\n                @change=\"handleFileChange\"\n                />\n          </div>\n  \n          <!-- 用户信息 -->\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center justify-between mb-3\">\n              <h2 class=\"text-lg font-medium text-gray-900\">\n                <template v-if=\"resumeData.name\">\n                  <span class=\"text-sm truncate\">{{ resumeData.name }}</span>\n                  <!-- 调试信息 -->\n                  <span class=\"hidden\">{{ console.log('Rendering name:', resumeData.name) }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400\">未设置姓名</span>\n              </h2>\n              <button\n                @click=\"$emit('edit')\"\n                class=\"inline-flex items-center px-2.5 py-1 text-xs font-medium text-primary-600 hover:text-primary-700 border border-primary-600 hover:border-primary-700 rounded\"\n              >\n                <PencilIcon class=\"w-3.5 h-3.5 mr-1\" />\n                编辑资料\n              </button>\n            </div>\n  \n            <!-- 基本信息列表 -->\n            <div class=\"grid grid-cols-2 gap-3\">\n              <!-- 手机号 -->\n              <div class=\"flex items-center text-gray-600\">\n                <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.phone\">\n                  <span class=\"text-sm truncate\">{{ resumeData.phone }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置手机号</span>\n              </div>\n  \n              <!-- 邮箱 -->\n              <div class=\"flex items-center text-gray-600\">\n                <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.email\">\n                  <span class=\"text-sm truncate\">{{ resumeData.email }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置邮箱</span>\n              </div>\n  \n              <!-- 所在地 -->\n              <div class=\"flex items-center text-gray-600\">\n                <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.location\">\n                  <span class=\"text-sm truncate\">{{ resumeData.location }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置所在地</span>\n              </div>\n  \n              <!-- 性别 -->\n              <div class=\"flex items-center text-gray-600\">\n                <UserIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.gender\">\n                  <span class=\"text-sm truncate\">{{ genderText }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置性别</span>\n              </div>\n  \n              <!-- 生日 -->\n              <div class=\"flex items-center text-gray-600\">\n                <CalendarIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.birth_date\">\n                  <span class=\"text-sm truncate\">{{ resumeData.birth_date }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未设置生日</span>\n              </div>\n  \n              <!-- 创建时间 -->\n              <div class=\"flex items-center text-gray-600\">\n                <ClockIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <template v-if=\"resumeData.created_at\">\n                  <span class=\"text-sm truncate\">{{ formatDate(resumeData.created_at) }}</span>\n                </template>\n                <span v-else class=\"text-sm text-gray-400 truncate\">未知创建时间</span>\n              </div>\n            </div>\n  \n            <!-- 个人简介 -->\n            <div class=\"mt-3\">\n              <div class=\"flex items-center text-gray-600 mb-1\">\n                <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                <span class=\"text-sm font-medium\">个人简介</span>\n              </div>\n              <template v-if=\"resumeData.personal_summary\">\n                <div class=\"relative\">\n                  <p class=\"text-sm text-gray-600 leading-relaxed\">\n                    {{ getBioText }}\n                  </p>\n                  <!-- 展开/收起按钮 -->\n                  <button\n                    v-if=\"showBioExpandButton\"\n                    @click=\"toggleBioExpand\"\n                    class=\"text-xs text-primary-600 hover:text-primary-700 mt-1\"\n                  >\n                    {{ bioExpanded ? '收起' : '展开全部' }}\n                  </button>\n                </div>\n              </template>\n              <p v-else class=\"text-sm text-gray-400 leading-relaxed\">\n                未设置个人简介\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed, nextTick, watch } from 'vue'\nimport { ElMessage , ElLoading } from 'element-plus'\nimport request, { API_PATHS } from '@/utils/request'  \nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nimport { profile } from '@/api/profile'\nconst store = useStore()\nconst loadingInstance = ref(null)\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon,\n  UserIcon,\n  CalendarIcon\n} from '@heroicons/vue/24/outline'\n// 从 store 获取头像\nconst avatarUrl = computed(() => store.getters.getUserAvatar)\n// 处理图片加载错误\nconst handleImageError = (e) => {\n  e.target.src = defaultAvatarImage\n}\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean,\n  bioExpanded: Boolean,\n  showBioExpandButton: Boolean,\n  getBioText: String\n})\n\nconst emit = defineEmits(['update:resumeData'])\nconst fileInput = ref(null)\n\n// 添加调试日志\nconsole.log('BasicInfo props:', {\n  resumeData: props.resumeData,\n  bioExpanded: props.bioExpanded,\n  showBioExpandButton: props.showBioExpandButton,\n  getBioText: props.getBioText\n})\n\n// 处理文件上传\nconst handleFileChange = async (event) => {\n  if (!event.target.files.length) return\n\n  try {\n    const file = event.target.files[0]\n    \n    // 文件验证\n    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif']\n    if (!allowedTypes.includes(file.type)) {\n      ElMessage.error('请上传 JPG、PNG 或 GIF 格式的图片')\n      return\n    }\n\n    // 文件大小验证 (5MB)\n    const maxSize = 5 * 1024 * 1024\n    if (file.size > maxSize) {\n      ElMessage.error('图片大小不能超过 5MB')\n      return\n    }\n\n    loadingInstance.value = ElLoading.service({\n      target: '.avatar-upload',\n      text: '上传中...'\n    })\n\n    try {\n      const response = await profile.uploadAvatar(file)\n      console.log('Upload response:', response)\n\n      if (response.code === 200 && response.data?.avatar_url) {\n        const newAvatarUrl = response.data.avatar_url\n\n        // 更新 store 中的用户信息\n        store.commit('SET_USER_INFO', {\n          avatar: newAvatarUrl\n        })\n\n        // 更新本地数据\n        emit('update:resumeData', {\n          ...props.resumeData,\n          avatar: newAvatarUrl\n        })\n\n        // 强制刷新用户信息\n        await store.dispatch('fetchUserInfo')\n\n        // 添加调试日志\n        console.log('Avatar updated:', {\n          newAvatar: newAvatarUrl,\n          storeAvatar: store.getters.getUserAvatar,\n          resumeDataAvatar: props.resumeData.avatar\n        })\n\n        ElMessage.success(response.message || '头像上传成功')\n      } else {\n        throw new Error(response.message || '上传失败')\n      }\n    } catch (uploadError) {\n      console.error('Upload error:', uploadError)\n      throw uploadError\n    }\n  } catch (error) {\n    console.error('头像上传失败:', error)\n    ElMessage.error(error.message || '头像上传失败，请重试')\n  } finally {\n    loadingInstance.value?.close()\n    loadingInstance.value = null\n    event.target.value = ''\n  }\n}\n\n// 添加一个计算属性来获取带时间戳的头像 URL\nconst currentAvatarUrl = computed(() => {\n  const baseUrl = store.getters.getUserAvatar\n  return baseUrl + '?t=' + Date.now()\n})\n\n// 触发文件选择\nconst triggerUpload = () => {\n  fileInput.value.click()\n}\n\n// 性别显示文本\nconst genderText = computed(() => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[props.resumeData.gender] || '未设置性别'\n})\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return date.toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'long',\n    day: 'numeric'\n  })\n}\n\n// 监听 resumeData 变化\nwatch(() => props.resumeData, (newVal) => {\n  console.log('BasicInfo resumeData changed:', newVal)\n}, { deep: true })\n</script>"],"mappings":";AAyIA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACnD,SAASC,SAAS,EAAGC,SAAS,QAAQ,cAAa;AACnD,OAAOC,OAAO,IAAIC,SAAS,QAAQ,iBAAiB;AACpD,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,OAAO,QAAQ,eAAc;AAGtC,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAU,EACVC,QAAQ,EACRC,YAAW,QACN,2BAA0B;AACjC;;;;;;;;;;;;;;;;;;;;IAfA,MAAMC,KAAK,GAAGb,QAAQ,CAAC;IACvB,MAAMc,eAAe,GAAGvB,GA