 // 文件大小验证 (5MB)\n        const maxSize = 5 * 1024 * 1024;\n        if (file.size > maxSize) {\n          ElMessage.error('图片大小不能超过 5MB');\n          return;\n        }\n        loadingInstance.value = ElLoading.service({\n          target: '.avatar-upload',\n          text: '上传中...'\n        });\n        try {\n          const response = await profile.uploadAvatar(file);\n          console.log('Upload response:', response);\n          if (response.code === 200 && response.data?.avatar_url) {\n            const newAvatarUrl = response.data.avatar_url;\n\n            // 更新 store 中的用户信息\n            store.commit('SET_USER_INFO', {\n              avatar: newAvatarUrl\n            });\n\n            // 更新本地数据\n            emit('update:resumeData', _objectSpread(_objectSpread({}, props.resumeData), {}, {\n              avatar: newAvatarUrl\n            }));\n\n            // 强制刷新用户信息\n            await store.dispatch('fetchUserInfo');\n\n            // 添加调试日志\n            console.log('Avatar updated:', {\n              newAvatar: newAvatarUrl,\n              storeAvatar: store.getters.getUserAvatar,\n              resumeDataAvatar: props.resumeData.avatar\n            });\n            ElMessage.success(response.message || '头像上传成功');\n          } else {\n            throw new Error(response.message || '上传失败');\n          }\n        } catch (uploadError) {\n          console.error('Upload error:', uploadError);\n          throw uploadError;\n        }\n      } catch (error) {\n        console.error('头像上传失败:', error);\n        ElMessage.error(error.message || '头像上传失败，请重试');\n      } finally {\n        loadingInstance.value?.close();\n        loadingInstance.value = null;\n        event.target.value = '';\n      }\n    };\n\n    // 添加一个计算属性来获取带时间戳的头像 URL\n    const currentAvatarUrl = computed(() => {\n      const baseUrl = store.getters.getUserAvatar;\n      return baseUrl + '?t=' + Date.now();\n    });\n\n    // 触发文件选择\n    const triggerUpload = () => {\n      fileInput.value.click();\n    };\n\n    // 性别显示文本\n    const genderText = computed(() => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[props.resumeData.gender] || '未设置性别';\n    });\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return date.toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'long',\n        day: 'numeric'\n      });\n    };\n\n    // 监听 resumeData 变化\n    watch(() => props.resumeData, newVal => {\n      console.log('BasicInfo resumeData changed:', newVal);\n    }, {\n      deep: true\n    });\n    const __returned__ = {\n      store,\n      loadingInstance,\n      avatarUrl,\n      handleImageError,\n      props,\n      emit,\n      fileInput,\n      handleFileChange,\n      currentAvatarUrl,\n      triggerUpload,\n      genderText,\n      formatDate,\n      ref,\n      computed,\n      nextTick,\n      watch,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElLoading() {\n        return ElLoading;\n      },\n      get request() {\n        return request;\n      },\n      get API_PATHS() {\n        return API_PATHS;\n      },\n      get defaultAvatarImage() {\n        return defaultAvatarImage;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get profile() {\n        return profile;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get PhoneIcon() {\n        return PhoneIcon;\n      },\n      get EnvelopeIcon() {\n        return EnvelopeIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },