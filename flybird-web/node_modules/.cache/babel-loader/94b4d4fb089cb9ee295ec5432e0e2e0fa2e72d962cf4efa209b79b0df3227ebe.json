f({})\n  \n  // 编辑相关\n  const showEditModal = ref(false)\n  const currentModule = ref(null)\n  const editFormData = ref({})\n  \n  // 活动模块\n  const activeModules = ref([\n    {\n      id: 'job_intention',\n      type: 'job_intention',\n      title: '求职意向',\n      data: {}\n    },\n    {\n      id: 'work_experience',\n      type: 'work_experience',\n      title: '工作经历',\n      data: []\n    }\n  ])\n  \n  // 档案数据 - 添加完整的初始结构\n  const profileData = ref({\n    basic_info: {\n      name: '',\n      name_en: '',\n      personal_summary: '',\n      personal_summary_en: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: ''\n    },\n    job_intention: {\n      job_type: '',\n      job_status: '',\n      expected_salary: '',\n      expected_city: '',\n      industries: ''\n    },\n    work_experiences: [],\n    educations: [],\n    skills: []\n  })\n  \n  // 完整度数据\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 获取档案数据\n  const fetchProfileData = async () => {\n    try {\n      loading.value = true\n      const response = await profile.getComplete()\n      if (response.data?.code === 200) {\n        const data = response.data.data\n        \n        // 更新档案数据\n        profileData.value = {\n          basic_info: data.basic_info || profileData.value.basic_info,\n          job_intention: data.job_intention || profileData.value.job_intention,\n          work_experiences: data.work_experiences || [],\n          educations: data.educations || [],\n          skills: data.skills || []\n        }\n\n        // 更新基本信息\n        basicInfo.value = data.basic_info || {}\n\n        // 更新完整度数据\n        completionData.value = {\n          total_score: data.completeness || 0,\n          dimensions: data.dimensions || {},\n          suggestions: data.suggestions || []\n        }\n\n        // 更新活动模块数据\n        const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n        if (jobIntentionModule) {\n          jobIntentionModule.data = data.job_intention || {}\n        }\n\n        const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n        if (workExperienceModule) {\n          workExperienceModule.data = data.work_experiences || []\n        }\n      }\n    } catch (error) {\n      console.error('获取档案数据失败:', error)\n      ElMessage.error('获取数据失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 处理生物信息展开/收起\n  const toggleBioExpand = () => {\n    bioExpanded.value = !bioExpanded.value\n  }\n  \n  // 处理编辑基本信息\n  const handleEdit = () => {\n    currentModule.value = {\n      type: 'basic_info',\n      data: basicInfo.value\n    }\n    editFormData.value = { ...currentModule.value.data }\n    showEditModal.value = true\n  }\n  \n  // 处理编辑模块\n  const handleEditModule = (moduleId) => {\n    currentModule.value = activeModules.value.find(m => m.id === moduleId)\n    \n    if (currentModule.value?.type === 'work_experience') {\n      editFormData.value = {}\n    } else if (currentModule.value?.type === 'job_intention') {\n      editFormData.value = { ...currentModule.value.data }\n    }\n    \n    showEditModal.value = true\n  }\n  \n  // 处理保存\n  const handleSave = async (data) => {\n    try {\n      loading.value = true\n      \n      if (currentModule.value?.type === 'work_experience') {\n        if (data.id) {\n          // 更新工作经历\n          const response = await profile.updateWorkExperience(data.id, data)\n          if (response.data?.code === 200) {\n            ElMessage.success('更新成功')\n            showEditModal.value = false\n            await fetchProfileData()\n          }\n        } else {\n          // 添加工作经历\n          const response = await profile.addWorkExperience(data)\n          if (response.data?.code === 200) {\n            ElMessage.success('添加成功')\n            showEditModal.value = false\n            await fetchProfileData()\n          }\n        }\n      } else if (currentModule.value?.type === 'job_intention') {\n        const response = await profile.updateJobIntention(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      } else if (currentModule.value?.type === 'basic_info') {\n        const response = await profile.updateBasicInfo(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('保存成功')\n          showEditModal.value = false\n          await fetchProfileData()\n        }\n      }\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error(error.message || '保存失败')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 处理 AI 优化\n  const handleAIOptimize = () => {\n    // AI 优化逻辑\n  }\n  \n  // 处理导入\n  const handleImport = () => {\n    // 导入逻辑\n  }\n  \n  // 处理预览\n  const handlePreview = () => {\n    // 预览逻辑\n  }\n  \n  onMounted(() => {\n    fetchProfileData()\n  })\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;;;;;uBAD1CC,mBAAA,CA+BM,OA/BNC,UA+BM,GA9BJC,mBAAA,CA6BM,OA7BNC,UA6BM,GA5BJC,YAAA,CAOAC,oBAAA;IANCC,UAAU,EAAEC,MAAA,CAAAC,SAAS;IACrBC,OAAO,EAAEF,MAAA,CAAAE,OAAO;IAChBC,WAAW,EAAEH,MAAA,CAAAG,WAAW;IACxBC,mBAAmB,EAAEJ,MAAA,CAAAI,mBAAmB;IACxCC,MAAI,EAAEL,MAAA,CAAAM,UAAU;IAChBC,iBAAe,EAAEP,MAAA,CAAAQ;4FAGlBX,YAAA,CAIEY,uBAAA;IAHC,iBAAe,EAAET,MAAA,CAAAU,cAAc;IAC/B,cAAY,EAAEV,MAAA,CAAAW,WAAW;IACzBT,OAAO,EAAEF,MAAA,CAAAE;2EAGZL,YAAA,CAIEe,qBAAA;IAHCC,OAAO,EAAEb,MAAA,CAAAc,aAAa;IACtBZ,OAAO,EAAEF,MAAA,CAAAE,OAAO;IAChBG,MAAI,EAAEL,MAAA,CAAAe;mDAGTlB,YAAA,CAMEmB,qBAAA;IA/BVC,UAAA,EA0BmBjB,MAAA,CAAAkB,aAAa;IA1BhC,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA0BmBpB,MAAA,CAAAkB,aAAa,GAAAE,MAAA;IACrBC,MAAM,EAAErB,MAAA,CAAAsB,aAAa;IACrB,cAAY,EAAEtB,MAAA,CAAAuB,YAAY;IAC1BrB,OAAO,EAAEF,MAAA,CAAAE,OAAO;IAChBsB,QAAM,EAAExB,MAAA,CAAAyB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDepen