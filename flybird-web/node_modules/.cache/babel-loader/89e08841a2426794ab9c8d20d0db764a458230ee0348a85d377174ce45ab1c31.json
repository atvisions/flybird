{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { auth } from '@/api/auth';\nimport { SMS_SCENE } from '@/constants';\nimport { sms } from '@/api/sms';\n\n// 接收父组件传递的 props\n\nexport default {\n  __name: 'AccountSettings',\n  props: {\n    userInfo: {\n      type: Object,\n      required: true\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n    const store = useStore();\n    const router = useRouter();\n\n    // 添加调试信息\n    console.log('Store userInfo:', {\n      id: store.state.userInfo?.id,\n      uid: store.state.userInfo?.uid,\n      username: store.state.userInfo?.username,\n      fullUserInfo: store.state.userInfo\n    });\n\n    // 移除 userBasicInfo ref 和 fetchUserBasicInfo 函数\n    const loading = ref(false);\n\n    // 直接使用 store 中的数据，username 来自 userInfo\n    const username = computed(() => {\n      return store.state.userInfo?.username || '未设置';\n    });\n    const uid = computed(() => {\n      return store.state.userInfo?.uid || '暂无';\n    });\n    const phone = computed(() => {\n      return store.state.basicInfo?.phone || store.state.userInfo?.phone || '';\n    });\n\n    // 手机号脱敏处理\n    const maskPhone = phone => {\n      if (!phone) return '未绑定';\n      return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2');\n    };\n\n    // 模态框状态\n    const showPhoneModal = ref(false);\n    const showPasswordModal = ref(false);\n\n    // 添加注销账户相关的状态和方法\n    const showDeleteConfirm = ref(false);\n    const deletePassword = ref('');\n\n    // 处理注销账户\n    const handleDeleteAccount = async () => {\n      try {\n        if (!deletePassword.value) {\n          showToast('请输入密码确认', 'warning');\n          return;\n        }\n\n        // 显示加载状态\n        loading.value = true;\n        await auth.deleteAccount({\n          password: deletePassword.value\n        });\n        showToast('账户已注销', 'success');\n        store.dispatch('logout');\n        router.push('/login');\n      } catch (error) {\n        showToast(error.message || '注销账户失败，请重试', 'error');\n      } finally {\n        loading.value = false;\n        showDeleteConfirm.value = false;\n        deletePassword.value = '';\n      }\n    };\n\n    // 昵称设置弹窗\n    const showNicknameModal = ref(false);\n    const newNickname = ref('');\n\n    // 昵称验证函数\n    const validateNickname = nickname => {\n      if (!nickname) {\n        showToast('请输入昵称', 'warning');\n        return false;\n      }\n\n      // 检查长度\n      if (nickname.length < 4 || nickname.length > 8) {\n        showToast('昵称长度需要在4-8位之间', 'warning');\n        return false;\n      }\n\n      // 只允许中文、字母、数字\n      const nicknameRegex = /^[\\u4e00-\\u9fa5a-zA-Z0-9]+$/;\n      if (!nicknameRegex.test(nickname)) {\n        showToast('昵称只能包含中文、字母、数字', 'warning');\n        return false;\n      }\n      return true;\n    };\n\n    // 修改昵称更新处理函数\n    const handleUpdateNickname = async () => {\n      const nickname = newNickname.value.trim();\n\n      // 验证昵称\n      if (!validateNickname(nickname)) return;\n      try {\n        const response = await auth.updateUsername({\n          username: nickname\n        });\n        if (response.data?.code === 200) {\n          // 直接更新 store 中的 userInfo\n          store.commit('SET_USER_INFO', _objectSpread(_objectSpread({}, store.state.userInfo), {}, {\n            username: nickname\n          }));\n          showToast('昵称修改成功', 'success');\n          showNicknameModal.value = false;\n          newNickname.value = '';\n        }\n      } catch (error) {\n        showToast(error.message || '昵称修改失败', 'error');\n      }\n    };\n\n    // 手机号相关\n    const newPhone = ref('');\n    const phoneVerifyCode = ref('');\n    const phoneCodeCountdown = ref(0);\n\n    // 密码相关\n    const currentPassword = ref('');\n    const newPassword = ref('');\n    const confirmPassword = ref('');\n\n    // 发送手机验证码\n    const handleSendPhoneCode = async () => {\n      try {\n        await sms.sendVerifyCode({\n          phone: newPhone.value,\n          scene: SMS_SCENE.CHANGE_PHONE\n        });\n        showToast('验证码已发送', 'success');\n        // 开始倒计时\n        phoneCodeCountdown.value = 60;\n        const timer = setInterval(() => {\n          phoneCodeCountdown.value--;\n          if (phoneCodeCountdown.value <= 0) {\n            clearInterval(timer);\n          }\n        }, 1000);\n      } catch (error) {\n        showToast(error.message || '发送验证码失败', 'error');\n      }\n    };\n\n    // 更新手机号\n    const handleUpdatePhone = async () => {\n      try {\n        const response = await auth.changePhone({\n          phone: newPhone.value,\n          code: phoneVerifyCode.value\n        });\n        if (response.data?.code === 200) {\n          // 直接更新 store 中的 userInfo\n          store.commit('SET_USER_INFO', _objectSpread(_objectSpread({}, store.state.userInfo), {}, {\n            phone: newPhone.value\n          }));\n\n          // 同时更新 basicInfo 中的手机号\n          store.commit('SET_BASIC_INFO', _objectSpread(_objectSpread({}, store.state.basicInfo), {}, {\n            phone: newPhone.value\n          }));\n          showToast('手机号更新成功', 'success');\n          showPhoneModal.value = false;\n          newPhone.value = '';\n          phoneVerifyCode.value = '';\n        }\n      } catch (error) {\n        showToast(error.message || '更新手机号失败', 'error');\n      }\n    };\n\n    // 更新密码\n    const handleUpdatePassword = async () => {\n      if (newPassword.value !== confirmPassword.value) {\n        showToast('两次输入的密码不一致', 'error');\n        return;\n      }\n      try {\n        await auth.updatePassword({\n          old_password: currentPassword.value,\n          new_password: newPassword.value,\n          confirm_password: confirmPassword.value\n        });\n        showToast('密码修改成功', 'success');\n        showPasswordModal.value = false;\n        currentPassword.value = '';\n        newPassword.value = '';\n        confirmPassword.value = '';\n      } catch (error) {\n        showToast(error.message || '修改密码失败', 'error');\n      }\n    };\n    const __returned__ = {\n      props,\n      store,\n      router,\n      loading,\n      username,\n      uid,\n      phone,\n      maskPhone,\n      showPhoneModal,\n      showPasswordModal,\n      showDeleteConfirm,\n      deletePassword,\n      handleDeleteAccount,\n      showNicknameModal,\n      newNickname,\n      validateNickname,\n      handleUpdateNickname,\n      newPhone,\n      phoneVerifyCode,\n      phoneCodeCountdown,\n      currentPassword,\n      newPassword,\n      confirmPassword,\n      handleSendPhoneCode,\n      handleUpdatePhone,\n      handleUpdatePassword,\n      ref,\n      computed,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get auth() {\n        return auth;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      },\n      get sms() {\n        return sms;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","useRouter","showToast","auth","SMS_SCENE","sms","props","__props","store","router","console","log","id","state","userInfo","uid","username","fullUserInfo","loading","phone","basicInfo","maskPhone","replace","showPhoneModal","showPasswordModal","showDeleteConfirm","deletePassword","handleDeleteAccount","value","deleteAccount","password","dispatch","push","error","message","showNicknameModal","newNickname","validateNickname","nickname","length","nicknameRegex","test","handleUpdateNickname","trim","response","updateUsername","data","code","commit","_objectSpread","newPhone","phoneVerifyCode","phoneCodeCountdown","currentPassword","newPassword","confirmPassword","handleSendPhoneCode","sendVerifyCode","scene","CHANGE_PHONE","timer","setInterval","clearInterval","handleUpdatePhone","changePhone","handleUpdatePassword","updatePassword","old_password","new_password","confirm_password"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/AccountSettings.vue"],"sourcesContent":["<template>\n  <div class=\"max-w-4xl mx-auto\">\n    <!-- 内容区域 -->\n    <div class=\"space-y-6\">\n\n      <!-- 账户信息 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <!-- 标题栏 -->\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户信息</h2>\n        </div>\n        \n        <!-- 内容区 -->\n        <div class=\"p-6 space-y-6\">\n          <!-- UID -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex items-center space-x-2\">\n              <span class=\"text-sm font-medium text-gray-500\">用户 ID</span>\n              <span class=\"text-sm text-gray-900\">{{ uid }}</span>\n            </div>\n            <div class=\"text-xs text-gray-500\">用户唯一标识</div>\n          </div>\n\n          <!-- 昵称 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex items-center space-x-2\">\n              <span class=\"text-sm font-medium text-gray-500\">昵称</span>\n              <span class=\"text-sm text-gray-900\">{{ username }}</span>\n              <span class=\"text-xs text-gray-400\" v-if=\"!username\">\n                (默认为 Flybird + 手机号后4位)\n              </span>\n            </div>\n            <button @click=\"showNicknameModal = true\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              <svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z\" />\n              </svg>\n              设置\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 账户安全 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <!-- 标题栏 -->\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户安全</h2>\n        </div>\n        \n        <!-- 内容区 -->\n        <div class=\"p-6 space-y-6\">\n          <!-- 手机号 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">手机号</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">{{ maskPhone(phone) }}</p>\n            </div>\n            <button @click=\"showPhoneModal = true\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              更换手机号\n            </button>\n          </div>\n\n          <!-- 密码 -->\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">登录密码</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">用于保护账号安全</p>\n            </div>\n            <button @click=\"showPasswordModal = true\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n              transition-colors rounded-md hover:bg-indigo-50\">\n              修改密码\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- 账户注销 -->\n      <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n        <!-- 标题栏 -->\n        <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n          <h2 class=\"text-lg font-medium text-gray-900\">账户注销</h2>\n        </div>\n        \n        <!-- 内容区 -->\n        <div class=\"p-6\">\n          <div class=\"flex items-center justify-between\">\n            <div class=\"flex-1\">\n              <div class=\"flex items-center space-x-2\">\n                <svg class=\"w-5 h-5 text-red-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                    d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\n                </svg>\n                <span class=\"text-sm font-medium text-gray-900\">账户注销</span>\n              </div>\n              <p class=\"mt-1 text-sm text-gray-500\">注销后，账户将被永久删除且无法恢复</p>\n            </div>\n            <button @click=\"showDeleteConfirm = true\"\n              class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-red-600 hover:text-red-700 \n              transition-colors rounded-md hover:bg-red-50\">\n              注销账户\n            </button>\n          </div>\n        </div>\n      </section>\n            <!-- 昵称设置弹窗 -->\n      <div v-if=\"showNicknameModal\" class=\"fixed inset-0 z-50 overflow-y-auto\" aria-labelledby=\"modal-title\" role=\"dialog\" aria-modal=\"true\">\n        <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n          <!-- 背景遮罩 -->\n          <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\" aria-hidden=\"true\"></div>\n          <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\" aria-hidden=\"true\">&#8203;</span>\n          \n          <!-- 弹窗内容 -->\n          <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n            <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n              <div class=\"sm:flex sm:items-start\">\n                <div class=\"mt-3 text-center sm:mt-0 sm:text-left w-full\">\n                  <h3 class=\"text-lg leading-6 font-medium text-gray-900\" id=\"modal-title\">设置昵称</h3>\n                  <div class=\"mt-4\">\n                    <input\n                      type=\"text\"\n                      v-model=\"newNickname\"\n                      maxlength=\"8\"\n                      class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                      placeholder=\"请输入4-8位昵称，支持中文、字母、数字\"\n                      @keyup.enter=\"handleUpdateNickname\"\n                    />\n                    <div class=\"mt-1 text-xs text-gray-500\">\n                      昵称长度需要在4-8位之间，只能包含中文、字母、数字\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n              <button\n                type=\"button\"\n                @click=\"handleUpdateNickname\"\n                :disabled=\"!newNickname.trim()\"\n                class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\"\n              >\n                确认\n              </button>\n              <button\n                type=\"button\"\n                @click=\"showNicknameModal = false\"\n                class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\"\n              >\n                取消\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 修改手机号弹窗 -->\n      <el-dialog\n        v-model=\"showPhoneModal\"\n        title=\"更换手机号\"\n        width=\"400px\"\n        :close-on-click-modal=\"false\"\n      >\n        <div class=\"space-y-4\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700\">新手机号</label>\n            <input\n              type=\"text\"\n              v-model=\"newPhone\"\n              class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\"\n              placeholder=\"请输入新手机号\"\n            />\n          </div>\n          <div class=\"flex space-x-2\">\n            <input\n              type=\"text\"\n              v-model=\"phoneVerifyCode\"\n              class=\"flex-1 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\"\n              placeholder=\"请输入验证码\"\n            />\n            <button\n              @click=\"handleSendPhoneCode\"\n              :disabled=\"phoneCodeCountdown > 0\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50\"\n            >\n              {{ phoneCodeCountdown > 0 ? `${phoneCodeCountdown}s` : '获取验证码' }}\n            </button>\n          </div>\n        </div>\n        <template #footer>\n          <div class=\"flex justify-end space-x-3\">\n            <button\n              @click=\"showPhoneModal = false\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n            >\n              取消\n            </button>\n            <button\n              @click=\"handleUpdatePhone\"\n              :disabled=\"!newPhone || !phoneVerifyCode\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 disabled:opacity-50\"\n            >\n              确认\n            </button>\n          </div>\n        </template>\n      </el-dialog>\n\n      <!-- 修改密码弹窗 -->\n      <el-dialog\n        v-model=\"showPasswordModal\"\n        title=\"修改密码\"\n        width=\"400px\"\n        :close-on-click-modal=\"false\"\n      >\n        <div class=\"space-y-4\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700\">当前密码</label>\n            <input\n              type=\"password\"\n              v-model=\"currentPassword\"\n              class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\"\n              placeholder=\"请输入当前密码\"\n            />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700\">新密码</label>\n            <input\n              type=\"password\"\n              v-model=\"newPassword\"\n              class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\"\n              placeholder=\"请输入新密码\"\n            />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700\">确认新密码</label>\n            <input\n              type=\"password\"\n              v-model=\"confirmPassword\"\n              class=\"mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm\"\n              placeholder=\"请再次输入新密码\"\n            />\n          </div>\n        </div>\n        <template #footer>\n          <div class=\"flex justify-end space-x-3\">\n            <button\n              @click=\"showPasswordModal = false\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n            >\n              取消\n            </button>\n            <button\n              @click=\"handleUpdatePassword\"\n              :disabled=\"!currentPassword || !newPassword || !confirmPassword\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 disabled:opacity-50\"\n            >\n              确认\n            </button>\n          </div>\n        </template>\n      </el-dialog>\n\n      <!-- 注销账户确认对话框 -->\n      <div v-if=\"showDeleteConfirm\" class=\"fixed inset-0 z-50 overflow-y-auto\" aria-labelledby=\"modal-title\" role=\"dialog\" aria-modal=\"true\">\n        <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n          <!-- 背景遮罩 -->\n          <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\" aria-hidden=\"true\"></div>\n          <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\" aria-hidden=\"true\">&#8203;</span>\n          \n          <!-- 对话框内容 -->\n          <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n            <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n              <div class=\"sm:flex sm:items-start\">\n                <div class=\"mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10\">\n                  <svg class=\"h-6 w-6 text-red-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n                  </svg>\n                </div>\n                <div class=\"mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left\">\n                  <h3 class=\"text-lg leading-6 font-medium text-gray-900\" id=\"modal-title\">确认注销账户？</h3>\n                  <div class=\"mt-2\">\n                    <div class=\"bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4\">\n                      <div class=\"flex\">\n                        <div class=\"flex-shrink-0\">\n                          <svg class=\"h-5 w-5 text-yellow-400\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path fill-rule=\"evenodd\" d=\"M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z\" clip-rule=\"evenodd\" />\n                          </svg>\n                        </div>\n                        <div class=\"ml-3\">\n                          <p class=\"text-sm text-yellow-700\">\n                            <strong>警告：</strong> 此操作将永久删除您的账户，包括：\n                          </p>\n                          <ul class=\"mt-2 text-sm text-yellow-700 list-disc list-inside\">\n                            <li>所有个人信息和设置</li>\n                            <li>账户关联的所有数据</li>\n                            <li>无法恢复已删除的数据</li>\n                          </ul>\n                        </div>\n                      </div>\n                    </div>\n                    <p class=\"text-sm text-gray-500\">\n                      请输入登录密码确认此操作。\n                    </p>\n                    <!-- 密码输入框 -->\n                    <div class=\"mt-4\">\n                      <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">\n                        登录密码\n                      </label>\n                      <div class=\"mt-1\">\n                        <input\n                          type=\"password\"\n                          id=\"password\"\n                          v-model=\"deletePassword\"\n                          class=\"shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md\"\n                          placeholder=\"请输入密码\"\n                          @keyup.enter=\"handleDeleteAccount\"\n                        />\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n              <button type=\"button\" \n                @click=\"handleDeleteAccount\"\n                :disabled=\"!deletePassword\"\n                class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed\">\n                确认注销\n              </button>\n              <button type=\"button\" \n                @click=\"showDeleteConfirm = false\"\n                class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\">\n                取消\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { auth } from '@/api/auth'\nimport { SMS_SCENE } from '@/constants'\nimport { sms } from '@/api/sms'\n\n// 接收父组件传递的 props\nconst props = defineProps({\n  userInfo: {\n    type: Object,\n    required: true\n  }\n})\n\nconst store = useStore()\nconst router = useRouter()\n\n// 添加调试信息\nconsole.log('Store userInfo:', {\n  id: store.state.userInfo?.id,\n  uid: store.state.userInfo?.uid,\n  username: store.state.userInfo?.username,\n  fullUserInfo: store.state.userInfo\n})\n\n// 移除 userBasicInfo ref 和 fetchUserBasicInfo 函数\nconst loading = ref(false)\n\n// 直接使用 store 中的数据，username 来自 userInfo\nconst username = computed(() => {\n  return store.state.userInfo?.username || '未设置'\n})\n\nconst uid = computed(() => {\n  return store.state.userInfo?.uid || '暂无'\n})\n\nconst phone = computed(() => {\n  return store.state.basicInfo?.phone || store.state.userInfo?.phone || ''\n})\n\n// 手机号脱敏处理\nconst maskPhone = (phone) => {\n  if (!phone) return '未绑定'\n  return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n// 模态框状态\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\n\n// 添加注销账户相关的状态和方法\nconst showDeleteConfirm = ref(false)\nconst deletePassword = ref('')\n\n// 处理注销账户\nconst handleDeleteAccount = async () => {\n  try {\n    if (!deletePassword.value) {\n      showToast('请输入密码确认', 'warning')\n      return\n    }\n\n    // 显示加载状态\n    loading.value = true\n\n    await auth.deleteAccount({\n      password: deletePassword.value\n    })\n\n    showToast('账户已注销', 'success')\n    store.dispatch('logout')\n    router.push('/login')\n  } catch (error) {\n    showToast(error.message || '注销账户失败，请重试', 'error')\n  } finally {\n    loading.value = false\n    showDeleteConfirm.value = false\n    deletePassword.value = ''\n  }\n}\n\n// 昵称设置弹窗\nconst showNicknameModal = ref(false)\nconst newNickname = ref('')\n\n// 昵称验证函数\nconst validateNickname = (nickname) => {\n  if (!nickname) {\n    showToast('请输入昵称', 'warning')\n    return false\n  }\n  \n  // 检查长度\n  if (nickname.length < 4 || nickname.length > 8) {\n    showToast('昵称长度需要在4-8位之间', 'warning')\n    return false\n  }\n  \n  // 只允许中文、字母、数字\n  const nicknameRegex = /^[\\u4e00-\\u9fa5a-zA-Z0-9]+$/\n  if (!nicknameRegex.test(nickname)) {\n    showToast('昵称只能包含中文、字母、数字', 'warning')\n    return false\n  }\n  \n  return true\n}\n\n// 修改昵称更新处理函数\nconst handleUpdateNickname = async () => {\n  const nickname = newNickname.value.trim()\n  \n  // 验证昵称\n  if (!validateNickname(nickname)) return\n  \n  try {\n    const response = await auth.updateUsername({ username: nickname })\n    if (response.data?.code === 200) {\n      // 直接更新 store 中的 userInfo\n      store.commit('SET_USER_INFO', {\n        ...store.state.userInfo,\n        username: nickname\n      })\n      showToast('昵称修改成功', 'success')\n      showNicknameModal.value = false\n      newNickname.value = ''\n    }\n  } catch (error) {\n    showToast(error.message || '昵称修改失败', 'error')\n  }\n}\n\n// 手机号相关\nconst newPhone = ref('')\nconst phoneVerifyCode = ref('')\nconst phoneCodeCountdown = ref(0)\n\n// 密码相关\nconst currentPassword = ref('')\nconst newPassword = ref('')\nconst confirmPassword = ref('')\n\n// 发送手机验证码\nconst handleSendPhoneCode = async () => {\n  try {\n    await sms.sendVerifyCode({\n      phone: newPhone.value,\n      scene: SMS_SCENE.CHANGE_PHONE\n    })\n    \n    showToast('验证码已发送', 'success')\n    // 开始倒计时\n    phoneCodeCountdown.value = 60\n    const timer = setInterval(() => {\n      phoneCodeCountdown.value--\n      if (phoneCodeCountdown.value <= 0) {\n        clearInterval(timer)\n      }\n    }, 1000)\n  } catch (error) {\n    showToast(error.message || '发送验证码失败', 'error')\n  }\n}\n\n// 更新手机号\nconst handleUpdatePhone = async () => {\n  try {\n    const response = await auth.changePhone({\n      phone: newPhone.value,\n      code: phoneVerifyCode.value\n    })\n    \n    if (response.data?.code === 200) {\n      // 直接更新 store 中的 userInfo\n      store.commit('SET_USER_INFO', {\n        ...store.state.userInfo,\n        phone: newPhone.value\n      })\n      \n      // 同时更新 basicInfo 中的手机号\n      store.commit('SET_BASIC_INFO', {\n        ...store.state.basicInfo,\n        phone: newPhone.value\n      })\n      \n      showToast('手机号更新成功', 'success')\n      showPhoneModal.value = false\n      newPhone.value = ''\n      phoneVerifyCode.value = ''\n    }\n  } catch (error) {\n    showToast(error.message || '更新手机号失败', 'error')\n  }\n}\n\n// 更新密码\nconst handleUpdatePassword = async () => {\n  if (newPassword.value !== confirmPassword.value) {\n    showToast('两次输入的密码不一致', 'error')\n    return\n  }\n  \n  try {\n    await auth.updatePassword({\n      old_password: currentPassword.value,\n      new_password: newPassword.value,\n      confirm_password: confirmPassword.value\n    })\n    \n    showToast('密码修改成功', 'success')\n    showPasswordModal.value = false\n    currentPassword.value = ''\n    newPassword.value = ''\n    confirmPassword.value = ''\n  } catch (error) {\n    showToast(error.message || '修改密码失败', 'error')\n  }\n}\n\n</script>\n\n<style scoped>\n/* 如果有任何样式，放在这里 */\n</style>"],"mappings":";AAyWA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,QAAQ,QAAQ,MAAK