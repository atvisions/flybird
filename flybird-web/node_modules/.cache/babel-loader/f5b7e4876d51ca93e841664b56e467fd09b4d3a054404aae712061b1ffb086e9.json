{"ast":null,"code":"export default {\n  __name: 'JobIntentionContent',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // ... script 部分保持不变 ...\n\n    const __returned__ = {};\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":[],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/JobIntentionContent.vue -->\n<template>\n  <div class=\"space-y-4\">\n    <!-- 求职状态 -->\n    <div class=\"flex items-center space-x-2\">\n      <div class=\"w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center\">\n        <UserCircleIcon class=\"w-5 h-5 text-green-600\" />\n      </div>\n      <div class=\"flex-1\">\n        <div class=\"text-sm text-gray-500\">求职状态</div>\n        <div class=\"text-gray-900\">{{ getJobStatusLabel(data?.job_status) }}</div>\n      </div>\n    </div>\n\n    <!-- 工作类型 -->\n    <div class=\"flex items-center space-x-2\">\n      <div class=\"w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center\">\n        <BriefcaseIcon class=\"w-5 h-5 text-blue-600\" />\n      </div>\n      <div class=\"flex-1\">\n        <div class=\"text-sm text-gray-500\">工作类型</div>\n        <div class=\"text-gray-900\">{{ getJobTypeLabel(data?.job_type) }}</div>\n      </div>\n    </div>\n\n    <!-- 期望薪资 -->\n    <div class=\"flex items-center space-x-2\">\n      <div class=\"w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center\">\n        <CurrencyYenIcon class=\"w-5 h-5 text-purple-600\" />\n      </div>\n      <div class=\"flex-1\">\n        <div class=\"text-sm text-gray-500\">期望薪资</div>\n        <div class=\"text-gray-900\">{{ getSalaryLabel(data?.expected_salary) }}</div>\n      </div>\n    </div>\n\n    <!-- 期望城市 -->\n    <div class=\"flex items-center space-x-2\">\n      <div class=\"w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center\">\n        <MapPinIcon class=\"w-5 h-5 text-orange-600\" />\n      </div>\n      <div class=\"flex-1\">\n        <div class=\"text-sm text-gray-500\">期望城市</div>\n        <div class=\"text-gray-900\">{{ formatCity(data?.expected_city) }}</div>\n      </div>\n    </div>\n\n    <!-- 期望行业 -->\n    <div class=\"flex items-center space-x-2\">\n      <div class=\"w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center\">\n        <BuildingOfficeIcon class=\"w-5 h-5 text-indigo-600\" />\n      </div>\n      <div class=\"flex-1\">\n        <div class=\"text-sm text-gray-500\">期望行业</div>\n        <div class=\"text-gray-900\">{{ formatIndustries(data?.industries) }}</div>\n      </div>\n    </div>\n\n    <!-- 空状态 -->\n    <div v-if=\"!data\" class=\"flex flex-col items-center justify-center py-8\">\n      <DocumentPlusIcon class=\"w-12 h-12 text-gray-300\" />\n      <p class=\"mt-2 text-gray-400\">暂无求职意向，点击编辑按钮添加</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\n// ... script 部分保持不变 ...\n</script>\n\n<style scoped>\n.w-8 {\n  transition: transform 0.2s ease;\n}\n\n.flex:hover .w-8 {\n  transform: scale(1.1);\n}\n</style>"],"mappings":";;;;;;;IAmEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}