{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, AcademicCapIcon, DocumentTextIcon, TrophyIcon } from '@heroicons/vue/24/outline';\nimport { watch, computed, ref } from 'vue';\nexport default {\n  __name: 'EducationContent',\n  props: {\n    data: {\n      type: Array,\n      required: true,\n      validator: value => {\n        console.log('【EducationContent】数据验证:', {\n          数据: value,\n          类型: Array.isArray(value) ? 'Array' : typeof value,\n          长度: value?.length,\n          第一条: value?.[0],\n          字段列表: value?.[0] ? Object.keys(value[0]) : [],\n          description: value?.[0]?.description,\n          achievements: value?.[0]?.achievements\n        });\n        return Array.isArray(value);\n      }\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;\n    };\n\n    // 获取学历标签\n    const getDegreeLabel = degree => {\n      const degreeMap = {\n        'high_school': '高中',\n        'junior_college': '大专',\n        'bachelor': '本科',\n        'master': '硕士',\n        'doctor': '博士',\n        'other': '其他'\n      };\n      return degreeMap[degree] || degree;\n    };\n\n    // 处理编辑\n    const handleEdit = edu => {\n      console.log('EducationContent handleEdit:', edu);\n      emit('edit', 'education', edu);\n    };\n\n    // 处理删除\n    const handleDelete = id => {\n      emit('delete', 'education', id);\n    };\n\n    // 处理添加\n    const handleAdd = () => {\n      console.log('EducationContent handleAdd');\n      emit('edit', 'education', null);\n    };\n\n    // 添加计算属性来检查字段\n    const hasFields = computed(() => {\n      if (!props.data?.length) return false;\n      const firstItem = props.data[0];\n      return {\n        description: 'description' in firstItem,\n        achievements: 'achievements' in firstItem,\n        descriptionType: typeof firstItem.description,\n        achievementsType: typeof firstItem.achievements,\n        descriptionValue: firstItem.description,\n        achievementsValue: firstItem.achievements\n      };\n    });\n\n    // 添加调试开关\n    const showDebug = ref(process.env.NODE_ENV === 'development');\n    const __returned__ = {\n      props,\n      emit,\n      formatDate,\n      getDegreeLabel,\n      handleEdit,\n      handleDelete,\n      handleAdd,\n      hasFields,\n      showDebug,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get AcademicCapIcon() {\n        return AcademicCapIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },\n      get TrophyIcon() {\n        return TrophyIcon;\n      },\n      watch,\n      computed,\n      ref\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","AcademicCapIcon","DocumentTextIcon","TrophyIcon","watch","computed","ref","props","__props","emit","__emit","formatDate","dateString","date","Date","getFullYear","String","getMonth","padStart","getDegreeLabel","degree","degreeMap","handleEdit","edu","console","log","handleDelete","id","handleAdd","hasFields","data","length","firstItem","description","achievements","descriptionType","achievementsType","descriptionValue","achievementsValue","showDebug","process","env","NODE_ENV"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/EducationContent.vue"],"sourcesContent":["<template>\n  <div class=\"relative space-y-0\">\n    <!-- 时间线 -->\n    <div class=\"absolute left-[0.5625rem] top-3 bottom-3 w-px bg-gray-200\"></div>\n\n    <!-- 教育经历列表 -->\n    <div \n      v-for=\"(edu, index) in data\" \n      :key=\"index\" \n      class=\"relative pl-12 pb-6\"\n    >\n      <!-- 时间节点 -->\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n      \n      <!-- 内容卡片 -->\n      <div class=\"bg-gray-50 rounded-lg border border-gray-100 p-4 hover:shadow-sm transition-shadow\">\n        <div class=\"flex flex-col space-y-2\">\n          <!-- 学校和专业信息 -->\n          <div class=\"flex items-start justify-between\">\n            <div class=\"flex-1 min-w-0\">\n              <h4 class=\"text-base font-medium text-gray-900 break-words\">{{ edu.school }}</h4>\n              <div class=\"text-sm font-medium text-blue-600 mt-1 break-words\">{{ edu.major }}</div>\n            </div>\n            <!-- 操作按钮 -->\n            <div class=\"flex items-center space-x-2 ml-4\">\n              <button\n                @click=\"handleEdit(edu)\"\n                class=\"p-1 rounded-full hover:bg-gray-200 transition-colors\"\n                title=\"编辑\"\n              >\n                <PencilSquareIcon class=\"w-5 h-5 text-gray-400 hover:text-gray-600\" />\n              </button>\n              <button\n                @click=\"handleDelete(edu.id)\"\n                class=\"p-1 rounded-full hover:bg-gray-200 transition-colors\"\n                title=\"删除\"\n              >\n                <TrashIcon class=\"w-5 h-5 text-gray-400 hover:text-red-500\" />\n              </button>\n            </div>\n          </div>\n\n          <!-- 教育经历描述 -->\n          <div class=\"text-sm leading-relaxed text-gray-600 break-words whitespace-pre-wrap\">\n            {{ edu.description }}\n          </div>\n\n          <!-- 学历 -->\n          <div class=\"space-y-2\">\n            <div class=\"flex items-center space-x-2\">\n              <AcademicCapIcon class=\"w-4 h-4 text-gray-400\" />\n              <span class=\"text-sm text-gray-500\">{{ getDegreeLabel(edu.degree) }}</span>\n            </div>\n          </div>\n\n          <!-- 在校经历 -->\n          <div v-if=\"edu.description !== undefined\" class=\"mt-3 space-y-2\">\n            <div class=\"flex items-center space-x-2\">\n              <DocumentTextIcon class=\"w-4 h-4 text-gray-400\" />\n              <span class=\"text-sm text-gray-500\">在校经历</span>\n            </div>\n            <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n              {{ edu.description }}\n            </div>\n          </div>\n\n          <!-- 在校成就 -->\n          <div v-if=\"edu.achievements !== undefined\" class=\"mt-3 space-y-2\">\n            <div class=\"flex items-center space-x-2\">\n              <TrophyIcon class=\"w-4 h-4 text-yellow-500\" />\n              <span class=\"text-sm text-gray-500\">在校成就</span>\n            </div>\n            <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n              {{ edu.achievements }}\n            </div>\n          </div>\n\n          <!-- 调试信息 -->\n          <div v-if=\"showDebug\" class=\"mt-2 text-xs text-gray-400\">\n            <div>description: {{ typeof edu.description }} = \"{{ edu.description }}\"</div>\n            <div>achievements: {{ typeof edu.achievements }} = \"{{ edu.achievements }}\"</div>\n            <div>字段列表: {{ Object.keys(edu).join(', ') }}</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 添加按钮 -->\n    <div class=\"relative pl-12\">\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n      <button\n        @click=\"handleAdd\"\n        class=\"w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n      >\n        <PlusIcon class=\"w-4 h-4 mr-2\" />\n        添加教育经历\n      </button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { \n  PencilSquareIcon,\n  TrashIcon,\n  PlusIcon,\n  AcademicCapIcon,\n  DocumentTextIcon,\n  TrophyIcon\n} from '@heroicons/vue/24/outline'\nimport { defineProps, watch, computed, ref } from 'vue'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    required: true,\n    validator: (value) => {\n      console.log('【EducationContent】数据验证:', {\n        数据: value,\n        类型: Array.isArray(value) ? 'Array' : typeof value,\n        长度: value?.length,\n        第一条: value?.[0],\n        字段列表: value?.[0] ? Object.keys(value[0]) : [],\n        description: value?.[0]?.description,\n        achievements: value?.[0]?.achievements\n      })\n      return Array.isArray(value)\n    }\n  }\n})\n\nconst emit = defineEmits(['edit', 'delete', 'add'])\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`\n}\n\n// 获取学历标签\nconst getDegreeLabel = (degree) => {\n  const degreeMap = {\n    'high_school': '高中',\n    'junior_college': '大专',\n    'bachelor': '本科',\n    'master': '硕士',\n    'doctor': '博士',\n    'other': '其他'\n  }\n  return degreeMap[degree] || degree\n}\n\n// 处理编辑\nconst handleEdit = (edu) => {\n  console.log('EducationContent handleEdit:', edu)\n  emit('edit', 'education', edu)\n}\n\n// 处理删除\nconst handleDelete = (id) => {\n  emit('delete', 'education', id)\n}\n\n// 处理添加\nconst handleAdd = () => {\n  console.log('EducationContent handleAdd')\n  emit('edit', 'education', null)\n}\n\n// 添加计算属性来检查字段\nconst hasFields = computed(() => {\n  if (!props.data?.length) return false\n  const firstItem = props.data[0]\n  return {\n    description: 'description' in firstItem,\n    achievements: 'achievements' in firstItem,\n    descriptionType: typeof firstItem.description,\n    achievementsType: typeof firstItem.achievements,\n    descriptionValue: firstItem.description,\n    achievementsValue: firstItem.achievements\n  }\n})\n\n// 添加调试开关\nconst showDebug = ref(process.env.NODE_ENV === 'development')\n\n\n</script>\n\n<style scoped>\n/* 时间线渐变效果 */\n.bg-gray-200 {\n  background: linear-gradient(180deg, \n    transparent 0%,\n    #e5e7eb 10%,\n    #e5e7eb 90%,\n    transparent 100%\n  );\n}\n\n/* 卡片悬浮效果 */\n.hover\\:shadow-sm:hover {\n  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);\n}\n\n/* 按钮悬浮效果 */\nbutton:hover .text-gray-400 {\n  @apply text-gray-500 transition-colors;\n}\n\n/* 操作按钮过渡效果 */\n.transition-colors {\n  @apply duration-200;\n}\n\n/* 删除按钮特殊效果 */\nbutton:hover .hover\\:text-red-500:hover {\n  @apply text-red-500;\n}\n</style> "],"mappings":"AAsGA,SACEA,gBAAgB,EAChBC,SAAS,EACTC,QAAQ,EACRC,eAAe,EACfC,gBAAgB,EAChBC,UAAS,QACJ,2BAA0B;AACjC,SAAsBC,KAAK,EAAEC,QAAQ,EAAEC,GAAG,QAAQ,KAAI;;;;;;;;;;;;;;;;;;;;;;;;;;;IAEtD,MAAMC,KAAK,GAAGC,OAAA;IAmBd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,UAAU,GAAIC,UAAU,IAAK;MACjC,IAAI,CAACA,UAAU,EAAE,OAAO,EAAC;MACzB,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,UAAU;MAChC,OAAO,GAAGC,IAAI,CAACE,WAAW,CAAC,CAAC,IAAIC,MAAM,CAACH,IAAI,CAACI,QAAQ,CAAC,CAAC,GAAG,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,EAAC;IAC/E;;IAEA;IACA,MAAMC,cAAc,GAAIC,MAAM,IAAK;MACjC,MAAMC,SAAS,GAAG;QAChB,aAAa,EAAE,IAAI;QACnB,gBAAgB,EAAE,IAAI;QACtB,UAAU,EAAE,IAAI;QAChB,QAAQ,EAAE,IAAI;QACd,QAAQ,EAAE,IAAI;QACd,OAAO,EAAE;MACX;MACA,OAAOA,SAAS,CAACD,MAAM,CAAC,IAAIA,MAAK;IACnC;;IAEA;IACA,MAAME,UAAU,GAAIC,GAAG,IAAK;MAC1BC,OAAO,CAACC,GAAG,CAAC,8BAA8B,EAAEF,GAAG;MAC/Cd,IAAI,CAAC,MAAM,EAAE,WAAW,EAAEc,GAAG;IAC/B;;IAEA;IACA,MAAMG,YAAY,GAAIC,EAAE,IAAK;MAC3BlB,IAAI,CAAC,QAAQ,EAAE,WAAW,EAAEkB,EAAE;IAChC;;IAEA;IACA,MAAMC,SAAS,GAAGA,CAAA,KAAM;MACtBJ,OAAO,CAACC,GAAG,CAAC,4BAA4B;MACxChB,IAAI,CAAC,MAAM,EAAE,WAAW,EAAE,IAAI;IAChC;;IAEA;IACA,MAAMoB,SAAS,GAAGxB,QAAQ,CAAC,MAAM;MAC/B,IAAI,CAACE,KAAK,CAACuB,IAAI,EAAEC,MAAM,EAAE,OAAO,KAAI;MACpC,MAAMC,SAAS,GAAGzB,KAAK,CAACuB,IAAI,CAAC,CAAC;MAC9B,OAAO;QACLG,WAAW,EAAE,aAAa,IAAID,SAAS;QACvCE,YAAY,EAAE,cAAc,IAAIF,SAAS;QACzC