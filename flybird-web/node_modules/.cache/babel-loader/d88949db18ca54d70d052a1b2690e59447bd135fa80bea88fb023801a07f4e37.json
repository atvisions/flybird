"initial-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"])) : _createCommentVNode(\"v-if\", true), _createVNode($setup[\"AIOptimizeDialog\"], {\n    modelValue: $setup.showAIOptimizeDialog,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showAIOptimizeDialog = $event),\n    \"profile-data\": $setup.profileData,\n    onApply: $setup.handleAIOptimize\n  }, null, 8 /* PROPS */, [\"modelValue\", \"profile-data\"])])]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","$setup","resumeData","basicInfo","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onUpdate","handleUpdate","onToggleBioExpand","toggleBioExpand","completionData","profileData","_createCommentVNode","coreModules","modulesLoading","handleEditModule","onAdd","_ctx","addItem","onRemove","handleModuleRemove","onEditItem","editItem","onRemoveItem","removeItem","optionalModules","length","_hoisted_3","inactiveModules","onActivate","activateModule","currentModule","type","_createBlock","modelValue","showEditModal","_cache","$event","editFormData","onSubmit","handleSubmit","showAIOptimizeDialog","onApply","handleAIOptimize"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @update=\"handleUpdate\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"loading\"\n      />\n\n      <!-- 核心模块列表 -->\n      <ModuleList\n        :active-modules=\"coreModules\"\n        :loading=\"loading || modulesLoading\"\n        @edit=\"handleEditModule\"\n        @add=\"addItem\"\n        @remove=\"handleModuleRemove\"\n        @edit-item=\"editItem\"\n        @remove-item=\"removeItem\"\n      />\n\n      <!-- 可选模块列表 -->\n      <div v-if=\"optionalModules.length > 0\" class=\"mt-8\">\n        <h3 class=\"text-lg font-medium text-gray-900 mb-4\">更多模块</h3>\n        <ModuleList\n          :active-modules=\"optionalModules\"\n          :loading=\"loading || modulesLoading\"\n          @edit=\"handleEditModule\"\n          @add=\"addItem\"\n          @remove=\"handleModuleRemove\"\n          @edit-item=\"editItem\"\n          @remove-item=\"removeItem\"\n        />\n      </div>\n\n      <AddModule\n        :inactive-modules=\"inactiveModules\"\n        :loading=\"loading\"\n        @activate=\"activateModule\"\n      />\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch } from 'vue'\nimport { useModules } from '@/composables/useModules'\nimport profile from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\nimport AIOptimizeDialog from './dialogs/AIOptimizeDialog.vue'\n\n// 使用 useModules 组合式函数\nconst { \n  loading: modulesLoading,\n  activeModules,\n  coreModules,\n  optionalModules,\n  fetchLayout,\n  fetchAvailableModules,\n  removeModule,\n  addModule,\n  updateOrder\n} = useModules()\n\n// 当前编辑的模块\nconst currentModule = ref(null)\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\nconst loading = ref(false)\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 用户基本信息\nconst userInfo = ref({\n  name: '',\n  username: '',\n  avatar: '',\n  phone: '',\n  email: '',\n  gender: '',\n  birth_date: '',\n  location: '',\n  personal_summary: ''\n})\n\n// 基本信息（用于 BasicInfo 组件）\nconst basicInfo = ref({})\n\n// 档案数据\nconst profileData = ref({\n  basic_info: {\n    name: '',\n    name_en: '',\n    personal_summary: '',\n    personal_summary_en: '',\n    gender: '',\n    phone: '',\n    email: '',\n    location: '',\n    birth_date: ''\n  },\n  job_intention: {\n    job_type: '',\n    job_status: '',\n    expected_salary: '',\n    expected_city: '',\n    industries: ''\n  },\n  work_experiences: [],\n  educations: [],\n  skills: []\n})\n\n// 完整度数据\nconst completionData = ref({\n  total_score: 0,\n  dimensions: {},\n  suggestions: []\n})\n\n// 添加缺失的响应式变量\nconst showAIOptimizeDialog = ref(false)\n\n// 处理 Bio 展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 定义组件的 emits\ndefineEmits([\n  'update:modelValue',\n  'edit',\n  'add',\n  'remove',\n  'edit-item',\n  'remove-item'\n])\n\n// 获取用户数据\nconst fetchUserData = async () => {\n  try {\n    loading.value = true\n    \n    // 获取基本信息\n    const basicResponse = await profile.getBasicInfo()\n    if (basicResponse.data?.code === 200) {\n      const { user, basic_info } = basicResponse.data.data\n      \n      // 更新用户信息\n      userInfo.value = {\n        ...user,\n        ...basic_info,\n        avatar: basic_info?.avatar || user?.avatar\n      }\n      \n      // 更新基本信息（用于 BasicInfo 组件）\n      basicInfo.value = {\n        ...userInfo.value\n      }\n    }\n\n    // 获取工作经历数据\n    const workResponse = await profile.workExperience.list()\n    if (workResponse.data?.code === 200) {\n      // 更新工作经历模块数据\n      const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n      if (workExperienceModule) {\n        workExperienceModule.data = workResponse.data.data || []\n        console.log('Work Experience Data:', workExperienceModule.data)\n      }\n    }\n\n    // 获取求职意向数据\n    const intentionResponse = await profile.jobIntention.get()\n    if (intentionResponse.data?.code === 200) {\n      const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n      if (jobIntentionModule) {\n        jobIntentionModule.data = intentionResponse.data.data || {}\n      }\n    }\n\n    // 获取完整度数据\n    await fetchCompleteness()\n    \n  } catch (error) {\n    console.error('获取数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 获取完整度数据\nconst fetchCompleteness = async () => {\n  try {\n    const response = await profile.getCompleteness()\n    if (response.data?.code === 200) {\n      completionData.value = {\n        total_score: response.data.data.total_score || 0,\n        dimensions: response.data.data.dimensions || {},\n        suggestions: response.data.data.suggestions || []\n      }\n    }\n  } catch (error) {\n    console.error('获取完整度失败:', error)\n  }\n}\n\n// 更新模块数据\nconst updateModules = (data) => {\n  const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n  if (jobIntentionModule) {\n    jobIntentionModule.data = data.job_intention || {}\n  }\n\n  const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n  if (workExperienceModule) {\n    workExperienceModule.data = data.work_experiences || []\n  }\n}\n\n// 处理数据更新\nconst handleDataUpdate = async () => {\n  await fetchUserData()\n}\n\n// 初始化数据\nonMounted(async () => {\n  try {\n    // 先获取布局\n    await fetchLayout()\n    // 再获取其他数据\n    await fetchUserData()\n    // 获取可用模块\n    await fetchAvailableModules()\n  } catch (error) {\n    console.error('初始化数据失败:', error)\n    ElMessage.error('初始化数据失败，请刷新页面重试')\n  }\n})\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchUserData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    loading.value = true\n    \n    if (currentModule.value?.type === 'basic_info') {\n      // 基本信息保存\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchUserData()\n      } else {\n        throw new Error(response.data?.message || '保存失败')\n      }\n    } else if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.workExperience.update(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchUserData()\n        } else {\n          throw new Error(response.data?.message || '更新失败')\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.workExperience.add(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchUserData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.jobIntention.update(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchUserData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\n// 处理 AI 优化结果\nconst handleAIOptimize = (optimizedData) => {\n  Object.entries(optimizedData).forEach(([key, value]) => {\n    const [category, field] = key.split('.')\n    if (category && field) {\n      if (!profileData.value[category]) {\n        profileData.value[category] = {}\n      }\n      profileData.value[category][field] = value\n    } else {\n      profileData.value[key] = value\n    }\n  })\n}\n\n// 添加更新处理方法\nconst handleUpdate = async () => {\n  await fetchUserData()\n}\n\n// 处理模块移除\nconst handleModuleRemove = async (moduleId) => {\n  try {\n    await removeModule(moduleId)\n    // 移除成功后重新获取数据\n    await fetchUserData()\n  } catch (error) {\n    console.error('移除模块失败:', error)\n  }\n}\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;EAH5CC,GAAA;EAgC6CD,KAAK,EAAC;;;uBA9BjDE,mBAAA,CAkFM,OAlFNC,UAkFM,GAjFJC,mBAAA,CAgFM,OAhFNC,UAgFM,GA/EJC,YAAA,CAQEC,MAAA;IAPCC,UAAU,EAAED,MAAA,CAAAE,SAAS;IACrBC,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChBC,WAAW,EAAEJ,MAAA,CAAAI,WAAW;IACxBC,mBAAmB,EAAEL,MAAA,CAAAK,mBAAmB;IACxCC,MAAI,EAAEN,MAAA,CAAAO,UAAU;IAChBC,QAAM,EAAER,MAAA,CAAAS,YAAY;IACpBC,iBAAe,EAAEV,MAAA,CAAAW;4FAGpBZ,YAAA,CAIEC,MAAA;IAHC,iBAAe,EAAEA,MAAA,CAAAY,cAAc;IAC/B,cAAY,EAAEZ,MAAA,CAAAa,WAAW;IACzBV,OAAO,EAAEH,MAAA,CAAAG;2EAGZW,mBAAA,YAAe,EACff,YAAA,CAQEC,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAAe,WAAW;IAC3BZ,OAAO,EAAEH,MAAA,CAAAG,OAAO,IAAIH,MAAA,CAAAgB,cAAc;IAClCV,MAAI,EAAEN,MAAA,CAAAiB,gBAAgB;IACtBC,KAAG,EAAEC,IAAA,CAAAC,OAAO;IACZC,QAAM,EAAErB,MAAA,CAAAsB,kBAAkB;IAC1BC,UAAS,EAAEvB,MAAA,CAAAwB,QAAQ;IACnBC,YAAW,EAAEzB,MAAA,CAAA0B;mEAGhBZ,mBAAA,YAAe,EACJd,MAAA,CAAA2B,eAAe,CAACC,MAAM,Q,cAAjCjC,mBAAA,CAWM,OAXNkC,UAWM,G,0BAVJhC,mBAAA,CAA4D;IAAxDJ,KAAK,EAAC;EAAwC,GAAC,MAAI,sBACvDM,YAAA,CAQEC,MAAA;IAPC,gBAAc,EAAEA,MAAA,CAAA2B,eAAe;IAC/BxB,OAAO,EAAEH,MAAA,CAAAG,OAAO,IAAIH,MAAA,CAAAgB,cAAc;IAClCV,MAAI,EAAEN,MAAA,CAAAiB,gBAAgB;IACtBC,KAAG,EAAEC,IAAA,CAAAC,OAAO;IACZC,QAAM,EAAErB,MAAA,CAAAsB,kBAAkB;IAC1BC,UAAS,EAAEvB,MAAA,CAAAwB,QAAQ;IACnBC,YAAW,EAAEzB,MAAA,CAAA0B;uEAzCxBZ,mBAAA,gBA6CMf,YAAA,CAIEC,MAAA;IAHC,kBAAgB,EAAEmB,IAAA,CAAAW,eAAe;IACjC3B,OAAO,EAAEH,MAAA,CAAAG,OAAO;IAChB4B,UAAQ,EAAEZ,IAAA,CAAAa;0EAGblB,mBAAA,cAAiB,EAETd,MAAA,CAAAiC,a