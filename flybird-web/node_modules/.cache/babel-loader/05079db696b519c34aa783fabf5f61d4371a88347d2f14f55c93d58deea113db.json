{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, AcademicCapIcon, DocumentTextIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'EducationContent',\n  props: {\n    data: {\n      type: Array,\n      default: () => []\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;\n    };\n\n    // 获取学历标签\n    const getDegreeLabel = degree => {\n      const degreeMap = {\n        'bachelor': '本科',\n        'master': '硕士',\n        'doctor': '博士',\n        'associate': '专科',\n        'high_school': '高中',\n        'other': '其他'\n      };\n      return degreeMap[degree] || degree;\n    };\n\n    // 处理编辑\n    const handleEdit = edu => {\n      emit('edit', edu);\n    };\n\n    // 处理删除\n    const handleDelete = id => {\n      emit('delete', id);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      formatDate,\n      getDegreeLabel,\n      handleEdit,\n      handleDelete,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get AcademicCapIcon() {\n        return AcademicCapIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","AcademicCapIcon","DocumentTextIcon","props","__props","emit","__emit","formatDate","dateString","date","Date","getFullYear","String","getMonth","padStart","getDegreeLabel","degree","degreeMap","handleEdit","edu","handleDelete","id"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/EducationContent.vue"],"sourcesContent":["<template>\n  <div class=\"relative space-y-0\">\n    <!-- 时间线 -->\n    <div class=\"absolute left-[0.5625rem] top-3 bottom-3 w-px bg-gray-200\"></div>\n\n    <!-- 教育经历列表 -->\n    <div \n      v-for=\"(edu, index) in data\" \n      :key=\"index\" \n      class=\"relative pl-12 pb-6\"\n    >\n      <!-- 时间节点 -->\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n      \n      <!-- 内容卡片 -->\n      <div class=\"bg-gray-50 rounded-lg border border-gray-100 p-4 hover:shadow-sm transition-shadow\">\n        <!-- 头部信息 -->\n        <div class=\"flex items-center justify-between mb-3\">\n          <div class=\"flex-1\">\n            <div class=\"text-sm text-gray-500\">\n              {{ formatDate(edu.start_date) }} - {{ edu.end_date ? formatDate(edu.end_date) : '至今' }}\n            </div>\n            <div class=\"flex items-center justify-between mt-1.5\">\n              <span class=\"text-base font-medium text-gray-900\">{{ edu.school }}</span>\n              <div class=\"flex items-center space-x-2\">\n                <button\n                  @click=\"handleEdit(edu)\"\n                  class=\"p-1 hover:bg-white rounded-full transition-colors\"\n                >\n                  <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n                </button>\n                <button\n                  @click=\"handleDelete(edu.id)\"\n                  class=\"p-1 hover:bg-white rounded-full transition-colors\"\n                >\n                  <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 专业 -->\n        <div class=\"text-sm font-medium text-blue-600 mb-3\">\n          {{ edu.major }}\n        </div>\n\n        <!-- 学历 -->\n        <div class=\"space-y-2\">\n          <div class=\"flex items-center space-x-2\">\n            <AcademicCapIcon class=\"w-4 h-4 text-gray-400\" />\n            <span class=\"text-sm text-gray-500\">{{ getDegreeLabel(edu.degree) }}</span>\n          </div>\n        </div>\n\n        <!-- 在校经历 -->\n        <div v-if=\"edu.experiences\" class=\"mt-3 space-y-2\">\n          <div class=\"flex items-center space-x-2\">\n            <DocumentTextIcon class=\"w-4 h-4 text-gray-400\" />\n            <span class=\"text-sm text-gray-500\">在校经历</span>\n          </div>\n          <div class=\"text-sm leading-relaxed text-gray-600 pl-6\">\n            {{ edu.experiences }}\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 添加按钮 -->\n    <div class=\"relative pl-12\">\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n      <button\n        @click=\"$emit('add')\"\n        class=\"w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n      >\n        <PlusIcon class=\"w-4 h-4 mr-2\" />\n        添加教育经历\n      </button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { \n  PencilSquareIcon,\n  TrashIcon,\n  PlusIcon,\n  AcademicCapIcon,\n  DocumentTextIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  data: {\n    type: Array,\n    default: () => []\n  }\n})\n\nconst emit = defineEmits(['edit', 'delete', 'add'])\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`\n}\n\n// 获取学历标签\nconst getDegreeLabel = (degree) => {\n  const degreeMap = {\n    'bachelor': '本科',\n    'master': '硕士',\n    'doctor': '博士',\n    'associate': '专科',\n    'high_school': '高中',\n    'other': '其他'\n  }\n  return degreeMap[degree] || degree\n}\n\n// 处理编辑\nconst handleEdit = (edu) => {\n  emit('edit', edu)\n}\n\n// 处理删除\nconst handleDelete = (id) => {\n  emit('delete', id)\n}\n</script>\n\n<style scoped>\n/* 时间线渐变效果 */\n.bg-gray-200 {\n  background: linear-gradient(180deg, \n    transparent 0%,\n    #e5e7eb 10%,\n    #e5e7eb 90%,\n    transparent 100%\n  );\n}\n\n/* 卡片悬浮效果 */\n.hover\\:shadow-sm:hover {\n  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);\n}\n\n/* 按钮悬浮效果 */\nbutton:hover .text-gray-400 {\n  @apply text-gray-500 transition-colors;\n}\n</style> "],"mappings":"AAmFA,SACEA,gBAAgB,EAChBC,SAAS,EACTC,QAAQ,EACRC,eAAe,EACfC,gBAAe,QACV,2BAA0B;;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;IAOd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,UAAU,GAAIC,UAAU,IAAK;MACjC,IAAI,CAACA,UAAU,EAAE,OAAO,EAAC;MACzB,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,UAAU;MAChC,OAAO,GAAGC,IAAI,CAACE,WAAW,CAAC,CAAC,IAAIC,MAAM,CAACH,IAAI,CAACI,QAAQ,CAAC,CAAC,GAAG,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,EAAC;IAC/E;;IAEA;IACA,MAAMC,cAAc,GAAIC,MAAM,IAAK;MACjC,MAAMC,SAAS,GAAG;QAChB,UAAU,EAAE,IAAI;QAChB,QAAQ,EAAE,IAAI;QACd,QAAQ,EAAE,IAAI;QACd,WAAW,EAAE,IAAI;QACjB,aAAa,EAAE,IAAI;QACnB,OAAO,EAAE;MACX;MACA,OAAOA,SAAS,CAACD,MAAM,CAAC,IAAIA,MAAK;IACnC;;IAEA;IACA,MAAME,UAAU,GAAIC,GAAG,IAAK;MAC1Bd,IAAI,CAAC,MAAM,EAAEc,GAAG;IAClB;;IAEA;IACA,MAAMC,YAAY,GAAIC,EAAE,IAAK;MAC3BhB,IAAI,CAAC,QAAQ,EAAEgB,EAAE;IACnB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}