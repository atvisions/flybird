{\n    \"completion-data\": _ctx.completionData,\n    \"profile-data\": _ctx.profileData,\n    loading: _ctx.loading\n  }, null, 8 /* PROPS */, [\"completion-data\", \"profile-data\", \"loading\"]), _createCommentVNode(\" 所有模块列表 \"), _createElementVNode(\"div\", _hoisted_3, [_createCommentVNode(\" 激活的模块 \"), _createVNode(_component_ModuleList, {\n    \"active-modules\": _ctx.activeModules,\n    loading: _ctx.loading || _ctx.modulesLoading,\n    onEdit: _ctx.handleEditModule,\n    onRemove: _ctx.handleModuleRemove,\n    onEditItem: _ctx.editItem,\n    onRemoveItem: _ctx.removeItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onEdit\", \"onRemove\", \"onEditItem\", \"onRemoveItem\"]), _createCommentVNode(\" 未激活的模块 \"), (_openBlock(true), _createElementBlock(_Fragment, null, _renderList(_ctx.inactiveModules, module => {\n    return _openBlock(), _createElementBlock(\"div\", {\n      key: module.type,\n      class: \"bg-white rounded-lg shadow\"\n    }, [_createElementVNode(\"div\", _hoisted_4, [_createElementVNode(\"h3\", _hoisted_5, _toDisplayString(_ctx.getModuleName(module.type)), 1 /* TEXT */), _createElementVNode(\"button\", {\n      onClick: $event => _ctx.handleAddModule(module.type),\n      class: \"p-1 hover:bg-gray-100 rounded-full\"\n    }, [_createVNode(_component_PlusIcon, {\n      class: \"w-5 h-5 text-gray-400\"\n    })], 8 /* PROPS */, _hoisted_6)]), _cache[4] || (_cache[4] = _createElementVNode(\"div\", {\n      class: \"px-4 pb-4\"\n    }, [_createElementVNode(\"div\", {\n      class: \"text-center text-gray-400 py-4\"\n    }, \" 暂无内容，点击添加 \")], -1 /* HOISTED */))]);\n  }), 128 /* KEYED_FRAGMENT */))]), _createCommentVNode(\" 工作经历编辑弹窗 \"), _ctx.currentModule?.type === 'work_experience' ? (_openBlock(), _createBlock(_component_EditWorkExperienceDialog, {\n    key: 0,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 求职意向编辑弹窗 \"), _ctx.currentModule?.type === 'job_intention' ? (_openBlock(), _createBlock(_component_EditJobIntentionDialog, {\n    key: 1,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true), _createCommentVNode(\" 基本信息编辑弹窗 \"), _ctx.currentModule?.type === 'basic_info' ? (_openBlock(), _createBlock(_component_EditBasicDialog, {\n    key: 2,\n    modelValue: _ctx.showEditModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => _ctx.showEditModal = $event),\n    \"initial-data\": _ctx.editFormData,\n    loading: _ctx.loading,\n    onSubmit: _ctx.handleSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\", \"onSubmit\"])) : _createCommentVNode(\"v-if\", true), _createVNode(_component_AIOptimizeDialog, {\n    modelValue: _ctx.showAIOptimizeDialog,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => _ctx.showAIOptimizeDialog = $event),\n    \"profile-data\": _ctx.profileData,\n    onApply: _ctx.handleAIOptimize\n  }, null, 8 /* PROPS */, [\"modelValue\", \"profile-data\", \"onApply\"])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createVNode","_component_BasicInfo","resumeData","_ctx","basicInfo","loading","bioExpanded","showBioExpandButton","onEdit","handleEdit","onUpdate","handleUpdate","onToggleBioExpand","toggleBioExpand","_component_ResumeStatus","completionData","profileData","_createCommentVNode","_hoisted_3","_component_ModuleList","activeModules","modulesLoading","handleEditModule","onRemove","handleModuleRemove","onEditItem","editItem","onRemoveItem","removeItem","_Fragment","_renderList","inactiveModules","module","key","type","_hoisted_4","_hoisted_5","_toDisplayString","getModuleName","onClick","$event","handleAddModule","_component_PlusIcon","_hoisted_6","currentModule","_createBlock","_component_EditWorkExperienceDialog","modelValue","showEditModal","_cache","editFormData","onSubmit","handleSubmit","_component_EditJobIntentionDialog","_component_EditBasicDialog","_component_AIOptimizeDialog","showAIOptimizeDialog","onApply","handleAIOptimize"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n  <div class=\"container mx-auto\">\n    <div class=\"max-w-4xl mx-auto space-y-4\">\n      <BasicInfo\n        :resumeData=\"basicInfo\"\n        :loading=\"loading\"\n        :bioExpanded=\"bioExpanded\"\n        :showBioExpandButton=\"showBioExpandButton\"\n        @edit=\"handleEdit\"\n        @update=\"handleUpdate\"\n        @toggleBioExpand=\"toggleBioExpand\"\n      />\n\n      <ResumeStatus\n        :completion-data=\"completionData\"\n        :profile-data=\"profileData\"\n        :loading=\"loading\"\n      />\n\n      <!-- 所有模块列表 -->\n      <div class=\"space-y-4\">\n        <!-- 激活的模块 -->\n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading || modulesLoading\"\n          @edit=\"handleEditModule\"\n          @remove=\"handleModuleRemove\"\n          @edit-item=\"editItem\"\n          @remove-item=\"removeItem\"\n        />\n\n        <!-- 未激活的模块 -->\n        <div v-for=\"module in inactiveModules\" \n          :key=\"module.type\" \n          class=\"bg-white rounded-lg shadow\"\n        >\n          <div class=\"flex items-center justify-between px-4 py-3\">\n            <h3 class=\"text-base font-medium text-gray-900\">{{ getModuleName(module.type) }}</h3>\n            <button\n              @click=\"handleAddModule(module.type)\"\n              class=\"p-1 hover:bg-gray-100 rounded-full\"\n            >\n              <PlusIcon class=\"w-5 h-5 text-gray-400\" />\n            </button>\n          </div>\n          <div class=\"px-4 pb-4\">\n            <div class=\"text-center text-gray-400 py-4\">\n              暂无内容，点击添加\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 工作经历编辑弹窗 -->\n      <EditWorkExperienceDialog\n        v-if=\"currentModule?.type === 'work_experience'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 求职意向编辑弹窗 -->\n      <EditJobIntentionDialog\n        v-if=\"currentModule?.type === 'job_intention'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <!-- 基本信息编辑弹窗 -->\n      <EditBasicDialog\n        v-if=\"currentModule?.type === 'basic_info'\"\n        v-model=\"showEditModal\"\n        :initial-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n      />\n\n      <AIOptimizeDialog\n        v-model=\"showAIOptimizeDialog\"\n        :profile-data=\"profileData\"\n        @apply=\"handleAIOptimize\"\n      />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, watch, computed } from 'vue'\nimport { useModules } from '@/composables/useModules'\nimport profile from '@/api/profile'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { PlusIcon } from '@heroicons/vue/24/outline'\nimport { ALL_MODULES } from '@/constants'\n\n// 组件引入\nimport BasicInfo from './components/BasicInfo.vue'\nimport ResumeStatus from './components/ResumeStatus.vue'\nimport ModuleList from './components/ModuleList.vue'\nimport AddModule from './components/AddModule.vue'\nimport EditBasicDialog from './dialogs/EditBasicDialog.vue'\nimport EditJobIntentionDialog from './dialogs/EditJobIntentionDialog.vue'\nimport EditWorkExperienceDialog from './dialogs/EditWorkExperienceDialog.vue'\nimport AIOptimizeDialog from './dialogs/AIOptimizeDialog.vue'\n\n// 使用 useModules 组合式函数\nconst { \n  loading: modulesLoading,\n  activeModules,\n  inactiveModules,\n  allModules,\n  coreModules,\n  optionalModules,\n  fetchLayout,\n  removeModule,\n  addModule,\n  updateOrder\n} = useModules()\n\n// 当前编辑的模块\nconst currentModule = ref(null)\n\n// 基本状态\nconst showEditModal = ref(false)\nconst editFormData = ref({})\nconst loading = ref(false)\n\n// 基本信息控制\nconst bioExpanded = ref(false)\nconst showBioExpandButton = ref(false)\n\n// 用户基本信息\nconst userInfo = ref({\n  name: '',\n  username: '',\n  avatar: '',\n  phone: '',\n  email: '',\n  gender: '',\n  birth_date: '',\n  location: '',\n  personal_summary: ''\n})\n\n// 基本信息（用于 BasicInfo 组件）\nconst basicInfo = ref({})\n\n// 档案数据\nconst profileData = ref({\n  basic_info: {\n    name: '',\n    name_en: '',\n    personal_summary: '',\n    personal_summary_en: '',\n    gender: '',\n    phone: '',\n    email: '',\n    location: '',\n    birth_date: ''\n  },\n  job_intention: {\n    job_type: '',\n    job_status: '',\n    expected_salary: '',\n    expected_city: '',\n    industries: ''\n  },\n  work_experiences: [],\n  educations: [],\n  skills: []\n})\n\n// 完整度数据\nconst completionData = ref({\n  total_score: 0,\n  dimensions: {},\n  suggestions: []\n})\n\n// 添加缺失的响应式变量\nconst showAIOptimizeDialog = ref(false)\n\n// 处理 Bio 展开/收起\nconst toggleBioExpand = () => {\n  bioExpanded.value = !bioExpanded.value\n}\n\n// 定义组件的 emits\ndefineEmits([\n  'update:modelValue',\n  'edit',\n  'add',\n  'remove',\n  'edit-item',\n  'remove-item'\n])\n\n// 获取用户数据\nconst fetchUserData = async () => {\n  try {\n    loading.value = true\n    // 重新获取布局\n    await fetchLayout()\n    \n    // 获取基本信息\n    const basicResponse = await profile.getBasicInfo()\n    if (basicResponse.data?.code === 200) {\n      const { user, basic_info } = basicResponse.data.data\n      \n      // 更新用户信息\n      userInfo.value = {\n        ...user,\n        ...basic_info,\n        avatar: basic_info?.avatar || user?.avatar\n      }\n      \n      // 更新基本信息（用于 BasicInfo 组件）\n      basicInfo.value = {\n        ...userInfo.value\n      }\n    }\n\n    // 获取工作经历数据\n    const workResponse = await profile.workExperience.list()\n    if (workResponse.data?.code === 200) {\n      // 更新工作经历模块数据\n      const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n      if (workExperienceModule) {\n        workExperienceModule.data = workResponse.data.data || []\n        console.log('Work Experience Data:', workExperienceModule.data)\n      }\n    }\n\n    // 获取求职意向数据\n    const intentionResponse = await profile.jobIntention.get()\n    if (intentionResponse.data?.code === 200) {\n      const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n      if (jobIntentionModule) {\n        jobIntentionModule.data = intentionResponse.data.data || {}\n      }\n    }\n\n    // 获取完整度数据\n    await fetchCompleteness()\n    \n  } catch (error) {\n    console.error('获取数据失败:', error)\n    ElMessage.error('获取数据失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 获取完整度数据\nconst fetchCompleteness = async () => {\n  try {\n    const response = await profile.getCompleteness()\n    if (response.data?.code === 200) {\n      completionData.value = {\n        total_score: response.data.data.total_score || 0,\n        dimensions: response.data.data.dimensions || {},\n        suggestions: response.data.data.suggestions || []\n      }\n    }\n  } catch (error) {\n    console.error('获取完整度失败:', error)\n  }\n}\n\n// 更新模块数据\nconst updateModules = (data) => {\n  const jobIntentionModule = activeModules.value.find(m => m.type === 'job_intention')\n  if (jobIntentionModule) {\n    jobIntentionModule.data = data.job_intention || {}\n  }\n\n  const workExperienceModule = activeModules.value.find(m => m.type === 'work_experience')\n  if (workExperienceModule) {\n    workExperienceModule.data = data.work_experiences || []\n  }\n}\n\n// 处理数据更新\nconst handleDataUpdate = async () => {\n  await fetchUserData()\n}\n\n// 初始化数据\nonMounted(async () => {\n  try {\n    // 先获取布局\n    await fetchLayout()\n    // 再获取其他数据\n    await fetchUserData()\n  } catch (error) {\n    console.error('初始化数据失败:', error)\n    ElMessage.error('初始化数据失败，请刷新页面重试')\n  }\n})\n\n// 处理编辑基本信息\nconst handleEdit = () => {\n  currentModule.value = {\n    type: 'basic_info',\n    data: basicInfo.value\n  }\n  editFormData.value = { ...currentModule.value.data }\n  showEditModal.value = true\n}\n\n// 编辑具体项目（用于工作经历）\nconst editItem = (moduleId, item) => {\n  currentModule.value = activeModules.value.find(m => m.id === moduleId)\n  editFormData.value = { ...item }\n  showEditModal.value = true\n}\n\n// 删除工作经历\nconst removeItem = async (moduleId, itemId) => {\n  try {\n    await ElMessageBox.confirm('确定要删除这条记录吗？', '提示', {\n      type: 'warning'\n    })\n    \n    if (moduleId === 'work_experience') {\n      await profile.deleteWorkExperience(itemId)\n      ElMessage.success('删除成功')\n      await fetchUserData()\n    }\n  } catch (error) {\n    if (error !== 'cancel') {\n      console.error('删除失败:', error)\n      ElMessage.error('删除失败')\n    }\n  }\n}\n\n// 提交表单\nconst handleSubmit = async (data) => {\n  try {\n    loading.value = true\n    \n    if (currentModule.value?.type === 'basic_info') {\n      // 基本信息保存\n      const response = await profile.updateBasicInfo(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchUserData()\n      } else {\n        throw new Error(response.data?.message || '保存失败')\n      }\n    } else if (currentModule.value?.type === 'work_experience') {\n      if (data.id) {\n        // 更新工作经历\n        const response = await profile.workExperience.update(data.id, data)\n        if (response.data?.code === 200) {\n          ElMessage.success('更新成功')\n          showEditModal.value = false\n          await fetchUserData()\n        } else {\n          throw new Error(response.data?.message || '更新失败')\n        }\n      } else {\n        // 添加工作经历\n        const response = await profile.workExperience.add(data)\n        if (response.data?.code === 200) {\n          ElMessage.success('添加成功')\n          showEditModal.value = false\n          await fetchUserData()\n        }\n      }\n    } else if (currentModule.value?.type === 'job_intention') {\n      const response = await profile.jobIntention.update(data)\n      if (response.data?.code === 200) {\n        ElMessage.success('保存成功')\n        showEditModal.value = false\n        await fetchUserData()\n      }\n    }\n  } catch (error) {\n    console.error('保存失败:', error)\n    ElMessage.error(error.message || '保存失败，请稍后重试')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 处理编辑模块\nconst handleEditModule = (moduleId) => {\n  currentModule.value = activeModules.value.find(m => m.type === moduleId)\n  \n  if (currentModule.value?.type === 'work_experience') {\n    editFormData.value = {}\n  } else if (currentModule.value?.type === 'job_intention') {\n    editFormData.value = { ...currentModule.value.data }\n  }\n  \n  showEditModal.value = true\n}\n\n// 处理 AI 优化结果\nconst handleAIOptimize = (optimizedData) => {\n  Object.entries(optimizedData).forEach(([key, value]) => {\n    const [category, field] = key.split('.')\n    if (category && field) {\n      if (!profileData.value[category]) {\n        profileData.value[category] = {}\n      }\n      profileData.value[category][field] = value\n    } else {\n      profileData.value[key] = value\n    }\n  })\n}\n\n// 添加更新处理方法\nconst handleUpdate = async () => {\n  await fetchUserData()\n}\n\n// 处理模块移除\nconst handleModuleRemove = async (moduleId) => {\n  try {\n    await removeModule(moduleId)\n    // 移除成功后重新获取所有数据\n    await fetchUserData()\n  } catch (error) {\n    console.error('移除模块失败:', error)\n  }\n}\n\n// 处理添加模块\nconst handleAddModule = async (moduleType) => {\n  try {\n    await addModule(moduleType)\n    // 添加成功后重新获取所有数据\n    await fetchUserData()\n  } catch (error) {\n    console.error('添加模块失败:', error)\n  }\n}\n\n// 获取模块显示名称\nconst getModuleName = (type) => {\n  return ALL_MODULES[type] || type\n}\n\n// 计算未激活的模块\nconst inactiveModules = computed(() => {\n  const activeTypes = activeModules.value.map(m => m.type)\n  return Object.entries(allModules.value)\n    .filter(([type, config]) => !config.visible)\n    .map(([type]) => ({\n      type,\n      name: ALL_MODULES[type]\n    }))\n})\n</script>"],"mappings":";;EAEOA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;EAkBjCA,KAAK,EAAC;AAAW;;EAgBbA,KAAK,EAAC;AAA6C;;EAClDA,KAAK,EAAC;AAAqC;mBAtC3D;;;;;;;;;;uBAEEC,mBAAA,CAqFM,OArFNC,UAqFM,GApFJC,mBAAA,CAmFM,OAnFNC,UAmFM,GAlFJC,YAAA,CAQEC,oBAAA;IAPCC,UAAU,EAAEC,IAAA,CAAAC,SAAS;IACrBC,OAAO,EAAEF,IAAA,CAAAE,OAAO;IAChBC,WAAW,EAAEH,IAAA,CAAAG,WAAW;IACxBC,mBAAmB,EAAEJ,IAAA,CAAAI,mBAAmB;IACxCC,MAAI,EAAEL,IAAA,CAAAM,UAAU;IAChBC,QAAM,EAAEP,IAAA,CAAAQ,YAAY;IACpBC,iBAAe,EAAET,IAAA,CAAAU;uIAGpBb,YAAA,CAIEc,uBAAA;IAHC,iBAAe,EAAEX,IAAA,CAAAY,cAAc;IAC/B,cAAY,EAAEZ,IAAA,CAAAa,WAAW;IACzBX,OAAO,EAAEF,IAAA,CAAAE;2EAGZY,mBAAA,YAAe,EACfnB,mBAAA,CA+BM,OA/BNoB,UA+BM,GA9BJD,mBAAA,WAAc,EACdjB,YAAA,CAOEmB,qBAAA;IANC,gBAAc,EAAEhB,IAAA,CAAAiB,aAAa;IAC7Bf,OAAO,EAAEF,IAAA,CAAAE,OAAO,IAAIF,IAAA,CAAAkB,cAAc;IAClCb,MAAI,EAAEL,IAAA,CAAAmB,gBAAgB;IACtBC,QAAM,EAAEpB,IAAA,CAAAqB,kBAAkB;IAC1BC,UAAS,EAAEtB,IAAA,CAAAuB,QAAQ;IACnBC,YAAW,EAAExB,IAAA,CAAAyB;8GAGhBX,mBAAA,YAAe,G,kBACfrB,mBAAA,CAkBMiC,SAAA,QAnDdC,WAAA,CAiC8B3B,IAAA,CAAA4B,eAAe,EAAzBC,MAAM;yBAAlBpC,mBAAA,CAkBM;MAjBHqC,GAAG,EAAED,MAAM,CAACE,IAAI;MACjBvC,KAAK,EAAC;QAENG,mBAAA,CAQM,OARNqC,UAQM,GAPJrC,mBAAA,CAAqF,MAArFsC,UAAqF,EAAAC,gBAAA,CAAlClC,IAAA,CAAAmC,aAAa,CAACN,MAAM,CAACE,IAAI,mBAC5EpC,mBAAA,CA