{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.reduce.js\";\nimport { computed } from 'vue';\nimport { SparklesIcon, ArrowDownTrayIcon, EyeIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'ResumeStatus',\n  props: {\n    completionData: {\n      type: Object,\n      required: true,\n      default: () => ({\n        total_score: 0,\n        dimensions: {},\n        suggestions: []\n      })\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['ai-optimize', 'import', 'preview'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 总分 - 保留一位小数\n    const totalScore = computed(() => {\n      console.log('计算总分，原始数据:', props.completionData);\n      const score = props.completionData?.total_score || 0;\n      const formattedScore = Number(score.toFixed(1));\n      console.log('格式化后的总分:', formattedScore);\n      return formattedScore;\n    });\n\n    // 维度数据 - 保留整数\n    const dimensions = computed(() => {\n      console.log('计算维度数据，原始数据:', props.completionData?.dimensions);\n      const dims = props.completionData?.dimensions || {};\n      const formattedDims = Object.entries(dims).reduce((acc, [key, value]) => {\n        acc[key] = _objectSpread(_objectSpread({}, value), {}, {\n          score: Math.round(value.score || 0)\n        });\n        return acc;\n      }, {});\n      console.log('格式化后的维度数据:', formattedDims);\n      return formattedDims;\n    });\n\n    // 建议\n    const suggestions = computed(() => {\n      console.log('获取建议数据:', props.completionData?.suggestions);\n      return props.completionData?.suggestions || [];\n    });\n\n    // 维度名称映射\n    const getDimensionName = key => {\n      const nameMap = {\n        basic_info: '基本信息',\n        experience: '工作经历',\n        capability: '能力素质',\n        achievement: '个人成就'\n      };\n      return nameMap[key] || key;\n    };\n\n    // 进度条颜色\n    const progressColorClass = computed(() => {\n      const score = totalScore.value;\n      if (score >= 80) return 'bg-green-500';\n      if (score >= 50) return 'bg-yellow-500';\n      return 'bg-red-500';\n    });\n\n    // 文字颜色\n    const progressTextColorClass = computed(() => {\n      const score = totalScore.value;\n      if (score >= 80) return 'text-green-600';\n      if (score >= 50) return 'text-yellow-600';\n      return 'text-red-600';\n    });\n    const __returned__ = {\n      props,\n      totalScore,\n      dimensions,\n      suggestions,\n      getDimensionName,\n      progressColorClass,\n      progressTextColorClass,\n      computed,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get ArrowDownTrayIcon() {\n        return ArrowDownTrayIcon;\n      },\n      get EyeIcon() {\n        return EyeIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","SparklesIcon","ArrowDownTrayIcon","EyeIcon","props","__props","totalScore","console","log","completionData","score","total_score","formattedScore","Number","toFixed","dimensions","dims","formattedDims","Object","entries","reduce","acc","key","value","_objectSpread","Math","round","suggestions","getDimensionName","nameMap","basic_info","experience","capability","achievement","progressColorClass","progressTextColorClass"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/components/ResumeStatus.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/ResumeStatus.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <div class=\"p-4\">\n        <!-- 标题和百分比 -->\n        <div class=\"flex items-center justify-between mb-4\">\n          <h3 class=\"text-base font-medium text-gray-900\">简历完整度</h3>\n          <span class=\"text-lg font-semibold\" :class=\"progressTextColorClass\">\n            {{ completionRate }}%\n          </span>\n        </div>\n  \n        <!-- 进度条 -->\n        <div class=\"bg-gray-200 rounded-full h-2.5 mb-4\">\n          <div \n            class=\"h-2.5 rounded-full transition-all duration-500\"\n            :class=\"progressColorClass\"\n            :style=\"{ width: `${completionRate}%` }\"\n          ></div>\n        </div>\n  \n        <!-- 操作按钮 -->\n        <div class=\"grid grid-cols-3 gap-3\">\n          <button\n            @click=\"$emit('ai-optimize')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 transition-all duration-200 shadow-sm\"\n          >\n            <SparklesIcon class=\"w-4 h-4 mr-1.5\" />\n            AI优化\n          </button>\n  \n          <button\n            @click=\"$emit('import')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <ArrowDownTrayIcon class=\"w-4 h-4 mr-1.5\" />\n            导入简历\n          </button>\n  \n          <button\n            @click=\"$emit('preview')\"\n            class=\"flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 transition-all duration-200\"\n          >\n            <EyeIcon class=\"w-4 h-4 mr-1.5\" />\n            预览简历\n          </button>\n        </div>\n      </div>\n    </div>\n  </template>\n  \n  <script setup>\n  import { computed } from 'vue'\n  import { \n    SparklesIcon,\n    ArrowDownTrayIcon,\n    EyeIcon \n  } from '@heroicons/vue/24/outline'\n  \n  const props = defineProps({\n    completionData: {\n      type: Object,\n      required: true,\n      default: () => ({\n        total_score: 0,\n        dimensions: {},\n        suggestions: []\n      })\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  })\n  \n  defineEmits(['ai-optimize', 'import', 'preview'])\n  \n  // 总分 - 保留一位小数\n  const totalScore = computed(() => {\n    console.log('计算总分，原始数据:', props.completionData)\n    const score = props.completionData?.total_score || 0\n    const formattedScore = Number(score.toFixed(1))\n    console.log('格式化后的总分:', formattedScore)\n    return formattedScore\n  })\n  \n  // 维度数据 - 保留整数\n  const dimensions = computed(() => {\n    console.log('计算维度数据，原始数据:', props.completionData?.dimensions)\n    const dims = props.completionData?.dimensions || {}\n    const formattedDims = Object.entries(dims).reduce((acc, [key, value]) => {\n      acc[key] = {\n        ...value,\n        score: Math.round(value.score || 0)\n      }\n      return acc\n    }, {})\n    console.log('格式化后的维度数据:', formattedDims)\n    return formattedDims\n  })\n  \n  // 建议\n  const suggestions = computed(() => {\n    console.log('获取建议数据:', props.completionData?.suggestions)\n    return props.completionData?.suggestions || []\n  })\n  \n  // 维度名称映射\n  const getDimensionName = (key) => {\n    const nameMap = {\n      basic_info: '基本信息',\n      experience: '工作经历',\n      capability: '能力素质',\n      achievement: '个人成就'\n    }\n    return nameMap[key] || key\n  }\n  \n  // 进度条颜色\n  const progressColorClass = computed(() => {\n    const score = totalScore.value\n    if (score >= 80) return 'bg-green-500'\n    if (score >= 50) return 'bg-yellow-500'\n    return 'bg-red-500'\n  })\n  \n  // 文字颜色\n  const progressTextColorClass = computed(() => {\n    const score = totalScore.value\n    if (score >= 80) return 'text-green-600'\n    if (score >= 50) return 'text-yellow-600'\n    return 'text-red-600'\n  })\n  </script>\n\n<style scoped>\n/* 添加按钮悬停效果 */\nbutton {\n  position: relative;\n  overflow: hidden;\n}\n\nbutton::after {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 100%;\n  height: 100%;\n  background-color: rgba(255, 255, 255, 0.1);\n  transform: translate(-50%, -50%) scale(0);\n  border-radius: inherit;\n  transition: transform 0.3s ease;\n}\n\nbutton:hover::after {\n  transform: translate(-50%, -50%) scale(1.5);\n}\n\n/* 渐变进度条效果 */\n.bg-green-500 {\n  background: linear-gradient(90deg, #10B981 0%, #34D399 100%);\n}\n\n.bg-yellow-500 {\n  background: linear-gradient(90deg, #F59E0B 0%, #FBBF24 100%);\n}\n\n.bg-red-500 {\n  background: linear-gradient(90deg, #EF4444 0%, #F87171 100%);\n}\n</style>"],"mappings":";;;AAoDE,SAASA,QAAQ,QAAQ,KAAI;AAC7B,SACEC,YAAY,EACZC,iBAAiB,EACjBC,OAAO,QACF,2BAA0B;;;;;;;;;;;;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;;IAkBd;IACA,MAAMC,UAAU,GAAGN,QAAQ,CAAC,MAAM;MAChCO,OAAO,CAACC,GAAG,CAAC,YAAY,EAAEJ,KAAK,CAACK,cAAc;MAC9C,MAAMC,KAAK,GAAGN,KAAK,CAACK,cAAc,EAAEE,WAAW,IAAI;MACnD,MAAMC,cAAc,GAAGC,MAAM,CAACH,KAAK,CAACI,OAAO,CAAC,CAAC,CAAC;MAC9CP,OAAO,CAACC,GAAG,CAAC,UAAU,EAAEI,cAAc;MACtC,OAAOA,cAAa;IACtB,CAAC;;IAED;IACA,MAAMG,UAAU,GAAGf,QAAQ,CAAC,MAAM;MAChCO,OAAO,CAACC,GAAG,CAAC,cAAc,EAAEJ,KAAK,CAACK,cAAc,EAAEM,UAAU;MAC5D,MAAMC,IAAI,GAAGZ,KAAK,CAACK,cAAc,EAAEM,UAAU,IAAI,CAAC;MAClD,MAAME,aAAa,GAAGC,MAAM,CAACC,OAAO,CAACH,IAAI,CAAC,CAACI,MAAM,CAAC,CAACC,GAAG,EAAE,CAACC,GAAG,EAAEC,KAAK,CAAC,KAAK;QACvEF,GAAG,CAACC,GAAG,CAAC,GAAAE,aAAA,CAAAA,aAAA,KACHD,KAAK;UACRb,KAAK,EAAEe,IAAI,CAACC,KAAK,CAACH,KAAK,CAACb,KAAK,IAAI,CAAC;QAAA,EACpC;QACA,OAAOW,GAAE;MACX,CAAC,EAAE,CAAC,CAAC;MACLd,OAAO,CAACC,GAAG,CAAC,YAAY,EAAES,aAAa;MACvC,OAAOA,aAAY;IACrB,CAAC;;IAED;IACA,MAAMU,WAAW,GAAG3B,QAAQ,CAAC,MAAM;MACjCO,OAAO,CAACC,GAAG,CAAC,SAAS,EAAEJ,KAAK,CAACK,cAAc,EAAEkB,WAAW;MACxD,OAAOvB,KAAK,CAACK,cAAc,EAAEkB,WAAW,IAAI,EAAC;IAC/C,CAAC;;IAED;IACA,MAAMC,gBAAgB,GAAIN,GAAG,IAAK;MAChC,MAAMO,OAAO,GAAG;QACdC,UAAU,EAAE,MAAM;QAClBC,UAAU,EAAE,MAAM;QAClBC,UAAU,EAAE,MAAM;QAClBC,WAAW,EAAE;MACf;MACA,OAAOJ,OAAO,CAACP,GAAG,CAAC,IAAIA,GAAE;IAC3B;;IAEA;IACA,MAAMY,k