{"ast":null,"code":"import { ref, computed, watch } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue';\nimport { CheckIcon, ChevronUpDownIcon } from '@heroicons/vue/20/solid';\n\n// 性别选项\n\nexport default {\n  __name: 'EditBasicDialog',\n  props: {\n    modelValue: {\n      type: Boolean,\n      default: false\n    },\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const genderOptions = [{\n      label: '男',\n      value: 'male'\n    }, {\n      label: '女',\n      value: 'female'\n    }, {\n      label: '其他',\n      value: 'other'\n    }];\n    const {\n      width\n    } = useWindowSize();\n\n    // 判断是否为移动端\n    const isMobile = computed(() => width.value < 640);\n\n    // 根据屏幕宽度设置弹窗宽度\n    const dialogWidth = computed(() => {\n      if (width.value < 640) return '94%';\n      if (width.value < 1024) return '80%';\n      return '640px';\n    });\n    const props = __props;\n    const emit = __emit;\n    const form = ref({\n      name: '',\n      gender: '',\n      phone: '',\n      email: '',\n      location: '',\n      birth_date: '',\n      personal_summary: ''\n    });\n\n    // 监听初始数据变化\n    watch(() => props.initialData, newVal => {\n      if (newVal) {\n        // 确保所有字段都有值\n        form.value = {\n          name: newVal.name || '',\n          gender: newVal.gender || '',\n          phone: newVal.phone || '',\n          email: newVal.email || '',\n          location: newVal.location || '',\n          birth_date: newVal.birth_date || '',\n          personal_summary: newVal.personal_summary || ''\n        };\n        console.log('Form data updated:', form.value); // 添加调试日志\n      }\n    }, {\n      immediate: true,\n      deep: true\n    });\n\n    // 添加调试日志\n    watch(form, newVal => {\n      console.log('Form changed:', newVal);\n    }, {\n      deep: true\n    });\n    const handleSubmit = () => {\n      emit('submit', form.value);\n    };\n    const handleClose = () => {\n      emit('update:modelValue', false);\n    };\n    const __returned__ = {\n      genderOptions,\n      width,\n      isMobile,\n      dialogWidth,\n      props,\n      emit,\n      form,\n      handleSubmit,\n      handleClose,\n      ref,\n      computed,\n      watch,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      },\n      get CheckIcon() {\n        return CheckIcon;\n      },\n      get ChevronUpDownIcon() {\n        return ChevronUpDownIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","useWindowSize","Listbox","ListboxButton","ListboxOptions","ListboxOption","CheckIcon","ChevronUpDownIcon","genderOptions","label","value","width","isMobile","dialogWidth","props","__props","emit","__emit","form","name","gender","phone","email","location","birth_date","personal_summary","initialData","newVal","console","log","immediate","deep","handleSubmit","handleClose"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/EditBasicDialog.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/dialogs/EditBasicDialog.vue -->\n<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    @update:model-value=\"$emit('update:modelValue', $event)\"\n    :width=\"dialogWidth\"\n    :close-on-click-modal=\"false\"\n    @close=\"handleClose\"\n    class=\"relative\"\n  >\n    <!-- Header -->\n    <template #header>\n      <div class=\"border-b border-gray-200 px-6 py-5\">\n        <h3 class=\"text-lg font-medium text-gray-900\">编辑基本信息</h3>\n      </div>\n    </template>\n\n    <!-- Body -->\n    <div class=\"px-6 py-5\">\n      <form @submit.prevent=\"handleSubmit\" class=\"space-y-5\">\n        <!-- 两列布局 -->\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n          <!-- 姓名输入框 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">姓名</label>\n            <div class=\"relative\">\n              <input\n                v-model=\"form.name\"\n                type=\"text\"\n                placeholder=\"请输入姓名\"\n                class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n              />\n            </div>\n          </div>\n\n          <!-- 性别 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">性别</label>\n            <Listbox v-model=\"form.gender\">\n              <div class=\"relative\">\n                <ListboxButton class=\"relative w-full cursor-default rounded-md border border-gray-300 bg-gray-50 py-2 pl-3 pr-10 text-left shadow-sm focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900/10 sm:text-sm\">\n                  <span class=\"block truncate\">\n                    {{ genderOptions.find(item => item.value === form.gender)?.label || '请选择性别' }}\n                  </span>\n                  <span class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2\">\n                    <ChevronUpDownIcon class=\"h-5 w-5 text-gray-400\" aria-hidden=\"true\" />\n                  </span>\n                </ListboxButton>\n\n                <ListboxOptions class=\"absolute z-10 mt-1 max-h-60 w-full overflow-auto rounded-md bg-white py-1 text-base shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none sm:text-sm\">\n                  <ListboxOption\n                    v-for=\"option in genderOptions\"\n                    :key=\"option.value\"\n                    :value=\"option.value\"\n                    v-slot=\"{ active, selected }\"\n                  >\n                    <li :class=\"[active ? 'bg-gray-100 text-gray-900' : 'text-gray-700', 'relative cursor-default select-none py-2 pl-3 pr-9']\">\n                      <span :class=\"[selected ? 'font-semibold' : 'font-normal', 'block truncate']\">\n                        {{ option.label }}\n                      </span>\n                      <span v-if=\"selected\" :class=\"[active ? 'text-gray-900' : 'text-gray-700', 'absolute inset-y-0 right-0 flex items-center pr-4']\">\n                        <CheckIcon class=\"h-5 w-5\" aria-hidden=\"true\" />\n                      </span>\n                    </li>\n                  </ListboxOption>\n                </ListboxOptions>\n              </div>\n            </Listbox>\n          </div>\n\n          <!-- 手机号码 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">手机号码</label>\n            <input\n              v-model=\"form.phone\"\n              type=\"tel\"\n              placeholder=\"请输入手机号码\"\n              class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n            />\n          </div>\n\n          <!-- 邮箱 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">邮箱</label>\n            <input\n              v-model=\"form.email\"\n              type=\"email\"\n              placeholder=\"请输入邮箱\"\n              class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n            />\n          </div>\n\n          <!-- 所在地 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">所在地</label>\n            <input\n              v-model=\"form.location\"\n              type=\"text\"\n              placeholder=\"请输入所在地\"\n              class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n            />\n          </div>\n\n          <!-- 生日 -->\n          <div class=\"space-y-2\">\n            <label class=\"block text-sm font-medium text-gray-700\">生日</label>\n            <input\n              v-model=\"form.birth_date\"\n              type=\"date\"\n              placeholder=\"请选择生日\"\n              class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n            />\n          </div>\n        </div>\n\n        <!-- 个人简介 -->\n        <div class=\"space-y-2\">\n          <label class=\"block text-sm font-medium text-gray-700\">个人简介</label>\n          <textarea\n            v-model=\"form.personal_summary\"\n            :rows=\"isMobile ? 3 : 4\"\n            placeholder=\"请简要介绍一下自己...\"\n            class=\"block w-full rounded-md border-gray-300 bg-gray-50 py-2 px-3 shadow-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900/10 sm:text-sm\"\n          ></textarea>\n        </div>\n      </form>\n    </div>\n\n    <!-- Footer -->\n    <template #footer>\n      <div class=\"border-t border-gray-200 px-6 py-4\">\n        <div class=\"flex justify-end space-x-3\">\n          <button\n            type=\"button\"\n            @click=\"handleClose\"\n            class=\"rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-900/10\"\n          >\n            取消\n          </button>\n          <button\n            type=\"button\"\n            @click=\"handleSubmit\"\n            :disabled=\"loading\"\n            class=\"rounded-md border border-transparent bg-gray-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/10 disabled:opacity-50\"\n          >\n            {{ loading ? '保存中...' : '保存' }}\n          </button>\n        </div>\n      </div>\n    </template>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, watch } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { Listbox, ListboxButton, ListboxOptions, ListboxOption } from '@headlessui/vue'\nimport { CheckIcon, ChevronUpDownIcon } from '@heroicons/vue/20/solid'\n\n// 性别选项\nconst genderOptions = [\n  { label: '男', value: 'male' },\n  { label: '女', value: 'female' },\n  { label: '其他', value: 'other' }\n]\n\nconst { width } = useWindowSize()\n\n// 判断是否为移动端\nconst isMobile = computed(() => width.value < 640)\n\n// 根据屏幕宽度设置弹窗宽度\nconst dialogWidth = computed(() => {\n  if (width.value < 640) return '94%'\n  if (width.value < 1024) return '80%'\n  return '640px'\n})\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    default: false\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst form = ref({\n  name: '',\n  gender: '',\n  phone: '',\n  email: '',\n  location: '',\n  birth_date: '',\n  personal_summary: ''\n})\n\n// 监听初始数据变化\nwatch(\n  () => props.initialData,\n  (newVal) => {\n    if (newVal) {\n      // 确保所有字段都有值\n      form.value = {\n        name: newVal.name || '',\n        gender: newVal.gender || '',\n        phone: newVal.phone || '',\n        email: newVal.email || '',\n        location: newVal.location || '',\n        birth_date: newVal.birth_date || '',\n        personal_summary: newVal.personal_summary || ''\n      }\n      console.log('Form data updated:', form.value) // 添加调试日志\n    }\n  },\n  { immediate: true, deep: true }\n)\n\n// 添加调试日志\nwatch(form, (newVal) => {\n  console.log('Form changed:', newVal)\n}, { deep: true })\n\nconst handleSubmit = () => {\n  emit('submit', form.value)\n}\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n</script>"],"mappings":"AA0JA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,QAAQ,KAAI;AACzC,SAASC,aAAa,QAAQ,cAAa;AAC3C,SAASC,OAAO,EAAEC,aAAa,EAAEC,cAAc,EAAEC,aAAa,QAAQ,iBAAgB;AACtF,SAASC,SAAS,EAAEC,iBAAiB,QAAQ,yBAAwB;;AAErE;;;;;;;;;;;;;;;;;;;;;;;;IACA,MAAMC,aAAa,GAAG,CACpB;MAAEC,KAAK,EAAE,GAAG;MAAEC,KAAK,EAAE;IAAO,CAAC,EAC7B;MAAED,KAAK,EAAE,GAAG;MAAEC,KAAK,EAAE;IAAS,CAAC,EAC/B;MAAED,KAAK,EAAE,IAAI;MAAEC,KAAK,EAAE;IAAQ,EAChC;IAEA,MAAM;MAAEC;IAAM,CAAC,GAAGV,aAAa,CAAC;;IAEhC;IACA,MAAMW,QAAQ,GAAGb,QAAQ,CAAC,MAAMY,KAAK,CAACD,KAAK,GAAG,GAAG;;IAEjD;IACA,MAAMG,WAAW,GAAGd,QAAQ,CAAC,MAAM;MACjC,IAAIY,KAAK,CAACD,KAAK,GAAG,GAAG,EAAE,OAAO,KAAI;MAClC,IAAIC,KAAK,CAACD,KAAK,GAAG,IAAI,EAAE,OAAO,KAAI;MACnC,OAAO,OAAM;IACf,CAAC;IAED,MAAMI,KAAK,GAAGC,OAAA;IAed,MAAMC,IAAI,GAAGC,MAAA;IAEb,MAAMC,IAAI,GAAGpB,GAAG,CAAC;MACfqB,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,gBAAgB,EAAE;IACpB,CAAC;;IAED;IACAzB,KAAK,CACH,MAAMc,KAAK,CAACY,WAAW,EACtBC,MAAM,IAAK;MACV,IAAIA,MAAM,EAAE;QACV;QACAT,IAAI,CAACR,KAAK,GAAG;UACXS,IAAI,EAAEQ,MAAM,CAACR,IAAI,IAAI,EAAE;UACvBC,MAAM,EAAEO,MAAM,CAACP,MAAM,IAAI,EAAE;UAC3BC,KAAK,EAAEM,MAAM,CAACN,KAAK,IAAI,EAAE;UACzBC,KAAK,EAAEK,MAAM,CAACL,KAAK,IAAI,EAAE;UACzBC,QAAQ,EAAEI,MAAM,CAACJ,QAAQ,IAAI,EAAE;UAC/BC,UAAU,EAAEG,MAAM,CAACH,UAAU,IAAI,EAAE;UACnCC,gBAAgB,EAAEE,MAAM,CAACF,gBAAgB,IAAI;QAC/C;QACAG,OAAO,CAACC,GAAG,CAAC,oBAAoB,EAAEX,IAAI,CAACR,KAAK,CAAC,EAAC;MAChD;IACF,CAAC,EACD;MAAEoB,SAAS,EAAE,IAAI;MAAEC,IAAI,EAAE;IAAK,CAChC;;IAEA;IACA/B,KAAK,CAACkB,IAAI,EAAGS,MAAM,IAAK;MACtBC,OAAO,CAACC,GAAG,CAAC,eAAe,EAAEF,MAAM;IACrC,CAAC,EAAE;MAAEI,IAAI,EAAE;I