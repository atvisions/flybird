{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.find.js\";\nimport { ref } from 'vue';\nimport { Dialog, DialogPanel, DialogTitle, Listbox, ListboxButton, ListboxOptions, ListboxOption, TransitionRoot, TransitionChild } from '@headlessui/vue';\nimport { XMarkIcon, ChevronUpDownIcon, CheckIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'EditJobIntentionDialog',\n  props: {\n    modelValue: Boolean,\n    initialData: {\n      type: Object,\n      default: () => ({})\n    },\n    loading: Boolean\n  },\n  emits: ['update:modelValue', 'submit'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n    const isOpen = ref(false);\n    const form = ref({\n      job_type: props.initialData?.job_type || ''\n      // ... 其他字段\n    });\n    const handleClose = () => {\n      emit('update:modelValue', false);\n    };\n    const handleSubmit = () => {\n      emit('submit', form.value);\n    };\n    const getJobTypeLabel = value => {\n      const option = JOB_TYPE_OPTIONS.find(opt => opt.value === value);\n      return option ? option.label : '请选择工作类型';\n    };\n    const __returned__ = {\n      props,\n      emit,\n      isOpen,\n      form,\n      handleClose,\n      handleSubmit,\n      getJobTypeLabel,\n      ref,\n      get Dialog() {\n        return Dialog;\n      },\n      get DialogPanel() {\n        return DialogPanel;\n      },\n      get DialogTitle() {\n        return DialogTitle;\n      },\n      get Listbox() {\n        return Listbox;\n      },\n      get ListboxButton() {\n        return ListboxButton;\n      },\n      get ListboxOptions() {\n        return ListboxOptions;\n      },\n      get ListboxOption() {\n        return ListboxOption;\n      },\n      get TransitionRoot() {\n        return TransitionRoot;\n      },\n      get TransitionChild() {\n        return TransitionChild;