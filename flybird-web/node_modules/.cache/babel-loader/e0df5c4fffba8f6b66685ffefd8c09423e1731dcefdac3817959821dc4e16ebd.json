{"ast":null,"code":"import _objectSpread from \"/Users/liuzhao/Documents/Projects/flybird/flybird-web/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.for-each.js\";\nimport \"core-js/modules/esnext.iterator.some.js\";\nimport { ref, computed, onMounted } from 'vue';\nimport { useWindowSize } from '@vueuse/core';\nimport { XMarkIcon, CheckCircleIcon, XCircleIcon, MinusCircleIcon } from '@heroicons/vue/24/solid';\nexport default {\n  __name: 'AIOptimizeDialog',\n  props: {\n    modelValue: Boolean,\n    profileData: {\n      type: Object,\n      required: true\n    }\n  },\n  emits: ['update:modelValue', 'apply'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 字段配置\n    const fieldConfig = [{\n      name: 'name',\n      label: '姓名'\n    }, {\n      name: 'name_en',\n      label: '英文姓名'\n    }, {\n      name: 'personal_summary',\n      label: '个人简介'\n    }, {\n      name: 'personal_summary_en',\n      label: '英文简介'\n    }\n    // ... 其他字段配置\n    ];\n\n    // 处理字段数据\n    const fields = ref(fieldConfig.map(field => _objectSpread(_objectSpread({}, field), {}, {\n      currentValue: props.profileData[field.name] || '',\n      optimizedValue: '',\n      status: 'pending' // pending, processing, success, failed\n    })));\n\n    // 计算属性\n    const displayFields = computed(() => {\n      return fields.value.sort((a, b) => {\n        if (a.status === 'pending' && b.status !== 'pending') return 1;\n        if (a.status !== 'pending' && b.status === 'pending') return -1;\n        return 0;\n      });\n    });\n    const completedCount = computed(() => fields.value.filter(f => ['success', 'failed'].includes(f.status)).length);\n    const totalFields = computed(() => fields.value.length);\n    const hasOptimized = computed(() => fields.value.some(f => f.status === 'success'));\n\n    // 模拟优化过程\n    const startOptimize = async () => {\n      for (const field of fields.value) {\n        if (!field.currentValue) continue;\n        field.status = 'processing';\n        try {\n          // 这里替换为实际的 AI 优化 API 调用\n          await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 2000));\n          field.optimizedValue = `优化后的 ${field.currentValue}`;\n          field.status = 'success';\n        } catch (error) {\n          field.status = 'failed';\n        }\n      }\n    };\n\n    // 对话框控制\n    const dialogVisible = computed({\n      get: () => props.modelValue,\n      set: value => emit('update:modelValue', value)\n    });\n\n    // 响应式布局\n    const {\n      width\n    } = useWindowSize();\n    const isMobile = computed(() => width.value < 640);\n    const dialogWidth = computed(() => {\n      if (isMobile.value) return '100%';\n      return '900px';\n    });\n\n    // 处理关闭\n    const handleClose = () => {\n      dialogVisible.value = false;\n    };\n\n    // 处理应用优化\n    const handleApply = () => {\n      const optimizedData = {};\n      fields.value.forEach(field => {\n        if (field.status === 'success') {\n          optimizedData[field.name] = field.optimizedValue;\n        }\n      });\n      emit('apply', optimizedData);\n      handleClose();\n    };\n\n    // 开始优化\n    onMounted(() => {\n      startOptimize();\n    });\n    const __returned__ = {\n      props,\n      emit,\n      fieldConfig,\n      fields,\n      displayFields,\n      completedCount,\n      totalFields,\n      hasOptimized,\n      startOptimize,\n      dialogVisible,\n      width,\n      isMobile,\n      dialogWidth,\n      handleClose,\n      handleApply,\n      ref,\n      computed,\n      onMounted,\n      get useWindowSize() {\n        return useWindowSize;\n      },\n      get XMarkIcon() {\n        return XMarkIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      },\n      get XCircleIcon() {\n        return XCircleIcon;\n      },\n      get MinusCircleIcon() {\n        return MinusCircleIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","useWindowSize","XMarkIcon","CheckCircleIcon","XCircleIcon","MinusCircleIcon","props","__props","emit","__emit","fieldConfig","name","label","fields","map","field","_objectSpread","currentValue","profileData","optimizedValue","status","displayFields","value","sort","a","b","completedCount","filter","f","includes","length","totalFields","hasOptimized","some","startOptimize","Promise","resolve","setTimeout","Math","random","error","dialogVisible","get","modelValue","set","width","isMobile","dialogWidth","handleClose","handleApply","optimizedData","forEach"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/dialogs/AIOptimizeDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    v-model=\"dialogVisible\"\n    :width=\"dialogWidth\"\n    :fullscreen=\"isMobile\"\n    :close-on-click-modal=\"false\"\n    :show-close=\"false\"\n    class=\"optimize-dialog\"\n    destroy-on-close\n  >\n    <div class=\"dialog-container\">\n      <!-- 头部 -->\n      <div class=\"dialog-header\">\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-3\">\n            <h3 class=\"text-lg font-medium text-gray-900\">AI 优化</h3>\n            <div class=\"flex items-center space-x-1 text-sm text-gray-500\">\n              <span>已完成</span>\n              <span class=\"font-medium text-blue-600\">{{ completedCount }}</span>\n              <span>/</span>\n              <span>{{ totalFields }}</span>\n            </div>\n          </div>\n          <button\n            @click=\"handleClose\"\n            class=\"text-gray-400 hover:text-gray-500\"\n          >\n            <XMarkIcon class=\"h-6 w-6\" />\n          </button>\n        </div>\n      </div>\n\n      <!-- 内容区域 -->\n      <div class=\"dialog-body\">\n        <div class=\"relative overflow-x-auto\">\n          <table class=\"w-full text-sm text-left\">\n            <thead class=\"text-xs text-gray-700 uppercase bg-gray-50 sticky top-0 z-10\">\n              <tr>\n                <th class=\"px-4 py-3 w-40\">字段名称</th>\n                <th class=\"px-4 py-3\">当前内容</th>\n                <th class=\"px-4 py-3\">AI 优化建议</th>\n                <th class=\"px-4 py-3 w-20 text-center\">状态</th>\n              </tr>\n            </thead>\n            <tbody>\n              <TransitionGroup \n                name=\"list\"\n                tag=\"template\"\n              >\n                <tr \n                  v-for=\"field in displayFields\" \n                  :key=\"field.name\"\n                  class=\"bg-white border-b hover:bg-gray-50\"\n                  :class=\"{'opacity-50': field.status === 'processing'}\"\n                >\n                  <td class=\"px-4 py-3 font-medium text-gray-900\">\n                    {{ field.label }}\n                  </td>\n                  <td class=\"px-4 py-3 text-gray-600\">\n                    <div class=\"max-h-20 overflow-y-auto\">\n                      {{ field.currentValue || '未填写' }}\n                    </div>\n                  </td>\n                  <td class=\"px-4 py-3\">\n                    <div \n                      class=\"max-h-20 overflow-y-auto\"\n                      :class=\"{\n                        'text-gray-400': !field.optimizedValue,\n                        'text-gray-900': field.optimizedValue\n                      }\"\n                    >\n                      <template v-if=\"field.status === 'processing'\">\n                        <div class=\"flex items-center space-x-2\">\n                          <div class=\"animate-pulse\">\n                            <div class=\"h-2 bg-gray-200 rounded w-full\"></div>\n                            <div class=\"h-2 bg-gray-200 rounded w-3/4 mt-2\"></div>\n                          </div>\n                        </div>\n                      </template>\n                      <template v-else>\n                        {{ field.optimizedValue || '等待优化...' }}\n                      </template>\n                    </div>\n                  </td>\n                  <td class=\"px-4 py-3 text-center\">\n                    <template v-if=\"field.status === 'success'\">\n                      <CheckCircleIcon class=\"w-5 h-5 text-green-500 mx-auto\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'failed'\">\n                      <XCircleIcon class=\"w-5 h-5 text-red-500 mx-auto\" />\n                    </template>\n                    <template v-else-if=\"field.status === 'processing'\">\n                      <div class=\"animate-spin rounded-full h-5 w-5 border-2 border-gray-300 border-t-blue-600 mx-auto\"></div>\n                    </template>\n                    <template v-else>\n                      <MinusCircleIcon class=\"w-5 h-5 text-gray-300 mx-auto\" />\n                    </template>\n                  </td>\n                </tr>\n              </TransitionGroup>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <!-- 底部 -->\n      <div class=\"dialog-footer\">\n        <div class=\"flex justify-between items-center\">\n          <div class=\"text-sm text-gray-500\">\n            优化完成后，您可以选择应用建议的内容\n          </div>\n          <div class=\"flex space-x-3\">\n            <button\n              @click=\"handleClose\"\n              class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50\"\n            >\n              取消\n            </button>\n            <button\n              @click=\"handleApply\"\n              :disabled=\"!hasOptimized\"\n              class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              应用优化\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport { useWindowSize } from '@vueuse/core'\nimport { \n  XMarkIcon, \n  CheckCircleIcon, \n  XCircleIcon,\n  MinusCircleIcon\n} from '@heroicons/vue/24/solid'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  profileData: {\n    type: Object,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'apply'])\n\n// 字段配置\nconst fieldConfig = [\n  { name: 'name', label: '姓名' },\n  { name: 'name_en', label: '英文姓名' },\n  { name: 'personal_summary', label: '个人简介' },\n  { name: 'personal_summary_en', label: '英文简介' },\n  // ... 其他字段配置\n]\n\n// 处理字段数据\nconst fields = ref(fieldConfig.map(field => ({\n  ...field,\n  currentValue: props.profileData[field.name] || '',\n  optimizedValue: '',\n  status: 'pending' // pending, processing, success, failed\n})))\n\n// 计算属性\nconst displayFields = computed(() => {\n  return fields.value.sort((a, b) => {\n    if (a.status === 'pending' && b.status !== 'pending') return 1\n    if (a.status !== 'pending' && b.status === 'pending') return -1\n    return 0\n  })\n})\n\nconst completedCount = computed(() => \n  fields.value.filter(f => ['success', 'failed'].includes(f.status)).length\n)\n\nconst totalFields = computed(() => fields.value.length)\n\nconst hasOptimized = computed(() => \n  fields.value.some(f => f.status === 'success')\n)\n\n// 模拟优化过程\nconst startOptimize = async () => {\n  for (const field of fields.value) {\n    if (!field.currentValue) continue\n    \n    field.status = 'processing'\n    try {\n      // 这里替换为实际的 AI 优化 API 调用\n      await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 2000))\n      field.optimizedValue = `优化后的 ${field.currentValue}`\n      field.status = 'success'\n    } catch (error) {\n      field.status = 'failed'\n    }\n  }\n}\n\n// 对话框控制\nconst dialogVisible = computed({\n  get: () => props.modelValue,\n  set: (value) => emit('update:modelValue', value)\n})\n\n// 响应式布局\nconst { width } = useWindowSize()\nconst isMobile = computed(() => width.value < 640)\nconst dialogWidth = computed(() => {\n  if (isMobile.value) return '100%'\n  return '900px'\n})\n\n// 处理关闭\nconst handleClose = () => {\n  dialogVisible.value = false\n}\n\n// 处理应用优化\nconst handleApply = () => {\n  const optimizedData = {}\n  fields.value.forEach(field => {\n    if (field.status === 'success') {\n      optimizedData[field.name] = field.optimizedValue\n    }\n  })\n  emit('apply', optimizedData)\n  handleClose()\n}\n\n// 开始优化\nonMounted(() => {\n  startOptimize()\n})\n</script>\n\n<style scoped>\n/* 表格动画 */\n.list-move,\n.list-enter-active,\n.list-leave-active {\n  transition: all 0.5s ease;\n}\n\n.list-enter-from,\n.list-leave-to {\n  opacity: 0;\n  transform: translateY(30px);\n}\n\n.list-leave-active {\n  position: absolute;\n}\n\n/* 移动端适配 */\n@media (max-width: 640px) {\n  .dialog-body {\n    @apply px-2;\n  }\n  \n  th, td {\n    @apply px-2 py-2;\n  }\n  \n  .dialog-footer {\n    @apply flex-col space-y-3;\n  }\n  \n  .dialog-footer button {\n    @apply w-full;\n  }\n}\n</style> "],"mappings":";;;;;AAqIA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAI;AAC7C,SAASC,aAAa,QAAQ,cAAa;AAC3C,SACEC,SAAS,EACTC,eAAe,EACfC,WAAW,EACXC,eAAc,QACT,yBAAwB;;;;;;;;;;;;;;;;IAE/B,MAAMC,KAAK,GAAGC,OAAA;IAQd,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,WAAW,GAAG,CAClB;MAAEC,IAAI,EAAE,MAAM;MAAEC,KAAK,EAAE;IAAK,CAAC,EAC7B;MAAED,IAAI,EAAE,SAAS;MAAEC,KAAK,EAAE;IAAO,CAAC,EAClC;MAAED,IAAI,EAAE,kBAAkB;MAAEC,KAAK,EAAE;IAAO,CAAC,EAC3C;MAAED,IAAI,EAAE,qBAAqB;MAAEC,KAAK,EAAE;IAAO;IAC7C;IAAA,CACF;;IAEA;IACA,MAAMC,MAAM,GAAGf,GAAG,CAACY,WAAW,CAACI,GAAG,CAACC,KAAK,IAAAC,aAAA,CAAAA,aA