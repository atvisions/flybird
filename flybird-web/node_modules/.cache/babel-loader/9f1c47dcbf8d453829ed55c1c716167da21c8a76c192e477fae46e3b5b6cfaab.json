{"ast":null,"code":"import { ref, computed, nextTick, watch, onMounted } from 'vue';\nimport { ElMessage } from 'element-plus';\nimport defaultAvatarImage from '@/assets/images/default-avatar.png';\nimport { useStore } from 'vuex';\nimport { MEDIA_URL } from '@/config';\nimport { showToast } from '@/components/ToastMessage';\nimport { PencilIcon, PhoneIcon, EnvelopeIcon, MapPinIcon, BriefcaseIcon, ClockIcon, CurrencyYenIcon, DocumentTextIcon, CameraIcon, UserIcon, CalendarIcon, ChevronDownIcon, ChevronUpIcon, CakeIcon, PencilSquareIcon } from '@heroicons/vue/24/outline';\n\n// 1. 首先声明 props\n\nexport default {\n  __name: 'BasicInfo',\n  props: {\n    resumeData: {\n      type: Object,\n      required: true\n    },\n    loading: Boolean,\n    bioExpanded: Boolean,\n    showBioExpandButton: Boolean,\n    getBioText: String\n  },\n  emits: ['update', 'edit', 'toggleBioExpand'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n\n    // 2. 声明 emits\n    const emit = __emit;\n\n    // 3. 导入和初始化其他变量\n    const store = useStore();\n    const loading = ref(true);\n    const fileInput = ref(null);\n    const basicInfo = ref({});\n\n    // 4. 计算属性\n    const formatBasicInfo = computed(() => {\n      // 优先使用父组件传入的 resumeData\n      const info = props.resumeData || {};\n      console.log('Props Data:', props.resumeData); // 调试日志\n\n      return {\n        name: info.name || '未填写',\n        gender: formatGender(info.gender),\n        phone: info.phone || '未填写',\n        email: info.email || '未填写',\n        location: info.location || '未填写',\n        age: calculateAge(info.birth_date) || '未填写',\n        personal_summary: info.personal_summary || '未填写'\n      };\n    });\n    const userAvatar = computed(() => {\n      const avatar = store.getters.userAvatar;\n      return avatar.startsWith('/') ? `${MEDIA_URL}${avatar}` : avatar;\n    });\n    const currentGender = computed(() => {\n      return props.resumeData?.gender || store.state.basicInfo?.gender;\n    });\n\n    // 5. 监听器\n    watch(() => props.resumeData, newVal => {\n      if (newVal && Object.keys(newVal).length > 0) {\n        loading.value = false;\n      }\n    }, {\n      immediate: true\n    });\n\n    // 6. 生命周期钩子\n    onMounted(async () => {\n      try {\n        loading.value = true;\n        // 不需要在这里获取数据，因为父组件会处理\n      } catch (error) {\n        console.error('初始化失败:', error);\n      } finally {\n        loading.value = false;\n      }\n    });\n\n    // 7. 方法定义\n    const handleFileChange = async event => {\n      const file = event.target.files[0];\n      if (!file) return;\n\n      // 验证文件类型\n      if (!file.type.startsWith('image/')) {\n        showToast('请选择图片文件', 'error');\n        return;\n      }\n\n      // 验证文件大小（例如限制为 2MB）\n      const maxSize = 2 * 1024 * 1024; // 2MB\n      if (file.size > maxSize) {\n        showToast('图片大小不能超过 2MB', 'error');\n        return;\n      }\n      await handleAvatarUpload(file);\n\n      // 清空文件选择器，以便能够选择同一个文件\n      event.target.value = '';\n    };\n    const handleEdit = () => {\n      console.log('点击编辑按钮, 当前数据:', props.resumeData);\n      emit('edit');\n    };\n    const toggleBioExpand = () => {\n      emit('toggleBioExpand');\n    };\n\n    // 8. 工具函数\n    const calculateAge = birthDate => {\n      if (!birthDate) return '';\n      const birth = new Date(birthDate);\n      const today = new Date();\n      let age = today.getFullYear() - birth.getFullYear();\n      const monthDiff = today.getMonth() - birth.getMonth();\n      if (monthDiff < 0 || monthDiff === 0 && today.getDate() < birth.getDate()) {\n        age--;\n      }\n      return `${age}岁`;\n    };\n    const formatGender = gender => {\n      const genderMap = {\n        male: '男',\n        female: '女',\n        other: '其他'\n      };\n      return genderMap[gender] || '未填写';\n    };\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return date.toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: 'long',\n        day: 'numeric'\n      });\n    };\n\n    // 调试辅助函数\n    const logResumeData = () => {\n      const plainData = {\n        name: props.resumeData.name,\n        gender: props.resumeData.gender,\n        phone: props.resumeData.phone,\n        email: props.resumeData.email,\n        location: props.resumeData.location,\n        birth_date: props.resumeData.birth_date,\n        personal_summary: props.resumeData.personal_summary,\n        created_at: props.resumeData.created_at,\n        updated_at: props.resumeData.updated_at\n      };\n      console.log('BasicInfo data:', plainData);\n    };\n    const __returned__ = {\n      props,\n      emit,\n      store,\n      loading,\n      fileInput,\n      basicInfo,\n      formatBasicInfo,\n      userAvatar,\n      currentGender,\n      handleFileChange,\n      handleEdit,\n      toggleBioExpand,\n      calculateAge,\n      formatGender,\n      formatDate,\n      logResumeData,\n      ref,\n      computed,\n      nextTick,\n      watch,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get defaultAvatarImage() {\n        return defaultAvatarImage;\n      },\n      get useStore() {\n        return useStore;\n      },\n      get MEDIA_URL() {\n        return MEDIA_URL;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get PencilIcon() {\n        return PencilIcon;\n      },\n      get PhoneIcon() {\n        return PhoneIcon;\n      },\n      get EnvelopeIcon() {\n        return EnvelopeIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get ClockIcon() {\n        return ClockIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      },\n      get CameraIcon() {\n        return CameraIcon;\n      },\n      get UserIcon() {\n        return UserIcon;\n      },\n      get CalendarIcon() {\n        return CalendarIcon;\n      },\n      get ChevronDownIcon() {\n        return ChevronDownIcon;\n      },\n      get ChevronUpIcon() {\n        return ChevronUpIcon;\n      },\n      get CakeIcon() {\n        return CakeIcon;\n      },\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","nextTick","watch","onMounted","ElMessage","defaultAvatarImage","useStore","MEDIA_URL","showToast","PencilIcon","PhoneIcon","EnvelopeIcon","MapPinIcon","BriefcaseIcon","ClockIcon","CurrencyYenIcon","DocumentTextIcon","CameraIcon","UserIcon","CalendarIcon","ChevronDownIcon","ChevronUpIcon","CakeIcon","PencilSquareIcon","props","__props","emit","__emit","store","loading","fileInput","basicInfo","formatBasicInfo","info","resumeData","console","log","name","gender","formatGender","phone","email","location","age","calculateAge","birth_date","personal_summary","userAvatar","avatar","getters","startsWith","currentGender","state","newVal","Object","keys","length","value","immediate","error","handleFileChange","event","file","target","files","type","maxSize","size","handleAvatarUpload","handleEdit","toggleBioExpand","birthDate","birth","Date","today","getFullYear","monthDiff","getMonth","getDate","genderMap","male","female","other","formatDate","dateString","date","toLocaleDateString","year","month","day","logResumeData","plainData","created_at","updated_at"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/BasicInfo.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/components/BasicInfo.vue -->\n<template>\n    <div class=\"bg-white rounded-lg shadow\">\n      <!-- 骨架图加载状态 -->\n      <template v-if=\"loading\">\n        <div class=\"p-4\">\n          <div class=\"flex items-start space-x-5\">\n            <!-- 头像骨架 -->\n            <div class=\"relative\">\n              <div class=\"w-20 h-20 rounded-full bg-gray-200 animate-pulse\"></div>\n              <div class=\"absolute -bottom-1 -right-1 w-6 h-6 rounded-full bg-gray-200 animate-pulse\"></div>\n            </div>\n            \n            <!-- 信息骨架 -->\n            <div class=\"flex-1 min-w-0\">\n              <!-- 名字骨架 -->\n              <div class=\"flex items-center justify-between mb-3\">\n                <div class=\"h-6 w-24 bg-gray-200 rounded animate-pulse\"></div>\n              </div>\n              \n              <!-- 基本信息骨架 -->\n              <div class=\"grid grid-cols-2 gap-3\">\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"flex items-center\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-24 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n              </div>\n              \n              <!-- 个人简介骨架 -->\n              <div class=\"mt-3\">\n                <div class=\"flex items-center mb-2\">\n                  <div class=\"w-4 h-4 bg-gray-200 rounded mr-1.5 animate-pulse\"></div>\n                  <div class=\"h-4 w-16 bg-gray-200 rounded animate-pulse\"></div>\n                </div>\n                <div class=\"bg-gray-50 rounded-md p-4\">\n                  <div class=\"space-y-2\">\n                    <div class=\"h-4 bg-gray-200 rounded animate-pulse\"></div>\n                    <div class=\"h-4 bg-gray-200 rounded animate-pulse\"></div>\n                    <div class=\"h-4 w-2/3 bg-gray-200 rounded animate-pulse\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </template>\n\n      <!-- 实际内容 -->\n      <template v-else>\n        <div class=\"p-4\">\n          <div class=\"flex items-start space-x-5\">\n            <!-- 头像部分 -->\n            <div class=\"relative group\">\n              <img \n                  :src=\"userAvatar\" \n                  class=\"w-20 h-20 rounded-full object-cover border-2 border-white shadow\"\n                  alt=\"用户头像\"\n                  @error=\"handleImageError\"\n                  />\n                  <!-- 性别图标 -->\n                  <div class=\"absolute -bottom-1 -right-1 bg-white rounded-full p-1 shadow\">\n                    <svg v-if=\"currentGender === 'male'\" \n                      class=\"w-4 h-4 text-blue-500\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                      <path d=\"M12 2C9.243 2 7 4.243 7 7v2h10V7c0-2.757-2.243-5-5-5zM9 11H7v9c0 1.654 1.346 3 3 3h4c1.654 0 3-1.346 3-3v-9h-2v9c0 .552-.448 1-1 1h-4c-.552 0-1-.448-1-1v-9z\"/>\n                    </svg>\n                    <svg v-else-if=\"currentGender === 'female'\" \n                      class=\"w-4 h-4 text-pink-500\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                      <path d=\"M12 2C9.243 2 7 4.243 7 7v2h10V7c0-2.757-2.243-5-5-5zM9 11H7v5h10v-5h-2v3H9v-3z\"/>\n                    </svg>\n                  </div>\n                  <div \n                  @click=\"triggerUpload\"\n                  class=\"absolute inset-0 flex items-center justify-center rounded-full bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity duration-200\"\n                  >\n                    <template v-if=\"loading\">\n                      <div class=\"animate-spin rounded-full h-8 w-8 border-2 border-white border-t-transparent\"></div>\n                    </template>\n                    <template v-else>\n                      <CameraIcon class=\"w-8 h-8 text-white\" />\n                    </template>\n                  </div>\n                  <input\n                  ref=\"fileInput\"\n                  type=\"file\"\n                  accept=\"image/*\"\n                  class=\"hidden\"\n                  @change=\"handleFileChange\"\n                  />\n            </div>\n    \n            <!-- 用户信息 -->\n            <div class=\"flex-1 min-w-0\">\n              <div class=\"flex items-center justify-between mb-3\">\n                <h2 class=\"text-lg font-medium text-gray-900\">\n                  {{ formatBasicInfo.name }}\n                </h2>\n                <div class=\"flex items-center space-x-2\">\n                  <!-- 使用 heroicons 的编辑图标 -->\n                  <button\n                    @click=\"handleEdit\"\n                    class=\"p-1 rounded-full hover:bg-gray-100 transition-colors duration-200\"\n                    title=\"编辑基本信息\"\n                  >\n                    <PencilSquareIcon class=\"w-5 h-5 text-gray-500 hover:text-gray-700\" />\n                  </button>\n                </div>\n              </div>\n    \n              <!-- 基本信息列表 -->\n              <div class=\"grid grid-cols-2 gap-3\">\n                <!-- 手机号 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <PhoneIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ formatBasicInfo.phone }}</span>\n                </div>\n    \n                <!-- 邮箱 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <EnvelopeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ formatBasicInfo.email }}</span>\n                </div>\n    \n                <!-- 所在地 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <MapPinIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ formatBasicInfo.location }}</span>\n                </div>\n    \n                <!-- 年龄 -->\n                <div class=\"flex items-center text-gray-600\">\n                  <CakeIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm truncate\">{{ formatBasicInfo.age }}</span>\n                </div>\n              </div>\n    \n              <!-- 个人简介 -->\n              <div class=\"mt-3\">\n                <div class=\"flex items-center text-gray-600 mb-2\">\n                  <DocumentTextIcon class=\"w-4 h-4 text-gray-400 mr-1.5\" />\n                  <span class=\"text-sm font-medium\">个人简介</span>\n                </div>\n                <div class=\"bg-gray-50 rounded-md p-4\">\n                  <div class=\"relative\">\n                    <template v-if=\"formatBasicInfo.personal_summary !== '未填写'\">\n                      <p \n                        class=\"text-sm text-gray-600 leading-relaxed min-h-[4.5em] line-clamp-3\"\n                        :class=\"{ 'line-clamp-none': bioExpanded }\"\n                      >\n                        {{ formatBasicInfo.personal_summary }}\n                      </p>\n                      <button\n                        v-if=\"showBioExpandButton\"\n                        @click=\"toggleBioExpand\"\n                        class=\"text-xs text-primary-600 hover:text-primary-700 mt-2 inline-flex items-center\"\n                      >\n                        {{ bioExpanded ? '收起' : '展开全部' }}\n                        <ChevronDownIcon \n                          v-if=\"!bioExpanded\" \n                          class=\"w-4 h-4 ml-0.5\" \n                        />\n                        <ChevronUpIcon \n                          v-else \n                          class=\"w-4 h-4 ml-0.5\" \n                        />\n                      </button>\n                    </template>\n                    <p \n                      v-else \n                      class=\"text-sm text-gray-400 text-center min-h-[4.5em] flex items-center justify-center\"\n                    >\n                      你还没有设置个人简介\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </template>\n    </div>\n  </template>\n  \n  <script setup>\nimport { ref, computed, nextTick, watch, onMounted } from 'vue'\nimport { ElMessage } from 'element-plus'\nimport defaultAvatarImage from '@/assets/images/default-avatar.png'\nimport { useStore } from 'vuex'\nimport { MEDIA_URL } from '@/config'\nimport { showToast } from '@/components/ToastMessage'\nimport {\n  PencilIcon,\n  PhoneIcon,\n  EnvelopeIcon,\n  MapPinIcon,\n  BriefcaseIcon,\n  ClockIcon,\n  CurrencyYenIcon,\n  DocumentTextIcon,\n  CameraIcon,\n  UserIcon,\n  CalendarIcon,\n  ChevronDownIcon,\n  ChevronUpIcon,\n  CakeIcon,\n  PencilSquareIcon\n} from '@heroicons/vue/24/outline'\n\n// 1. 首先声明 props\nconst props = defineProps({\n  resumeData: {\n    type: Object,\n    required: true\n  },\n  loading: Boolean,\n  bioExpanded: Boolean,\n  showBioExpandButton: Boolean,\n  getBioText: String\n})\n\n// 2. 声明 emits\nconst emit = defineEmits(['update', 'edit', 'toggleBioExpand'])\n\n// 3. 导入和初始化其他变量\nconst store = useStore()\nconst loading = ref(true)\nconst fileInput = ref(null)\nconst basicInfo = ref({})\n\n// 4. 计算属性\nconst formatBasicInfo = computed(() => {\n  // 优先使用父组件传入的 resumeData\n  const info = props.resumeData || {}\n  \n  console.log('Props Data:', props.resumeData)  // 调试日志\n  \n  return {\n    name: info.name || '未填写',\n    gender: formatGender(info.gender),\n    phone: info.phone || '未填写',\n    email: info.email || '未填写',\n    location: info.location || '未填写',\n    age: calculateAge(info.birth_date) || '未填写',\n    personal_summary: info.personal_summary || '未填写'\n  }\n})\n\nconst userAvatar = computed(() => {\n  const avatar = store.getters.userAvatar\n  return avatar.startsWith('/') ? `${MEDIA_URL}${avatar}` : avatar\n})\n\nconst currentGender = computed(() => {\n  return props.resumeData?.gender || store.state.basicInfo?.gender\n})\n\n// 5. 监听器\nwatch(\n  () => props.resumeData,\n  (newVal) => {\n    if (newVal && Object.keys(newVal).length > 0) {\n      loading.value = false\n    }\n  },\n  { immediate: true }\n)\n\n// 6. 生命周期钩子\nonMounted(async () => {\n  try {\n    loading.value = true\n    // 不需要在这里获取数据，因为父组件会处理\n  } catch (error) {\n    console.error('初始化失败:', error)\n  } finally {\n    loading.value = false\n  }\n})\n\n// 7. 方法定义\nconst handleFileChange = async (event) => {\n  const file = event.target.files[0]\n  if (!file) return\n\n  // 验证文件类型\n  if (!file.type.startsWith('image/')) {\n    showToast('请选择图片文件', 'error')\n    return\n  }\n\n  // 验证文件大小（例如限制为 2MB）\n  const maxSize = 2 * 1024 * 1024 // 2MB\n  if (file.size > maxSize) {\n    showToast('图片大小不能超过 2MB', 'error')\n    return\n  }\n\n  await handleAvatarUpload(file)\n  \n  // 清空文件选择器，以便能够选择同一个文件\n  event.target.value = ''\n}\n\nconst handleEdit = () => {\n  console.log('点击编辑按钮, 当前数据:', props.resumeData)\n  emit('edit')\n}\n\nconst toggleBioExpand = () => {\n  emit('toggleBioExpand')\n}\n\n// 8. 工具函数\nconst calculateAge = (birthDate) => {\n  if (!birthDate) return ''\n  \n  const birth = new Date(birthDate)\n  const today = new Date()\n  \n  let age = today.getFullYear() - birth.getFullYear()\n  const monthDiff = today.getMonth() - birth.getMonth()\n  \n  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {\n    age--\n  }\n  \n  return `${age}岁`\n}\n\nconst formatGender = (gender) => {\n  const genderMap = {\n    male: '男',\n    female: '女',\n    other: '其他'\n  }\n  return genderMap[gender] || '未填写'\n}\n\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return date.toLocaleDateString('zh-CN', {\n    year: 'numeric',\n    month: 'long',\n    day: 'numeric'\n  })\n}\n\n// 调试辅助函数\nconst logResumeData = () => {\n  const plainData = {\n    name: props.resumeData.name,\n    gender: props.resumeData.gender,\n    phone: props.resumeData.phone,\n    email: props.resumeData.email,\n    location: props.resumeData.location,\n    birth_date: props.resumeData.birth_date,\n    personal_summary: props.resumeData.personal_summary,\n    created_at: props.resumeData.created_at,\n    updated_at: props.resumeData.updated_at\n  }\n  console.log('BasicInfo data:', plainData)\n}\n</script>"],"mappings":"AAmMA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,KAAK,EAAEC,SAAS,QAAQ,KAAI;AAC9D,SAASC,SAAS,QAAQ,cAAa;AACvC,OAAOC,kBAAkB,MAAM,oCAAmC;AAClE,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,UAAS;AACnC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SACEC,UAAU,EACVC,SAAS,EACTC,YAAY,EACZC,UAAU,EACVC,aAAa,EACbC,SAAS,EACTC,eAAe,EACfC,gBAAgB,EAChBC,UAAU,EACVC,QAAQ,EACRC,YAAY,EACZC,eAAe,EACfC,aAAa,EACbC,QAAQ,EACRC,gBAAe,QACV,2BAA0B;;AAEjC;;;;;;;;;;;;;;;;;;;;IACA,MAAMC,KAAK,GAAGC,OAAA;;IAWd;IACA,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,KAAK,GAAGtB,QAAQ,CAAC;IACvB,MAAMuB,OAAO,GAAG9B,GAAG,CAAC,IAAI;IACxB,MAAM+B,SAAS,GAAG/B,GAAG,CAAC,IAAI;IAC1B,MAAMgC,SAAS,GAAGhC,GAAG,CAAC,CAAC,CAAC;;IAExB;IACA,MAAMiC,eAAe,GAAGhC,QAAQ,CAAC,MAAM;MACrC;MACA,MAAMiC,IAAI,GAAGT,KAAK,CAACU,UAAU,IAAI,CAAC;MAElCC,OAAO,CAACC,GAAG,CAAC,aAAa,EAAEZ,KAAK,CAACU,UAAU,CAAC,EAAE;;MAE9C,OAAO;QACLG,IAAI,EAAEJ,IAAI,CAACI,IAAI,IAAI,KAAK;QACxBC,MAAM,EAAEC,YAAY,CAACN,IAAI,CAACK,MAAM,CAAC;QACjCE,KAAK,EAAEP,IAAI,CAACO,KAAK,IAAI,KAAK;QAC1BC,KAAK,EAAER