-gray-200 px-6 py-4\"\n              >\n                <h3 class=\"text-lg font-medium text-gray-900\">\n                  {{ initialData?.id ? '编辑项目经历' : '添加项目经历' }}\n                </h3>\n                <button\n                  @click=\"handleClose\"\n                  class=\"rounded-full p-1 hover:bg-gray-100 transition-colors\"\n                >\n                  <XMarkIcon class=\"w-5 h-5 text-gray-400\" />\n                </button>\n              </DialogTitle>\n\n              <!-- 表单内容 -->\n              <form @submit.prevent=\"handleSubmit\" class=\"p-6\">\n                <div class=\"space-y-6\">\n                  <!-- 项目名称 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      项目名称 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <input\n                      type=\"text\"\n                      v-model=\"form.name\"\n                      required\n                      class=\"w-full rounded-lg border border-gray-300 py-2.5 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500\"\n                      placeholder=\"请输入项目名称\"\n                    />\n                  </div>\n\n                  <!-- 起止时间 -->\n                  <div class=\"grid grid-cols-2 gap-6\">\n                    <div class=\"space-y-1\">\n                      <label class=\"block text-sm font-medium text-gray-700\">\n                        开始时间 <span class=\"text-red-500\">*</span>\n                      </label>\n                      <el-date-picker\n                        v-model=\"form.start_date\"\n                        type=\"month\"\n                        placeholder=\"选择开始时间\"\n                        format=\"YYYY-MM\"\n                        value-format=\"YYYY-MM\"\n                        class=\"!w-full\"\n                      />\n                    </div>\n                    <div class=\"space-y-1\">\n                      <label class=\"block text-sm font-medium text-gray-700\">\n                        结束时间\n                      </label>\n                      <el-date-picker\n                        v-model=\"form.end_date\"\n                        type=\"month\"\n                        placeholder=\"选择结束时间\"\n                        format=\"YYYY-MM\"\n                        value-format=\"YYYY-MM\"\n                        class=\"!w-full\"\n                      />\n                    </div>\n                  </div>\n\n                  <!-- 项目描述 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      项目描述 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <el-input\n                      v-model=\"form.description\"\n                      type=\"textarea\"\n                      :rows=\"4\"\n                      placeholder=\"请描述项目内容、你的职责和贡献等\"\n                      class=\"!w-full\"\n                    />\n                  </div>\n\n                  <!-- 项目链接 -->\n                  <div class=\"space-y-1\">\n                    <label class=\"block text-sm font-medium text-gray-700\">\n                      项目链接\n                    </label>\n                    <input\n                      type=\"url\"\n                      v-model=\"form.link\"\n                      class=\"w-full rounded-lg border border-gray-300 py-2.5 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500\"\n                      placeholder=\"请输入项目链接（选填）\"\n                    />\n                  </div>\n\n                  <!-- 底部按钮 -->\n                  <div class=\"flex justify-end space-x-3 pt-6\">\n                    <button\n                      type=\"button\"\n                      @click=\"handleClose\"\n                      class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500\"\n                    >\n                      取消\n                    </button>\n                    <button\n                      type=\"submit\"\n                      :disabled=\"loading\"\n                      class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                    >\n                      {{ loading ? '保存中...' : '确认' }}\n                    </button>\n                  </div>\n                </div>\n              </form>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { ref, watch } from 'vue'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  TransitionRoot,\n  TransitionChild\n} from '@headlessui/vue'\nimport { XMarkIcon } from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  modelValue: Boolean,\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\n// 表单数据\nconst form = ref({\n  name: '',\n  start_date: '',\n  end_date: '',\n  description: '',\n  link: ''\n})\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newVal) => {\n  if (newVal) {\n    form.value = {\n      ...newVal,\n      // 确保所有字段都有值\n      name: newVal.name || '',\n      start_date: newVal.start_date || '',\n      end_date: newVal.end_date || '',\n      description: newVal.description || '',\n      link: newVal.link || ''\n    }\n  }\n}, { immediate: true, deep: true })\n\nconst handleClose = () => {\n  emit('update:modelValue', false)\n}\n\nconst handleSubmit = () => {\n  emit('submit', form.value)\n}\n</script>\n\n<sty