{"ast":null,"code":"import { ref, computed, onMounted, onUnmounted } from 'vue';\nimport { SparklesIcon, DocumentMagnifyingGlassIcon, DocumentCheckIcon, PencilSquareIcon, CheckCircleIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'AIOptimizingDialog',\n  props: {\n    modelValue: Boolean\n  },\n  emits: ['update:modelValue', 'complete'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const props = __props;\n    const emit = __emit;\n\n    // 优化阶段定义\n    const phases = [{\n      name: '分析',\n      icon: DocumentMagnifyingGlassIcon,\n      title: '正在分析简历内容',\n      description: 'AI 正在深度分析您的简历内容和结构'\n    }, {\n      name: '优化',\n      icon: PencilSquareIcon,\n      title: '正在优化内容',\n      description: 'AI 正在根据行业标准优化简历表达'\n    }, {\n      name: '校对',\n      icon: DocumentCheckIcon,\n      title: '正在校对完善',\n      description: 'AI 正在校对并完善细节'\n    }, {\n      name: '完成',\n      icon: CheckCircleIcon,\n      title: '优化完成',\n      description: '您的简历已经焕然一新'\n    }];\n    const currentPhaseIndex = ref(0);\n    const progress = ref(0);\n    const optimizationLogs = ref(['开始简历优化...', '正在加载 AI 模型...']);\n\n    // 当前阶段信息\n    const currentPhase = computed(() => phases[currentPhaseIndex.value]);\n\n    // 模拟优化过程\n    let progressInterval;\n    let phaseInterval;\n    const startOptimization = () => {\n      // 进度更新\n      progressInterval = setInterval(() => {\n        if (progress.value < 100) {\n          progress.value += 1;\n        } else {\n          clearInterval(progressInterval);\n          emit('complete');\n        }\n      }, 600);\n\n      // 阶段更新\n      phaseInterval = setInterval(() => {\n        if (currentPhaseIndex.value < phases.length - 1) {\n          currentPhaseIndex.value += 1;\n          // 添加日志\n          optimizationLogs.value.push(phases[currentPhaseIndex.value].description);\n        } else {\n          clearInterval(phaseInterval);\n        }\n      }, 15000); // 每15秒切换一个阶段\n    };\n    onMounted(() => {\n      startOptimization();\n    });\n    onUnmounted(() => {\n      clearInterval(progressInterval);\n      clearInterval(phaseInterval);\n    });\n    const __returned__ = {\n      props,\n      emit,\n      phases,\n      currentPhaseIndex,\n      progress,\n      optimizationLogs,\n      currentPhase,\n      get progressInterval() {\n        return progressInterval;\n      },\n      set progressInterval(v) {\n        progressInterval = v;\n      },\n      get phaseInterval() {\n        return phaseInterval;\n      },\n      set phaseInterval(v) {\n        phaseInterval = v;\n      },\n      startOptimization,\n      ref,\n      computed,\n      onMounted,\n      onUnmounted,\n      get SparklesIcon() {\n        return SparklesIcon;\n      },\n      get DocumentMagnifyingGlassIcon() {\n        return DocumentMagnifyingGlassIcon;\n      },\n      get DocumentCheckIcon() {\n        return DocumentCheckIcon;\n      },\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get CheckCircleIcon() {\n        return CheckCircleIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","onUnmounted","SparklesIcon","DocumentMagnifyingGlassIcon","DocumentCheckIcon","PencilSquareIcon","CheckCircleIcon","props","__props","emit","__emit","phases","name","icon","title","description","currentPhaseIndex","progress","optimizationLogs","currentPhase","value","progressInterval","phaseInterval","startOptimization","setInterval","clearInterval","length","push"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/dialogs/AIOptimizingDialog.vue"],"sourcesContent":["<template>\n  <el-dialog\n    :model-value=\"modelValue\"\n    :show-close=\"false\"\n    :close-on-click-modal=\"false\"\n    :close-on-press-escape=\"false\"\n    width=\"640px\"\n    class=\"ai-optimizing-dialog\"\n  >\n    <div class=\"space-y-8 py-6\">\n      <!-- AI 动画区域 -->\n      <div class=\"relative h-48 flex items-center justify-center\">\n        <!-- 中心光环 -->\n        <div class=\"absolute w-32 h-32 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full opacity-20 animate-pulse\"></div>\n        \n        <!-- 旋转光环 -->\n        <div class=\"absolute w-40 h-40 border-4 border-indigo-500/30 rounded-full animate-spin-slow\"></div>\n        <div class=\"absolute w-48 h-48 border-4 border-purple-500/20 rounded-full animate-spin-reverse\"></div>\n        \n        <!-- AI 图标 -->\n        <div class=\"relative z-10\">\n          <SparklesIcon class=\"w-16 h-16 text-indigo-600 animate-float\" />\n        </div>\n\n        <!-- 扫描线效果 -->\n        <div class=\"absolute inset-0 overflow-hidden\">\n          <div class=\"absolute w-full h-1 bg-gradient-to-r from-transparent via-indigo-500 to-transparent top-0 animate-scan\"></div>\n        </div>\n      </div>\n\n      <!-- 优化状态 -->\n      <div class=\"text-center space-y-4\">\n        <h3 class=\"text-xl font-medium text-gray-900\">\n          {{ currentPhase.title }}\n        </h3>\n        <p class=\"text-sm text-gray-500\">{{ currentPhase.description }}</p>\n      </div>\n\n      <!-- 进度条 -->\n      <div class=\"space-y-2\">\n        <div class=\"flex justify-between text-sm\">\n          <span class=\"text-gray-500\">优化进度</span>\n          <span class=\"text-indigo-600 font-medium\">{{ progress }}%</span>\n        </div>\n        <div class=\"h-2 bg-gray-100 rounded-full overflow-hidden\">\n          <div \n            class=\"h-full bg-gradient-to-r from-indigo-500 to-purple-500 transition-all duration-500 rounded-full\"\n            :style=\"{ width: `${progress}%` }\"\n          ></div>\n        </div>\n      </div>\n\n      <!-- 优化阶段指示器 -->\n      <div class=\"flex justify-between\">\n        <div \n          v-for=\"(phase, index) in phases\" \n          :key=\"index\"\n          class=\"flex flex-col items-center space-y-2\"\n        >\n          <div \n            class=\"w-8 h-8 rounded-full flex items-center justify-center transition-colors\"\n            :class=\"[\n              currentPhaseIndex >= index \n                ? 'bg-indigo-600 text-white' \n                : 'bg-gray-100 text-gray-400'\n            ]\"\n          >\n            <component \n              :is=\"phase.icon\" \n              class=\"w-4 h-4\"\n            />\n          </div>\n          <span \n            class=\"text-xs\"\n            :class=\"[\n              currentPhaseIndex >= index \n                ? 'text-indigo-600' \n                : 'text-gray-400'\n            ]\"\n          >\n            {{ phase.name }}\n          </span>\n        </div>\n      </div>\n\n      <!-- 实时日志 -->\n      <div class=\"bg-gray-50 rounded-lg p-4 h-24 overflow-y-auto\">\n        <div \n          v-for=\"(log, index) in optimizationLogs\" \n          :key=\"index\"\n          class=\"text-sm\"\n          :class=\"{\n            'text-gray-500': index !== optimizationLogs.length - 1,\n            'text-indigo-600': index === optimizationLogs.length - 1\n          }\"\n        >\n          {{ log }}\n        </div>\n      </div>\n    </div>\n  </el-dialog>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, onUnmounted } from 'vue'\nimport { \n  SparklesIcon,\n  DocumentMagnifyingGlassIcon,\n  DocumentCheckIcon,\n  PencilSquareIcon,\n  CheckCircleIcon\n} from '@heroicons/vue/24/outline'\n\nconst props = defineProps({\n  modelValue: Boolean\n})\n\nconst emit = defineEmits(['update:modelValue', 'complete'])\n\n// 优化阶段定义\nconst phases = [\n  {\n    name: '分析',\n    icon: DocumentMagnifyingGlassIcon,\n    title: '正在分析简历内容',\n    description: 'AI 正在深度分析您的简历内容和结构'\n  },\n  {\n    name: '优化',\n    icon: PencilSquareIcon,\n    title: '正在优化内容',\n    description: 'AI 正在根据行业标准优化简历表达'\n  },\n  {\n    name: '校对',\n    icon: DocumentCheckIcon,\n    title: '正在校对完善',\n    description: 'AI 正在校对并完善细节'\n  },\n  {\n    name: '完成',\n    icon: CheckCircleIcon,\n    title: '优化完成',\n    description: '您的简历已经焕然一新'\n  }\n]\n\nconst currentPhaseIndex = ref(0)\nconst progress = ref(0)\nconst optimizationLogs = ref([\n  '开始简历优化...',\n  '正在加载 AI 模型...'\n])\n\n// 当前阶段信息\nconst currentPhase = computed(() => phases[currentPhaseIndex.value])\n\n// 模拟优化过程\nlet progressInterval\nlet phaseInterval\n\nconst startOptimization = () => {\n  // 进度更新\n  progressInterval = setInterval(() => {\n    if (progress.value < 100) {\n      progress.value += 1\n    } else {\n      clearInterval(progressInterval)\n      emit('complete')\n    }\n  }, 600)\n\n  // 阶段更新\n  phaseInterval = setInterval(() => {\n    if (currentPhaseIndex.value < phases.length - 1) {\n      currentPhaseIndex.value += 1\n      // 添加日志\n      optimizationLogs.value.push(phases[currentPhaseIndex.value].description)\n    } else {\n      clearInterval(phaseInterval)\n    }\n  }, 15000) // 每15秒切换一个阶段\n}\n\nonMounted(() => {\n  startOptimization()\n})\n\nonUnmounted(() => {\n  clearInterval(progressInterval)\n  clearInterval(phaseInterval)\n})\n</script>\n\n<style>\n.animate-spin-slow {\n  animation: spin 8s linear infinite;\n}\n\n.animate-spin-reverse {\n  animation: spin 12s linear infinite reverse;\n}\n\n.animate-float {\n  animation: float 3s ease-in-out infinite;\n}\n\n.animate-scan {\n  animation: scan 2s linear infinite;\n}\n\n@keyframes float {\n  0%, 100% {\n    transform: translateY(0);\n  }\n  50% {\n    transform: translateY(-10px);\n  }\n}\n\n@keyframes scan {\n  0% {\n    transform: translateY(0);\n  }\n  100% {\n    transform: translateY(100%);\n  }\n}\n\n/* 自定义滚动条样式 */\n.ai-optimizing-dialog ::-webkit-scrollbar {\n  width: 4px;\n}\n\n.ai-optimizing-dialog ::-webkit-scrollbar-track {\n  background: #f3f4f6;\n  border-radius: 2px;\n}\n\n.ai-optimizing-dialog ::-webkit-scrollbar-thumb {\n  background: #818cf8;\n  border-radius: 2px;\n}\n\n.ai-optimizing-dialog ::-webkit-scrollbar-thumb:hover {\n  background: #6366f1;\n}\n</style> "],"mappings":"AAwGA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,WAAW,QAAQ,KAAI;AAC1D,SACEC,YAAY,EACZC,2BAA2B,EAC3BC,iBAAiB,EACjBC,gBAAgB,EAChBC,eAAc,QACT,2BAA0B;;;;;;;;;;;;IAEjC,MAAMC,KAAK,GAAGC,OAAA;IAId,MAAMC,IAAI,GAAGC,MAAA;;IAEb;IACA,MAAMC,MAAM,GAAG,CACb;MACEC,IAAI,EAAE,IAAI;MACVC,IAAI,EAAEV,2BAA2B;MACjCW,KAAK,EAAE,UAAU;MACjBC,WAAW,EAAE;IACf,CAAC,EACD;MACEH,IAAI,EAAE,IAAI;MACVC,IAAI,EAAER,gBAAgB;MACtBS,KAAK,EAAE,QAAQ;MACfC,WAAW,EAAE;IACf,CAAC,EACD;MACEH,IAAI,EAAE,IAAI;MACVC,IAAI,EAAET,iBAAiB;MACvBU,KAAK,EAAE,QAAQ;MACfC,WAAW,EAAE;IACf,CAAC,EACD;MACEH,IAAI,EAAE,IAAI;MACVC,IAAI,EAAEP,eAAe;MACrBQ,KAAK,EAAE,MAAM;MACbC,WAAW,EAAE;IACf,EACF;IAEA,MAAMC,iBAAiB,GAAGlB,GAAG,CAAC,CAAC;IAC/B,MAAMmB,QAAQ,GAAGnB,GAAG,CAAC,CAAC;IACtB,MAAMoB,gBAAgB,GAAGpB,GAAG,CAAC,CAC3B,WAAW,EACX,eAAc,CACf;;IAED;IACA,MAAMqB,YAAY,GAAGpB,QAAQ,CAAC,MAAMY,MAAM,CAACK,iBAAiB,CAACI,KAAK,CAAC;;IAEnE;IACA,IAAIC,gBAAe;IACnB,IAAIC,aAAY;IAEhB,MAAMC,iBAAiB,GAAGA,CAAA,KAAM;MAC9B;MACAF,gBAAgB,GAAGG,WAAW,CAAC,MAAM;QACnC,IAAIP,QAAQ,CAACG,KAAK,GAAG,GAAG,EAAE;UACxBH,QAAQ,CAACG,KAAK,IAAI;QACpB,CAAC,MAAM;UACLK,aAAa,CAACJ,gBAAgB;UAC9BZ,IAAI,CAAC,UAAU;QACjB;MACF,CAAC,EAAE,GAAG;;MAEN;MACAa,aAAa,GAAGE,WAAW,CAAC,MAAM;QAChC,IAAIR,iBAAiB,CAACI,KAAK,GAAGT,MAAM,CAACe,MAAM,GAAG,CAAC,EAAE;UAC/CV,iBAAiB,CAACI,KAAK,IAAI;UAC3B;UACAF,gBAAgB,CAACE,KAAK,CAACO,IAAI,CAAChB,MAAM,CAACK,iBAAiB,CAACI,KAAK,CAAC,CAACL,WAAW;QACzE,CAAC,MAAM;UACLU,aAAa,CAACH,aAAa;QAC7B;MACF,CAAC,EAAE,KAAK,CAAC,EAAC;IACZ;IAEAtB,SAAS,CAAC,MAAM;MACduB,iBAAiB,CAAC;IACpB,CAAC;IAEDtB,WAAW,CAAC,MAAM;MAChBwB,aAAa,CAACJ,gBAAgB;MAC9BI,aAAa,CAACH,aAAa;IAC7B,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}