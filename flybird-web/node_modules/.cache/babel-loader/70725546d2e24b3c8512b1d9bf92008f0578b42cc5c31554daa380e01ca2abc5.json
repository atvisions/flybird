e\"], {\n    \"inactive-modules\": $setup.inactiveModules,\n    loading: $setup.loading,\n    onActivate: $setup.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"])]), _createCommentVNode(\" 弹窗组件 \"), _createVNode($setup[\"EditBasicDialog\"], {\n    modelValue: $setup.showEditBasicDialog,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditBasicDialog = $event),\n    \"initial-data\": $setup.basicFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleBasicSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"]), _createVNode($setup[\"EditDialog\"], {\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    module: $setup.currentModule,\n    \"initial-form-data\": _ctx.formData,\n    loading: _ctx.profileLoading,\n    onSubmit: $setup.handleSubmit,\n    onCancel: $setup.handleCancel\n  }, null, 8 /* PROPS */, [\"modelValue\", \"module\", \"initial-form-data\", \"loading\"]), _createVNode($setup[\"AIDialog\"], {\n    modelValue: $setup.showAIModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showAIModal = $event),\n    suggestions: $setup.aiSuggestions,\n    loading: _ctx.profileLoading,\n    onAction: $setup.handleAIAction\n  }, null, 8 /* PROPS */, [\"modelValue\", \"suggestions\", \"loading\", \"onAction\"]), _createVNode($setup[\"CreationDialog\"], {\n    modelValue: $setup.showCreationModal,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showCreationModal = $event),\n    \"selected-ids\": $setup.selectedCreationIds,\n    loading: _ctx.profileLoading,\n    onSubmit: $setup.handleCreationsSelected,\n    onCancel: $setup.closeCreationModal\n  }, null, 8 /* PROPS */, [\"modelValue\", \"selected-ids\", \"loading\", \"onCancel\"])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createCommentVNode","$setup","profileData","resumeData","value","_createBlock","key","loading","bioExpanded","showBioExpandButton","getBioText","onSave","handleSave","onToggleBioExpand","toggleBioExpand","onEdit","handleEdit","_createVNode","_ctx","completionRate","onAiOptimize","showAIOptimize","onImport","importResume","onPreview","previewResume","activeModules","editModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","inactiveModules","onActivate","activateModule","modelValue","showEditBasicDialog","_cache","$event","basicFormData","onSubmit","handleBasicSubmit","showEditModal","module","currentModule","formData","profileLoading","handleSubmit","onCancel","handleCancel","showAIModal","suggestions","aiSuggestions","onAction","handleAIAction","showCreationModal","selectedCreationIds","handleCreationsSelected","closeCreationModal"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <!-- 基本信息卡片 -->\n        <BasicInfo\n        v-if=\"profileData.resumeData.value\"\n        :resumeData=\"profileData.resumeData.value\"\n        :loading=\"loading\"\n        :bioExpanded=\"profileData.bioExpanded\"\n        :showBioExpandButton=\"profileData.showBioExpandButton\"\n        :getBioText=\"getBioText\"\n        @save=\"handleSave\"\n        @toggleBioExpand=\"toggleBioExpand\"\n        @edit=\"handleEdit\"\n      />\n  \n        <!-- 简历状态卡片 -->\n        <ResumeStatus\n          :completion-rate=\"completionRate\"\n          :loading=\"loading\"\n          @ai-optimize=\"showAIOptimize\"\n          @import=\"importResume\"\n          @preview=\"previewResume\"\n        />\n  \n        <!-- 常规模块列表 -->\n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"editModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n        />\n  \n        <!-- 添加更多模块 -->\n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 弹窗组件 -->\n      <EditBasicDialog\n        v-model=\"showEditBasicDialog\"\n        :initial-data=\"basicFormData\"\n        :loading=\"loading\"\n        @submit=\"handleBasicSubmit\"\n      />\n  \n      <EditDialog\n        v-model=\"showEditModal\"\n        :module=\"currentModule\"\n        :initial-form-data=\"formData\"\n        :loading=\"profileLoading\"\n        @submit=\"handleSubmit\"\n        @cancel=\"handleCancel\"\n      />\n  \n      <AIDialog\n        v-model=\"showAIModal\"\n        :suggestions=\"aiSuggestions\"\n        :loading=\"profileLoading\"\n        @action=\"handleAIAction\"\n      />\n  \n      <CreationDialog\n        v-model=\"showCreationModal\"\n        :selected-ids=\"selectedCreationIds\"\n        :loading=\"profileLoading\"\n        @submit=\"handleCreationsSelected\"\n        @cancel=\"closeCreationModal\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted, computed, watch, onBeforeUnmount } from 'vue'\n  import { ElMessage } from 'element-plus'\n  \n  // 组件导入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditDialog from './dialogs/EditDialog.vue'\n  import AIDialog from './dialogs/AIDialog.vue'\n  import CreationDialog from './dialogs/CreationDialog.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  \n  // Composables\n  import { useProfileData } from './composables/useProfileData'\n  import { useModules } from './composables/useModules'\n  import { useDialog } from './composables/useDialog'\n  import { useLoading } from './composables/useLoading'\n \n  // 初始化 profileData\n  const profileData = useProfileData()\n  const loading = ref(false)\n  \n  // 添加调试日志\n  console.log('MyProfile profileData:', profileData)\n  \n  // 计算属性：获取处理后的个人简介文本\n  const getBioText = computed(() => {\n    console.log('Computing getBioText:', profileData.resumeData)\n    return profileData.getBioText()\n  })\n  \n  // 处理保存\n  const handleSave = async (formData) => {\n    console.log('Handling save:', formData)\n    const success = await profileData.updateResumeData(formData)\n    if (success) {\n      await profileData.fetchInitialData()\n    }\n    return success\n  }\n  \n  // 处理展开/收起\n  const toggleBioExpand = () => {\n    console.log('Toggling bio expand')\n    profileData.toggleBioExpand()\n  }\n  \n  const {\n    activeModules,\n    inactiveModules,\n    currentModule,\n    editModule,\n    addItem,\n    removeModule,\n    activateModule\n  } = useModules()\n  \n  const {\n    showEditModal,\n    showAIModal,\n    showCreationModal,\n    aiSuggestions,\n    selectedCreationIds,\n    showAIOptimize,\n    closeCreationModal,\n    handleAIAction\n  } = useDialog()\n  \n  const { loading: actionLoading, withLoading } = useLoading()  // 重命名避免冲突\n  \n  // 基本信息编辑状态\n  const showEditBasicDialog = ref(false)\n  const basicFormData = ref({})\n  \n  // 处理编辑按钮点击\n  const handleEdit = () => {\n    basicFormData.value = {\n      name: profileData.resumeData.value.name || '',\n      gender: profileData.resumeData.value.gender || '',\n      phone: profileData.resumeData.value.phone || '',\n      email: profileData.resumeData.value.email || '',\n      location: profileData.resumeData.value.location || '',\n      birth_date: profileData.resumeData.value.birth_date || '',\n      personal_summary: profileData.resumeData.value.personal_summary || ''\n    }\n    console.log('编辑表单数据:', basicFormData.value)\n    showEditBasicDialog.value = true\n  }\n  \n  // 处理基本信息提交\n  const handleBasicSubmit = async (formData) => {\n    if (!formData) return\n\n    loading.value = true\n    try {\n      await profileData.updateResumeData(formData)\n      showEditBasicDialog.value = false\n      ElMessage.success('保存成功')\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 生命周期钩子\n  onMounted(async () => {\n    console.log('MyProfile mounted')\n    await profileData.fetchInitialData()\n  })\n  \n  // 处理函数\n  const handleSubmit = async (formData) => {\n    try {\n      await withLoading(async () => {\n        await profileData.updateResumeData(formData)\n        showEditModal.value = false\n        ElMessage.success('保存成功')\n      })\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请检查表单')\n    }\n  }\n  \n  const handleCancel = () => {\n    showEditModal.value = false\n  }\n  \n  \n  const importResume = async () => {\n    try {\n      await withLoading(async () => {\n        // TODO: 实现导入功能\n        ElMessage.info('功能开发中')\n      })\n    } catch (error) {\n      console.error('导入失败:', error)\n      ElMessage.error('导入失败，请稍后重试')\n    }\n  }\n  \n  const previewResume = () => {\n    // TODO: 实现预览功能\n    ElMessage.info('功能开发中')\n  }\n  // 处理头像更新\n\n  const handleCreationsSelected = async (selectedIds) => {\n    try {\n      await withLoading(async () => {\n        selectedCreationIds.value = selectedIds\n        closeCreationModal()\n        ElMessage.success('作品选择成功')\n      })\n    } catch (error) {\n      console.error('作品选择失败:', error)\n      ElMessage.error('作品选择失败，请稍后重试')\n    }\n  }\n  \n  const editItem = (moduleId, item) => {\n    editModule(moduleId)\n    formData.value = { ...item }\n    showEditModal.value = true\n  }\n  \n  // 添加调试日志\n  watch(() => profileData.resumeData.value, (newVal) => {\n    console.log('Profile data changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 添加调试日志\n  watch(() => store.getters.getUserInfo, (newVal) => {\n    console.log('Store user info changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 处理组件卸载\n  onBeforeUnmount(() => {\n    // 清理状态\n    showEditBasicDialog.value = false\n    loading.value = false\n  })\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CAyEM,OAzENC,UAyEM,GAxEJC,mBAAA,CAuCM,OAvCNC,UAuCM,GAtCJC,mBAAA,YAAe,EAETC,MAAA,CAAAC,WAAW,CAACC,UAAU,CAACC,KAAK,I,cADlCC,YAAA,CAUAJ,MAAA;IAfRK,GAAA;IAOSH,UAAU,EAAEF,MAAA,CAAAC,WAAW,CAACC,UAAU,CAACC,KAAK;IACxCG,OAAO,EAAEN,MAAA,CAAAM,OAAO;IAChBC,WAAW,EAAEP,MAAA,CAAAC,WAAW,CAACM,WAAW;IACpCC,mBAAmB,EAAER,MAAA,CAAAC,WAAW,CAACO,mBAAmB;IACpDC,UAAU,EAAET,MAAA,CAAAS,UAAU;IACtBC,MAAI,EAAEV,MAAA,CAAAW,UAAU;IAChBC,iBAAe,EAAEZ,MAAA,CAAAa,eAAe;IAChCC,MAAI,EAAEd,MAAA,CAAAe;4GAdfhB,mBAAA,gBAiBQA,mBAAA,YAAe,EACfiB,YAAA,CAMEhB,MAAA;IALC,iBAAe,EAAEiB,IAAA,CAAAC,cAAc;IAC/BZ,OAAO,EAAEN,MAAA,CAAAM,OAAO;IAChBa,YAAW,EAAEnB,MAAA,CAAAoB,cAAc;IAC3BC,QAAM,EAAErB,MAAA,CAAAsB,YAAY;IACpBC,SAAO,EAAEvB,MAAA,CAAAwB;2EAGZzB,mBAAA,YAAe,EACfiB,YAAA,CAOEhB,MAAA;IANC,gBAAc,EAAEA,MAAA,CAAAyB,aAAa;IAC7BnB,OAAO,EAAEN,MAAA,CAAAM,OAAO;IAChBQ,MAAI,EAAEd,MAAA,CAAA0B,UAAU;IAChBC,KAAG,EAAE3B,MAAA,CAAA4B,OAAO;IACZC,QAAM,EAAE7B,MAAA,CAAA8B,YAAY;IACpBC,UAAS,EAAE/B,MAAA,CAAAgC;yFAGdjC,mBAAA,YAAe,EACfiB,YAAA,CAIEhB,MAAA;IAHC,kBAAgB,EAAEA,MAAA,CAAAiC,eAAe;IACjC3B,OAAO,EAAEN,MAAA,CAAAM,OAAO;IAChB4B,UAAQ,EAAElC,MAAA,CAAAmC;4EAIfpC,mBAAA,UAAa,EACbiB,YAAA,CAKEhB,MAAA;IAlDRoC,UAAA,EA8CiBpC,MAAA,CAAAqC,mBAAmB;IA9CpC,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA8CiBvC,MAAA,CAAAqC,mBAAmB,GAAAE,MAAA;IAC3B,cAAY,EAAEvC,MAAA,CAAAwC,aAAa;IAC3BlC,OAAO,EAAEN,MAAA,CAAAM,OAAO;IAChBmC,QAAM,EAAEzC,MAAA,CAAA0C;sEAGX1B,YAAA,CAOEhB,MAAA;IA3DRoC,UAAA,EAqDiBpC,MAAA,CAAA2C,aAAa;IArD9B,uBAAAL,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAqDiBvC,MAAA,CAAA2C,aAAa,GAAAJ,MAAA;IACrBK,MAAM,EAAE5C,MAAA,CAAA6C,aAAa;IACrB,mBAAiB,EAAE5B,IAAA,CAAA6B,QAAQ;IAC3BxC,OAAO,EAAEW,IAAA,CAAA8B,cAAc;IACvBN,QAAM,EAAEzC,MAAA,CAAAgD,YAAY;IACpBC,QAAM,EAAEjD,MAAA,CAAAkD;qFAGXlC,YAAA,CAKEhB,MAAA;IAlERoC,UAAA,EA8DiBpC,MAAA,CAAAmD,WAAW;IA9D5B,uBAAAb,MAAA,QAAAA,MAAA,MAAAC,MAAA,IA8DiBvC,MAAA,CAAAmD,WAAW,GAAAZ,MAAA;IACnBa,WAAW,EAAEpD,MAAA,CAAAqD,aAAa;IAC1B/C,OAAO,EAAEW,IAAA,CAAA8B,cAAc;IACvBO,QAAM,EAAEtD,MAAA,CAAAuD;iFAGXvC,YAAA,CAMEhB,MAAA;IA1ERoC,UAAA,EAqEiBpC,MAAA,CAAAwD,iBAAiB;IArElC,uBAAAlB,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAqEiBvC,MAAA,CAAAwD,iBAAiB,GAAAjB,MAAA;IACzB,cAAY,EAAEvC,MAAA,CAAAyD,mBAAmB;IACjCnD,OAAO,EAAEW,IAAA,CAAA8B,cAAc;IACvBN,QAAM,EAAEzC,MAAA,CAAA0D,uBAAuB;IAC/BT,QAAM,EAAEjD,MAAA,CAAA2D","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}