enter\">\n          <TransitionChild\n            as=\"template\"\n            enter=\"duration-300 ease-out\"\n            enter-from=\"opacity-0 scale-95\"\n            enter-to=\"opacity-100 scale-100\"\n            leave=\"duration-200 ease-in\"\n            leave-from=\"opacity-100 scale-100\"\n            leave-to=\"opacity-0 scale-95\"\n          >\n            <DialogPanel class=\"w-full max-w-md transform overflow-hidden rounded-xl bg-white text-left align-middle shadow-xl transition-all\">\n              <DialogTitle as=\"h3\" class=\"text-lg font-medium text-gray-900 p-6 pb-0\">\n                {{ initialData?.id ? '编辑社交主页' : '添加社交主页' }}\n              </DialogTitle>\n\n              <form @submit.prevent=\"handleSubmit\" class=\"p-6\">\n                <div class=\"space-y-4\">\n                  <!-- 平台选择 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      平台名称 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <select\n                      v-model=\"formData.platform\"\n                      required\n                      class=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                    >\n                      <option value=\"\">请选择平台</option>\n                      <option v-for=\"platform in platformOptions\" \n                        :key=\"platform.value\" \n                        :value=\"platform.value\"\n                      >\n                        {{ platform.label }}\n                      </option>\n                    </select>\n                  </div>\n\n                  <!-- 用户名/账号 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      用户名/账号 <span class=\"text-red-500\">*</span>\n                    </label>\n                    <div class=\"flex items-center space-x-2\">\n                      <input\n                        v-model=\"formData.username\"\n                        type=\"text\"\n                        required\n                        class=\"flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                        :placeholder=\"getPlaceholder\"\n                      />\n                      <span v-if=\"platformPrefix\" class=\"text-sm text-gray-500\">\n                        {{ platformPrefix }}\n                      </span>\n                    </div>\n                  </div>\n\n                  <!-- 链接预览 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      链接地址\n                    </label>\n                    <div class=\"px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600\">\n                      {{ generatedUrl }}\n                    </div>\n                  </div>\n\n                  <!-- 描述 -->\n                  <div>\n                    <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                      描述\n                    </label>\n                    <textarea\n                      v-model=\"formData.description\"\n                      rows=\"3\"\n                      class=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                      placeholder=\"简单描述一下这个社交主页\"\n                    />\n                  </div>\n                </div>\n\n                <div class=\"mt-6 flex justify-end space-x-3\">\n                  <button\n                    type=\"button\"\n                    @click=\"$emit('update:modelValue', false)\"\n                    class=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50\"\n                  >\n                    取消\n                  </button>\n                  <button\n                    type=\"submit\"\n                    :disabled=\"loading\"\n                    class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed\"\n                  >\n                    {{ loading ? '保存中...' : '保存' }}\n                  </button>\n                </div>\n              </form>\n            </DialogPanel>\n          </TransitionChild>\n        </div>\n      </div>\n    </Dialog>\n  </TransitionRoot>\n</template>\n\n<script setup>\nimport { ref, watch, computed } from 'vue'\nimport {\n  Dialog,\n  DialogPanel,\n  DialogTitle,\n  TransitionRoot,\n  TransitionChild\n} from '@headlessui/vue'\n\n// 平台配置\nconst platformOptions = [\n  { value: 'weibo', label: '新浪微博', urlPattern: 'https://weibo.com/{username}' },\n  { value: 'zhihu', label: '知乎', urlPattern: 'https://www.zhihu.com/people/{username}' },\n  { value: 'zcool', label: '站酷', urlPattern: 'https://www.zcool.com.cn/u/{username}' },\n  { value: 'douyin', label: '抖音', urlPattern: 'https://www.douyin.com/user/{username}' },\n  { value: 'bilibili', label: 'Bilibili', urlPattern: 'https://space.bilibili.com/{username}' },\n  { value: 'github', label: 'GitHub', urlPattern: 'https://github.com/{username}' },\n  { value: 'twitter', label: 'Twitter', urlPattern: 'https://twitter.com/{username}' },\n  { value: 'website', label: '个人网站', urlPattern: '{username}' },\n  { value: 'other', label: '其他', urlPattern: '{username}' }\n]\n\nconst props = defineProps({\n  modelValue: {\n    type: Boolean,\n    required: true\n  },\n  initialData: {\n    type: Object,\n    default: () => ({})\n  },\n  loading: {\n    type: Boolean,\n    default: false\n  }\n})\n\nconst emit = defineEmits(['update:modelValue', 'submit'])\n\nconst formData = ref({\n  platform: '',\n  username: '',\n  description: ''\n})\n\n// 获取当前选择的平台配置\nconst currentPlatform = computed(() => \n  platformOptions.find(p => p.value === formData.value.platform)\n)\n\n// 生成输入框占位符\nconst getPlaceholder = computed(() => {\n  switch (formData.value.platform) {\n    case 'weibo': return '输入微博用户名或ID'\n    case 'zhihu': return '输入知乎用户名或ID'\n    case 'zcool': return '输入站酷用户ID'\n    case 'douyin': return '输入抖音号'\n    case 'bilibili': return '输入B站UID'\n    case 'github': return '输入GitHub用户名'\n    case 'twitter': return '输入Twitter用户名'\n    case 'website': return '输入完整的网址'\n    case 'other': return '输入完整的网址'\n    default: return '请先选择平台'\n  }\n})\n\n// 生成完整URL\nconst generatedUrl = computed(() => {\n  if (!formData.value.platform || !formData.value.username) return ''\n  \n  const platform = currentPlatform.value\n  if (!platform) return ''\n\n  if (platform.value === 'website' || platform.value === 'other') {\n    return formData.value.username\n  }\n\n  return platform.urlPattern.replace('{username}', formData.value.username)\n})\n\n// 监听初始数据变化\nwatch(() => props.initialData, (newData) => {\n  if (newData) {\n    // 如果是编辑模式，从URL中提取用户名\n    const platform = platformOptions.find(p => p.value === newData.platform)\n    let username = newData.url\n    \n    if (platform && platform.urlPattern) {\n      const pattern = platform.urlPattern.replace('{username}', '(.*)')\n      const regex = new RegExp(pattern)\n      const match = newData.url.match(regex)\n      if (match) {\n        username = match[1]\n      }\n    }\n\n    formData.value = {\n      ...formData.value,\n      ...newData,\n      username\n    }\n  }\n}, { immediate: true })\n\nconst handleSubmit = () => {\n  emit('submit', {\n    ...formData.value,\n    url: generatedUrl.value,\n    id: props.initialData?.id\n  })\n}\n</script> "],"mappings":";AA0HA,SAASA,GAAG,EAAEC,KAAK,EAAEC,QAAQ,QAAQ,KAAI;AACzC,SACEC,MAAM,EACNC,WAAW,EACXC,WAAW,EACXC,cAAc,EACdC,eAAc,QACT,iBAAgB;;AAEvB;;;;;;;;;;;;;;;;;;;;;;;;IACA,MAAMC,eAAe,GAAG,CACtB;MAAEC,KAAK,EAAE,OAAO;MAAEC,KAA