{"ast":null,"code":"import { createCommentVNode as _createCommentVNode, createVNode as _createVNode, createElementVNode as _createElementVNode, openBlock as _openBlock, createElementBlock as _createElementBlock } from \"vue\";\nconst _hoisted_1 = {\n  class: \"container mx-auto\"\n};\nconst _hoisted_2 = {\n  class: \"max-w-4xl mx-auto space-y-4\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createElementVNode(\"div\", _hoisted_2, [_createCommentVNode(\" 基本信息卡片 \"), _createVNode($setup[\"BasicInfo\"], {\n    resumeData: $setup.profileData.resumeData.value || {},\n    loading: $setup.loading,\n    bioExpanded: $setup.profileData.bioExpanded.value,\n    showBioExpandButton: $setup.profileData.showBioExpandButton.value,\n    getBioText: $setup.getBioText,\n    onSave: $setup.handleSave,\n    onToggleBioExpand: $setup.toggleBioExpand,\n    onEdit: $setup.handleEdit\n  }, null, 8 /* PROPS */, [\"resumeData\", \"loading\", \"bioExpanded\", \"showBioExpandButton\", \"getBioText\"]), _createCommentVNode(\" 简历状态卡片 \"), _createVNode($setup[\"ResumeStatus\"], {\n    \"completion-data\": $setup.completionData,\n    loading: $setup.loading,\n    onAiOptimize: $setup.showAIOptimize,\n    onImport: $setup.importResume,\n    onPreview: $setup.previewResume\n  }, null, 8 /* PROPS */, [\"completion-data\", \"loading\", \"onAiOptimize\"]), _createCommentVNode(\" 常规模块列表 \"), _createVNode($setup[\"ModuleList\"], {\n    \"active-modules\": $setup.activeModules,\n    loading: $setup.loading,\n    onEdit: $setup.editModule,\n    onAdd: $setup.addItem,\n    onRemove: $setup.removeModule,\n    onEditItem: $setup.editItem\n  }, null, 8 /* PROPS */, [\"active-modules\", \"loading\", \"onEdit\", \"onAdd\", \"onRemove\"]), _createCommentVNode(\" 添加更多模块 \"), _createVNode($setup[\"AddModule\"], {\n    \"inactive-modules\": $setup.inactiveModules,\n    loading: $setup.loading,\n    onActivate: $setup.activateModule\n  }, null, 8 /* PROPS */, [\"inactive-modules\", \"loading\", \"onActivate\"])]), _createCommentVNode(\" 弹窗组件 \"), _createVNode($setup[\"EditBasicDialog\"], {\n    modelValue: $setup.showEditBasicDialog,\n    \"onUpdate:modelValue\": _cache[0] || (_cache[0] = $event => $setup.showEditBasicDialog = $event),\n    \"initial-data\": $setup.basicFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleBasicSubmit\n  }, null, 8 /* PROPS */, [\"modelValue\", \"initial-data\", \"loading\"]), _createVNode($setup[\"EditDialog\"], {\n    modelValue: $setup.showEditModal,\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.showEditModal = $event),\n    module: $setup.currentModule,\n    \"initial-form-data\": $setup.editFormData,\n    loading: $setup.loading,\n    onSubmit: $setup.handleSubmit,\n    onCancel: $setup.handleCancel\n  }, null, 8 /* PROPS */, [\"modelValue\", \"module\", \"initial-form-data\", \"loading\"]), _createVNode($setup[\"AIDialog\"], {\n    modelValue: $setup.showAIModal,\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.showAIModal = $event),\n    suggestions: $setup.aiSuggestions,\n    loading: $setup.loading,\n    onAction: $setup.handleAIAction\n  }, null, 8 /* PROPS */, [\"modelValue\", \"suggestions\", \"loading\", \"onAction\"]), _createVNode($setup[\"CreationDialog\"], {\n    modelValue: $setup.showCreationModal,\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $setup.showCreationModal = $event),\n    \"selected-ids\": $setup.selectedCreationIds,\n    loading: $setup.loading,\n    onSubmit: $setup.handleCreationsSelected,\n    onCancel: $setup.closeCreationModal\n  }, null, 8 /* PROPS */, [\"modelValue\", \"selected-ids\", \"loading\", \"onCancel\"])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_createCommentVNode","_createVNode","$setup","resumeData","profileData","value","loading","bioExpanded","showBioExpandButton","getBioText","onSave","handleSave","onToggleBioExpand","toggleBioExpand","onEdit","handleEdit","completionData","onAiOptimize","showAIOptimize","onImport","importResume","onPreview","previewResume","activeModules","editModule","onAdd","addItem","onRemove","removeModule","onEditItem","editItem","inactiveModules","onActivate","activateModule","modelValue","showEditBasicDialog","_cache","$event","basicFormData","onSubmit","handleBasicSubmit","showEditModal","module","currentModule","editFormData","handleSubmit","onCancel","handleCancel","showAIModal","suggestions","aiSuggestions","onAction","handleAIAction","showCreationModal","selectedCreationIds","handleCreationsSelected","closeCreationModal"],"sources":["/Users/liuzhao/Documents/Projects/flybird-web/src/views/user/MyProfile/index.vue"],"sourcesContent":["<!-- src/views/user/MyProfile/index.vue -->\n<template>\n    <div class=\"container mx-auto\">\n      <div class=\"max-w-4xl mx-auto space-y-4\">\n        <!-- 基本信息卡片 -->\n        <BasicInfo\n        :resumeData=\"profileData.resumeData.value || {}\"\n        :loading=\"loading\"\n        :bioExpanded=\"profileData.bioExpanded.value\"\n        :showBioExpandButton=\"profileData.showBioExpandButton.value\"\n        :getBioText=\"getBioText\"\n        @save=\"handleSave\"\n        @toggleBioExpand=\"toggleBioExpand\"\n        @edit=\"handleEdit\"\n      />\n  \n        <!-- 简历状态卡片 -->\n        <ResumeStatus\n          :completion-data=\"completionData\"\n          :loading=\"loading\"\n          @ai-optimize=\"showAIOptimize\"\n          @import=\"importResume\"\n          @preview=\"previewResume\"\n        />\n  \n        <!-- 常规模块列表 -->\n        <ModuleList\n          :active-modules=\"activeModules\"\n          :loading=\"loading\"\n          @edit=\"editModule\"\n          @add=\"addItem\"\n          @remove=\"removeModule\"\n          @edit-item=\"editItem\"\n        />\n  \n        <!-- 添加更多模块 -->\n        <AddModule\n          :inactive-modules=\"inactiveModules\"\n          :loading=\"loading\"\n          @activate=\"activateModule\"\n        />\n      </div>\n  \n      <!-- 弹窗组件 -->\n      <EditBasicDialog\n        v-model=\"showEditBasicDialog\"\n        :initial-data=\"basicFormData\"\n        :loading=\"loading\"\n        @submit=\"handleBasicSubmit\"\n      />\n  \n      <EditDialog\n        v-model=\"showEditModal\"\n        :module=\"currentModule\"\n        :initial-form-data=\"editFormData\"\n        :loading=\"loading\"\n        @submit=\"handleSubmit\"\n        @cancel=\"handleCancel\"\n      />\n  \n      <AIDialog\n        v-model=\"showAIModal\"\n        :suggestions=\"aiSuggestions\"\n        :loading=\"loading\"\n        @action=\"handleAIAction\"\n      />\n  \n      <CreationDialog\n        v-model=\"showCreationModal\"\n        :selected-ids=\"selectedCreationIds\"\n        :loading=\"loading\"\n        @submit=\"handleCreationsSelected\"\n        @cancel=\"closeCreationModal\"\n      />\n    </div>\n  </template>\n  \n  <script setup>\n  import { ref, onMounted, computed, watch, onBeforeUnmount } from 'vue'\n  import { ElMessage } from 'element-plus'\n  import store from '@/store'\n  import { profile } from '@/api/profile'\n  \n  // 组件导入\n  import BasicInfo from './components/BasicInfo.vue'\n  import ResumeStatus from './components/ResumeStatus.vue'\n  import ModuleList from './components/ModuleList.vue'\n  import AddModule from './components/AddModule.vue'\n  import EditDialog from './dialogs/EditDialog.vue'\n  import AIDialog from './dialogs/AIDialog.vue'\n  import CreationDialog from './dialogs/CreationDialog.vue'\n  import EditBasicDialog from './dialogs/EditBasicDialog.vue'\n  \n  // Composables\n  import { useProfileData } from './composables/useProfileData'\n  import { useModules } from './composables/useModules'\n  import { useDialog } from './composables/useDialog'\n  import { useLoading } from './composables/useLoading'\n \n  // 初始化 profileData\n  const profileData = useProfileData()\n  const loading = ref(false)\n  const editFormData = ref({})\n  \n  // 添加调试日志\n  console.log('MyProfile profileData:', profileData)\n  \n  // 计算属性：获取处理后的个人简介文本\n  const getBioText = computed(() => {\n    if (!profileData.resumeData.value) return ''\n    return profileData.getBioText()\n  })\n  \n  // 处理保存\n  const handleSave = async (formData) => {\n    console.log('Handling save:', formData)\n    const success = await profileData.updateResumeData(formData)\n    if (success) {\n      await profileData.fetchInitialData()\n    }\n    return success\n  }\n  \n  // 处理展开/收起\n  const toggleBioExpand = () => {\n    console.log('Toggling bio expand')\n    profileData.toggleBioExpand()\n  }\n  \n  const {\n    activeModules,\n    inactiveModules,\n    currentModule,\n    editModule,\n    addItem,\n    removeModule,\n    activateModule\n  } = useModules()\n  \n  const {\n    showEditModal,\n    showAIModal,\n    showCreationModal,\n    aiSuggestions,\n    selectedCreationIds,\n    showAIOptimize,\n    closeCreationModal,\n    handleAIAction\n  } = useDialog()\n  \n  const { loading: actionLoading, withLoading } = useLoading()  // 重命名避免冲突\n  \n  // 基本信息编辑状态\n  const showEditBasicDialog = ref(false)\n  const basicFormData = ref({})\n  \n  // 处理编辑按钮点击\n  const handleEdit = () => {\n    if (!profileData.resumeData.value) return\n    basicFormData.value = {\n      name: profileData.resumeData.value.name || '',\n      gender: profileData.resumeData.value.gender || '',\n      phone: profileData.resumeData.value.phone || '',\n      email: profileData.resumeData.value.email || '',\n      location: profileData.resumeData.value.location || '',\n      birth_date: profileData.resumeData.value.birth_date || '',\n      personal_summary: profileData.resumeData.value.personal_summary || ''\n    }\n    console.log('编辑表单数据:', basicFormData.value)\n    showEditBasicDialog.value = true\n  }\n  \n  // 处理基本信息提交\n  const handleBasicSubmit = async (formData) => {\n    if (!formData) return\n\n    loading.value = true\n    try {\n      await profileData.updateResumeData(formData)\n      showEditBasicDialog.value = false\n      ElMessage.success('保存成功')\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请稍后重试')\n    } finally {\n      loading.value = false\n    }\n  }\n  \n  // 修改完整度状态\n  const completionData = ref({\n    total_score: 0,\n    dimensions: {},\n    suggestions: []\n  })\n  \n  // 获取完整度数据\n  const fetchCompleteness = async () => {\n    try {\n      const response = await profile.getCompleteness()\n      if (response.data) {\n        completionData.value = response.data\n      }\n    } catch (error) {\n      console.error('获取简历完整度失败:', error)\n    }\n  }\n  \n  // 生命周期钩子\n  onMounted(async () => {\n    console.log('MyProfile mounted')\n    loading.value = true\n    try {\n      // 并行请求所有数据\n      await Promise.all([\n        profileData.fetchInitialData(),\n        fetchCompleteness()\n      ])\n    } catch (error) {\n      console.error('初始化数据失败:', error)\n      ElMessage.error('加载数据失败，请刷新页面重试')\n    } finally {\n      loading.value = false\n    }\n  })\n  \n  // 监听数据变化，当基本信息更新时重新获取完整度\n  watch(() => profileData.resumeData.value, async () => {\n    try {\n      await fetchCompleteness()\n    } catch (error) {\n      console.error('更新完整度失败:', error)\n    }\n  }, { deep: true })\n  \n  // 处理函数\n  const handleSubmit = async (formData) => {\n    try {\n      await withLoading(async () => {\n        await profileData.updateResumeData(formData)\n        showEditModal.value = false\n        ElMessage.success('保存成功')\n      })\n    } catch (error) {\n      console.error('保存失败:', error)\n      ElMessage.error('保存失败，请检查表单')\n    }\n  }\n  \n  const handleCancel = () => {\n    showEditModal.value = false\n  }\n  \n  \n  const importResume = async () => {\n    try {\n      await withLoading(async () => {\n        // TODO: 实现导入功能\n        ElMessage.info('功能开发中')\n      })\n    } catch (error) {\n      console.error('导入失败:', error)\n      ElMessage.error('导入失败，请稍后重试')\n    }\n  }\n  \n  const previewResume = () => {\n    // TODO: 实现预览功能\n    ElMessage.info('功能开发中')\n  }\n  // 处理头像更新\n\n  const handleCreationsSelected = async (selectedIds) => {\n    try {\n      await withLoading(async () => {\n        selectedCreationIds.value = selectedIds\n        closeCreationModal()\n        ElMessage.success('作品选择成功')\n      })\n    } catch (error) {\n      console.error('作品选择失败:', error)\n      ElMessage.error('作品选择失败，请稍后重试')\n    }\n  }\n  \n  const editItem = (moduleId, item) => {\n    editModule(moduleId)\n    editFormData.value = { ...item }\n    showEditModal.value = true\n  }\n  \n  // 添加调试日志\n  watch(() => profileData.resumeData.value, (newVal) => {\n    console.log('Profile data changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 添加调试日志\n  watch(() => store.getters.getUserInfo, (newVal) => {\n    console.log('Store user info changed:', newVal)\n  }, { deep: true, immediate: true })\n  \n  // 处理组件卸载\n  onBeforeUnmount(() => {\n    // 清理状态\n    showEditBasicDialog.value = false\n    loading.value = false\n  })\n  </script>"],"mappings":";;EAESA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAA6B;;uBAD1CC,mBAAA,CAwEM,OAxENC,UAwEM,GAvEJC,mBAAA,CAsCM,OAtCNC,UAsCM,GArCJC,mBAAA,YAAe,EACfC,YAAA,CASAC,MAAA;IARCC,UAAU,EAAED,MAAA,CAAAE,WAAW,CAACD,UAAU,CAACE,KAAK;IACxCC,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBC,WAAW,EAAEL,MAAA,CAAAE,WAAW,CAACG,WAAW,CAACF,KAAK;IAC1CG,mBAAmB,EAAEN,MAAA,CAAAE,WAAW,CAACI,mBAAmB,CAACH,KAAK;IAC1DI,UAAU,EAAEP,MAAA,CAAAO,UAAU;IACtBC,MAAI,EAAER,MAAA,CAAAS,UAAU;IAChBC,iBAAe,EAAEV,MAAA,CAAAW,eAAe;IAChCC,MAAI,EAAEZ,MAAA,CAAAa;0GAGPf,mBAAA,YAAe,EACfC,YAAA,CAMEC,MAAA;IALC,iBAAe,EAAEA,MAAA,CAAAc,cAAc;IAC/BV,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBW,YAAW,EAAEf,MAAA,CAAAgB,cAAc;IAC3BC,QAAM,EAAEjB,MAAA,CAAAkB,YAAY;IACpBC,SAAO,EAAEnB,MAAA,CAAAoB;2EAGZtB,mBAAA,YAAe,EACfC,YAAA,CAOEC,MAAA;IANC,gBAAc,EAAEA,MAAA,CAAAqB,aAAa;IAC7BjB,OAAO,EAAEJ,MAAA,CAAAI,OAAO;IAChBQ,MAAI,EAAEZ,MAAA,CAA