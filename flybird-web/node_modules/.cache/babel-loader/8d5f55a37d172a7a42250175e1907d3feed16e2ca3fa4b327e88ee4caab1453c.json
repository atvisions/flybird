{"ast":null,"code":"import { ref, computed, watch, onMounted } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter } from 'vue-router';\nimport { showToast } from '@/components/ToastMessage';\nimport { auth } from '@/api/auth';\nimport { deleteAccount } from '@/api/user';\nimport { SMS_SCENE } from '@/store';\nexport default {\n  __name: 'AccountSettings',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const store = useStore();\n    const router = useRouter();\n\n    // 用户基本信息\n    const userBasicInfo = ref(null);\n    const loading = ref(false);\n\n    // 获取用户基本信息\n    const fetchUserBasicInfo = async () => {\n      try {\n        loading.value = true;\n        const response = await auth.getUserInfo();\n        if (response.data?.code === 200) {\n          userBasicInfo.value = response.data.data;\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n        showToast('获取用户信息失败', 'error');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 在组件挂载时获取用户信息\n    onMounted(() => {\n      if (store.state.isAuthenticated) {\n        fetchUserBasicInfo();\n      }\n    });\n\n    // 监听认证状态变化\n    watch(() => store.state.isAuthenticated, isAuthenticated => {\n      if (isAuthenticated) {\n        fetchUserBasicInfo();\n      } else {\n        userBasicInfo.value = null;\n      }\n    });\n\n    // 计算属性\n    const username = computed(() => userBasicInfo.value?.user?.username || '未设置');\n    const uid = computed(() => userBasicInfo.value?.user?.uid || '暂无');\n    const phone = computed(() => userBasicInfo.value?.user?.phone || '');\n\n    // 手机号脱敏处理\n    const maskPhone = phone => {\n      if (!phone) return '未绑定';\n      return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2');\n    };\n\n    // 模态框状态\n    const showPhoneModal = ref(false);\n    const showPasswordModal = ref(false);\n\n    // 添加注销账户相关的状态和方法\n    const showDeleteConfirm = ref(false);\n\n    // 处理注销账户\n    const handleDeleteAccount = async () => {\n      try {\n        await deleteAccount();\n        showToast('账户已注销', 'success');\n        store.dispatch('logout');\n        router.push('/login');\n      } catch (error) {\n        showToast(error.message || '注销账户失败，请重试', 'error');\n      } finally {\n        showDeleteConfirm.value = false;\n      }\n    };\n    const __returned__ = {\n      store,\n      router,\n      userBasicInfo,\n      loading,\n      fetchUserBasicInfo,\n      username,\n      uid,\n      phone,\n      maskPhone,\n      showPhoneModal,\n      showPasswordModal,\n      showDeleteConfirm,\n      handleDeleteAccount,\n      ref,\n      computed,\n      watch,\n      onMounted,\n      get useStore() {\n        return useStore;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      },\n      get auth() {\n        return auth;\n      },\n      get deleteAccount() {\n        return deleteAccount;\n      },\n      get SMS_SCENE() {\n        return SMS_SCENE;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","watch","onMounted","useStore","useRouter","showToast","auth","deleteAccount","SMS_SCENE","store","router","userBasicInfo","loading","fetchUserBasicInfo","value","response","getUserInfo","data","code","error","console","state","isAuthenticated","username","user","uid","phone","maskPhone","replace","showPhoneModal","showPasswordModal","showDeleteConfirm","handleDeleteAccount","dispatch","push","message"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/AccountSettings.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <!-- 账户信息 -->\n    <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n      <!-- 标题栏 -->\n      <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n        <h2 class=\"text-lg font-medium text-gray-900\">账户信息</h2>\n      </div>\n      \n      <!-- 内容区 -->\n      <div class=\"p-6 space-y-6\">\n        <!-- UID -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-2\">\n            <span class=\"text-sm font-medium text-gray-500\">用户 ID</span>\n            <span class=\"text-sm text-gray-900\">{{ uid }}</span>\n          </div>\n          <div class=\"text-xs text-gray-500\">用户唯一标识</div>\n        </div>\n\n        <!-- 昵称 -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex items-center space-x-2\">\n            <span class=\"text-sm font-medium text-gray-500\">昵称</span>\n            <span class=\"text-sm text-gray-900\">{{ username }}</span>\n            <span class=\"text-xs text-gray-400\" v-if=\"!username\">\n              (默认为 Flybird + 手机号后4位)\n            </span>\n          </div>\n          <button @click=\"showNicknameModal = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n            transition-colors rounded-md hover:bg-indigo-50\">\n            <svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                d=\"M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z\" />\n            </svg>\n            设置\n          </button>\n        </div>\n      </div>\n    </section>\n\n    <!-- 账户安全 -->\n    <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n      <!-- 标题栏 -->\n      <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n        <h2 class=\"text-lg font-medium text-gray-900\">账户安全</h2>\n      </div>\n      \n      <!-- 内容区 -->\n      <div class=\"p-6 space-y-6\">\n        <!-- 手机号 -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex-1\">\n            <div class=\"flex items-center space-x-2\">\n              <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z\" />\n              </svg>\n              <span class=\"text-sm font-medium text-gray-900\">手机号</span>\n            </div>\n            <p class=\"mt-1 text-sm text-gray-500\">{{ maskPhone(phone) }}</p>\n          </div>\n          <button @click=\"showPhoneModal = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n            transition-colors rounded-md hover:bg-indigo-50\">\n            更换手机号\n          </button>\n        </div>\n\n        <!-- 密码 -->\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex-1\">\n            <div class=\"flex items-center space-x-2\">\n              <svg class=\"w-5 h-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n              </svg>\n              <span class=\"text-sm font-medium text-gray-900\">登录密码</span>\n            </div>\n            <p class=\"mt-1 text-sm text-gray-500\">用于保护账号安全</p>\n          </div>\n          <button @click=\"showPasswordModal = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700 \n            transition-colors rounded-md hover:bg-indigo-50\">\n            修改密码\n          </button>\n        </div>\n      </div>\n    </section>\n\n    <!-- 注销账户 -->\n    <section class=\"bg-white rounded-lg shadow overflow-hidden\">\n      <!-- 标题栏 -->\n      <div class=\"px-6 py-4 bg-gray-100 border-b border-gray-200\">\n        <h2 class=\"text-lg font-medium text-gray-900\">注销账户</h2>\n      </div>\n      \n      <!-- 内容区 -->\n      <div class=\"p-6\">\n        <div class=\"flex items-center justify-between\">\n          <div class=\"flex-1\">\n            <div class=\"flex items-center space-x-2\">\n              <svg class=\"w-5 h-5 text-red-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" \n                  d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\n              </svg>\n              <span class=\"text-sm font-medium text-gray-900\">注销账户</span>\n            </div>\n            <p class=\"mt-1 text-sm text-gray-500\">注销后，账户将被永久删除且无法恢复</p>\n          </div>\n          <button @click=\"showDeleteConfirm = true\"\n            class=\"inline-flex items-center px-3 py-1.5 text-sm font-medium text-red-600 hover:text-red-700 \n            transition-colors rounded-md hover:bg-red-50\">\n            注销账户\n          </button>\n        </div>\n      </div>\n    </section>\n\n    <!-- 注销确认对话框 -->\n    <div v-if=\"showDeleteConfirm\" class=\"fixed inset-0 z-50 overflow-y-auto\" aria-labelledby=\"modal-title\" role=\"dialog\" aria-modal=\"true\">\n      <div class=\"flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0\">\n        <!-- 背景遮罩 -->\n        <div class=\"fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity\" aria-hidden=\"true\"></div>\n        <span class=\"hidden sm:inline-block sm:align-middle sm:h-screen\" aria-hidden=\"true\">&#8203;</span>\n        \n        <!-- 对话框内容 -->\n        <div class=\"inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full\">\n          <div class=\"bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4\">\n            <div class=\"sm:flex sm:items-start\">\n              <div class=\"mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10\">\n                <svg class=\"h-6 w-6 text-red-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n                </svg>\n              </div>\n              <div class=\"mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left\">\n                <h3 class=\"text-lg leading-6 font-medium text-gray-900\" id=\"modal-title\">确认注销账户？</h3>\n                <div class=\"mt-2\">\n                  <p class=\"text-sm text-gray-500\">\n                    注销后，您的账户将被永久删除，所有数据将无法恢复。请谨慎操作。\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div class=\"bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse\">\n            <button type=\"button\" @click=\"handleDeleteAccount\"\n              class=\"w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:ml-3 sm:w-auto sm:text-sm\">\n              确认注销\n            </button>\n            <button type=\"button\" @click=\"showDeleteConfirm = false\"\n              class=\"mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm\">\n              取消\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, watch, onMounted } from 'vue'\nimport { useStore } from 'vuex'\nimport { useRouter } from 'vue-router'\nimport { showToast } from '@/components/ToastMessage'\nimport { auth } from '@/api/auth'\nimport { deleteAccount } from '@/api/user'\nimport { SMS_SCENE } from '@/store'\n\nconst store = useStore()\nconst router = useRouter()\n\n// 用户基本信息\nconst userBasicInfo = ref(null)\nconst loading = ref(false)\n\n// 获取用户基本信息\nconst fetchUserBasicInfo = async () => {\n  try {\n    loading.value = true\n    const response = await auth.getUserInfo()\n    if (response.data?.code === 200) {\n      userBasicInfo.value = response.data.data\n    }\n  } catch (error) {\n    console.error('获取用户信息失败:', error)\n    showToast('获取用户信息失败', 'error')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 在组件挂载时获取用户信息\nonMounted(() => {\n  if (store.state.isAuthenticated) {\n    fetchUserBasicInfo()\n  }\n})\n\n// 监听认证状态变化\nwatch(() => store.state.isAuthenticated, (isAuthenticated) => {\n  if (isAuthenticated) {\n    fetchUserBasicInfo()\n  } else {\n    userBasicInfo.value = null\n  }\n})\n\n// 计算属性\nconst username = computed(() => userBasicInfo.value?.user?.username || '未设置')\nconst uid = computed(() => userBasicInfo.value?.user?.uid || '暂无')\nconst phone = computed(() => userBasicInfo.value?.user?.phone || '')\n\n// 手机号脱敏处理\nconst maskPhone = (phone) => {\n  if (!phone) return '未绑定'\n  return phone.replace(/(\\d{3})\\d{4}(\\d{4})/, '$1****$2')\n}\n\n// 模态框状态\nconst showPhoneModal = ref(false)\nconst showPasswordModal = ref(false)\n\n// 添加注销账户相关的状态和方法\nconst showDeleteConfirm = ref(false)\n\n// 处理注销账户\nconst handleDeleteAccount = async () => {\n  try {\n    await deleteAccount()\n    showToast('账户已注销', 'success')\n    store.dispatch('logout')\n    router.push('/login')\n  } catch (error) {\n    showToast(error.message || '注销账户失败，请重试', 'error')\n  } finally {\n    showDeleteConfirm.value = false\n  }\n}\n\n</script>\n\n<style scoped>\n/* 如果有任何样式，放在这里 */\n</style>"],"mappings":"AAmKA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAK,EAAEC,SAAS,QAAQ,KAAI;AACpD,SAASC,QAAQ,QAAQ,MAAK;AAC9B,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,2BAA0B;AACpD,SAASC,IAAI,QAAQ,YAAW;AAChC,SAASC,aAAa,QAAQ,YAAW;AACzC,SAASC,SAAS,QAAQ,SAAQ;;;;;;;IAElC,MAAMC,KAAK,GAAGN,QAAQ,CAAC;IACvB,MAAMO,MAAM,GAAGN,SAAS,CAAC;;IAEzB;IACA,MAAMO,aAAa,GAAGZ,GAAG,CAAC,IAAI;IAC9B,MAAMa,OAAO,GAAGb,GAAG,CAAC,KAAK;;IAEzB;IACA,MAAMc,kBAAkB,GAAG,MAAAA,CAAA,KAAY;MACrC,IAAI;QACFD,OAAO,CAACE,KAAK,GAAG,IAAG;QACnB,MAAMC,QAAQ,GAAG,MAAMT,IAAI,CAACU,WAAW,CAAC;QACxC,IAAID,QAAQ,CAACE,IAAI,EAAEC,IAAI,KAAK,GAAG,EAAE;UAC/BP,aAAa,CAACG,KAAK,GAAGC,QAAQ,CAACE,IAAI,CAACA,IAAG;QACzC;MACF,CAAC,CAAC,OAAOE,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;QAChCd,SAAS,CAAC,UAAU,EAAE,OAAO;MAC/B,CAAC,SAAS;QACRO,OAAO,CAACE,KAAK,GAAG,KAAI;MACtB;IACF;;IAEA;IACAZ,SAAS,CAAC,MAAM;MACd,IAAIO,KAAK,CAACY,KAAK,CAACC,eAAe,EAAE;QAC/BT,kBAAkB,CAAC;MACrB;IACF,CAAC;;IAED;IACAZ,KAAK,CAAC,MAAMQ,KAAK,CAACY,KAAK,CAACC,eAAe,EAAGA,eAAe,IAAK;MAC5D,IAAIA,eAAe,EAAE;QACnBT,kBAAkB,CAAC;MACrB,CAAC,MAAM;QACLF,aAAa,CAACG,KAAK,GAAG,IAAG;MAC3B;IACF,CAAC;;IAED;IACA,MAAMS,QAAQ,GAAGvB,QAAQ,CAAC,MAAMW,aAAa,CAACG,KAAK,EAAEU,IAAI,EAAED,QAAQ,IAAI,KAAK;IAC5E,MAAME,GAAG,GAAGzB,QAAQ,CAAC,MAAMW,aAAa,CAACG,KAAK,EAAEU,IAAI,EAAEC,GAAG,IAAI,IAAI;IACjE,MAAMC,KAAK,GAAG1B,QAAQ,CAAC,MAAMW,aAAa,CAACG,KAAK,EAAEU,IAAI,EAAEE,KAAK,IAAI,EAAE;;IAEnE;IACA,MAAMC,SAAS,GAAID,KAAK,IAAK;MAC3B,IAAI,CAACA,KAAK,EAAE,OAAO,KAAI;MACvB,OAAOA,KAAK,CAACE,OAAO,CAAC,qBAAqB,EAAE,UAAU;IACxD;;IAEA;IACA,MAAMC,cAAc,GAAG9B,GAAG,CAAC,KAAK;IAChC,MAAM+B,iBAAiB,GAAG/B,GAAG,CAAC,KAAK;;IAEnC;IACA,MAAMgC,iBAAiB,GAAGhC,GAAG,CAAC,KAAK;;IAEnC;IACA,MAAMiC,mBAAmB,GAAG,MAAAA,CAAA,KAAY;MACtC,IAAI;QACF,MAAMzB,aAAa,CAAC;QACpBF,SAAS,CAAC,OAAO,EAAE,SAAS;QAC5BI,KAAK,CAACwB,QAAQ,CAAC,QAAQ;QACvBvB,MAAM,CAACwB,IAAI,CAAC,QAAQ;MACtB,CAAC,CAAC,OAAOf,KAAK,EAAE;QACdd,SAAS,CAACc,KAAK,CAACgB