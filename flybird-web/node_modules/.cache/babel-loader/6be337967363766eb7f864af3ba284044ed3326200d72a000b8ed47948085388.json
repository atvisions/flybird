{"ast":null,"code":"import { BriefcaseIcon, UserCircleIcon, CurrencyYenIcon, MapPinIcon, BuildingOfficeIcon, DocumentPlusIcon, AcademicCapIcon } from '@heroicons/vue/24/outline';\nimport { onMounted, watch } from 'vue';\nexport default {\n  __name: 'JobIntentionContent',\n  props: {\n    data: {\n      type: Object,\n      default: () => ({})\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // 获取工作类型标签\n    const getJobTypeLabel = value => {\n      const typeMap = {\n        'full_time': '全职',\n        'part_time': '兼职',\n        'internship': '实习',\n        'freelance': '自由职业'\n      };\n      return typeMap[value] || '未设置';\n    };\n\n    // 获取求职状态标签\n    const getJobStatusLabel = value => {\n      const statusMap = {\n        'actively_looking': '正在积极找工作',\n        'open_to_offers': '对机会持开放态度',\n        'not_looking': '暂时不找工作'\n      };\n      return statusMap[value] || '未设置';\n    };\n\n    // 获取薪资标签\n    const getSalaryLabel = value => {\n      if (!value) return '未设置';\n      if (typeof value === 'string') return value;\n      return `${value}K/月`;\n    };\n\n    // 格式化城市\n    const formatCity = city => {\n      if (!city) return '未设置';\n      return city.split('-').join('、');\n    };\n\n    // 格式化行业\n    const formatIndustries = industries => {\n      if (!industries) return '未设置';\n      if (Array.isArray(industries)) {\n        return industries.join('、');\n      }\n      return industries.split(',').join('、');\n    };\n\n    // 调试日志\n    onMounted(() => {\n      console.log('JobIntentionContent mounted, data:', props.data);\n    });\n    watch(() => props.data, newData => {\n      console.log('JobIntentionContent data changed:', newData);\n    }, {\n      deep: true\n    });\n    const __returned__ = {\n      props,\n      getJobTypeLabel,\n      getJobStatusLabel,\n      getSalaryLabel,\n      formatCity,\n      formatIndustries,\n      get BriefcaseIcon() {\n        return BriefcaseIcon;\n      },\n      get UserCircleIcon() {\n        return UserCircleIcon;\n      },\n      get CurrencyYenIcon() {\n        return CurrencyYenIcon;\n      },\n      get MapPinIcon() {\n        return MapPinIcon;\n      },\n      get BuildingOfficeIcon() {\n        return BuildingOfficeIcon;\n      },\n      get DocumentPlusIcon() {\n        return DocumentPlusIcon;\n      },\n      get AcademicCapIcon() {\n        return AcademicCapIcon;\n      },\n      onMounted,\n      watch\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["BriefcaseIcon","UserCircleIcon","CurrencyYenIcon","MapPinIcon","BuildingOfficeIcon","DocumentPlusIcon","AcademicCapIcon","onMounted","watch","props","__props","getJobTypeLabel","value","typeMap","getJobStatusLabel","statusMap","getSalaryLabel","formatCity","city","split","join","formatIndustries","industries","Array","isArray","console","log","data","newData","deep"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/JobIntentionContent.vue"],"sourcesContent":["<template>\n  <div>\n    <template v-if=\"data\">\n      <!-- 网格布局 -->\n      <div class=\"grid grid-cols-2 gap-4\">\n        <!-- 求职状态 -->\n        <div class=\"bg-gradient-to-br from-green-50/50 to-emerald-50/50 rounded-xl p-4 transition duration-300 hover:shadow-sm hover:-translate-y-0.5\">\n          <div class=\"flex items-start space-x-3\">\n            <div class=\"p-2 bg-white/80 rounded-lg shadow-sm\">\n              <UserCircleIcon class=\"w-5 h-5 text-green-600\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-medium text-gray-400\">求职状态</div>\n              <div class=\"mt-1 text-sm text-gray-800\">{{ getJobStatusLabel(data.job_status) }}</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 工作类型 -->\n        <div class=\"bg-gradient-to-br from-blue-50/50 to-indigo-50/50 rounded-xl p-4 transition duration-300 hover:shadow-sm hover:-translate-y-0.5\">\n          <div class=\"flex items-start space-x-3\">\n            <div class=\"p-2 bg-white/80 rounded-lg shadow-sm\">\n              <BriefcaseIcon class=\"w-5 h-5 text-blue-600\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-medium text-gray-400\">工作类型</div>\n              <div class=\"mt-1 text-sm text-gray-800\">{{ getJobTypeLabel(data.job_type) }}</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 期望薪资 -->\n        <div class=\"bg-gradient-to-br from-purple-50/50 to-fuchsia-50/50 rounded-xl p-4 transition duration-300 hover:shadow-sm hover:-translate-y-0.5\">\n          <div class=\"flex items-start space-x-3\">\n            <div class=\"p-2 bg-white/80 rounded-lg shadow-sm\">\n              <CurrencyYenIcon class=\"w-5 h-5 text-purple-600\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-medium text-gray-400\">期望薪资</div>\n              <div class=\"mt-1 text-sm text-gray-800\">{{ data.expected_salary || '未设置' }}</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 期望城市 -->\n        <div class=\"bg-gradient-to-br from-orange-50/50 to-amber-50/50 rounded-xl p-4 transition duration-300 hover:shadow-sm hover:-translate-y-0.5\">\n          <div class=\"flex items-start space-x-3\">\n            <div class=\"p-2 bg-white/80 rounded-lg shadow-sm\">\n              <MapPinIcon class=\"w-5 h-5 text-orange-600\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-medium text-gray-400\">期望城市</div>\n              <div class=\"mt-1 text-sm text-gray-800\">{{ formatCity(data.expected_city) }}</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 底部行业和职位 -->\n      <div class=\"mt-4 space-y-3\">\n        <!-- 期望行业 -->\n        <div class=\"bg-gradient-to-br from-rose-50/50 to-pink-50/50 rounded-xl p-4 transition duration-300 hover:shadow-sm hover:-translate-y-0.5\">\n          <div class=\"flex items-start space-x-3\">\n            <div class=\"p-2 bg-white/80 rounded-lg shadow-sm\">\n              <BuildingOfficeIcon class=\"w-5 h-5 text-rose-600\" />\n            </div>\n            <div class=\"flex-1\">\n              <div class=\"text-xs font-medium text-gray-400\">期望行业</div>\n              <div class=\"mt-1 text-sm text-gray-800\">{{ formatIndustries(data.industries) }}</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 期望职位 -->\n        <div class=\"bg-gradient-to-br from-cyan-50/50 to-sky-50/50 rounded-xl p-4 transition duration-300 hover:shadow-sm hover:-translate-y-0.5\">\n          <div class=\"flex items-start space-x-3\">\n            <div class=\"p-2 bg-white/80 rounded-lg shadow-sm\">\n              <AcademicCapIcon class=\"w-5 h-5 text-cyan-600\" />\n            </div>\n            <div class=\"flex-1\">\n              <div class=\"text-xs font-medium text-gray-400\">期望职位</div>\n              <div class=\"mt-1 text-sm text-gray-800\">{{ data.position || '未设置' }}</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </template>\n\n    <!-- 空状态 -->\n    <div v-else class=\"flex flex-col items-center justify-center py-12 bg-gray-50/50 rounded-xl\">\n      <DocumentPlusIcon class=\"w-12 h-12 text-gray-300\" />\n      <p class=\"mt-2 text-sm text-gray-400\">暂无求职意向，点击编辑按钮添加</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { \n  BriefcaseIcon,\n  UserCircleIcon,\n  CurrencyYenIcon,\n  MapPinIcon,\n  BuildingOfficeIcon,\n  DocumentPlusIcon,\n  AcademicCapIcon\n} from '@heroicons/vue/24/outline'\nimport { onMounted, watch } from 'vue'\n\nconst props = defineProps({\n  data: {\n    type: Object,\n    default: () => ({})\n  }\n})\n\n// 获取工作类型标签\nconst getJobTypeLabel = (value) => {\n  const typeMap = {\n    'full_time': '全职',\n    'part_time': '兼职',\n    'internship': '实习',\n    'freelance': '自由职业'\n  }\n  return typeMap[value] || '未设置'\n}\n\n// 获取求职状态标签\nconst getJobStatusLabel = (value) => {\n  const statusMap = {\n    'actively_looking': '正在积极找工作',\n    'open_to_offers': '对机会持开放态度',\n    'not_looking': '暂时不找工作'\n  }\n  return statusMap[value] || '未设置'\n}\n\n// 获取薪资标签\nconst getSalaryLabel = (value) => {\n  if (!value) return '未设置'\n  if (typeof value === 'string') return value\n  return `${value}K/月`\n}\n\n// 格式化城市\nconst formatCity = (city) => {\n  if (!city) return '未设置'\n  return city.split('-').join('、')\n}\n\n// 格式化行业\nconst formatIndustries = (industries) => {\n  if (!industries) return '未设置'\n  if (Array.isArray(industries)) {\n    return industries.join('、')\n  }\n  return industries.split(',').join('、')\n}\n\n// 调试日志\nonMounted(() => {\n  console.log('JobIntentionContent mounted, data:', props.data)\n})\n\nwatch(() => props.data, (newData) => {\n  console.log('JobIntentionContent data changed:', newData)\n}, { deep: true })\n</script>\n\n<style scoped>\n.bg-gradient-to-br {\n  transition: all 0.3s ease;\n}\n\n@media (max-width: 640px) {\n  .grid-cols-2 {\n    @apply grid-cols-1;\n  }\n}\n</style>"],"mappings":"AAiGA,SACEA,aAAa,EACbC,cAAc,EACdC,eAAe,EACfC,UAAU,EACVC,kBAAkB,EAClBC,gBAAgB,EAChBC,eAAc,QACT,2BAA0B;AACjC,SAASC,SAAS,EAAEC,KAAK,QAAQ,KAAI;;;;;;;;;;;;;IAErC,MAAMC,KAAK,GAAGC,OAAA;;IAOd;IACA,MAAMC,eAAe,GAAIC,KAAK,IAAK;MACjC,MAAMC,OAAO,GAAG;QACd,WAAW,EAAE,IAAI;QACjB,WAAW,EAAE,IAAI;QACjB,YAAY,EAAE,IAAI;QAClB,WAAW,EAAE;MACf;MACA,OAAOA,OAAO,CAACD,KAAK,CAAC,IAAI,KAAI;IAC/B;;IAEA;IACA,MAAME,iBAAiB,GAAIF,KAAK,IAAK;MACnC,MAAMG,SAAS,GAAG;QAChB,kBAAkB,EAAE,SAAS;QAC7B,gBAAgB,EAAE,UAAU;QAC5B,aAAa,EAAE;MACjB;MACA,OAAOA,SAAS,CAACH,KAAK,CAAC,IAAI,KAAI;IACjC;;IAEA;IACA,MAAMI,cAAc,GAAIJ,KAAK,IAAK;MAChC,IAAI,CAACA,KAAK,EAAE,OAAO,KAAI;MACvB,IAAI,OAAOA,KAAK,KAAK,QAAQ,EAAE,OAAOA,KAAI;MAC1C,OAAO,GAAGA,KAAK,KAAI;IACrB;;IAEA;IACA,MAAMK,UAAU,GAAIC,IAAI,IAAK;MAC3B,IAAI,CAACA,IAAI,EAAE,OAAO,KAAI;MACtB,OAAOA,IAAI,CAACC,KAAK,CAAC,GAAG,CAAC,C