{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon, DocumentTextIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'SkillContent',\n  props: {\n    data: {\n      type: Array,\n      required: true\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 获取熟练度标签\n    const getLevelLabel = level => {\n      const levelMap = {\n        'beginner': '入门',\n        'intermediate': '熟练',\n        'advanced': '精通',\n        'expert': '专家'\n      };\n      return levelMap[level] || level;\n    };\n    const __returned__ = {\n      getLevelLabel,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      },\n      get DocumentTextIcon() {\n        return DocumentTextIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","DocumentTextIcon","getLevelLabel","level","levelMap"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/SkillContent.vue"],"sourcesContent":["<template>\n  <div class=\"relative space-y-0\">\n    <!-- 时间线 -->\n    <div class=\"absolute left-[0.5625rem] top-3 bottom-3 w-px bg-gray-200\"></div>\n\n    <!-- 技能列表 -->\n    <div \n      v-for=\"(skill, index) in data\" \n      :key=\"index\" \n      class=\"relative pl-12 pb-6\"\n    >\n      <!-- 时间节点 -->\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-blue-500\"></div>\n      \n      <!-- 内容卡片 -->\n      <div class=\"bg-gray-50 rounded-lg border border-gray-100 p-4 hover:shadow-sm transition-shadow\">\n        <div class=\"flex flex-col space-y-2\">\n          <!-- 技能名称和操作按钮 -->\n          <div class=\"flex items-start justify-between\">\n            <div class=\"flex-1 min-w-0\">\n              <h4 class=\"text-base font-medium text-gray-900 break-words\">{{ skill.name }}</h4>\n              <div class=\"text-sm text-gray-500 mt-1\">\n                熟练度: {{ getLevelLabel(skill.level) }}\n              </div>\n            </div>\n            <div class=\"flex items-center space-x-2\">\n              <button\n                @click=\"$emit('edit', skill)\"\n                class=\"p-1 hover:bg-white rounded-full transition-colors\"\n              >\n                <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n              </button>\n              <button\n                @click=\"$emit('delete', skill.id)\"\n                class=\"p-1 hover:bg-white rounded-full transition-colors\"\n              >\n                <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n              </button>\n            </div>\n          </div>\n\n          <!-- 技能描述 -->\n          <div class=\"mt-3 space-y-2\">\n            <div class=\"flex items-center space-x-2\">\n              <DocumentTextIcon class=\"w-4 h-4 text-gray-400 flex-shrink-0\" />\n              <span class=\"text-sm text-gray-500\">技能描述</span>\n            </div>\n            <div class=\"text-sm leading-relaxed text-gray-600 pl-6 break-words whitespace-pre-wrap\">\n              {{ skill.description }}\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 添加按钮 -->\n    <div class=\"relative pl-12\">\n      <div class=\"absolute left-[0.5625rem] -translate-x-1/2 top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-300\"></div>\n      <button\n        @click=\"$emit('add')\"\n        class=\"w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n      >\n        <PlusIcon class=\"w-4 h-4 mr-2\" />\n        添加专业技能\n      </button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { PencilSquareIcon, TrashIcon, PlusIcon, DocumentTextIcon } from '@heroicons/vue/24/outline'\n\ndefineProps({\n  data: {\n    type: Array,\n    required: true\n  }\n})\n\ndefineEmits(['edit', 'delete', 'add'])\n\n// 获取熟练度标签\nconst getLevelLabel = (level) => {\n  const levelMap = {\n    'beginner': '入门',\n    'intermediate': '熟练',\n    'advanced': '精通',\n    'expert': '专家'\n  }\n  return levelMap[level] || level\n}\n</script> "],"mappings":"AAsEA,SAASA,gBAAgB,EAAEC,SAAS,EAAEC,QAAQ,EAAEC,gBAAgB,QAAQ,2BAA0B;;;;;;;;;;;;;;;IAWlG;IACA,MAAMC,aAAa,GAAIC,KAAK,IAAK;MAC/B,MAAMC,QAAQ,GAAG;QACf,UAAU,EAAE,IAAI;QAChB,cAAc,EAAE,IAAI;QACpB,UAAU,EAAE,IAAI;QAChB,QAAQ,EAAE;MACZ;MACA,OAAOA,QAAQ,CAACD,KAAK,CAAC,IAAIA,KAAI;IAChC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}