{"ast":null,"code":"import { PencilSquareIcon, TrashIcon, PlusIcon } from '@heroicons/vue/24/outline';\nexport default {\n  __name: 'ProjectContent',\n  props: {\n    data: {\n      type: Array,\n      required: true\n    }\n  },\n  emits: ['edit', 'delete', 'add'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const formatDate = dateString => {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;\n    };\n    const __returned__ = {\n      formatDate,\n      get PencilSquareIcon() {\n        return PencilSquareIcon;\n      },\n      get TrashIcon() {\n        return TrashIcon;\n      },\n      get PlusIcon() {\n        return PlusIcon;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["PencilSquareIcon","TrashIcon","PlusIcon","formatDate","dateString","date","Date","getFullYear","String","getMonth","padStart"],"sources":["/Users/liuzhao/Documents/Projects/flybird/flybird-web/src/views/user/MyProfile/components/ProjectContent.vue"],"sourcesContent":["<template>\n  <div class=\"text-gray-600 px-4 pb-4\">\n    <div class=\"space-y-4\">\n      <div v-for=\"(project, index) in data\" :key=\"index\" \n        class=\"bg-gray-50 rounded-lg p-4\">\n        <div class=\"flex items-center justify-between mb-2\">\n          <div class=\"font-medium\">{{ project.name }}</div>\n          <div class=\"flex items-center space-x-2\">\n            <button\n              @click=\"$emit('edit', project)\"\n              class=\"p-1 hover:bg-white rounded-full transition-colors\"\n            >\n              <PencilSquareIcon class=\"w-4 h-4 text-gray-400\" />\n            </button>\n            <button\n              @click=\"$emit('delete', project.id)\"\n              class=\"p-1 hover:bg-white rounded-full transition-colors\"\n            >\n              <TrashIcon class=\"w-4 h-4 text-gray-400\" />\n            </button>\n          </div>\n        </div>\n        <div class=\"text-sm text-gray-500\">\n          {{ formatDate(project.start_date) }} - {{ project.end_date ? formatDate(project.end_date) : '至今' }}\n        </div>\n        <div class=\"mt-2 text-sm text-gray-600\">{{ project.description }}</div>\n      </div>\n    </div>\n    \n    <button\n      @click=\"$emit('add')\"\n      class=\"mt-4 w-full flex items-center justify-center px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-all\"\n    >\n      <PlusIcon class=\"w-4 h-4 mr-2\" />\n      添加项目经历\n    </button>\n  </div>\n</template>\n\n<script setup>\nimport { PencilSquareIcon, TrashIcon, PlusIcon } from '@heroicons/vue/24/outline'\n\ndefineProps({\n  data: {\n    type: Array,\n    required: true\n  }\n})\n\ndefineEmits(['edit', 'delete', 'add'])\n\nconst formatDate = (dateString) => {\n  if (!dateString) return ''\n  const date = new Date(dateString)\n  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`\n}\n</script> "],"mappings":"AAwCA,SAASA,gBAAgB,EAAEC,SAAS,EAAEC,QAAQ,QAAQ,2BAA0B;;;;;;;;;;;;;;IAWhF,MAAMC,UAAU,GAAIC,UAAU,IAAK;MACjC,IAAI,CAACA,UAAU,EAAE,OAAO,EAAC;MACzB,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,UAAU;MAChC,OAAO,GAAGC,IAAI,CAACE,WAAW,CAAC,CAAC,IAAIC,MAAM,CAACH,IAAI,CAACI,QAAQ,CAAC,CAAC,GAAG,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,EAAC;IAC/E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}